  <link rel="icon" type="image/png" href="zummee_mark_32.png">
  <link rel="stylesheet" href="shared/header.css?v=2026-03-27-1">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="shared/supabase-client.js?v=2026-04-08-2"></script>

  <script id="zummeeStaffGuard">
window.addEventListener("DOMContentLoaded", function(){
  (async () => {
    if (window.__zummeeStaffGuardRan) return;
    window.__zummeeStaffGuardRan = true;

    function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }

    async function getClient(){
      for (let i = 0; i < 80; i++) {
        try {
          if (typeof ensureSupabase === "function") {
            const c = await ensureSupabase();
            if (c && c.auth && typeof c.auth.getSession === "function") return c;
          }
        } catch(_e) {}
        try {
          if (window.supabaseClient && window.supabaseClient.auth && typeof window.supabaseClient.auth.getSession === "function") return window.supabaseClient;
        } catch(_e) {}
        try {
          if (window.sb && window.sb.auth && typeof window.sb.auth.getSession === "function") return window.sb;
        } catch(_e) {}
        await sleep(100);
      }
      return null;
    }

    const go = (target) => {
      var next = encodeURIComponent(window.location.pathname.split("/").pop() || "preferred_vendors.html");
      var url = target === "login.html" ? ("login.html?next=" + next) : target;
      try { window.location.replace(url); }
      catch(_e) { window.location.href = url; }
    };

    const sb = await getClient();
    if (!sb) { go("login.html"); return; }

    let sessionRes = null;
    try { sessionRes = await sb.auth.getSession(); } catch(_e) {}
    const user = sessionRes && sessionRes.data && sessionRes.data.session ? sessionRes.data.session.user : null;
    if (!user) { go("login.html"); return; }

    let ud = null;
    try {
      ud = await sb.from("userdirectory").select("role").eq("auth_user_id", user.id).single();
    } catch(_e) {}

    const role = String((ud && ud.data && ud.data.role) || "").trim();
    if (role === "Resident") { go("resident_portal.html"); return; }

    document.documentElement.setAttribute("data-staff-role", role || "");
  })();
});
</script>
</head>
