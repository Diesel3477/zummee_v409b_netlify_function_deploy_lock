<!doctype html>
<html lang="en">
<head>

  <div class="delete-modal-backdrop" id="pv_deleteModal" aria-hidden="true">
    <div class="delete-modal" role="dialog" aria-modal="true" aria-labelledby="pv_deleteTitle" aria-describedby="pv_deleteText">
      <div class="delete-modal__pill">Vendor Management</div>
      <h3 id="pv_deleteTitle">Remove vendor?</h3>
      <p id="pv_deleteText">This will remove the vendor from your preferred vendors list for the active company.</p>
      <div class="delete-modal__vendor" id="pv_deleteVendorName">Vendor</div>
      <div class="delete-modal__actions">
        <button class="delete-modal__btn delete-modal__btn--secondary" type="button" id="pv_deleteCancel">Cancel</button>
        <button class="delete-modal__btn delete-modal__btn--danger" type="button" id="pv_deleteConfirm">Remove Vendor</button>
      </div>
    </div>
  </div>

<script>window.ZUMMEE_BUILD="2026-03-27-1";console.log("Zummee build:",window.ZUMMEE_BUILD);</script>

<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Preferred Vendors</title>
<style>
  :root{--bg:#f6f7fb;--card:#fff;--text:#111827;--muted:#6b7280;--line:#e5e7eb;--shadow:0 10px 30px rgba(0,0,0,.08);--r:14px;--brand:#0f2f4a}
  *{box-sizing:border-box}
  body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
  .wrap{max-width:980px;margin:0 auto;padding:18px 14px 60px}
  .top{display:flex;gap:8px;flex-wrap:wrap;align-items:flex-start;justify-content:flex-start;margin-bottom:12px}
  .btn{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);background:#fff;color:var(--text);
    padding:10px 12px;border-radius:12px;text-decoration:none;font-weight:900;font-size:13px;box-shadow:0 1px 0 rgba(0,0,0,.02);cursor:pointer}
  .btn:hover{border-color:#d1d5db;box-shadow:0 8px 20px rgba(0,0,0,.06)}
  h1{margin:0;font-size:26px;letter-spacing:-.02em}
  .sub{color:var(--muted);font-size:13px;margin:6px 0 14px;line-height:1.4}

  .top > div:first-child{flex:1 1 100%;text-align:left}
  .top h1,.top .sub{text-align:left}
  .card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);padding:14px}

/* Preferred Vendors blue section styling (match Mileage Tracker / Company Directory) */
.wrap > .card{
  background: linear-gradient(180deg, rgba(145,175,221,0.96) 0%, rgba(108,149,207,0.96) 100%) !important;
  border: 1px solid rgba(255,255,255,0.35) !important;
  border-radius: 28px !important;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
  color:#0f2f4a !important;
  padding:24px 24px 18px !important;
}
.wrap > .card .row{align-items:center;}
.wrap > .card table{
  background: rgba(255,255,255,0.42) !important;
  border:1px solid rgba(255,255,255,0.28) !important;
  border-radius: 22px !important;
  overflow:hidden;
}
.wrap > .card th{
  background: rgba(255,255,255,0.18) !important;
  color:#17324d !important;
}
.wrap > .card td{ color:#17324d; }
.wrap > .card .pill{
  background: rgba(255,255,255,0.22) !important;
  border:1px solid rgba(255,255,255,0.30) !important;
  color:#17324d !important;
}
.wrap > .card input,
.wrap > .card select,
.wrap > .card .btn{
  background:#ffffff !important;
  color:#0f2f4a !important;
  border:1px solid rgba(15,47,74,0.10) !important;
  box-shadow:none !important;
}
.wrap > .card .tiny{ color:#17324d !important; }
  .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
  input,select{border:1px solid var(--line);border-radius:12px;padding:10px 12px;font-weight:800;background:#fff}
  input{min-width:220px;flex:1}
  table{width:100%;border-collapse:separate;border-spacing:0;overflow:hidden;border:1px solid var(--line);border-radius:14px;background:#fff}
  th,td{padding:10px 10px;border-bottom:1px solid var(--line);vertical-align:top}
  th{font-size:12px;color:var(--muted);text-align:left;background:#fafafa}
  tr:last-child td{border-bottom:none}
  .tiny{font-size:12px;color:var(--muted)}
  .pill{display:inline-block;padding:3px 8px;border-radius:999px;border:1px solid var(--line);font-size:12px;font-weight:900;color:var(--brand);background:#f8fafc}
  a.link{color:var(--brand);font-weight:900;text-decoration:none}
  a.link:hover{text-decoration:underline}

/* GLOBAL ZUMMEE SECTION EDGING */
.wrap .card,
.wrap .section,
.pageBox {
  border: 2px solid #0f2f4a !important;
  border-radius: 18px !important;
  background: rgba(255,255,255,0.96) !important;
  box-shadow: 0 10px 28px rgba(15,47,74,0.12) !important;
}

/* === Zummee Brand Header Override (v1211) === */
.zummee-header{
  background:#0f2f4a !important;
  color:#ffffff !important;
  border-bottom:1px solid rgba(255,255,255,0.10) !important;
}
.zummee-header a, .zummee-header a:visited{ color:#ffffff !important; }
.zummee-header button, .zummee-header select, .zummee-header label, .zummee-header span, .zummee-header div{ color:inherit; }
.zummee-header button{
  background:rgba(255,255,255,0.14) !important;
  border:1px solid rgba(255,255,255,0.18) !important;
}
.zummee-header button:hover{ border-color: rgba(123,224,0,0.55) !important; }
.zummee-header__logo img{ height:120px !important; width:auto !important; }
  .zummee-header__logo img{ margin-top:6px !important; }

/* === Modern Community Selector (match Manager Hub) === */
.zummee-communityPicker{ position:relative; display:inline-block; min-width:260px; }
.zummee-communityBtn{
  width:100%;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid rgba(15,47,74,0.22);
  background:#ffffff;
  color:#0f2f4a;
  font-weight:700;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  box-shadow:0 6px 18px rgba(0,0,0,0.10);
}
.zummee-communityBtn:focus{ outline:2px solid rgba(145, 255, 78, 0.55); outline-offset:2px; }
.zummee-communityChevron{ width:10px; height:10px; border-right:2px solid rgba(15,47,74,0.55); border-bottom:2px solid rgba(15,47,74,0.55); transform:rotate(45deg); margin-top:-2px; }
.zummee-communityMenu{
  position:absolute;
  right:0;
  top:calc(100% + 10px);
  width:340px;
  max-width:84vw;
  background:#ffffff;
  border:1px solid rgba(15,47,74,0.18);
  border-radius:16px;
  box-shadow:0 18px 60px rgba(0,0,0,0.22);
  padding:10px;
  z-index:9999;
  opacity:0;
  transform: translateY(-6px) scale(0.99);
  pointer-events:none;
  visibility:hidden;
  transition: opacity 140ms ease, transform 160ms ease, visibility 0s linear 160ms;
}
.zummee-communityMenu.open{
  opacity:1;
  transform: translateY(0) scale(1);
  pointer-events:auto;
  visibility:visible;
  transition: opacity 140ms ease, transform 160ms ease;
}
.zummee-communitySearch{
  width:100%;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid rgba(15,47,74,0.18);
  background:#f7fafc;
  color:#000000;
  font-weight:600;
  margin-bottom:8px;
}
.zummee-communitySearch::placeholder{ color:rgba(0,0,0,0.55); }
.zummee-communityList{ max-height:280px; overflow:auto; padding:4px 2px; }
.zummee-communityItem{
  width:100%;
  text-align:left;
  border:0;
  background:transparent;
  padding:10px 10px;
  border-radius:12px;
  cursor:pointer;
  font-weight:650;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  color:#000000;
  position:relative;
}
.zummee-communityItem + .zummee-communityItem{ border-top:1px solid rgba(15,47,74,0.08); }
.zummee-communityItem:hover{ background:rgba(15,47,74,0.06); }
.zummee-communityItem[aria-selected="true"]{
  background:rgba(145,255,78,0.16);
  box-shadow: inset 0 0 0 1px rgba(145,255,78,0.30);
}
.zummee-communityCheck{
  width:18px;height:18px;border-radius:999px;
  display:inline-flex;align-items:center;justify-content:center;
  flex:0 0 auto;color:#0f2f4a;opacity:0;transform: scale(0.9);
  transition: opacity 120ms ease, transform 140ms ease;
}
.zummee-communityItem[aria-selected="true"] .zummee-communityCheck{ opacity:1; transform: scale(1); }
.zummee-communityCheck::before{ content:"✓"; font-weight:900; font-size:13px; line-height:1; }

/* Ensure native <select> readable in edge cases */
#zummeeCommunitySelect, #zummeeCommunitySelect option{ color:#0f2f4a !important; background:#ffffff !important; }

/* Hub button readable */
.zummee-header__action--hub{ color:#173a56 !important; }

/* Force Hub action pill styling (match other header actions) */
.zummee-header a.zummee-header__action--hub{
  background:#ffffff !important;
  color:#0f2f4a !important;
  border:1px solid rgba(15,47,74,0.22) !important;
  box-shadow:0 6px 18px rgba(0,0,0,0.10) !important;
  height:44px !important;
  min-width:120px !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  text-decoration:none !important;
}
.zummee-header a.zummee-header__action--hub:hover{
  background:rgba(255,255,255,0.92) !important;
}

/* Ensure community dropdown text is dark and readable */
#zummeeCommunitySelect{
  color:#0f2f4a !important;
  font-weight:700 !important;
}
.zummee-modern-picker__button,
.zummee-modern-picker__item{
  color:#0f2f4a !important;
}

/* Force subpage dropdown to match Manager Hub */
#zummeeCommunitySelect{
  background:#ffffff !important;
  color:#000000 !important;
  font-weight:700 !important;
}

.zummee-modern-picker__button{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

.zummee-modern-picker__menu{
  background:#ffffff !important;
}

.zummee-modern-picker__item{
  color:#000000 !important;
}

/* Match Manager Hub community picker styling (white dropdown, black text) */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communityBtn span{
  color:#000000 !important;
}
.zummee-communityMenu{
  background:#ffffff !important;
  border:1px solid rgba(15,47,74,0.18) !important;
}
.zummee-communitySearch{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communitySearch::placeholder{
  color: rgba(0,0,0,0.55) !important;
}
.zummee-communityItem{
  color:#000000 !important;
}

/* Force dropdown button background to white */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Override header generic button styling for community picker */
.zummee-header .zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Remove bullet points from modern community dropdown */
.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
  padding-left:0 !important;
  margin-left:0 !important;
}

.zummee-communityItem::before{
  content:none !important;
  display:none !important;
}

/* FORCE remove bullets everywhere inside community dropdown */
.zummee-communityMenu,
.zummee-communityMenu *{
  list-style-type:none !important;
  list-style:none !important;
}

.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
}

.zummee-communityMenu li::marker{
  content:"" !important;
}

.zummee-communityMenu li::before{
  content:none !important;
  display:none !important;
}

/* Subpage Hub button — match Manager Hub */
.zummee-header .zummee-hubBtn {
  background: #ffffff !important;
  color: #0f2f4a !important;
  border-radius: 28px !important;
  padding: 10px 22px !important;
  font-weight: 700 !important;
  font-size: 16px !important;
  border: 1px solid rgba(15,47,74,0.15) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  transition: all .2s ease;
  text-decoration:none !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
}

.zummee-header .zummee-hubBtn:hover {
  background: #f4f6f8 !important;
}

/* Fix Hub button text color + alignment under dropdown */
.zummee-header .zummee-hubBtn {
  color: #000000 !important;
  display: block !important;
  margin-left: auto !important;
  margin-top: 10px !important;
}

.zummee-header .community-header-right {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important;
}

/* Correct Hub button sizing and force black text */
.zummee-header .zummee-hubBtn {
  background:#ffffff !important;
  color:#000000 !important;
  border-radius:28px !important;
  padding:8px 18px !important;
  font-weight:700 !important;
  font-size:15px !important;
  border:1px solid rgba(15,47,74,0.15) !important;
  box-shadow:0 4px 10px rgba(0,0,0,0.08) !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:auto !important;
  min-width:auto !important;
  margin-top:8px !important;
  align-self:flex-end !important;
}

/* Ensure container stacks properly */
.zummee-header .community-header-right {
  display:flex !important;
  flex-direction:column !important;
  align-items:flex-end !important;
}

/* Subpage header: stack hub under dropdown aligned right */
.zummee-header__controls{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
}
.zummee-header__communityRow{
  display:flex;
  align-items:center;
  gap:12px;
  justify-content:flex-end;
}
.zummee-header__communityActions{
  width:100%;
  display:flex;
  justify-content:flex-end;
  margin-top:10px;
}

/* Force Hub button text to true black */
.zummee-header .zummee-hubBtn,
.zummee-header .zummee-hubBtn:visited,
.zummee-header .zummee-hubBtn span {
  color:#000000 !important;
}

/* Align page titles (like Daily Ops) to the left */
.page-title,
h1.page-title,
.ops-title,
h1 {
  text-align:left !important;
  margin-left:0 !important;
}

/* Precisely align page titles with main card container */
.main-content h1,
.content-wrapper h1,
.page-container h1 {
  text-align:left !important;
  margin-left:40px !important;  /* matches card container padding */
  margin-right:0 !important;
}

/* Prevent centering from parent flex containers */
.page-header,
.title-row {
  justify-content:flex-start !important;
  text-align:left !important;
}

/* Precisely match left edge of main section container */
#opsHeaderRow {
  padding-left: 60px !important; /* match section container padding */
  justify-content: flex-start !important;
}

#opsHeaderRow h1 {
  margin: 0 !important;
}

/* Match subpage logo size to Manager Hub */
.zummee-header .zummee-logo {
  font-size: 42px !important;
  line-height: 1 !important;
}

.zummee-header .zummee-subtitle {
  font-size: 16px !important;
  letter-spacing: 2px !important;
}

.zummee-header svg {
  height: 28px !important;
}

/* === Zummee Standard Header (shared across pages) === */
.zummee-header{
  background-color: rgb(15, 47, 74);
}
.zummee-header__divider{
  display:none;
}
@media (min-width: 701px){
  .zummee-header__divider{
    display:block;
    width:1px;
    height:36px;
    background: rgba(255,255,255,0.28);
  }
}
@media (max-width: 700px){
  .zummee-header{
    padding: 10px 12px;
  }
  .zummee-header__inner{
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .zummee-header__brand{
    justify-content: center;
  }
  .zummee-header__controls{
    width: 100%;
    display:flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .zummee-header__community{
    width: 100%;
    max-width: 420px;
    justify-content: center;
    gap: 10px;
  }
  .zummee-header__community-label{
    min-width: auto;
  }
  #zummeeCommunitySelect{
    width: 100%;
  }
  .zummee-header__hub{
    width: 100%;
    max-width: 420px;
    justify-content: center;
  }
  .zummee-header__hubbtn{
    width: 100%;
  }
}
/* === End Zummee Standard Header === */


/* FINAL Preferred Vendors blue override */
body .wrap > .card{
  background: linear-gradient(180deg, rgba(145,175,221,0.96) 0%, rgba(108,149,207,0.96) 100%) !important;
  border: 1px solid rgba(255,255,255,0.35) !important;
  border-radius: 28px !important;
  box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
  color:#0f2f4a !important;
}
body .wrap > .card table{
  background: rgba(255,255,255,0.42) !important;
  border:1px solid rgba(255,255,255,0.28) !important;
  border-radius: 22px !important;
}
body .wrap > .card th{
  background: rgba(255,255,255,0.18) !important;
  color:#17324d !important;
}
body .wrap > .card td,
body .wrap > .card .tiny,
body .wrap > .card .pill{
  color:#17324d !important;
}
body .wrap > .card .pill{
  background: rgba(255,255,255,0.22) !important;
  border:1px solid rgba(255,255,255,0.30) !important;
}
body .wrap > .card input,
body .wrap > .card select,
body .wrap > .card .btn{
  background:#ffffff !important;
  color:#0f2f4a !important;
  border:1px solid rgba(15,47,74,0.10) !important;
  box-shadow:none !important;
}


.delete-modal-backdrop{position:fixed;inset:0;background:rgba(9,24,38,.46);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;z-index:9999;padding:24px;}
.delete-modal-backdrop.is-open{display:flex;}
.delete-modal{width:min(520px,92vw);border-radius:24px;padding:24px 24px 20px;background:#ffffff;border:1px solid rgba(17,24,39,.08);box-shadow:0 24px 70px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.65);color:#111827;position:relative;overflow:hidden;}
.delete-modal:before{content:'';position:absolute;inset:0;background:linear-gradient(135deg, rgba(255,255,255,.82), rgba(255,255,255,.28) 42%, rgba(255,255,255,0) 78%);pointer-events:none;}
.delete-modal__pill{display:inline-flex;align-items:center;padding:7px 12px;border-radius:999px;background:#f1f5f9;border:1px solid rgba(148,163,184,.28);font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;position:relative;z-index:1;color:#64748b;}
.delete-modal h3{margin:14px 0 8px;font-size:32px;line-height:1.05;color:#0f172a;position:relative;z-index:1;}
.delete-modal p{margin:0;color:#475569;font-size:15px;line-height:1.55;position:relative;z-index:1;}
.delete-modal__vendor{margin-top:14px;display:inline-flex;align-items:center;padding:9px 14px;border-radius:999px;background:#e2e8f0;border:1px solid rgba(148,163,184,.24);font-weight:700;position:relative;z-index:1;color:#1e293b;}
.delete-modal__actions{display:flex;justify-content:flex-end;gap:12px;margin-top:22px;position:relative;z-index:1;}
.delete-modal__btn{border:none;border-radius:14px;padding:12px 18px;font-weight:800;font-size:15px;cursor:pointer;transition:transform .16s ease, box-shadow .16s ease, opacity .16s ease;}
.delete-modal__btn:hover{transform:translateY(-1px);}
.delete-modal__btn--secondary{background:#f8fafc;color:#1f2937;border:1px solid rgba(148,163,184,.24);box-shadow:0 10px 24px rgba(15,23,42,.08);}
.delete-modal__btn--danger{background:linear-gradient(180deg, #fff3f2, #ffd7d3);color:#8c1d18;border:1px solid #fecaca;box-shadow:0 12px 28px rgba(15,23,42,.10);}
@media (max-width: 680px){.delete-modal{padding:20px 18px 18px;border-radius:22px;}.delete-modal h3{font-size:28px;}.delete-modal__actions{flex-direction:column-reverse;}.delete-modal__btn{width:100%;}}


  .btn--ghost{background:rgba(255,255,255,0.85) !important}
  .marketplace{display:flex;flex-direction:column;gap:18px}
  .category-section{
    background:rgba(255,255,255,0.34);
    border:1px solid rgba(255,255,255,0.34);
    border-radius:24px;
    padding:18px;
    box-shadow:0 10px 30px rgba(15,47,74,0.08);
    transition:padding .18s ease, box-shadow .18s ease;
  }
  .category-toggle{
    display:block;
    width:100%;
    border:none;
    background:transparent;
    padding:0;
    margin:0 0 14px;
    text-align:left;
    cursor:pointer;
  }
  .category-header{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin:0;padding:16px 18px;border-radius:18px;background:rgba(255,255,255,0.72);border:1px solid rgba(255,255,255,0.78);box-shadow:0 8px 20px rgba(15,47,74,0.08)}
  .category-title-wrap{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .category-title{font-size:22px;font-weight:900;letter-spacing:-.02em;color:#0f2f4a}
  .category-count{display:inline-flex;align-items:center;justify-content:center;padding:5px 10px;border-radius:999px;background:rgba(255,255,255,0.66);border:1px solid rgba(15,47,74,0.08);font-size:12px;font-weight:900;color:#17324d}
  .category-sub{font-size:12px;color:#23415d;font-weight:700;margin-top:4px}
  .category-toggle-pill{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;background:#ffffff;border:1px solid rgba(15,47,74,0.10);font-size:12px;font-weight:900;color:#17324d;box-shadow:0 8px 18px rgba(15,47,74,0.08);white-space:nowrap}
  .category-chevron{display:inline-block;transition:transform .18s ease;font-size:14px;line-height:1}
  .category-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
  .category-section.is-collapsed{padding-bottom:14px}
  .category-section.is-collapsed .category-grid{display:none}
  .category-section.is-collapsed .category-chevron{transform:rotate(-90deg)}
  .sponsor-card,.vendor-card{
    border-radius:20px;
    border:1px solid rgba(15,47,74,0.10);
    background:#ffffff;
    box-shadow:0 12px 28px rgba(15,47,74,0.10);
    padding:16px;
    min-height:164px;
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .sponsor-card{
    background:linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(241,247,255,0.98) 100%);
    border:1px solid rgba(64,112,184,0.18);
    position:relative;
    overflow:hidden;
  }
  .sponsor-card:before{
    content:"";
    position:absolute;
    inset:0;
    background:radial-gradient(circle at top right, rgba(145,175,221,0.22), transparent 42%);
    pointer-events:none;
  }
  .sponsor-top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;position:relative;z-index:1}
  .sponsor-label{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:rgba(15,47,74,0.08);color:#17324d;font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase}
  .sponsor-slot{font-size:11px;font-weight:900;color:#57789a;text-transform:uppercase;letter-spacing:.08em}
  .sponsor-title{font-size:20px;font-weight:900;color:#0f2f4a;line-height:1.05;position:relative;z-index:1}
  .sponsor-copy{font-size:13px;line-height:1.45;color:#35516c;position:relative;z-index:1}
  .sponsor-cta{display:inline-flex;align-items:center;justify-content:center;border-radius:14px;padding:10px 12px;background:#0f2f4a;color:#ffffff;font-size:12px;font-weight:900;position:relative;z-index:1;align-self:flex-start}
  .vendor-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
  .vendor-name{font-size:19px;font-weight:900;color:#0f2f4a;line-height:1.1}
  .vendor-meta{display:flex;flex-wrap:wrap;gap:8px;font-size:12px;color:#35516c;font-weight:700}
  .vendor-contact{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  .vendor-contact-block{padding:10px 12px;border-radius:14px;background:rgba(15,47,74,0.04);border:1px solid rgba(15,47,74,0.05)}
  .vendor-contact-label{display:block;font-size:11px;font-weight:900;letter-spacing:.08em;color:#57789a;text-transform:uppercase;margin-bottom:4px}
  .vendor-contact-value{font-size:13px;color:#17324d;font-weight:800;word-break:break-word}
  .vendor-notes{padding:10px 12px;border-radius:14px;background:rgba(64,112,184,0.06);border:1px solid rgba(64,112,184,0.10);font-size:13px;color:#17324d;line-height:1.45}
  .vendor-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:auto}
  .vendor-empty{grid-column:1/-1;border:1px dashed rgba(15,47,74,0.18);border-radius:18px;padding:16px;background:rgba(255,255,255,0.55);color:#35516c;font-weight:700}
  .vendor-empty strong{display:block;color:#0f2f4a;margin-bottom:4px}
  @media (max-width: 860px){
    .category-grid{grid-template-columns:1fr}
  }
  @media (max-width: 640px){
    .category-section{padding:14px}
    .category-toggle{margin-bottom:12px}
    .category-header{padding:14px 14px;align-items:flex-start}
    .category-toggle-pill{padding:9px 12px;font-size:11px}
    .vendor-contact{grid-template-columns:1fr}
    .category-title{font-size:19px}
    .sponsor-title{font-size:18px}
    .vendor-name{font-size:17px}
  }


/* === GOLD SPONSORED CARDS === */
.vendor-card.sponsored-card {
  background: linear-gradient(135deg, #f7d774 0%, #f1c24b 100%) !important;
  border: 1px solid rgba(180, 140, 0, 0.4);
  box-shadow: 0 8px 18px rgba(240, 193, 75, 0.35);
}
.vendor-card.sponsored-card * {
  color: #1a2a3a !important;
}

