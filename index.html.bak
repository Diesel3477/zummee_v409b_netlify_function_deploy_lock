<script>
(function(){
  const el = document.getElementById("todayBanner");
  if(!el) return;
  function update(){
    const d = new Date();
    const dateOpts = { weekday:'long', year:'numeric', month:'long', day:'numeric' };
    const timeOpts = { hour:'numeric', minute:'2-digit', second:'2-digit' };
    el.textContent = d.toLocaleDateString(undefined, dateOpts) + " • " + d.toLocaleTimeString(undefined, timeOpts);
  }
  update();
  setInterval(update, 1000);
})();
</script>



