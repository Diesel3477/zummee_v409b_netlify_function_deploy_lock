    <div id="sup_perCommunityAssign" class="sup-list"></div>
    <div class="muted tiny" style="margin-top:8px;">Tip: selecting an employee grants them access to that community automatically.</div>
  </div>

  <div id="sup_tab_employees" class="sup-tabpanel" style="display:none">
    <h4 style="margin:10px 0 6px">Company Employees</h4>
    <div class="muted tiny" style="margin-top:-4px; margin-bottom:10px;">Select a company to view employees and grant Supervisor access.</div>
