<script>
/* Manager Hub: card order (drag & drop, always-on) + FLIP animation + Reset Layout */
(function(){
  const wrap = document.getElementById("hubCards") || document.querySelector(".cards");
  if(!wrap) return;

  const KEY_BASE = "zummee_hub_card_order_v3";
  function getUserId(){
    try{ return String(localStorage.getItem("zummee_user_id_v1")||"").trim(); }catch(_e){ return ""; }
  }
  function storageKey(){
    const uid = getUserId();
    return uid ? (KEY_BASE + "__user__" + uid) : KEY_BASE;
  }

// Cloud sync (Supabase) for card order so it follows the user across devices
const PREF_KEY = KEY_BASE; // stored per-user in Supabase

function getSbClient(){
  try{
    const sb = (typeof ensureSupabaseSync === "function") ? ensureSupabaseSync() : (window.sb || window.supabaseClient || window.supabase);
    if(sb && typeof sb.from === "function") return sb;
  }catch(_e){}
  return null;
}

async function getAuthUserId(){
  // Prefer cached user id used elsewhere, then Supabase auth
  const local = getUserId();
  if(local) return local;
  const sb = getSbClient();
  if(!sb || !sb.auth || typeof sb.auth.getUser !== "function") return "";
  try{
    const res = await sb.auth.getUser();
    return String(res?.data?.user?.id || "").trim();
  }catch(_e){ return ""; }
}

async function loadOrderCloud(){
  const sb = getSbClient();
  if(!sb) return null;
  const uid = await getAuthUserId();
  if(!uid) return null;
  try{
    const { data, error } = await sb
      .from("user_ui_prefs")
      .select("pref_value, updated_at")
      .eq("user_id", uid)
      .eq("pref_key", PREF_KEY)
      .maybeSingle();
    if(error || !data) return null;
    const v = data.pref_value;
    if(Array.isArray(v)) return v;
    if(v && Array.isArray(v.order)) return v.order;
    return null;
  }catch(_e){
    return null;
  }
}

let __saveCloudTimer = null;
function saveOrderCloudDebounced(order){
  if(__saveCloudTimer) clearTimeout(__saveCloudTimer);
  __saveCloudTimer = setTimeout(async ()=>{
    const sb = getSbClient();
    if(!sb) return;
    const uid = await getAuthUserId();
    if(!uid) return;
    try{
      await sb.from("user_ui_prefs").upsert({
        user_id: uid,
        pref_key: PREF_KEY,
        pref_value: order,
        updated_at: new Date().toISOString()
      }, { onConflict: "user_id,pref_key" });
    }catch(_e){}
  }, 600);
}


  function cards(){
    return Array.from(wrap.querySelectorAll(".card[data-card-id]"));
  }

  function saveOrder(){
    const order = cards().map(c => c.getAttribute("data-card-id")).filter(Boolean);
    try{ localStorage.setItem(storageKey(), JSON.stringify(order)); }catch(_e){}
    saveOrderCloudDebounced(order);
  }

  function applyOrder(){
    let order = [];
    try{ order = JSON.parse(localStorage.getItem(storageKey())||"[]") || []; }catch(_e){ order=[]; }
    if(!order.length) return;

    const byId = {};
    cards().forEach(c => { byId[c.getAttribute("data-card-id")] = c; });

    // Append in saved order
    order.forEach(id => { const el = byId[id]; if(el) wrap.appendChild(el); });

    // Append any new cards not in saved list
    cards().forEach(c => {
      const id = c.getAttribute("data-card-id");
      if(id && !order.includes(id)) wrap.appendChild(c);
    });
  }

  // --- FLIP animation for smooth rearrange ---
  function measure(){
    const m = new Map();
    cards().forEach(c => m.set(c, c.getBoundingClientRect()));
    return m;
  }
  function flip(prev, draggingEl){
    cards().forEach(c => {
      if(c === draggingEl) return;
      const a = c.getBoundingClientRect();
      const b = prev.get(c);
      if(!b) return;
      const dx = b.left - a.left;
      const dy = b.top  - a.top;
      if(!dx && !dy) return;

      c.style.transition = "transform 0s";
      c.style.transform = `translate(${dx}px, ${dy}px)`;
      // next frame animate to natural position
      requestAnimationFrame(() => {
        c.style.transition = "transform 180ms ease";
        c.style.transform = "";
        // cleanup
        window.setTimeout(() => {
          c.style.transition = "";
          c.style.transform = "";
        }, 220);
      });
    });
  }

  // --- Drag and drop (always enabled) ---
  let dragging = null;
  function clearOver(){
    cards().forEach(c => c.classList.remove("drag-over"));
  }

  function onDragStart(e){
    dragging = e.currentTarget;
    dragging.classList.add("dragging");
    document.body.classList.add("hub-dragging");

    try{ e.dataTransfer.effectAllowed = "move"; }catch(_e){}
    try{ e.dataTransfer.setData("text/plain", dragging.getAttribute("data-card-id")||""); }catch(_e){}
  }

  function onDragEnd(){
    if(dragging) dragging.classList.remove("dragging");
    dragging = null;
    clearOver();
    document.body.classList.remove("hub-dragging");
    saveOrder();
  }

  function onDragOver(e){
    if(!dragging) return;
    e.preventDefault();

    const target = e.currentTarget;
    if(!target || target === dragging) return;

    clearOver();
    target.classList.add("drag-over");

    const rect = target.getBoundingClientRect();
    const after = (e.clientY - rect.top) > (rect.height / 2);

    const prev = measure();
    if(after){
      const next = target.nextElementSibling;
      if(next) wrap.insertBefore(dragging, next);
      else wrap.appendChild(dragging);
    }else{
      wrap.insertBefore(dragging, target);
    }
    flip(prev, dragging);
  }

  function onDrop(e){
    if(!dragging) return;
    e.preventDefault();
    clearOver();
    saveOrder();
  }

  function bind(){
    cards().forEach(card => {
      card.setAttribute("draggable", "true");
      card.addEventListener("dragstart", onDragStart);
      card.addEventListener("dragend", onDragEnd);
      card.addEventListener("dragover", onDragOver);
      card.addEventListener("drop", onDrop);
    });

    // prevent accidental navigation during a drag
    wrap.addEventListener("click", (e)=>{
      if(document.body.classList.contains("hub-dragging")){
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    const resetBtn = document.getElementById("hubResetLayout");
    if(resetBtn){
      resetBtn.addEventListener("click", ()=>{
        try{ localStorage.removeItem(storageKey()); }catch(_e){}
        window.location.reload();
      });
    }
  }

  document.addEventListener("DOMContentLoaded", ()=>{
    applyOrder();

// Try cloud order after local apply (non-blocking). If present, it becomes source of truth.
(async ()=>{
  const cloud = await loadOrderCloud();
  if(Array.isArray(cloud) && cloud.length){
    // Only re-apply if different
    let local = [];
    try{ local = JSON.parse(localStorage.getItem(storageKey())||"[]") || []; }catch(_e){ local=[]; }
    const same = JSON.stringify(local) === JSON.stringify(cloud);
    if(!same){
      try{ localStorage.setItem(storageKey(), JSON.stringify(cloud)); }catch(_e){}
      applyOrder();
    }
  }
})();
    bind();
  });
})();
</script>

<!-- Supervisor Only: Community Assignments
<section class="card" id="supervisorBox" style="display:none; margin-top:18px">
  <div class="card__header">
    <h2>Supervisor Access</h2>
    <p class="muted">Assign company communities to registered users. Assigned communities will appear automatically in the user’s community dropdown on this device.</p>
    <div id="sup_companySetter" style="display:none; margin-top:10px; padding:10px; border:1px dashed rgba(15,47,74,0.35); border-radius:12px; background:rgba(255,255,255,0.7)">
      <div style="font-weight:800; color:#0f2f4a; margin-bottom:6px;">Company is not set</div>
      <div class="sup-row">
        <input id="sup_companyInput" placeholder="Enter company name (e.g., BlueSky Management)" />
        <button class="btn" id="sup_setCompanyBtn" type="button">Set Company</button>
      </div>
      <div class="muted tiny" style="margin-top:6px;">Setting the company enables Supervisor assignments and company-wide views.</div>
    </div>
    <div id="sup_companyAdminPicker" style="display:none; margin-top:10px; padding:10px; border:1px solid rgba(15,47,74,0.18); border-radius:12px; background:rgba(255,255,255,0.85)">
      <div style="display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap">
        <div style="min-width:240px; flex:1">
          <label for="sup_companySelect" style="display:block; font-weight:800; color:#0f2f4a; margin-bottom:6px;">Company</label>
          <select id="sup_companySelect"><option value="">Loading companies…</option></select>
          <div class="muted tiny" style="margin-top:6px;">Admins can manage users across all companies.</div>
        </div>
        <button class="btn" id="sup_refreshCompaniesBtn" type="button">Refresh</button>
      </div>
    </div>

  </div>

  <div class="sup-grid2">
