    <div class="sup-subcard sup-subcard--wide">
  <div class="sup-subhead">
    <div>
      <h3 style="margin:0">Supervisor Tools</h3>
      <div class="muted tiny" style="margin-top:4px;">Manage employees, assign communities, and review current assignments.</div>
    </div>
    <div class="sup-tabs" role="tablist" aria-label="Supervisor tools tabs">
      <button class="sup-tab is-active" type="button" data-sup-tab="assign">Assignments</button>
      <button class="sup-tab" type="button" data-sup-tab="employees">Employees</button>
      <button class="sup-tab" type="button" data-sup-tab="current">Current</button>
    </div>
  </div>

  <div id="sup_tab_assign" class="sup-tabpanel">
    <h4 style="margin:10px 0 6px">Assign Communities</h4>
    <p class="muted tiny" style="margin-top:-4px; margin-bottom:10px;">Assign each community to the employee who manages it.</p>

    <div id="sup_bulkBox" class="sup-bulk">
      <div class="sup-bulk__grid">
        <div class="sup-bulk__left">
          <label style="display:block; font-weight:800; color:#0f2f4a; margin-bottom:6px;">Bulk assign to employee</label>
          <select id="sup_bulkEmployeeSelect"><option value="">Select employee…</option></select>
          <div class="muted tiny tiny-status" style="margin-top:6px;">Select communities to bulk assign.</div>
        </div>
        <div class="sup-bulk__actions">
          <button class="btn btn--ghost" id="sup_selectAllBtn" type="button">Select all</button>
          <button class="btn btn--ghost" id="sup_clearSelBtn" type="button">Clear</button>
          <button class="btn" id="sup_bulkAssignBtn" type="button" disabled>Assign to Selected</button>
        </div>
