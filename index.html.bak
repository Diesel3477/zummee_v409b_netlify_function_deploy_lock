<script>
// v1140: Board Member Hub card attention rules
// Red when (A) there are ANY open Board Member action items OR (B) there are ANY overdue items.
(function(){
  function safeGetLS(k){ try{ return String(localStorage.getItem(k)||'').trim(); }catch(_e){ return ''; } }
  function getActiveCommunityId(){
    return safeGetLS('zummee_selected_community_id') || safeGetLS('activeCommunityId') || safeGetLS('zummee_community_id');
  }

  function normalizeStatus(s){
    return String(s||'').trim().toLowerCase();
  }

  function isCompleteRow(r){
    // Consider complete if completed_at is set OR status is complete-ish OR legacy marker exists in details.
    try{
      if(r && r.completed_at) return true;
      var st = normalizeStatus(r && r.status);
      if(st && ['complete','completed','closed','done','resolved'].includes(st)) return true;
      var details = String((r && r.details) || '');
      if(/__ZUMMEE_BM_STATUS__:\s*COMPLETE\|/i.test(details)) return true;
    }catch(_e){}
    return false;
  }

  function isOverdueRow(r){
    try{
      if(isCompleteRow(r)) return false;
      if(!r || !r.due_date) return false;
      // due_date comes back as YYYY-MM-DD
      var due = new Date(String(r.due_date) + 'T00:00:00');
      if(isNaN(due.getTime())) return false;
      var now = new Date();
      // Compare by local date only
      var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      return due < today;
    }catch(_e){}
    return false;
  }

  function ensureStyles(){
    if(document.getElementById('bmHubAlertStyles')) return;
    var s = document.createElement('style');
    s.id = 'bmHubAlertStyles';
    s.textContent = "\n"+
      "#boardMemberHubCard.bm-alert{ background: rgba(220, 38, 38, 0.14) !important; border-color: rgba(220, 38, 38, 0.45) !important; }\n"+
      "#boardMemberHubCard .bm-alert-badge{ display:inline-block; margin-left:10px; padding:2px 10px; border-radius:999px; font-size:12px; font-weight:900; background: rgba(220, 38, 38, 0.18); border:1px solid rgba(220, 38, 38, 0.45); }\n"+
      // Daily Ops card has a strong blue inset glow by default; override it so the alert is visually obvious.
      "#dailyOpsCard.ops-alert{ background: linear-gradient(135deg, rgba(255, 228, 228, 0.95), rgba(255, 214, 214, 0.92)) !important; "+
      "box-shadow: inset 0 0 0 var(--hubGlowWidth) rgba(220, 38, 38, 0.70), 0 12px 28px rgba(220, 38, 38, 0.18) !important; }\n"+
      "#dailyOpsCard.ops-alert:hover{ box-shadow: inset 0 0 0 var(--hubGlowWidth) rgba(220, 38, 38, 0.85), 0 16px 34px rgba(220, 38, 38, 0.22) !important; }\n"+
      "#dailyOpsCard .ops-alert-badge{ display:inline-block; margin-left:10px; padding:2px 10px; border-radius:999px; font-size:12px; font-weight:900; background: rgba(220, 38, 38, 0.18); color: #b91c1c; border:1px solid rgba(220, 38, 38, 0.35); }\n";
    document.head.appendChild(s);
  }

  function ensureBadgeEl(card){
    var existing = card.querySelector('.bm-alert-badge');
    if(existing) return existing;
    // Try to attach near the title if present
    var titleEl = card.querySelector('.title') || card.querySelector('h2') || card.querySelector('h3') || card;
    var badge = document.createElement('span');
    badge.className = 'bm-alert-badge';
    badge.style.display = 'none';
    badge.textContent = '';
    titleEl.appendChild(badge);
    return badge;
  }

  function setCardState(openCount, overdueCount){
    var card = document.getElementById('boardMemberHubCard');
    if(!card) return;
    ensureStyles();

    var badge = ensureBadgeEl(card);
    var isAlert = (openCount > 0) || (overdueCount > 0);

    if(isAlert){
      card.classList.add('bm-alert');
      var parts = [];
      if(openCount > 0) parts.push("Open " + openCount);
      if(overdueCount > 0) parts.push("Overdue " + overdueCount);
      badge.textContent = parts.join(" • ");
      badge.style.display = 'inline-block';
    }else{
      card.classList.remove('bm-alert');
      badge.textContent = '';
      badge.style.display = 'none';
    }
  }

  async function refreshBoardMemberHubAttention(){
    var card = document.getElementById('boardMemberHubCard');
    if(!card) return;
    if(!window.sb){ setCardState(0,0); return; }

    var communityId = getActiveCommunityId();
    if(!communityId){ setCardState(0,0); return; }

    try{
      var q = await window.sb
        .from('BoardMemberActionItems')
        .select('id,details,status,completed_at,due_date')
        .eq('community_id', communityId)
        .limit(500);

      if(q && q.error) throw q.error;
      var rows = (q && q.data) ? q.data : [];

      var openCount = 0;
      var overdueCount = 0;

      for(var i=0;i<rows.length;i++){
        var r = rows[i] || {};
        if(!isCompleteRow(r)){
          openCount++;
          if(isOverdueRow(r)) overdueCount++;
        }
      }

      setCardState(openCount, overdueCount);
    }catch(_e){
      setCardState(0,0);
    }
  }

  function schedule(){
    refreshBoardMemberHubAttention();
    document.addEventListener('community:changed', function(){
      setTimeout(refreshBoardMemberHubAttention, 150);
    });
    setInterval(refreshBoardMemberHubAttention, 60000);
  }

  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', schedule);
  else schedule();
})();


// Daily Ops Non-Negotiables attention: turn Daily Ops card red until today's non-negotiables are marked complete.
  (function(){
    var NONNEG_TEMPLATE_KEY = "zummee_nonnegotiables_template_v1";
    var NONNEG_COMPLETION_TABLE = "daily_ops_nonneg_completion";
    var NONNEG_COMPLETION_KEY = "zummee_nonneg_completion_mark_v1";

    function getDateKeyLocal(){
      try{
        var d = new Date();
        var y = d.getFullYear();
        var m = String(d.getMonth()+1).padStart(2,'0');
        var day = String(d.getDate()).padStart(2,'0');
        return y + "-" + m + "-" + day;
      }catch(_e){ return ""; }
    }

    async function getNonNegTemplateCount(){
      // Cloud-first: count active Non-Neg template items from structured table.
      var countSup = 0;
      try{
        var sb = await ensureSupabase();
        var companyId = (window.activeCompanyId || localStorage.getItem("activeCompanyId") || "").trim();
        if(sb && companyId){
          var q = await sb
            .from("daily_ops_template_items")
            .select("id", { count: "exact", head: true })
            .eq("company_id", companyId)
            .eq("template_type", "nonneg")
            .eq("is_active", true);
          if(q && !q.error){
            countSup = (typeof q.count === "number") ? q.count : 0;
          }
        }
      }catch(_e){ /* fall back */ }

      if(countSup > 0) return countSup;

      // Fallback: legacy localStorage-only template (device-scoped).
      try{
        var raw = localStorage.getItem(NONNEG_TEMPLATE_KEY);
        if(!raw) return 0;
        var arr = JSON.parse(raw);
        if(!Array.isArray(arr)) return 0;
        var seen = {};
        var n = 0;
        for(var i=0;i<arr.length;i++){
          var s = String(arr[i]||"").trim();
          if(!s) continue;
          if(seen[s]) continue;
          seen[s]=1;
          n++;
        }
        return n;
      }catch(_e2){ return 0; }
    }

    function setDailyOpsCardState(needsAttention){
      var card = document.getElementById("dailyOpsCard");
      if(!card) return;
      ensureStyles();
      if(needsAttention){
        card.classList.add("ops-alert");
      }else{
        card.classList.remove("ops-alert");
      }
    }

    async function isCompletedToday(){
      var templateCount = await getNonNegTemplateCount();
      if(templateCount <= 0) return true; // nothing required => no attention
      var dateKey = getDateKeyLocal();
      if(!dateKey) return true;

      // First: use the local Daily Ops state (daily_ops_manager_v9) to determine whether today's Non-Negotiables are completed.
      // This reflects the actual checkboxes the user sees in ops.html and avoids "sticky complete" markers.
      try{
        var baseKey = "daily_ops_manager_v9";
        var uidLocal = "";
        var cidLocal = "";
        try{
          uidLocal = (window.ZummeeAuth && typeof window.ZummeeAuth.getUserId === "function") ? (window.ZummeeAuth.getUserId()||"") : "";
          cidLocal = (window.ZummeeAuth && typeof window.ZummeeAuth.getSelectedCommunityId === "function") ? (window.ZummeeAuth.getSelectedCommunityId()||"") : "";
        }catch(_e){}
        cidLocal = cidLocal || (localStorage.getItem("activeCommunityId")||localStorage.getItem("zummee_selected_community_id")||"");
        uidLocal = uidLocal || (localStorage.getItem("activeUserId")||localStorage.getItem("auth_user_id")||"");

        var candidates = [];
        if(uidLocal && cidLocal) candidates.push(baseKey + "::" + uidLocal + "::" + cidLocal);
        if(uidLocal) candidates.push(baseKey + "::" + uidLocal);
        if(cidLocal) candidates.push(baseKey + "::" + cidLocal);
        candidates.push(baseKey);

        var rawState = null;
        for(var i=0;i<candidates.length;i++){
          var r = null;
          try{ r = localStorage.getItem(candidates[i]); }catch(_e2){ r=null; }
          if(r){ rawState = r; break; }
        }

        if(rawState){
          var st = JSON.parse(rawState);
          var bucket = st && st.meta && st.meta.nonNegDoneByDate ? st.meta.nonNegDoneByDate[dateKey] : null;
          if(bucket && typeof bucket === "object"){
            var doneCount = 0;
            for(var k in bucket){ if(bucket[k]) doneCount++; }
            // If we have local completion info, use it as the source of truth.
            return doneCount >= templateCount;
          }
        }
      }catch(_eLocal){ /* ignore and fall through */ }


      try{
        // Cloud-first structured completion: compare completed count vs template count.
        var sb = await ensureSupabase();
        var uid = await requireUid();
        window.__zummee_uid_cached = uid;
        var companyId = (window.activeCompanyId || localStorage.getItem("activeCompanyId") || "").trim();
        if(!companyId) return true;
        var q = await sb
          .from("daily_ops_item_completion")
          .select("id", { count: "exact", head: true })
          .eq("company_id", companyId)
          .eq("user_id", uid)
          .eq("day", dateKey);
        if(q && q.error) throw q.error;
        var doneCount = (typeof q.count === "number") ? q.count : 0;
        return doneCount >= templateCount;
      }catch(_e){
        // If we cannot check Supabase (table missing/RLS/etc.), fall back to the local marker written by ops.html.
        try{
          var raw = localStorage.getItem(NONNEG_COMPLETION_KEY) || "{}";
          var obj = JSON.parse(raw);
          var bucket = (obj && obj[dateKey]) ? obj[dateKey] : null;
          if(!bucket || typeof bucket !== 'object') return false;

          // Get best-effort identity (uid/email). Prefer Supabase auth if available on this page.
          var uid2 = (window.__zummee_uid_cached || "").trim();
          var email2 = "";
          try{
            var sb2 = await ensureSupabase();
            if(sb2 && sb2.auth && typeof sb2.auth.getUser === "function"){
              var u2 = await sb2.auth.getUser();
              uid2 = uid2 || (u2 && u2.data && u2.data.user && u2.data.user.id ? String(u2.data.user.id) : "");
              email2 = (u2 && u2.data && u2.data.user && u2.data.user.email) ? String(u2.data.user.email) : "";
            }
          }catch(_eAuth){}
          email2 = email2 || ((window.sessionUser && window.sessionUser.email) || (window.__sessionUser && window.__sessionUser.email) || "").trim();

          if(uid2 && bucket[uid2] && bucket[uid2].completed_at) return true;
          if(email2 && bucket[email2] && bucket[email2].completed_at) return true;

          // As a last resort (single-user device), treat any completion marker for today as complete.
          // This prevents the hub from staying red when the user just completed in ops.html but identity keys differ.
          for(var k in bucket){
            if(bucket[k] && bucket[k].completed_at) return true;
          }
          return false;
        }catch(_e2){
          return false;
        }
      }
    }

async function refresh(){
      try{
        var done = await isCompletedToday();
        setDailyOpsCardState(!done);
      }catch(_e){
        setDailyOpsCardState(false);
      }
    }

    function schedule(){
      refresh();
      document.addEventListener("community:changed", function(){ setTimeout(refresh, 150); });
      // When returning from Daily Ops via back button (bfcache), re-check.
      window.addEventListener("focus", function(){ setTimeout(refresh, 50); });
      window.addEventListener("pageshow", function(){ setTimeout(refresh, 50); });
      document.addEventListener("visibilitychange", function(){
        if(!document.hidden) setTimeout(refresh, 50);
      });
      setInterval(refresh, 60000);
    }

    if(document.readyState==="loading") document.addEventListener("DOMContentLoaded", schedule);
    else schedule();
  })();

})();
</script>





</body>
</html>
