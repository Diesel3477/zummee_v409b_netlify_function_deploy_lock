<script>
/* Supervisor card visibility: hidden by default, show instantly for cached privileged users, then confirm with profile. */
document.addEventListener("DOMContentLoaded", () => {
  const card = document.getElementById("supervisorHubCard");
  if (!card) return;

  const isPriv = (p) => {
    const role = String(p?.role || p?.user_role || p?.access_level || p?.access || "").toLowerCase().trim();
    const dept = String(p?.department || p?.dept || "").toLowerCase().trim();
    const authRole = String(window?.ZUMMEE_AUTH?.role || "").toLowerCase().trim();
    const authDept = String(window?.ZUMMEE_AUTH?.department || "").toLowerCase().trim();
    const s = [role, dept, authRole, authDept].filter(Boolean).join(" ");
    const flag = !!(p?.is_supervisor || p?.is_admin || p?.is_companyadmin);
    return flag || /\b(companyadmin|admin|supervisor)\b/.test(s) || /(company\s*admin)/.test(s);
  };

  // Start hidden (CSS), but show immediately if we already know user is privileged from cached state.
  const cachedProfile = window.__zummeeProfile || window.__profile || null;
  if (isPriv(cachedProfile || {})) {
    card.classList.add("zummee-allow");
    card.style.display = "";
  } else if (isPriv({})) {
    // Covers the case where ZUMMEE_AUTH already carries role/department
    card.classList.add("zummee-allow");
    card.style.display = "";
  } else {
    card.style.display = "none";
  }

  // Confirm with fresh profile (async) and correct visibility.
  (async () => {
    let profile = null;
    for (let i = 0; i < 6; i++) {
      try {
        if (typeof window.getProfile === "function") profile = await window.getProfile();
        else profile = window.__zummeeProfile || window.__profile || null;
      } catch (e) {
        profile = null;
      }
      if (profile && (profile.role || profile.department || profile.dept || profile.user_role || profile.access_level || profile.access || profile.is_supervisor || profile.is_admin || profile.is_companyadmin)) break;
      await new Promise(r => setTimeout(r, 120));
    }

    try {
      if (isPriv(profile || {})) {
        card.classList.add("zummee-allow");
        card.style.display = "";
      } else {
        card.classList.remove("zummee-allow");
        card.style.display = "none";
      }
    } catch (e) {
      console.warn("Supervisor card role check failed:", e);
      card.classList.remove("zummee-allow");
      card.style.display = "none";
    }
  })();
});
</script>

<script>
/* v530 CLEAN: Manager Hub Add Community -> real Supabase insert into PropertyCommunities.
   - CompanyAdmin/Admin/Supervisor choose an Active Company once; remembered in localStorage.
   - Employees should not use this button (UI already hides/guards).
*/
(function(){
  function isPriv(profile){
    const role = String(profile?.role||"").toLowerCase().trim();
    const dept = String(profile?.department||profile?.dept||"").toLowerCase().trim();
    return ["companyadmin","admin","supervisor"].includes(role) || ["companyadmin","admin","supervisor"].includes(dept);
  }

  async function ensureSB(){
    if(!window.sb && typeof window.ensureSupabase === "function"){
      await window.ensureSupabase();
    }
    return window.sb;
  }

  async function fetchCompanies(){
    const sb = await ensureSB();
    if(!sb) throw new Error("Supabase not initialized");
    // Try both table casings
    let res = await sb.from("Companies").select("id,name").order("name", {ascending:true});
    if(res.error){
      res = await sb.from("companies").select("id,name").order("name", {ascending:true});
    }
    if(res.error) throw res.error;
    return res.data || [];
  }

  async function getActiveCompany(profile){
    // 1) profile.company_id if present
    if(profile?.company_id) return { id: profile.company_id, name: profile.company || profile.company_name || "" };

    // 2) remembered selection
    const savedId = localStorage.getItem("zummee_active_company_id") || "";
    const savedName = localStorage.getItem("zummee_active_company_name") || "";
    if(savedId) return { id: savedId, name: savedName };

    // 3) prompt once
    const companies = await fetchCompanies();
    if(!companies.length) throw new Error("No companies found");

    const menu = companies.map((c,i)=>`${i+1}) ${c.name}`).join("\n");
    const pick = prompt("Select Active Company (enter number):\n\n"+menu);
    const n = Number(String(pick||"").trim());
    if(!Number.isFinite(n) || n<1 || n>companies.length) return null;

    const chosen = companies[n-1];
    localStorage.setItem("zummee_active_company_id", chosen.id);
    localStorage.setItem("zummee_active_company_name", chosen.name);
    return { id: chosen.id, name: chosen.name };
  }

  async function addCommunityCloud(){
    const profile = (typeof window.getProfile === "function") ? await window.getProfile() : (window.__zummeeProfile || window.__profile || null);
    if(!profile) return alert("Profile unavailable.");

    if(!isPriv(profile)) return alert("Access denied.");

    const active = await getActiveCompany(profile);
    if(!active?.id) return; // user canceled

    const raw = prompt("New Community Name:");
    const name = (raw||"").trim();
    if(!name) return;

    const sb = await ensureSB();
    if(!sb) return alert("Supabase not initialized.");

    const payload = {
      name,
      company_id: active.id,
      company: active.name || profile.company || profile.company_name || ""
    };

    const { error } = await sb.from("PropertyCommunities").insert([payload]);
    if(error){
      console.error("PropertyCommunities insert failed:", error);
      alert("Could not create community. Check Console for details.");
      return;
    }

    // Refresh view
    location.reload();
  }

  // Expose a single canonical entrypoint so any legacy code that calls
  // addCommunity() will go through the cloud insert path.
  window.addCommunity = addCommunityCloud;

  // Belt-and-suspenders: intercept Add clicks in the capture phase so
  // no previously-registered legacy handlers can swallow the click.
  document.addEventListener("click", (e)=>{
    const t = e.target;
    if(t && t.id === "zummeeCommunityAdd"){
      try{ e.preventDefault(); }catch(_e){}
      try{ e.stopImmediatePropagation(); }catch(_e){}
      addCommunityCloud();
    }
  }, true);

  document.addEventListener("DOMContentLoaded", ()=>{
    const btn = document.getElementById("zummeeCommunityAdd");
    if(!btn) return;

    // IMPORTANT: The Add button already has legacy addEventListener handlers attached earlier in page load.
    // If we simply add another listener, the earlier capture/bubble listeners may still run first.
    // To guarantee our Supabase POST runs (and ONLY our handler), we replace the node with a clone.
    const clone = btn.cloneNode(true);
    btn.parentNode.replaceChild(clone, btn);

    clone.onclick = (e)=>{
      try{ e.preventDefault(); }catch(_e){}
      addCommunityCloud();
    };

    // Also intercept clicks in capture phase to prevent any earlier legacy
    // addEventListener handlers from running.
    clone.addEventListener('click', (ev)=>{
      try{
        ev.preventDefault();
        ev.stopPropagation();
        ev.stopImmediatePropagation();
      }catch(_e){}
      addCommunityCloud();
    }, true);
  });
})();
</script>


<!-- v933: Unified Sign out modal -->
<div id="zum_signOutModal" class="zum-modal-backdrop">
  <div class="zum-modal" role="dialog" aria-modal="true" aria-labelledby="zum_signOutTitle">
    <div class="zum-modal-title" id="zum_signOutTitle">Sign out</div>
    <div class="zum-modal-body">Are you sure you want to sign out?</div>
    <div class="zum-modal-actions">
      <button class="zum-btn secondary" type="button" id="zum_signOutCancel">Cancel</button>
      <button class="zum-btn primary" type="button" id="zum_signOutOk">Sign out</button>
    </div>
  </div>
</div>

<script>

// v933: unified sign-out modal helpers
(function(){
  function qs(id){ return document.getElementById(id); }
  window.zumOpenSignOutModal = function(){
    const m = qs('zum_signOutModal'); if(!m) return;
    m.style.display='flex';
    setTimeout(()=>{ try{ qs('zum_signOutOk')?.focus?.(); }catch(_e){} }, 20);
  };
  window.zumCloseSignOutModal = function(){
    const m = qs('zum_signOutModal'); if(!m) return;
    m.style.display='none';
  };
  
  // v1003: robust button bindings (prevents "popup OK button not working")
  function bindSignOutModal(){
    const m = qs('zum_signOutModal');
    const ok = qs('zum_signOutOk');
    const cancel = qs('zum_signOutCancel');
    if(ok && !ok.__zum_bound){
      ok.__zum_bound = true;
      ok.addEventListener('pointerdown', (ev)=>{ try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){} }, true);
      ok.addEventListener('click', async (ev)=>{
        try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){}
        try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
        try{ await (window.zummeePerformSignOut ? window.zummeePerformSignOut() : null); }catch(_e){}
      }, true);
    }
    if(cancel && !cancel.__zum_bound){
      cancel.__zum_bound = true;
      cancel.addEventListener('pointerdown', (ev)=>{ try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){} }, true);
      cancel.addEventListener('click', (ev)=>{
        try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){}
        try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
      }, true);
    }
    if(m && !m.__zum_bound){
      m.__zum_bound = true;
      m.addEventListener('pointerdown', (ev)=>{ /* block click-through */ try{ ev.stopPropagation(); }catch(_e){} }, true);
      m.addEventListener('click', (ev)=>{
        const t = ev.target;
        if(t && t.id === 'zum_signOutModal'){
          try{ ev.preventDefault(); ev.stopPropagation(); }catch(_e){}
          try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
        }
      }, true);
    }
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', bindSignOutModal);
  }else{
    bindSignOutModal();
  }

document.addEventListener('click', (ev)=>{
    const t = ev.target;
    const m = qs('zum_signOutModal');
    if(!m || m.style.display!=='flex') return;
    if(t && (t.id==='zum_signOutCancel')){ window.zumCloseSignOutModal(); return; }
    if(t && (t.id==='zum_signOutOk')){ window.zumCloseSignOutModal(); try{ window.zummeePerformSignOut && window.zummeePerformSignOut(); }catch(_e){} return; }
    if(t && t.id==='zum_signOutModal'){ window.zumCloseSignOutModal(); return; }
  });
  document.addEventListener('keydown',(ev)=>{
    const m = qs('zum_signOutModal');
    if(!m || m.style.display!=='flex') return;
    if(ev.key==='Escape'){ window.zumCloseSignOutModal(); }
  });
})();

</script>

<script>
// v955: Add community button id alias (supports sup_addCommunityBtn and sup_addCommunityBtn)
(function(){
