        <input id="sup_newCommunityName" placeholder="Add community name" />
        <button class="btn" id="sup_addCommunityBtn" type="button">Add</button>
        <button class="btn btn--ghost" id="sup_editCommunityBtn" type="button" disabled>Edit</button>
      </div>
      <div id="sup_status" class="muted tiny" style="margin-top:8px;"></div>
      <div id="sup_companyCommunityList" class="sup-list"></div>
      <p class="muted tiny">Tip: this is the master list supervisors assign from.</p>
