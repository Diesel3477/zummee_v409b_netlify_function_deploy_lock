}
/* If cards use a title + subtitle, keep them centered */
.card.with-icon h3,
.card.with-icon .title{
  margin: 0;
  text-align: center;
}
.card.with-icon p,
.card.with-icon .subtitle,
.card.with-icon .desc{
  margin: 0;
  text-align: center;
}

/* Hub icons: enforce consistent sizing (override any legacy rules) */
.card.with-icon .card-icon{
  width:72px !important;
  height:72px !important;
  max-width:72px !important;
  max-height:72px !important;
  object-fit:contain !important;
  display:block;
  margin:10px auto 6px auto !important;
}
/* Hub cards: lock consistent height & layout */
