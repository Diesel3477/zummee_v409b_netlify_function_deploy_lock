<div class="zummee-modal-backdrop" id="boardHubClearModal" aria-hidden="true">
  <div class="zummee-modal" role="dialog" aria-modal="true" aria-labelledby="boardHubClearModalTitle">
    <div class="zummee-modal__header" id="boardHubClearModalTitle">Clear status records?</div>
    <div class="zummee-modal__body">
      This will remove all Board Member Hub status records for the currently selected community from the manager hub.
      Use this for clearing test data before launch.
    </div>
    <div class="zummee-modal__footer">
      <button class="zummee-modal__btn zummee-modal__btn--ghost" id="boardHubClearCancelBtn" type="button">Cancel</button>
      <button class="zummee-modal__btn zummee-modal__btn--danger" id="boardHubClearConfirmBtn" type="button">Clear Records</button>
    </div>
  </div>
</div>
<script id="board-hub-clear-status-v1">
(function(){
  function getSb(){
    try{
      if(typeof ensureSupabaseSync === 'function'){
        var sb = ensureSupabaseSync();
        if(sb && typeof sb.from === 'function') return sb;
      }
    }catch(_e){}
    try{
      var sb2 = window.sb || window.supabaseClient || window.supabase;
      if(sb2 && typeof sb2.from === 'function') return sb2;
    }catch(_e2){}
    return null;
  }

  function getSelectedCommunityId(){
    try{
      if(window.ZummeeAuth && typeof window.ZummeeAuth.getSelectedCommunityId === 'function'){
        var zid = String(window.ZummeeAuth.getSelectedCommunityId() || '').trim();
        if(zid) return zid;
      }
    }catch(_e){}
    try{
      return String(
        localStorage.getItem('activeCommunityId')
        || localStorage.getItem('zummee_selected_community_v1')
        || localStorage.getItem('currentCommunityId')
        || localStorage.getItem('zummee_selected_community_id')
        || localStorage.getItem('zummeeActiveCommunityId')
        || ''
      ).trim();
    }catch(_e2){ return ''; }
  }

  function openModal(){
    var m = document.getElementById('boardHubClearModal');
    if(!m) return;
    m.classList.add('is-open');
    m.setAttribute('aria-hidden', 'false');
  }

  function closeModal(){
    var m = document.getElementById('boardHubClearModal');
    if(!m) return;
    m.classList.remove('is-open');
    m.setAttribute('aria-hidden', 'true');
  }

  async function clearBoardHubStatus(){
    var body = document.getElementById('managerBoardHubStatusBody');
    var btn = document.getElementById('managerBoardHubStatusClearBtn');
    var confirmBtn = document.getElementById('boardHubClearConfirmBtn');
    var communityId = getSelectedCommunityId();
    var sb = getSb();

    if(!communityId){
      alert('Select a community first.');
      return;
    }
    if(!(sb && sb.from)){
      alert('Database connection unavailable.');
      return;
    }

    try{
      if(btn) btn.disabled = true;
      if(confirmBtn) confirmBtn.disabled = true;
      if(body) body.innerHTML = '<div class="board-items-panel__empty">Clearing board member hub status…</div>';

      var q = await sb.from('annual_meeting_packet_requests')
        .select('id')
        .eq('community_id', communityId)
        .in('status', ['pending_board_approval','pending_supervisor_approval','approved_ready_to_send','mailed']);

      var ids = Array.isArray(q && q.data) ? q.data.map(function(r){ return r && r.id; }).filter(Boolean) : [];

      if(ids.length){
        try{
          await sb.from('annual_meeting_board_approvals').delete().in('request_id', ids);
        }catch(_e){}
        try{
          await sb.from('board_meetings_state').delete().eq('community_id', communityId);
        }catch(_e2){}
        await sb.from('annual_meeting_packet_requests').delete().in('id', ids);
      } else {
        try{
          await sb.from('board_meetings_state').delete().eq('community_id', communityId);
        }catch(_e3){}
      }

      if(body) body.innerHTML = '<div class="board-items-panel__empty">No annual meeting routing activity is active for this community.</div>';
      closeModal();
    }catch(e){
      if(body) body.innerHTML = '<div class="board-items-panel__empty">Could not clear status records right now.</div>';
      try{ console.warn('clear board hub status failed', e); }catch(_e4){}
      alert('Could not clear status records. Check permissions or try again.');
    }finally{
      if(btn) btn.disabled = false;
      if(confirmBtn) confirmBtn.disabled = false;
    }
  }

  function bind(){
    var btn = document.getElementById('managerBoardHubStatusClearBtn');
    var cancelBtn = document.getElementById('boardHubClearCancelBtn');
    var confirmBtn = document.getElementById('boardHubClearConfirmBtn');
    var modal = document.getElementById('boardHubClearModal');

    if(btn && !btn.dataset.bound){
      btn.dataset.bound = '1';
      btn.addEventListener('click', openModal);
    }
    if(cancelBtn && !cancelBtn.dataset.bound){
      cancelBtn.dataset.bound = '1';
      cancelBtn.addEventListener('click', closeModal);
    }
    if(confirmBtn && !confirmBtn.dataset.bound){
      confirmBtn.dataset.bound = '1';
      confirmBtn.addEventListener('click', clearBoardHubStatus);
    }
    if(modal && !modal.dataset.bound){
      modal.dataset.bound = '1';
      modal.addEventListener('click', function(e){
        if(e.target === modal) closeModal();
      });
    }
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape') closeModal();
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', bind);
  } else {
    bind();
  }
})();
</script>

<script id="zummeeCommunityWeatherSyncFix_v1">
(function(){
  function safeGet(key){
    try{ return String(localStorage.getItem(key) || '').trim(); }catch(_e){ return ''; }
  }
  function safeSet(key, val){
    try{ localStorage.setItem(key, String(val || '').trim()); }catch(_e){}
  }
  function getSelect(){
    try{ return document.getElementById('zummeeCommunitySelect'); }catch(_e){ return null; }
  }
  function getSelected(){
    var sel = getSelect();
    if(!sel) return { id:'', name:'' };
    var id = String(sel.value || '').trim();
    var opt = null;
    try{ opt = sel.options && sel.selectedIndex >= 0 ? sel.options[sel.selectedIndex] : null; }catch(_e){ opt = null; }
    var name = String((opt && (opt.textContent || opt.text)) || '').trim();
    return { id:id, name:name };
  }
  function syncCommunitySelection(source){
    var picked = getSelected();
    if(!picked.id) return;
    safeSet('zummee_selected_community_id', picked.id);
    safeSet('zummee_selected_community_v1', picked.id);
    safeSet('activeCommunityId', picked.id);
    try{ window.__zummeeSelectedCommunityId = picked.id; }catch(_e){}
    try{ document.dispatchEvent(new CustomEvent('community:changed', { detail:{ community_id:picked.id, community_name:picked.name || '', source: source || 'sync-fix' } })); }catch(_e){
      try{ document.dispatchEvent(new Event('community:changed')); }catch(_e2){}
    }
  }
  function syncZipToCommunity(){
    try{
      var input = document.getElementById('weatherZipInput');
      var picked = getSelected();
      if(!input || !picked.id) return;
      var zip = String(input.value || '').replace(/\D+/g,'').slice(0,5);
      if(zip.length !== 5) return;
      var map = JSON.parse(localStorage.getItem('zummee_zip_map') || '{}');
      map[picked.id] = zip;
      localStorage.setItem('zummee_zip_map', JSON.stringify(map));
      localStorage.setItem('zummee_weather_zip', zip);
    }catch(_e){}
  }
  function bindDelegates(){
    if(document.__zummeeCommunityWeatherSyncFixBound) return;
    document.__zummeeCommunityWeatherSyncFixBound = true;

    document.addEventListener('change', function(e){
      if(!(e && e.target && e.target.id === 'zummeeCommunitySelect')) return;
      setTimeout(function(){ syncCommunitySelection('select-change'); }, 0);
    }, true);

    document.addEventListener('input', function(e){
      if(!(e && e.target && e.target.id === 'weatherZipInput')) return;
      setTimeout(syncZipToCommunity, 0);
    }, true);

    document.addEventListener('blur', function(e){
      if(!(e && e.target && e.target.id === 'weatherZipInput')) return;
      setTimeout(syncZipToCommunity, 0);
    }, true);

    document.addEventListener('keydown', function(e){
      if(!(e && e.target && e.target.id === 'weatherZipInput' && e.key === 'Enter')) return;
      setTimeout(syncZipToCommunity, 0);
    }, true);
  }
  function init(){
    bindDelegates();
    setTimeout(function(){ syncCommunitySelection('boot'); }, 250);
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init);
  }else{
    init();
  }
})();
</script>


<script>
/* v26 Supervisor card stable fix: use initialized client + userdirectory role/approved only. */
document.addEventListener("DOMContentLoaded", function(){
  var card = document.getElementById("supervisorHubCard");
  var mainCard = document.getElementById("supervisorHubMainCard");
  if(!card && !mainCard) return;

  function showCard(show){
    try{
      if(card) card.style.display = "none";
      if(mainCard) mainCard.style.display = show ? "" : "none";
    }catch(_e){}
  }

  (async function(){
    try{
      var db = window.supabaseClient || window.sb;
      if(!db || !db.auth || !db.from) return;
      var au = await db.auth.getUser();
      var authId = au && au.data && au.data.user && au.data.user.id;
      if(!authId) return;
      var q = await db.from("userdirectory").select("role,approved,auth_user_id").eq("auth_user_id", authId).maybeSingle();
      var role = String(q && q.data && q.data.role || "").toLowerCase().trim();
      var approved = !!(q && q.data && q.data.approved);
      var isSup = approved && (role === "supervisor" || role === "admin" || role === "companyadmin");
      showCard(isSup);
    }catch(_e){}
  })();
});
</script>


<script id="manager-board-preview-fix">
(function(){
  function $(id){ return document.getElementById(id); }

  function ensurePreviewModal(){
    var modal = $('managerBoardPacketPreviewModal');
    if(modal) return modal;

    modal = document.createElement('div');
    modal.id = 'managerBoardPacketPreviewModal';
    modal.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(11,28,46,.58);z-index:99999;align-items:center;justify-content:center;padding:18px;';
    modal.innerHTML = ''
      + '<div style="width:min(1100px,96vw);height:min(88vh,920px);background:#fff;border-radius:24px;box-shadow:0 18px 48px rgba(15,47,74,.28);display:flex;flex-direction:column;overflow:hidden;border:1px solid rgba(15,47,74,.12);">'
      + '  <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid rgba(15,47,74,.1);background:linear-gradient(180deg,#ffffff,#f7fbff);">'
      + '    <div style="font:700 24px/1.2 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#17324d;">Packet Preview</div>'
      + '    <button id="managerBoardPacketPreviewClose" type="button" style="border:0;background:#17324d;color:#fff;border-radius:999px;padding:10px 16px;font:700 14px/1 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;cursor:pointer;">Close</button>'
      + '  </div>'
      + '  <div id="managerBoardPacketPreviewStatus" style="display:none;padding:12px 18px;border-bottom:1px solid rgba(15,47,74,.08);font:600 14px/1.3 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#17324d;background:#f6fbff;"></div>'
      + '  <iframe id="managerBoardPacketPreviewFrame" title="Packet Preview" style="width:100%;height:100%;border:0;background:#fff;"></iframe>'
      + '</div>';

    document.body.appendChild(modal);

    function closeModal(){
      modal.style.display = 'none';
      $('managerBoardPacketPreviewFrame').src = 'about:blank';
    }

    modal.addEventListener('click', function(e){
      if(e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && modal.style.display !== 'none') closeModal();
    });
    $('managerBoardPacketPreviewClose').addEventListener('click', closeModal);

    function isAppleMobilePreview(){
      try{
        var ua = String(navigator.userAgent || '');
        var platform = String(navigator.platform || '');
        var touchMac = platform === 'MacIntel' && navigator.maxTouchPoints > 1;
        return /iPad|iPhone|iPod/i.test(ua) || touchMac;
      }catch(_e){ return false; }
    }
    modal.__open = function(url, label){
      var status = $('managerBoardPacketPreviewStatus');
      status.style.display = 'block';
      status.textContent = label || 'Loading packet preview…';
      if(isAppleMobilePreview()){
        try{
          var opened = window.open(url, '_blank');
          if(!opened) window.location.href = url;
        }catch(_eOpen){
          try{ window.location.href = url; }catch(_eNav){}
        }
        status.textContent = 'Opening full packet preview…';
      }else{
        $('managerBoardPacketPreviewFrame').src = url;
      }
      modal.style.display = 'flex';
    };

    return modal;
  }

  async function getClient(){
    try{
      if(typeof ensureSupabase === 'function'){
        return await ensureSupabase();
      }
    }catch(_e){}
    try{
      return window.sb || window.supabaseClient || null;
    }catch(_e2){}
    return null;
  }

  async function resolvePreviewUrlByRequestId(requestId){
    var client = await getClient();
    if(!client) throw new Error('Supabase client unavailable.');

    var res = await client
      .from('annual_meeting_packet_requests')
      .select('id, packet_payload')
      .eq('id', requestId)
      .maybeSingle();

    if(res && res.error) throw res.error;
    var row = res && res.data ? res.data : null;
    if(!row) throw new Error('Preview packet record not found.');

    var attachment = row && row.packet_payload && row.packet_payload.pdf_attachment ? row.packet_payload.pdf_attachment : null;
    var mime = String((attachment && attachment.type) || 'application/pdf');
    var b64 = String((attachment && attachment.content) || '').trim();

    if(!b64) throw new Error('No preview file is attached to this packet yet.');

    try{
      var binary = atob(b64);
      var len = binary.length;
      var bytes = new Uint8Array(len);
      for(var i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);
      var blob = new Blob([bytes], { type: mime });
      return URL.createObjectURL(blob);
    }catch(_e){
      throw new Error('Packet preview could not be decoded.');
    }
  }

  document.addEventListener('click', async function(e){
    var btn = e.target && e.target.closest ? e.target.closest('[data-manager-board-preview]') : null;
    if(!btn) return;

    e.preventDefault();
    e.stopPropagation();

    var requestId = String(btn.getAttribute('data-manager-board-preview') || '').trim();
    if(!requestId) return;

    var modal = ensurePreviewModal();
    var status = $('managerBoardPacketPreviewStatus');
    status.style.display = 'block';
    status.textContent = 'Loading packet preview…';

    try{
      btn.disabled = true;
      btn.style.opacity = '0.72';
      var url = await resolvePreviewUrlByRequestId(requestId);
      modal.__open(url, 'Preview ready');
    }catch(err){
      console.error('Manager Hub preview failed:', err);
      status.style.display = 'block';
      status.textContent = (err && err.message) ? err.message : 'Unable to load packet preview.';
      modal.style.display = 'flex';
    }finally{
      btn.disabled = false;
      btn.style.opacity = '';
    }
  }, true);
})();
</script>


<script id="managerHubBackNavStabilityJs">
(function(){
  if(window.__managerHubBackNavStabilityInstalled) return;
  window.__managerHubBackNavStabilityInstalled = true;

  function markRestoring(){
    try{
      document.documentElement.classList.add('mh-restoring-back');
      document.body && document.body.classList.add('mh-restoring-back');
    }catch(_e){}
  }

  function clearRestoring(){
    try{
      document.documentElement.classList.remove('mh-restoring-back');
      document.body && document.body.classList.remove('mh-restoring-back');
    }catch(_e){}
  }

  window.addEventListener('pageshow', function(e){
    try{
      if(e && e.persisted){
        markRestoring();
        var y = window.scrollY || window.pageYOffset || 0;
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){
            try{ window.scrollTo(0, y); }catch(_e2){}
            setTimeout(function(){
              clearRestoring();
            }, 120);
          });
        });
      }
    }catch(_e){}
  });

  // Prevent duplicate heavy boot on back/forward cache restores.
  try{
    var origAdd = document.addEventListener.bind(document);
    var domReadyFired = false;
    document.addEventListener = function(type, listener, options){
      if(type === 'DOMContentLoaded'){
        var wrapped = function(ev){
          if(domReadyFired) return;
          domReadyFired = true;
          return listener.call(this, ev);
        };
        return origAdd(type, wrapped, options);
      }
      return origAdd(type, listener, options);
    };
  }catch(_e){}

  // Lightweight focus recovery only, do not force top scroll.
  window.addEventListener('focus', function(){
    try{
      var y = window.scrollY || window.pageYOffset || 0;
      requestAnimationFrame(function(){
        try{ window.scrollTo(0, y); }catch(_e2){}
      });
    }catch(_e){}
  }, true);
})();
</script>


<script id="managerHubIdleStabilityJs">
(function(){
  if(window.__managerHubIdleStabilityInstalled) return;
  window.__managerHubIdleStabilityInstalled = true;

  var wakeRefreshTimer = null;
  var refreshLockedUntil = 0;

  function nowMs(){
    try{ return Date.now(); }catch(_e){ return 0; }
  }

  function isVisible(){
    try{ return document.visibilityState === 'visible'; }catch(_e){ return true; }
  }

  function preserveScroll(fn){
    try{
      var y = window.scrollY || window.pageYOffset || 0;
      var x = window.scrollX || window.pageXOffset || 0;
      var result = typeof fn === 'function' ? fn() : null;
      Promise.resolve(result).finally(function(){
        requestAnimationFrame(function(){
          try{ window.scrollTo(x, y); }catch(_e2){}
        });
      });
      return result;
    }catch(_e){
      try{ return typeof fn === 'function' ? fn() : null; }catch(_e2){ return null; }
    }
  }

  function shouldSuppressRefresh(){
    try{
      if(!isVisible()) return true;
      return nowMs() < refreshLockedUntil;
    }catch(_e){ return false; }
  }

  function lockRefresh(ms){
    try{ refreshLockedUntil = nowMs() + (ms || 0); }catch(_e){}
  }

  // Quietly preserve scroll around common wake-up events.
  document.addEventListener('visibilitychange', function(){
    if(document.visibilityState !== 'visible') return;
    clearTimeout(wakeRefreshTimer);
    wakeRefreshTimer = setTimeout(function(){
      preserveScroll(function(){});
      lockRefresh(800);
    }, 400);
  }, true);

  window.addEventListener('focus', function(){
    clearTimeout(wakeRefreshTimer);
    wakeRefreshTimer = setTimeout(function(){
      preserveScroll(function(){});
      lockRefresh(800);
    }, 300);
  }, true);

  // Wrap setInterval callbacks so hidden-tab wakeups don't cause heavy jump.
  try{
    var _setInterval = window.setInterval;
    window.setInterval = function(fn, delay){
      if(typeof fn !== 'function'){
        return _setInterval.apply(window, arguments);
      }
      var wrapped = function(){
        if(shouldSuppressRefresh()) return;
        return preserveScroll(fn);
      };
      return _setInterval.call(window, wrapped, delay);
    };
  }catch(_e){}

  // Wrap requestAnimationFrame-triggered refresh bursts after idle/wake.
  try{
    var _raf = window.requestAnimationFrame;
    window.requestAnimationFrame = function(cb){
      if(typeof cb !== 'function') return _raf.apply(window, arguments);
      var wrapped = function(ts){
        if(shouldSuppressRefresh()){
          return _raf(function(){});
        }
        return cb(ts);
      };
      return _raf.call(window, wrapped);
    };
  }catch(_e){}

})();
</script>


<script id="annualStatusLogicV90Js">
(function(){
  function applyAnnualStatusLogic(){
    var body = document.getElementById('annualApprovalBody');
    if(!body) return;
    var rows = body.querySelectorAll('.annual-approval-row');
    rows.forEach(function(row){
      // remove buttons if any
      var actions = row.querySelector('.annual-approval-row__actions');
      if(actions) actions.style.display = 'none';

      var status = String(row.getAttribute('data-status') || '').toLowerCase();
      if(!status){
        var txt = String(row.innerText || '').toLowerCase();
        if(txt.includes('mailed')) status = 'mailed';
        else if(txt.includes('sent')) status = 'sent_to_admin';
        else if(txt.includes('approved')) status = 'approved_ready_to_send';
      }

      var helper = row.querySelector('.annual-approval-row__helper, .board-items-row__helper, .itemHelper, .approval-helper');
      if(!helper){
        // fallback: first paragraph-ish text block after meta
        var candidates = row.querySelectorAll('div, p, span');
        for(var i=0;i<candidates.length;i++){
          var t = (candidates[i].innerText || '').trim();
          if(t && /review the draft packet|generate resident-ready/i.test(t)){
            helper = candidates[i];
            break;
          }
        }
      }

      var pillClass = 'approved';
      var pillText = 'Supervisor Approved';
      var helperText = 'Packet approved and ready for mailing coordination.';

      if(status === 'sent_to_admin'){
        pillClass = 'sent';
        pillText = 'Sent to Admin';
        helperText = 'Packet has been sent for mailing coordination.';
      } else if(status === 'mailed'){
        pillClass = 'mailed';
        pillText = 'Mailed';
        helperText = 'Resident packets have been mailed.';
      }

      if(helper) helper.textContent = helperText;

      var existing = row.querySelector('.annual-status-pill');
      if(existing) existing.remove();

      var target = helper || row;
      var pill = document.createElement('div');
      pill.className = 'annual-status-pill ' + pillClass;
      pill.textContent = pillText;
      target.insertAdjacentElement('afterend', pill);
    });
  }

  document.addEventListener('DOMContentLoaded', function(){
    applyAnnualStatusLogic();
    setTimeout(applyAnnualStatusLogic, 250);
    setTimeout(applyAnnualStatusLogic, 1000);
  });
})();
</script>


<script>
/* Manager Hub scroll glide fix */
(function(){
  function applyScrollFix(){
    try{
      document.documentElement.style.overflowY = 'auto';
      document.documentElement.style.overflowX = 'hidden';
      document.body.style.overflowY = 'auto';
      document.body.style.overflowX = 'hidden';
      document.body.style.webkitOverflowScrolling = 'touch';
      [
        '.manager-hub','.managerhub','.managerhub-shell','.managerhub-page',
        '.main-content','.content','.page-wrap','.page-shell'
      ].forEach(function(sel){
        document.querySelectorAll(sel).forEach(function(el){
          el.style.minHeight = '100vh';
          el.style.height = 'auto';
          el.style.overflow = 'visible';
          el.style.overflowY = 'visible';
          el.style.webkitOverflowScrolling = 'touch';
        });
      });
      window.scrollTo(window.scrollX, window.scrollY);
    }catch(e){}
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', applyScrollFix);
  } else {
    applyScrollFix();
  }
  window.addEventListener('pageshow', applyScrollFix);
})();
</script>


<script>
(function(){
  function fix(){
    if(window.innerWidth > 1024) return;
    document.documentElement.style.overflowY='auto';
    document.body.style.overflowY='auto';
    document.body.style.webkitOverflowScrolling='touch';
  }
  document.addEventListener('DOMContentLoaded', fix);
  window.addEventListener('resize', fix);
})();
</script>


<script id="employee-hub-card-visibility-fix">
(function(){
  function isEmployeeRole(){
    var bodyRole = String((document.body && document.body.getAttribute('data-staff-role')) || '').trim().toLowerCase();
    var globalRole = String(window.__zummeeUserRole || '').trim().toLowerCase();
    return bodyRole === 'employee' || globalRole === 'employee';
  }

  function refreshEmployeeMoreToolsCount(){
    var countEl = document.getElementById('moreToolsCount');
    var more = document.getElementById('moreToolsContainer');
    if(!countEl || !more) return;
    var count = Array.from(more.querySelectorAll('.card.clickable-card')).filter(function(card){
      var style = window.getComputedStyle(card);
      return style.display !== 'none' && style.visibility !== 'hidden';
    }).length;
    countEl.textContent = count + ' cards';
  }

  function hideEmployeeRestrictedCards(){
    if(!isEmployeeRole()) return;
    ['employeePerformanceCard','annualMeetingApprovalsCard','dailyTasksCard','communityAssignmentsCard','employeeAccountActivationsCard','companyBrandingTextingCard'].forEach(function(id){
      var el = document.getElementById(id);
      if(el) el.style.display = 'none';
    });
    refreshEmployeeMoreToolsCount();
  }

  document.addEventListener('DOMContentLoaded', hideEmployeeRestrictedCards);
  window.addEventListener('load', hideEmployeeRestrictedCards);
  setTimeout(hideEmployeeRestrictedCards, 300);
  setTimeout(hideEmployeeRestrictedCards, 1200);

  var observer = new MutationObserver(function(){ hideEmployeeRestrictedCards(); });
  document.addEventListener('DOMContentLoaded', function(){
    observer.observe(document.body, {childList:true, subtree:true, attributes:true, attributeFilter:['data-staff-role','style','class']});
    setTimeout(function(){ try{ observer.disconnect(); }catch(_e){} }, 5000);
  });
})();
</script>

<div class="zm-fav-modal-backdrop" id="favoritesLimitModal" aria-hidden="true">
  <div class="zm-fav-modal" role="dialog" aria-modal="true" aria-labelledby="favoritesLimitTitle">
