<script>
/* HUB_LONGPRESS_REORDER */
(function(){
  function onReady(fn){
    if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", fn);
    else fn();
  }
  onReady(function(){
    // Use existing hub customize functions if present
    var setCustomize = null;
    try{
      // setCustomize is inside the hub script scope; but we can trigger the hidden toggle by simulating click if it exists
      var toggleBtn = document.getElementById("hubCustomizeToggle");
      // fallback: add a hidden toggle button if script created one, otherwise we rely on body class toggling via click handlers
      function toggle(){
        if(toggleBtn) { toggleBtn.click(); return; }
        // If no toggle button exists, try toggling body class only (drag will be enabled by existing script when on)
        document.body.classList.toggle("hub-customize");
      }

      var HOLD_MS = 550;
      var t = null;
      function start(){ cancel(); t = setTimeout(toggle, HOLD_MS); }
      function cancel(){ if(t){ clearTimeout(t); t=null; } }

      var cards = document.querySelectorAll(".cards .card[data-card-id]");
      cards.forEach(function(card){
        card.addEventListener("touchstart", start, {passive:true});
        card.addEventListener("touchend", cancel);
        card.addEventListener("touchmove", cancel);
        card.addEventListener("touchcancel", cancel);

        card.addEventListener("mousedown", start);
        card.addEventListener("mouseup", cancel);
        card.addEventListener("mouseleave", cancel);
      });
    }catch(_e){}
  });
})();
</script>

