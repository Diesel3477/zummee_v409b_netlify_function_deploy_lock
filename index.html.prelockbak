}

/* Prevent centering from parent flex containers */
.page-header,
.title-row {
  justify-content:flex-start !important;
  text-align:left !important;
}

/* Precisely match left edge of main section container */
#opsHeaderRow {
  padding-left: 60px !important; /* match section container padding */
  justify-content: flex-start !important;
}

#opsHeaderRow h1 {
  margin: 0 !important;
}

/* Match subpage logo size to Manager Hub */
.zummee-header .zummee-logo {
  font-size: 42px !important;
