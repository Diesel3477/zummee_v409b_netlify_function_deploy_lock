  }
}


/* Live Team Activity iPad layout + live dots */
#activityFeedCard .activity-feed-link{
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  gap: 18px !important;
  width: 100% !important;
}

#activityFeedCard .activity-feed-time{
  flex: 0 0 190px !important;
  min-width: 190px !important;
  white-space: nowrap !important;
}

#activityFeedCard .activity-feed-text{
  flex: 1 1 auto !important;
  min-width: 0 !important;
}

#activityFeedCard .activity-feed-text::before{
  content: "" !important;
  display: inline-block !important;
  width: 10px !important;
  height: 10px !important;
  margin-right: 12px !important;
  border-radius: 999px !important;
  background: #22c55e !important;
  box-shadow:
    0 0 0 0 rgba(34,197,94,0.55),
    0 0 10px rgba(34,197,94,0.45) !important;
  vertical-align: middle !important;
  animation: liveFeedPulse 1.8s ease-out infinite !important;
}

@keyframes liveFeedPulse{
  0%{
    box-shadow:
      0 0 0 0 rgba(34,197,94,0.50),
      0 0 8px rgba(34,197,94,0.35);
    transform: scale(1);
  }
  70%{
    box-shadow:
      0 0 0 8px rgba(34,197,94,0),
      0 0 14px rgba(34,197,94,0.18);
    transform: scale(1.02);
  }
  100%{
    box-shadow:
      0 0 0 0 rgba(34,197,94,0),
      0 0 8px rgba(34,197,94,0.08);
    transform: scale(1);
  }
}

/* Keep same horizontal row layout on iPad */
