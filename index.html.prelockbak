(function(){
  var backdrop = document.getElementById('favoritesLimitModal');
  if(!backdrop) return;
  backdrop.addEventListener('click', function(ev){ if(ev.target === backdrop) closeFavoritesLimitModal(); });
  document.addEventListener('keydown', function(ev){ if(ev.key === 'Escape') closeFavoritesLimitModal(); });
})();
</script>


<script>
(function(){
  function triggerSupervisorCardShimmer(card){
    if(!card) return;
    card.classList.remove('is-shimmering');
    void card.offsetWidth;
    card.classList.add('is-shimmering');
    clearTimeout(card.__shimmerTimer);
    card.__shimmerTimer = setTimeout(function(){ card.classList.remove('is-shimmering'); }, 1200);
  }
  document.addEventListener('pointerdown', function(e){
    var card = e.target && e.target.closest ? e.target.closest('.supervisor-card') : null;
    if(card) triggerSupervisorCardShimmer(card);
  }, true);
  document.addEventListener('keydown', function(e){
    var active = document.activeElement;
    if((e.key === 'Enter' || e.key === ' ') && active && active.classList && active.classList.contains('supervisor-card')){
      triggerSupervisorCardShimmer(active);
    }
  });
})();
</script>

<script>
(function(){
  function applySupervisorGoldCards(){
    var cards=document.querySelectorAll('.card.supervisor-card, .clickable-card.supervisor-card');
    cards.forEach(function(card){
      card.style.background='linear-gradient(145deg, #f3d98a 0%, #e2b84f 52%, #cb9932 100%)';
      card.style.border='1px solid rgba(132, 95, 18, 0.42)';
      card.style.boxShadow='inset 0 1px 0 rgba(255,255,255,0.36), 0 12px 24px rgba(110, 78, 15, 0.16)';
      if(card.dataset.supervisorGoldBound==='1') return;
      card.dataset.supervisorGoldBound='1';
      ['pointerdown','mouseenter','focus'].forEach(function(evt){
        card.addEventListener(evt, function(){
          card.classList.remove('supervisor-shimmer-on');
          void card.offsetWidth;
          card.classList.add('supervisor-shimmer-on');
          setTimeout(function(){ card.classList.remove('supervisor-shimmer-on'); }, 1000);
        });
      });
    });
  }
  document.addEventListener('DOMContentLoaded', applySupervisorGoldCards);
  window.addEventListener('load', applySupervisorGoldCards);
  var mo=new MutationObserver(function(){ applySupervisorGoldCards(); });
  mo.observe(document.documentElement,{childList:true,subtree:true});
  setTimeout(function(){ try{mo.disconnect();}catch(e){} }, 8000);
})();
</script>


<script>
(async function(){
  try{
    var sb = (window.getSb && getSb()) || (window.sb) || null;
    if(!sb || !sb.auth) return;

    var res = await sb.auth.getUser();
    var user = res && res.data && res.data.user ? res.data.user : null;
    if(!user) return;

    var q = await sb.from('userdirectory').select('role, approved').eq('auth_user_id', user.id).maybeSingle();
    var profile = q && q.data ? q.data : null;

    var role = String((profile && profile.role) || '').toLowerCase();
    var approved = profile && typeof profile.approved !== 'undefined' ? !!profile.approved : true;

    var isAdmin = approved && (role === 'admin' || role === 'companyadmin');

    if(!isAdmin){
      var card = document.querySelector('[data-card-id="supervisor_access_main"]');
      if(card) card.remove();
    }
  }catch(_e){}
})();
</script>


