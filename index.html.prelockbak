.zummee-header .zummee-subtitle {
  font-size: 16px !important;
  letter-spacing: 2px !important;
}

.zummee-header svg {
  height: 28px !important;
}

/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}

