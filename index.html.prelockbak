<!-- ZUMMEE PATCH v510: Force  Add -> Supabase POST -->
<!-- ZUMMEE PATCH v511: Hard override  Add click -->
<script>
/* Supervisor card visibility: hidden by default, show instantly for cached privileged users, then confirm with profile. */
document.addEventListener("DOMContentLoaded", () => {
  const card = document.getElementById("supervisorHubCard");
  if (!card) return;

  const isPriv = (p) => {
    const role = String(p?.role || p?.user_role || p?.access_level || p?.access || "").toLowerCase().trim();
    const dept = String(p?.department || p?.dept || "").toLowerCase().trim();
    const authRole = String(window?.ZUMMEE_AUTH?.role || "").toLowerCase().trim();
    const authDept = String(window?.ZUMMEE_AUTH?.department || "").toLowerCase().trim();
    const s = [role, dept, authRole, authDept].filter(Boolean).join(" ");
    const flag = !!(p?.is_supervisor || p?.is_admin || p?.is_companyadmin);
    return flag || /\b(companyadmin|admin|supervisor)\b/.test(s) || /(company\s*admin)/.test(s);
  };

  // Start hidden (CSS), but show immediately if we already know user is privileged from cached state.
  const cachedProfile = window.__zummeeProfile || window.__profile || null;
  if (isPriv(cachedProfile || {})) {
    card.classList.add("zummee-allow");
    card.style.display = "";
  } else if (isPriv({})) {
    // Covers the case where ZUMMEE_AUTH already carries role/department
    card.classList.add("zummee-allow");
    card.style.display = "";
  } else {
    card.style.display = "none";
  }

  // Confirm with fresh profile (async) and correct visibility.
  (async () => {
    let profile = null;
    for (let i = 0; i < 6; i++) {
      try {
        if (typeof window.getProfile === "function") profile = await window.getProfile();
        else profile = window.__zummeeProfile || window.__profile || null;
      } catch (e) {
        profile = null;
      }
      if (profile && (profile.role || profile.department || profile.dept || profile.user_role || profile.access_level || profile.access || profile.is_supervisor || profile.is_admin || profile.is_companyadmin)) break;
      await new Promise(r => setTimeout(r, 120));
    }

    try {
      if (isPriv(profile || {})) {
        card.classList.add("zummee-allow");
        card.style.display = "";
      } else {
        card.classList.remove("zummee-allow");
        card.style.display = "none";
      }
    } catch (e) {
      console.warn("Supervisor card role check failed:", e);
      card.classList.remove("zummee-allow");
      card.style.display = "none";
    }
  })();
});
</script>
<script>
/* v530 CLEAN:  Add Community -> real Supabase insert into PropertyCommunities.
   - CompanyAdmin/Admin/Supervisor choose an Active Company once; remembered in localStorage.
   - Employees should not use this button (UI already hides/guards).
*/
(function(){
  function isPriv(profile){
    const role = String(profile?.role||"").toLowerCase().trim();
    const dept = String(profile?.department||profile?.dept||"").toLowerCase().trim();
    return ["companyadmin","admin","supervisor"].includes(role) || ["companyadmin","admin","supervisor"].includes(dept);
  }

  async function ensureSB(){
    if(!window.sb && typeof window.ensureSupabase === "function"){
      await window.ensureSupabase();
    }
    return window.sb;
  }

  async function fetchCompanies(){
    const sb = await ensureSB();
    if(!sb) throw new Error("Supabase not initialized");
    // Try both table casings
    let res = await sb.from("Companies").select("id,name").order("name", {ascending:true});
    if(res.error){
      res = await sb.from("companies").select("id,name").order("name", {ascending:true});
    }
    if(res.error) throw res.error;
    return res.data || [];
  }

  async function getActiveCompany(profile){
    // 1) profile.company_id if present
    if(profile?.company_id) return { id: profile.company_id, name: profile.company || profile.company_name || "" };

    // 2) remembered selection
    const savedId = localStorage.getItem("zummee_active_company_id") || "";
    const savedName = localStorage.getItem("zummee_active_company_name") || "";
    if(savedId) return { id: savedId, name: savedName };

    // 3) prompt once
    const companies = await fetchCompanies();
    if(!companies.length) throw new Error("No companies found");

    const menu = companies.map((c,i)=>`${i+1}) ${c.name}`).join("\n");
    const pick = prompt("Select Active Company (enter number):\n\n"+menu);
    const n = Number(String(pick||"").trim());
    if(!Number.isFinite(n) || n<1 || n>companies.length) return null;

    const chosen = companies[n-1];
    localStorage.setItem("zummee_active_company_id", chosen.id);
    localStorage.setItem("zummee_active_company_name", chosen.name);
    return { id: chosen.id, name: chosen.name };
  }

  async function addCommunityCloud(){
    const profile = (typeof window.getProfile === "function") ? await window.getProfile() : (window.__zummeeProfile || window.__profile || null);
    if(!profile) return alert("Profile unavailable.");

    if(!isPriv(profile)) return alert("Access denied.");

    const active = await getActiveCompany(profile);
    if(!active?.id) return; // user canceled

    const raw = prompt("New Community Name:");
    const name = (raw||"").trim();
    if(!name) return;

    const sb = await ensureSB();
    if(!sb) return alert("Supabase not initialized.");

    const payload = {
      name,
      company_id: active.id,
      company: active.name || profile.company || profile.company_name || ""
    };

    const { error } = await sb.from("PropertyCommunities").insert([payload]);
    if(error){
      console.error("PropertyCommunities insert failed:", error);
      alert("Could not create community. Check Console for details.");
      return;
    }

    // Refresh view
    location.reload();
  }

  // Expose a single canonical entrypoint so any legacy code that calls
  // addCommunity() will go through the cloud insert path.
  window.addCommunity = addCommunityCloud;

  // Belt-and-suspenders: intercept Add clicks in the capture phase so
  // no previously-registered legacy handlers can swallow the click.
  document.addEventListener("click", (e)=>{
    const t = e.target;
    if(t && t.id === "zummeeCommunityAdd"){
      try{ e.preventDefault(); }catch(_e){}
      try{ e.stopImmediatePropagation(); }catch(_e){}
      addCommunityCloud();
    }
  }, true);

  document.addEventListener("DOMContentLoaded", ()=>{
    const btn = document.getElementById("zummeeCommunityAdd");
    if(!btn) return;

    // IMPORTANT: The Add button already has legacy addEventListener handlers attached earlier in page load.
    // If we simply add another listener, the earlier capture/bubble listeners may still run first.
    // To guarantee our Supabase POST runs (and ONLY our handler), we replace the node with a clone.
    const clone = btn.cloneNode(true);
    btn.parentNode.replaceChild(clone, btn);

    clone.onclick = (e)=>{
      try{ e.preventDefault(); }catch(_e){}
      addCommunityCloud();
    };

    // Also intercept clicks in capture phase to prevent any earlier legacy
    // addEventListener handlers from running.
    clone.addEventListener('click', (ev)=>{
      try{
        ev.preventDefault();
        ev.stopPropagation();
        ev.stopImmediatePropagation();
      }catch(_e){}
      addCommunityCloud();
    }, true);
  });
})();
</script>
<!-- v933: Unified Sign out modal -->
<div class="zum-modal-backdrop" id="zum_signOutModal">
<div aria-labelledby="zum_signOutTitle" aria-modal="true" class="zum-modal" role="dialog">
<div class="zum-modal-title" id="zum_signOutTitle">Sign out</div>
<div class="zum-modal-body">Are you sure you want to sign out?</div>
<div class="zum-modal-actions">
<button class="zum-btn secondary" id="zum_signOutCancel" type="button">Cancel</button>
<button class="zum-btn primary" id="zum_signOutOk" type="button">Sign out</button>
</div>
</div>
</div>
<script>

// v933: unified sign-out modal helpers
(function(){
  function qs(id){ return document.getElementById(id); }
  window.zumOpenSignOutModal = function(){
    const m = qs('zum_signOutModal'); if(!m) return;
    m.style.display='flex';
    setTimeout(()=>{ try{ qs('zum_signOutOk')?.focus?.(); }catch(_e){} }, 20);
  };
  window.zumCloseSignOutModal = function(){
    const m = qs('zum_signOutModal'); if(!m) return;
    m.style.display='none';
  };
  
  // v1003: robust button bindings (prevents "popup OK button not working")
  function bindSignOutModal(){
    const m = qs('zum_signOutModal');
    const ok = qs('zum_signOutOk');
    const cancel = qs('zum_signOutCancel');
    if(ok && !ok.__zum_bound){
      ok.__zum_bound = true;
      ok.addEventListener('pointerdown', (ev)=>{ try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){} }, true);
      ok.addEventListener('click', async (ev)=>{
        try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){}
        try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
        try{ await (window.zummeePerformSignOut ? window.zummeePerformSignOut() : null); }catch(_e){}
      }, true);
    }
    if(cancel && !cancel.__zum_bound){
      cancel.__zum_bound = true;
      cancel.addEventListener('pointerdown', (ev)=>{ try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){} }, true);
      cancel.addEventListener('click', (ev)=>{
        try{ ev.preventDefault(); ev.stopPropagation(); ev.stopImmediatePropagation(); }catch(_e){}
        try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
      }, true);
    }
    if(m && !m.__zum_bound){
      m.__zum_bound = true;
      m.addEventListener('pointerdown', (ev)=>{ /* block click-through */ try{ ev.stopPropagation(); }catch(_e){} }, true);
      m.addEventListener('click', (ev)=>{
        const t = ev.target;
        if(t && t.id === 'zum_signOutModal'){
          try{ ev.preventDefault(); ev.stopPropagation(); }catch(_e){}
          try{ window.zumCloseSignOutModal && window.zumCloseSignOutModal(); }catch(_e){}
        }
      }, true);
    }
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', bindSignOutModal);
  }else{
    bindSignOutModal();
  }

document.addEventListener('click', (ev)=>{
    const t = ev.target;
    const m = qs('zum_signOutModal');
    if(!m || m.style.display!=='flex') return;
    if(t && (t.id==='zum_signOutCancel')){ window.zumCloseSignOutModal(); return; }
    if(t && (t.id==='zum_signOutOk')){ window.zumCloseSignOutModal(); try{ window.zummeePerformSignOut && window.zummeePerformSignOut(); }catch(_e){} return; }
    if(t && t.id==='zum_signOutModal'){ window.zumCloseSignOutModal(); return; }
  });
  document.addEventListener('keydown',(ev)=>{
    const m = qs('zum_signOutModal');
    if(!m || m.style.display!=='flex') return;
    if(ev.key==='Escape'){ window.zumCloseSignOutModal(); }
  });
})();


(function(){
  function bindManagerHubSignOutConfirm(){
    var wrap = document.getElementById('managerHubSignOutWrap');
    var pop = document.getElementById('managerHubSignOutPop');
    var cancelBtn = document.getElementById('managerHubSignOutCancel');
    var confirmBtn = document.getElementById('managerHubSignOutConfirm');
    if(!wrap || !pop) return;
    if(cancelBtn && !cancelBtn.__zumBound){
      cancelBtn.__zumBound = true;
      cancelBtn.addEventListener('click', function(ev){
        try{ ev.preventDefault(); ev.stopPropagation(); }catch(_e){}
        try{ window.zummeeManagerHubCloseSignOutConfirm && window.zummeeManagerHubCloseSignOutConfirm(); }catch(_e){}
      });
    }
    if(confirmBtn && !confirmBtn.__zumBound){
      confirmBtn.__zumBound = true;
      confirmBtn.addEventListener('click', async function(ev){
        try{ ev.preventDefault(); ev.stopPropagation(); }catch(_e){}
        try{ window.zummeeManagerHubCloseSignOutConfirm && window.zummeeManagerHubCloseSignOutConfirm(); }catch(_e){}
        try{ await (window.zummeePerformSignOut ? window.zummeePerformSignOut() : null); }catch(_e){ console.warn('manager hub confirmed sign out failed', _e); }
      });
    }
    if(!document.__zumManagerHubSignOutDocBound){
      document.__zumManagerHubSignOutDocBound = true;
      document.addEventListener('click', function(ev){
        var localWrap = document.getElementById('managerHubSignOutWrap');
        var localPop = document.getElementById('managerHubSignOutPop');
        if(!localWrap || !localPop || !localPop.classList.contains('is-open')) return;
        if(localWrap.contains(ev.target)) return;
        try{ window.zummeeManagerHubCloseSignOutConfirm && window.zummeeManagerHubCloseSignOutConfirm(); }catch(_e){}
      });
      document.addEventListener('keydown', function(ev){
        if(ev.key === 'Escape'){
          try{ window.zummeeManagerHubCloseSignOutConfirm && window.zummeeManagerHubCloseSignOutConfirm(); }catch(_e){}
        }
      });
    }
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bindManagerHubSignOutConfirm);
  else bindManagerHubSignOutConfirm();
})();
</script>
<script>
// v955: Add community button id alias (supports sup_addCommunityBtn and sup_addCommunityBtn)
(function(){
  function wire(){
    var a = document.getElementById('sup_addCommunityBtn');
    var b = document.getElementById('sup_addCommunityBtn');
    if(a && b && a!==b){
      b.addEventListener('click', function(ev){
        try{ ev.preventDefault(); ev.stopPropagation(); }catch(e){}
        a.click();
      });
    }
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', wire);
  else wire();
})();
</script>
<script>
(function(){
  function makeCardNavigate(cardId, href){
    const card = document.getElementById(cardId);
    if(!card) return;
    card.style.cursor = "pointer";
    // If there's already a button link inside, keep it working.
    card.addEventListener("click", function(e){
      // allow normal link clicks
      const a = e.target && e.target.closest ? e.target.closest("a") : null;
      if(a) return;
      window.location.href = href;
    });
  }
  document.addEventListener("DOMContentLoaded", function(){
    makeCardNavigate("boardMemberHubCard", "board_member_hub.html");
  });
})();
</script>
<script>
// v1141: Board Member Hub card attention rules
// Red only when there are overdue Board Member items.
// Gold when there are open items but nothing overdue.
(function(){
  function safeGetLS(k){ try{ return String(localStorage.getItem(k)||'').trim(); }catch(_e){ return ''; } }
  function getActiveCommunityId(){
    try {
      var sel = document.getElementById('zummeeCommunitySelect');
      if (sel && sel.value) return String(sel.value).trim();
    } catch(e) {}
    return (window.getActiveCommunityId && window.getActiveCommunityId()) || safeGetLS('zummee_selected_community_id') || safeGetLS('activeCommunityId') || safeGetLS('zummeeActiveCommunityId') || safeGetLS('currentCommunityId') || safeGetLS('zummee_community_id');
  }

  function normalizeStatus(s){
    return String(s||'').trim().toLowerCase();
  }

  function hasConvertedMarker(r){
    try{
      var details = String((r && r.details) || '');
      return /__ZUMMEE_BM_CONVERTED__:\s*RWO\|/i.test(details);
    }catch(_e){}
    return false;
  }

  function isCompleteRow(r){
    // Match Board Member Hub page logic: treat completed items as closed,
    // and exclude legacy complete-ish rows as a fallback.
    try{
      if(r && r.completed_at) return true;
      var st = normalizeStatus(r && r.status);
      if(st && ['complete','completed','closed','done','resolved'].includes(st)) return true;
      var details = String((r && r.details) || '');
      if(/__ZUMMEE_BM_STATUS__:\s*COMPLETE\|/i.test(details)) return true;
    }catch(_e){}
    return false;
  }

  function shouldCountAsOpenRow(r){
    // Submitted Items on board_member_hub.html only show rows that are:
    // 1) not completed and 2) not converted into work orders yet.
    try{
      if(isCompleteRow(r)) return false;
      if(hasConvertedMarker(r)) return false;
    }catch(_e){}
    return true;
  }

  function isOverdueRow(r){
    try{
      if(!shouldCountAsOpenRow(r)) return false;
      if(!r || !r.due_date) return false;
      // due_date comes back as YYYY-MM-DD
      var due = new Date(String(r.due_date) + 'T00:00:00');
      if(isNaN(due.getTime())) return false;
      var now = new Date();
      // Compare by local date only
      var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      return due < today;
    }catch(_e){}
    return false;
  }

  function ensureStyles(){
    if(document.getElementById('bmHubAlertStyles')) return;
    var s = document.createElement('style');
    s.id = 'bmHubAlertStyles';
    s.textContent = "\n"+
      "#boardMemberHubCard.bm-alert{ background: rgba(220, 38, 38, 0.14) !important; border-color: rgba(220, 38, 38, 0.45) !important; }\n"+
      "#boardMemberHubCard.bm-warn{ background: linear-gradient(135deg, rgba(245, 200, 66, 0.94), rgba(218, 166, 33, 0.96)) !important; border-color: rgba(201, 145, 12, 0.92) !important; box-shadow: 0 0 0 2px rgba(224, 169, 29, 0.55), 0 12px 26px rgba(196, 139, 16, 0.20) !important; }\n"+
      "#boardMemberHubCard .bm-alert-badge{ display:inline-block; margin-left:10px; padding:2px 10px; border-radius:999px; font-size:12px; font-weight:900; background: rgba(245, 200, 66, 0.22); color:#7a5400; border:1px solid rgba(201, 145, 12, 0.45); }\n"+
      "#boardMemberHubCard .bm-alert-badge.is-overdue{ background: rgba(220, 38, 38, 0.18); color:#b91c1c; border:1px solid rgba(220, 38, 38, 0.45); }\n"+
      // Daily Ops card has a strong blue inset glow by default; override it so the alert is visually obvious.
      "#dailyOpsCard.ops-alert{ background: linear-gradient(135deg, rgba(255, 228, 228, 0.95), rgba(255, 214, 214, 0.92)) !important; "+
      "box-shadow: inset 0 0 0 var(--hubGlowWidth) rgba(220, 38, 38, 0.70), 0 12px 28px rgba(220, 38, 38, 0.18) !important; }\n"+
      "#dailyOpsCard.ops-alert:hover{ box-shadow: inset 0 0 0 var(--hubGlowWidth) rgba(220, 38, 38, 0.85), 0 16px 34px rgba(220, 38, 38, 0.22) !important; }\n"+
      "#dailyOpsCard .ops-alert-badge{ display:inline-block; margin-left:10px; padding:2px 10px; border-radius:999px; font-size:12px; font-weight:900; background: rgba(220, 38, 38, 0.18); color: #b91c1c; border:1px solid rgba(220, 38, 38, 0.35); }\n";
    document.head.appendChild(s);
  }

  // Expose for other inline modules (e.g., Daily Ops card attention) that run in a separate IIFE.
  window.ensureStyles = ensureStyles;

  function ensureBadgeEl(card){
    var existing = card.querySelector('.bm-alert-badge');
    if(existing) return existing;
    // Try to attach near the title if present
    var titleEl = card.querySelector('.title') || card.querySelector('h2') || card.querySelector('h3') || card;
    var badge = document.createElement('span');
    badge.className = 'bm-alert-badge';
    badge.style.display = 'none';
    badge.textContent = '';
    titleEl.appendChild(badge);
    return badge;
  }

  function setCardState(openCount, overdueCount){
    var card = document.getElementById('boardMemberHubCard');
    if(!card) return;
    ensureStyles();

    var badge = ensureBadgeEl(card);
    card.classList.remove('bm-alert', 'bm-warn');
    badge.classList.remove('is-overdue');

    if(overdueCount > 0){
      card.classList.add('bm-alert');
      var overdueParts = [];
      if(openCount > 0) overdueParts.push("Open " + openCount);
      overdueParts.push("Overdue " + overdueCount);
      badge.textContent = overdueParts.join(" ");
      badge.classList.add('is-overdue');
      badge.style.display = 'inline-block';
    }else if(openCount > 0){
      card.classList.add('bm-warn');
      badge.textContent = "Open " + openCount;
      badge.style.display = 'inline-block';
    }else{
      badge.textContent = '';
      badge.style.display = 'none';
    }
  }

  async function refreshBoardMemberHubAttention(){
    var card = document.getElementById('boardMemberHubCard');
    if(!card) return;
    if(!window.sb){ setCardState(0,0); return; }

    var communityId = getActiveCommunityId();
    if(!communityId){ setCardState(0,0); return; }

    try{
      var q = await window.sb
        .from('BoardMemberActionItems')
        .select('id,details,status,completed_at,due_date')
        .eq('community_id', communityId)
        .order('created_at', { ascending:false })
        .limit(500);

      if(q && q.error) throw q.error;
      var rows = (q && q.data) ? q.data : [];

      var openCount = 0;
      var overdueCount = 0;

      for(var i=0;i<rows.length;i++){
        var r = rows[i] || {};
        if(shouldCountAsOpenRow(r)){
          openCount++;
          if(isOverdueRow(r)) overdueCount++;
        }
      }

      setCardState(openCount, overdueCount);
    }catch(_e){
      setCardState(0,0);
    }
  }

  function schedule(){
    refreshBoardMemberHubAttention();
    document.addEventListener('community:changed', function(){
      setTimeout(refreshBoardMemberHubAttention, 150);
    });
    setInterval(refreshBoardMemberHubAttention, 60000);
  }

  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', schedule);
  else schedule();
})();

// Daily Ops Non-Negotiables attention: turn Daily Ops card red until today's non-negotiables are marked complete.
  (function(){
    var NONNEG_TEMPLATE_KEY = "zummee_nonnegotiables_template_v1";
    var NONNEG_COMPLETION_TABLE = "daily_ops_nonneg_completion";
    var NONNEG_COMPLETION_KEY = "zummee_nonneg_completion_mark_v1";

    function getDateKeyLocal(){
      try{
        var d = new Date();
        var y = d.getFullYear();
        var m = String(d.getMonth()+1).padStart(2,'0');
        var day = String(d.getDate()).padStart(2,'0');
        return y + "-" + m + "-" + day;
      }catch(_e){ return ""; }
    }

    function getCompanyIdSafe(){
      try{
        // Prefer auth/context helpers if present.
        if(window.ZummeeAuth){
          if(typeof window.ZummeeAuth.getSelectedCompanyId === "function"){
            var c1 = (window.ZummeeAuth.getSelectedCompanyId()||"").trim();
            if(c1) return c1;
          }
          if(typeof window.ZummeeAuth.getCompanyId === "function"){
            var c2 = (window.ZummeeAuth.getCompanyId()||"").trim();
            if(c2) return c2;
          }
        }
      }catch(_e){ /* ignore */ }
      try{
        var c3 = (window.activeCompanyId || "").trim();
        if(c3) return c3;
      }catch(_e2){ /* ignore */ }
      try{
        // Common storage keys used across pages.
        var c4 = (localStorage.getItem("activeCompanyId") || localStorage.getItem("zummee_selected_company_id") || localStorage.getItem("zummee_active_company_id") || "").trim();
        if(c4) return c4;
      }catch(_e3){ /* ignore */ }
      return "";
    }

    async function resolveCompanyId(){
      var cid = getCompanyIdSafe();
      if(cid) return cid;
      try{
        var sb = await ensureSupabase();
        if(!sb) return "";
        var uid = "";
        try{ uid = await requireUid(); }catch(_e){ uid = (window.__zummee_uid_cached||""); }
        uid = String(uid||"").trim();
        if(!uid) return "";

        // Try profiles (common)
        try{
          var q1 = await sb.from("profiles").select("company_id").eq("auth_user_id", uid).limit(1).maybeSingle();
          if(q1 && !q1.error && q1.data && q1.data.company_id){
            cid = String(q1.data.company_id||"").trim();
          }
        }catch(_eP){}

        // Try userdirectory (fallback)
        if(!cid){
          try{
            var q2 = await sb.from("userdirectory").select("company_id").eq("auth_user_id", uid).limit(1).maybeSingle();
            if(q2 && !q2.error && q2.data && q2.data.company_id){
              cid = String(q2.data.company_id||"").trim();
            }
          }catch(_eU){}
        }

        if(cid){
          try{ localStorage.setItem("activeCompanyId", cid); }catch(_eS){}
          try{ window.activeCompanyId = cid; }catch(_eW){}
          return cid;
        }
      }catch(_e){ /* ignore */ }
      return "";
    }

    async function getNonNegTemplateCount(){
      // Cloud-first: count active Non-Neg template items from structured table.
      // IMPORTANT: on some roles/pages we may not have an activeCompanyId cached yet.
      // If companyId is unavailable, rely on RLS to scope rows and count by template_type/is_active.
      var countSup = 0;
      try{
        var sb = await ensureSupabase();
        var companyId = await resolveCompanyId();
        if(sb){
          var q = sb
            .from("daily_ops_template_items")
            .select("id", { count: "exact", head: true })
            .eq("template_type", "nonneg")
            .eq("is_active", true);
          if(companyId){
            q = q.eq("company_id", companyId);
          }
          var r = await q;
          if(r && !r.error){
            countSup = (typeof r.count === "number") ? r.count : 0;
          }
        }
      }catch(_e){ /* fall back */ }

      if(countSup > 0) return countSup;

      // Fallback: legacy localStorage-only template (device-scoped).
      try{
        var raw = localStorage.getItem(NONNEG_TEMPLATE_KEY);
        if(!raw) return 0;
        var arr = JSON.parse(raw);
        if(!Array.isArray(arr)) return 0;
        var seen = {};
        var n = 0;
        for(var i=0;i<arr.length;i++){
          var s = String(arr[i]||"").trim();
          if(!s) continue;
          if(seen[s]) continue;
          seen[s]=1;
          n++;
        }
        return n;
      }catch(_e2){ return 0; }
    }

    function setDailyOpsCardState(needsAttention){
      var card = document.getElementById("dailyOpsCard");
      if(!card) return;
      if(window.ensureStyles) window.ensureStyles();
      card.classList.remove("ops-alert", "ops-complete");
      if(needsAttention){
        card.classList.add("ops-alert");
      }else{
        card.classList.add("ops-complete");
      }
    }

    async function getTodayNonNegSnapshot(dateKey){
      try{
        if(!dateKey) return null;
        var companyIdSnap = await resolveCompanyId();
        var snapshotKeys = [];
        if(companyIdSnap) snapshotKeys.push("zummee_nonneg_snapshot_v1:" + companyIdSnap);
        try{
          snapshotKeys = snapshotKeys.concat(
            Object.keys(localStorage || {}).filter(function(k){
              return /^zummee_nonneg_snapshot_v1:/i.test(k || "");
            })
          );
        }catch(_eKeys){}

        var seenSnap = {};
        for(var sk=0; sk<snapshotKeys.length; sk++){
          var key = snapshotKeys[sk];
          if(!key || seenSnap[key]) continue;
          seenSnap[key] = 1;
          try{
            var snapRaw = localStorage.getItem(key) || "";
            if(!snapRaw) continue;
            var snap = JSON.parse(snapRaw);
            var snapDay = String((snap && snap.day) || "");
            var total = Number((snap && snap.total) || 0);
            var done = Number((snap && snap.done) || 0);
            if(snapDay === dateKey){
              return { total: total, done: done };
            }
          }catch(_eSnap){}
        }
      }catch(_eOuter){}
      return null;
    }

    async function snapshotShowsCompleteToday(dateKey){
      try{
        var snap = await getTodayNonNegSnapshot(dateKey);
        if(!snap) return false;
        return (snap.total === 0 || snap.done >= snap.total);
      }catch(_eOuter){}
      return false;
    }

    async function snapshotShowsNeedsAttentionToday(dateKey){
      try{
        var snap = await getTodayNonNegSnapshot(dateKey);
        if(!snap) return false;
        return (snap.total > 0 && snap.done < snap.total);
      }catch(_eOuter){}
      return false;
    }

    async function isCompletedToday(){
      var templateCount = await getNonNegTemplateCount();
      if(templateCount <= 0) return true; // nothing required => no attention
      var dateKey = getDateKeyLocal();
      if(!dateKey) return true;
      // Trust the live Daily Ops progress snapshot first so the hub does not stay red
      // when the Daily Ops page already shows all current items complete.
      try{
        if(await snapshotShowsCompleteToday(dateKey)) return true;
      }catch(_eSnapFirst){}

      // Local-storage completion markers can become stale when supervisors change the Non-Neg template (delete/add items).
      // For the  card, we intentionally avoid using local markers to prevent false "green" states.
      // Cloud check below is active-template-aware (joins completions to currently active template items).
      try{
        // Cloud-first structured completion (active template aware):
        // Count ONLY completions tied to currently active Non-Neg template items.
        var sb = await ensureSupabase();
        var uid = await requireUid();
        window.__zummee_uid_cached = uid;
        var companyId = await resolveCompanyId();

        // 1) Load active Non-Neg template item ids (RLS may scope rows even without companyId).
        var tq = sb
          .from("daily_ops_template_items")
          .select("id")
          .eq("template_type", "nonneg")
          .eq("is_active", true);
        if(companyId){ tq = tq.eq("company_id", companyId); }
        var tr = await tq;
        if(tr && tr.error) throw tr.error;
        var ids = (tr && tr.data) ? tr.data.map(function(r){ return r && r.id; }).filter(Boolean) : [];
        // No active items => nothing required => no attention.
        if(ids.length === 0) return true;

        // 2) Count todays completions for THIS user that match the active template ids.
        var cq = sb
          .from("daily_ops_item_completion")
          .select("id", { count: "exact", head: true })
          .eq("user_id", uid)
          .eq("day", dateKey)
          .in("template_item_id", ids);
        if(companyId){ cq = cq.eq("company_id", companyId); }
        var cr = await cq;
        if(cr && cr.error) throw cr.error;
        var doneCount = (typeof cr.count === "number") ? cr.count : 0;
        if(doneCount >= ids.length) return true;

        // v299: trust the same-day local completion marker written by ops.html as an immediate success override.
        // This prevents the hub from staying red when Daily Ops shows all current non-negotiables complete
        // but the cloud count is lagging or filtered differently on the hub page.
        try{
          var rawLocal = localStorage.getItem(NONNEG_COMPLETION_KEY) || "{}";
          var objLocal = JSON.parse(rawLocal);
          var bucketLocal = (objLocal && objLocal[dateKey]) ? objLocal[dateKey] : null;
          if(bucketLocal && typeof bucketLocal === 'object'){
            var uidLocal = (window.__zummee_uid_cached || "").trim();
            var emailLocal = "";
            try{
              var uLocal = await sb.auth.getUser();
              uidLocal = uidLocal || (uLocal && uLocal.data && uLocal.data.user && uLocal.data.user.id ? String(uLocal.data.user.id) : "");
              emailLocal = (uLocal && uLocal.data && uLocal.data.user && uLocal.data.user.email) ? String(uLocal.data.user.email) : "";
            }catch(_eAuthLocal){}
            emailLocal = emailLocal || ((window.sessionUser && window.sessionUser.email) || (window.__sessionUser && window.__sessionUser.email) || "").trim();

            if(uidLocal && bucketLocal[uidLocal] && bucketLocal[uidLocal].completed_at) return true;
            if(emailLocal && bucketLocal[emailLocal] && bucketLocal[emailLocal].completed_at) return true;
            try{
              var localKeys = Object.keys(bucketLocal||{});
              if(localKeys.length === 1){
                var onlyLocal = bucketLocal[localKeys[0]];
                if(onlyLocal && onlyLocal.completed_at) return true;
              }
            }catch(_eLocalKeys){}
          }
        }catch(_eLocal){}

        // v300: fallback to the actual Daily Ops local state bucket used by ops.html.
        // When Daily Ops shows "All current non-negotiable items are complete", it writes
        // state.meta.nonNegCompletedAt[YYYY-MM-DD]. The hub should trust that on the same device.
        try{
          var cidFallback = ((window.activeCommunityId || localStorage.getItem("activeCommunityId") || "") + "").trim();
          var uidFallback = ((window.__zummee_uid_cached || "") + "").trim();
          try{
            if(!uidFallback && sb && sb.auth && typeof sb.auth.getUser === "function"){
              var ufb = await sb.auth.getUser();
              uidFallback = (ufb && ufb.data && ufb.data.user && ufb.data.user.id) ? String(ufb.data.user.id) : "";
            }
          }catch(_eUidFb){}

          var candidateKeys = [];
          if(uidFallback && cidFallback) candidateKeys.push("daily_ops_manager_v9::" + uidFallback + "::" + cidFallback);
          if(uidFallback) candidateKeys.push("daily_ops_manager_v9::" + uidFallback);
          if(cidFallback) candidateKeys.push("daily_ops_manager_v9::" + cidFallback);
          candidateKeys.push("daily_ops_manager_v9");

          for(var ck=0; ck<candidateKeys.length; ck++){
            try{
              var rawState = localStorage.getItem(candidateKeys[ck]) || "";
              if(!rawState) continue;
              var parsedState = JSON.parse(rawState);
              var completedAt = parsedState && parsedState.meta && parsedState.meta.nonNegCompletedAt;
              if(completedAt && completedAt[dateKey]) return true;
            }catch(_eStateKey){}
          }
        }catch(_eStateFb){}

        // v302: fallback to the exact live non-neg snapshot key used by Daily Ops.
        // Observed shape:
        // key   = zummee_nonneg_snapshot_v1:<companyId>
        // value = { companyId, day: 'YYYY-MM-DD', total, done, ... }
        try{
          if(await snapshotShowsCompleteToday(dateKey)) return true;
        }catch(_eSnapOuter){}

        return false;
      }catch(_e){
        // If we cannot check Supabase (table missing/RLS/etc.), fall back to the local marker written by ops.html.
        try{
          var raw = localStorage.getItem(NONNEG_COMPLETION_KEY) || "{}";
          var obj = JSON.parse(raw);
          var bucket = (obj && obj[dateKey]) ? obj[dateKey] : null;
          if(!bucket || typeof bucket !== 'object') return false;

          // Get best-effort identity (uid/email). Prefer Supabase auth if available on this page.
          var uid2 = (window.__zummee_uid_cached || "").trim();
          var email2 = "";
          try{
            var sb2 = await ensureSupabase();
            if(sb2 && sb2.auth && typeof sb2.auth.getUser === "function"){
              var u2 = await sb2.auth.getUser();
              uid2 = uid2 || (u2 && u2.data && u2.data.user && u2.data.user.id ? String(u2.data.user.id) : "");
              email2 = (u2 && u2.data && u2.data.user && u2.data.user.email) ? String(u2.data.user.email) : "";
            }
          }catch(_eAuth){}
          email2 = email2 || ((window.sessionUser && window.sessionUser.email) || (window.__sessionUser && window.__sessionUser.email) || "").trim();

          if(uid2 && bucket[uid2] && bucket[uid2].completed_at) return true;
          if(email2 && bucket[email2] && bucket[email2].completed_at) return true;

          // As a last resort, only treat "any completion" as complete if there is exactly ONE identity key.
          // This avoids false positives when multiple users share a device.
          try{
            var keys = Object.keys(bucket||{});
            if(keys.length === 1){
              var only = bucket[keys[0]];
              if(only && only.completed_at) return true;
            }
          }catch(_eKeys){}
          return false;
        }catch(_e2){
          return false;
        }
      }
    }

async function refresh(){
      try{
        var dateKey = getDateKeyLocal();
        var done = await isCompletedToday();
        if(done){
          setDailyOpsCardState(false);
          return;
        }

        // Only show red when we have a same-day Daily Ops snapshot proving there are
        // still open current items. On login/bootstrap, that snapshot can lag or be
        // absent, and we should prefer a non-alert state over a false red card.
        try{
          if(await snapshotShowsNeedsAttentionToday(dateKey)){
            setDailyOpsCardState(true);
          }else{
            setDailyOpsCardState(false);
          }
          return;
        }catch(_eSnapGate){}

        setDailyOpsCardState(false);
      }catch(_e){
        setDailyOpsCardState(false);
      }
    }

    function schedule(){
      refresh();
      document.addEventListener("community:changed", function(){ setTimeout(refresh, 150); });
      // When returning from Daily Ops via back button (bfcache), re-check.
      window.addEventListener("focus", function(){ setTimeout(refresh, 50); });
      window.addEventListener("pageshow", function(){ setTimeout(refresh, 50); });
      document.addEventListener("visibilitychange", function(){
        if(!document.hidden) setTimeout(refresh, 50);
      });
      setInterval(refresh, 60000);
    }

    if(document.readyState==="loading") document.addEventListener("DOMContentLoaded", schedule);
    else schedule();
  })();

</script>
</div><script>
(function(){
  var card = document.getElementById('dailyOpsCard');
  if(!card) return;
  var href = card.getAttribute('data-href') || 'ops.html';
  function go(){ window.location.href = href; }
  card.addEventListener('click', function(e){
    // ignore if user is selecting text
    go();
  });
  card.addEventListener('keydown', function(e){
    if(e.key === 'Enter' || e.key === ' '){
      e.preventDefault();
      go();
    }
  });
})();
</script>
<script>
(function(){
  function activateLink(el){
    var href = el.getAttribute("data-href");
    if(!href) return;
    el.addEventListener("click", function(){ window.location.href = href; });
    el.addEventListener("keydown", function(e){
      if(e.key === "Enter" || e.key === " "){
        e.preventDefault();
        window.location.href = href;
      }
    });
  }
  document.querySelectorAll('[role="link"][data-href]').forEach(activateLink);
})();
</script>

<script id="zummeeCommunityController_v1">
/* Unified Community Controller — single source of truth for all pages (v2092) */
(function(){
  const KEY="activeCommunityId";

  function getSelect(){
    return document.getElementById("zummeeCommunitySelect");
  }

  function isPlaceholder(opt){
    const v = (opt?.value || "").trim();
    const t = (opt?.textContent || "").trim().toLowerCase();
    if(!v) return true;
    return (t === "select" || t === "select..." || t === "— select —" || t === "-- select --");
  }

  function firstRealValue(sel){
    const opts = Array.from(sel?.options || []);
    for(const o of opts){
      if(!isPlaceholder(o)) return o.value;
    }
    return "";
  }

  function syncLabel(){
    const sel=getSelect();
    if(!sel) return;
    const txt=sel.selectedOptions?.[0]?.textContent?.trim();
    if(!txt) return;
    [
      document.getElementById("mzCommunityPickerLabel"),
      document.getElementById("zummeeCommunityLabel"),
      document.querySelector(".communityPickerLabel"),
      document.querySelector("[data-community-label]"),
      // Hub header uses this label class
      document.querySelector(".zummee-header__communityLabelValue")
    ].filter(Boolean).forEach(el=>{ try{ el.textContent=txt; }catch(_e){} });
  }

  function applySaved(){
    const sel=getSelect();
    if(!sel) return;

    const saved=(localStorage.getItem(KEY)||"").trim();

    // If saved exists and option exists, apply it.
    if(saved){
      const opt=sel.querySelector('option[value="'+CSS.escape(saved)+'"]');
      if(opt){
        sel.value=saved;
      }
    }

    // If still placeholder/empty, choose first real option.
    const currentOpt = sel.selectedOptions?.[0];
    if(!sel.value || isPlaceholder(currentOpt)){
      const first = firstRealValue(sel);
      if(first){
        sel.value = first;
      }
    }

    if(sel.value){
      localStorage.setItem(KEY, sel.value);
    }

    syncLabel();
  }

  function wire(){
    const sel=getSelect();
    if(!sel) return;

    if(!sel.__zummeeBound){
      sel.__zummeeBound=true;
      sel.addEventListener("change", ()=>{
        const opt = sel.selectedOptions?.[0];
        if(sel.value && !isPlaceholder(opt)){
          localStorage.setItem(KEY, sel.value);
        }
        syncLabel();
      });
    }

    applySaved();
  }

  function start(){
    wire();

    // Observe for header rebuild / option repopulation (Hub does this)
    const obs = new MutationObserver(()=>{ if(getSelect()) wire(); });
    obs.observe(document.body,{childList:true,subtree:true});

    // Retry window during load
    let tries=0;
    const t=setInterval(()=>{
      wire();
      tries++;
      if(tries>120) clearInterval(t);
    },100);
  }

  document.addEventListener("DOMContentLoaded", start);
  start();
})();
</script>

<script id="hubRemindersCardScript_v2093">
(function(){
  const STORE_KEY = "zummee_reminders_v1";
  const TICK_MS = 30000;

  function readStore(){
    try { return JSON.parse(localStorage.getItem(STORE_KEY) || "[]"); } catch(e){ return []; }
  }
  function safeGetLS(k){
    try { return String(localStorage.getItem(k) || '').trim(); } catch(e){ return ''; }
  }
  function getActiveCommunityScope(){
    var sel = null;
    var id = '';
    var name = '';
    try { sel = document.getElementById('zummeeCommunitySelect'); } catch(_e) {}
    try { if (sel && sel.value) id = String(sel.value).trim(); } catch(_e2) {}
    try { if (sel && sel.selectedOptions && sel.selectedOptions[0]) name = String(sel.selectedOptions[0].textContent || '').trim(); } catch(_e3) {}
    if (!id) id = safeGetLS('zummee_selected_community_id') || safeGetLS('activeCommunityId') || safeGetLS('zummee_community_id') || safeGetLS('zummeeActiveCommunityId');
    if (!name) name = safeGetLS('zummee_selected_community_name') || safeGetLS('selectedCommunityName') || safeGetLS('zummee_selected_community');
    return { id: String(id || '').trim(), name: String(name || '').trim().toLowerCase() };
  }
  function reminderMatchesActiveCommunity(reminder, scope){
    if (!scope || (!scope.id && !scope.name)) return true;
    var reminderId = String(reminder && (reminder.communityId || reminder.community_id || reminder.communityID || '')).trim();
    var reminderName = String(reminder && (reminder.communityName || reminder.community_name || reminder.community || '')).trim().toLowerCase();
    if (scope.id && reminderId && reminderId === scope.id) return true;
    if (scope.name && reminderName && reminderName === scope.name) return true;
    return false;
  }
  function remindersForActiveCommunity(all){
    var scope = getActiveCommunityScope();
    if ((!scope.id && !scope.name) || !Array.isArray(all)) return Array.isArray(all) ? all : [];
    var matched = (all || []).filter(function(reminder){
      return reminderMatchesActiveCommunity(reminder, scope);
    });
    return matched.length ? matched : (Array.isArray(all) ? all : []);
  }
  function startOfToday(now){
    return new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0, 0);
  }
  function endOfToday(now){
    return new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59, 999);
  }
  function classifyReminder(reminder, now){
    const status = String((reminder && reminder.status) || 'open').toLowerCase().trim();
    if (status === 'done' || status === 'completed' || status === 'complete' || status === 'closed') return 'completed';
    const rawDue = reminder && (reminder.dueAt || reminder.due_at || reminder.reminderAt || reminder.reminder_at || '');
    if (!rawDue) return 'scheduled';
    const due = new Date(rawDue);
    if (isNaN(due.getTime())) return 'scheduled';
    if (due.getTime() <= now.getTime()) return 'overdue';
    if (due.getTime() <= endOfToday(now).getTime()) return 'dueToday';
    return 'scheduled';
  }
  function bucketReminders(all, now){
    const buckets = { overdue: 0, dueToday: 0, scheduled: 0, completed: 0 };
    (all || []).forEach(function(reminder){
      const bucket = classifyReminder(reminder, now);
      if (buckets[bucket] == null) buckets[bucket] = 0;
      buckets[bucket] += 1;
    });
    return buckets;
  }
  function escapeHtml(v){
    return String(v == null ? '' : v).replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch] || ch; });
  }
  function notifyHubReminderState(buckets){
    try { window.__zummeeHubReminderBuckets = buckets || null; } catch(e) {}
    try {
      window.dispatchEvent(new CustomEvent('zummee:hub-reminders-updated', { detail: buckets || null }));
    } catch(e) {}
  }
  function update(){
    const el = document.getElementById("remindersCardSub");
    if (!el) return;

    const now = new Date();
    const all = remindersForActiveCommunity(readStore());
    const buckets = bucketReminders(all, now);
    const parts = [];

    if (buckets.overdue){
      parts.push('<span class="hubRemPill"><span class="hubRemDot overdue"></span>'+buckets.overdue+' overdue</span>');
    }
    if (buckets.dueToday){
      parts.push('<span class="hubRemPill"><span class="hubRemDot upcoming"></span>'+buckets.dueToday+' due today</span>');
    }
    if (!parts.length){
      if (buckets.scheduled){
        el.innerHTML = '<div class="hubRemLine">No reminders due</div>';
      } else if (buckets.completed){
        el.innerHTML = '<div class="hubRemLine">No reminders due</div>';
      } else {
        el.textContent = 'No reminders due';
      }
      notifyHubReminderState(buckets);
      return;
    }

    el.innerHTML = '<div class="hubRemLine">'+parts.join(' ')+'</div>';
    notifyHubReminderState(buckets);
  }

  function handleStorage(e){
    if (e && e.key && e.key !== STORE_KEY) return;
    update();
  }
  function handleVisibility(){
    if (!document.hidden) update();
  }

  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", update);
  else update();

  window.addEventListener("focus", update);
  window.addEventListener("storage", handleStorage);
  window.addEventListener("zummee:reminders-changed", update);
  window.addEventListener("community:changed", update);
  document.addEventListener("community:changed", update);
  document.addEventListener("visibilitychange", handleVisibility);
  document.addEventListener("change", function(e){
    try{
      if(e && e.target && e.target.id === 'zummeeCommunitySelect') setTimeout(update, 0);
    }catch(_e){}
  });
  setInterval(update, TICK_MS);
})();
</script>

<script>
(function(){
  async function loadResidentWorkOrderCard(){
    const card = document.getElementById('residentWorkOrdersCard');
    const summary = document.getElementById('residentWorkOrdersSummary');
    if(!card || !summary) return;
    try{
      if(typeof ensureSupabase !== 'function'){
        summary.textContent = 'Open resident work orders.';
        return;
      }
      const sb = await ensureSupabase();
      if(!sb || typeof sb.from !== 'function'){
        summary.textContent = 'Open resident work orders.';
        return;
      }
      const activeCommunityId = String(localStorage.getItem('zummeeActiveCommunityId') || localStorage.getItem('activeCommunityId') || '').trim();
      let q = sb.from('resident_work_orders').select('status,priority,community_id', { count: 'exact', head: false }).limit(500);
      if(activeCommunityId){ q = q.eq('community_id', activeCommunityId); }
      const res = await q;
      if(res.error){
        summary.textContent = 'Resident work order queue.';
        return;
      }
      const rows = Array.isArray(res.data) ? res.data : [];
      let newCount = 0, awaiting = 0, inProgress = 0, urgentCount = 0;
      rows.forEach(function(r){
        const s = String(r.status || '').toLowerCase();
        const p = String(r.priority || '').toLowerCase();
        if((s === 'submitted' || s === 'under_review') && p === 'urgent') urgentCount += 1;
        if(s === 'submitted' || s === 'under_review') newCount += 1;
        if(s === 'awaiting_assignment') awaiting += 1;
        if(s === 'assigned_to_vendor' || s === 'in_progress') inProgress += 1;
      });
      const hasAttention = (newCount > 0 || awaiting > 0 || urgentCount > 0);
      card.classList.toggle('rwo-alert', hasAttention);
      card.classList.toggle('rwo-urgent', urgentCount > 0);
      if(badge){
        badge.classList.remove('urgent','awaiting');
        if(urgentCount > 0){ badge.style.display = 'inline-block'; badge.textContent = 'Urgent ' + urgentCount; badge.classList.add('urgent'); }
        else if(newCount > 0){ badge.style.display = 'inline-block'; badge.textContent = 'New ' + newCount; }
        else if(awaiting > 0){ badge.style.display = 'inline-block'; badge.textContent = 'Awaiting ' + awaiting; badge.classList.add('awaiting'); }
        else { badge.style.display = 'none'; badge.textContent = ''; }
      }
      summary.textContent = '🔴 ' + newCount + ' new  ·  ⚠ ' + urgentCount + ' urgent  ·  🟠 ' + awaiting + ' awaiting assignment  ·  ✅ ' + inProgress + ' active';
      if(pills){
        const bits = [];
        if(urgentCount > 0) bits.push('<span class="hub-smart-pill urgent">Urgent ' + urgentCount + '</span>');
        if(newCount > 0) bits.push('<span class="hub-smart-pill">New ' + newCount + '</span>');
        if(awaiting > 0) bits.push('<span class="hub-smart-pill warn">Awaiting ' + awaiting + '</span>');
        if(inProgress > 0) bits.push('<span class="hub-smart-pill ok">Active ' + inProgress + '</span>');
        pills.innerHTML = bits.join('');
      }
    }catch(_e){
      summary.textContent = 'Open resident work orders.';
    }
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', loadResidentWorkOrderCard, { once:true });
  } else {
    loadResidentWorkOrderCard();
  }
  window.addEventListener('resident-work-orders:changed', loadResidentWorkOrderCard);
  document.addEventListener('resident-work-orders:changed', loadResidentWorkOrderCard);
  window.addEventListener('focus', loadResidentWorkOrderCard);
})();
</script>

<script>
(function(){
  async function loadLiveMaintenanceCard(){
    const card = document.getElementById('liveMaintenanceUpdatesCard');
    const summary = document.getElementById('liveMaintenanceSummary');
    const pills = document.getElementById('liveMaintenancePills');
    if(!card || !summary || !pills) return;
    try{
      if(typeof ensureSupabase !== 'function'){
        summary.textContent = 'Recent vendor and maintenance activity.';
        return;
      }
      const sb = await ensureSupabase();
      if(!sb || typeof sb.from !== 'function'){
        summary.textContent = 'Recent vendor and maintenance activity.';
        return;
      }
      const activeCommunityId = String(localStorage.getItem('zummeeActiveCommunityId') || localStorage.getItem('activeCommunityId') || localStorage.getItem('zummee_selected_community_id') || '').trim();
      let q = sb.from('maintenance_request_events').select('*').order('created_at', { ascending: false }).limit(24);
      const res = await q;
      if(res.error){
        summary.textContent = 'Live maintenance activity.';
        pills.innerHTML = '';
        console.warn('maintenance summary load failed', res.error);
        return;
      }
      let rows = Array.isArray(res.data) ? res.data : [];
      if(activeCommunityId){ rows = rows.filter(function(row){ return String(((row && row.community_id) || (row && row.property_community_id) || '')).trim() === activeCommunityId; }); }
      const recentWindowMs = 1000 * 60 * 60 * 48;
      const now = Date.now();
      let recent = 0, started = 0, completed = 0, reminders = 0;
      rows.forEach(r => {
        const type = String(r.event_type || '').toLowerCase();
        const ts = r.created_at ? new Date(r.created_at).getTime() : 0;
        if(ts && (now - ts) <= recentWindowMs) recent += 1;
        if(type.includes('started')) started += 1;
        if(type.includes('completed')) completed += 1;
        if(type.includes('reminder') || type.includes('escalation')) reminders += 1;
      });
      card.classList.toggle('maint-alert', recent > 0 || reminders > 0);
      card.classList.toggle('maint-urgent', reminders > 0);
      summary.textContent = '🔔 ' + recent + ' recent updates  ·  🛠 ' + started + ' started  ·  ✅ ' + completed + ' completed';
      const bits = [];
      if(reminders > 0) bits.push('<span class="hub-smart-pill urgent">Reminders ' + reminders + '</span>');
      if(recent > 0) bits.push('<span class="hub-smart-pill">Recent ' + recent + '</span>');
      if(started > 0) bits.push('<span class="hub-smart-pill warn">Started ' + started + '</span>');
      if(completed > 0) bits.push('<span class="hub-smart-pill ok">Completed ' + completed + '</span>');
      pills.innerHTML = bits.join('');
    }catch(_e){
      summary.textContent = 'Live maintenance activity.';
      pills.innerHTML = '';
    }
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', loadLiveMaintenanceCard, { once:true });
  } else {
    loadLiveMaintenanceCard();
  }
  window.addEventListener('resident-work-orders:changed', loadLiveMaintenanceCard);
  document.addEventListener('resident-work-orders:changed', loadLiveMaintenanceCard);
  document.addEventListener('community:changed', () => setTimeout(loadLiveMaintenanceCard, 150));
  window.addEventListener('focus', loadLiveMaintenanceCard);
})();
</script>


<script id="mileageHubCardDashboard_v147u1">
(function(){
  function $(id){ return document.getElementById(id); }
  function escapeHtml(s){
    return String(s ?? '').replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch]; });
  }
  function monthRangeLocal(){
    var now = new Date();
    var start = new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
    var end = new Date(now.getFullYear(), now.getMonth()+1, 1, 0, 0, 0, 0);
    return { start:start, end:end };
  }
  function monthLabel(){
    return new Date().toLocaleDateString(undefined, { month:'long', year:'numeric' });
  }
  function roleAllowsCompanyView(profile){
    var s = [profile && profile.role, profile && profile.department, window && window.__zummeeUserRole, window && window.__zummeeUserDepartment].filter(Boolean).join(' ').toLowerCase();
    return s.includes('admin') || s.includes('supervisor') || s.includes('companyadmin');
  }
  function parseRowDate(row){
    var keys = ['date','log_date','entry_date','mileage_date','created_at'];
    for(var i=0;i<keys.length;i++) {
      var v = row && row[keys[i]];
      if(!v) continue;
      var d = new Date(v);
      if(!isNaN(d.getTime())) return d;
    }
    return null;
  }
  function rowMiles(row){
    var v = Number(row && (row.miles ?? row.mileage ?? row.distance ?? row.total_miles ?? 0));
    return isFinite(v) ? v : 0;
  }
  function rowUserId(row){
    return String((row && (row.user_id || row.auth_user_id || row.auth_userid || row.authUserId || row.employee_user_id)) || '').trim();
  }
  function rowName(row){
    var keys = ['employee_name','profile_name','user_name','name','employee','staff_name'];
    for(var i=0;i<keys.length;i++) {
      var v = row && row[keys[i]];
      if(v && String(v).trim()) return String(v).trim();
    }
    return '';
  }
  async function getSb(){
    try{ if(typeof ensureSupabaseSync === 'function') return ensureSupabaseSync(); }catch(_e){}
    return window.sb || window.supabaseClient || window.supabase || null;
  }
  async function getProfileSafe(){
    try{ if(typeof window.getProfile === 'function') return await window.getProfile(); }catch(_e){}
    return {};
  }
  async function getAuthUserId(sb){
    try{
      if(sb && sb.auth && typeof sb.auth.getUser === 'function'){
        var r = await sb.auth.getUser();
        return String(r && r.data && r.data.user && r.data.user.id || '').trim();
      }
    }catch(_e){}
    return '';
  }
  async function fetchLogsForCompany(sb, profile){
    var tries = [];
    var companyId = String((profile && profile.company_id) || localStorage.getItem('zummee_active_company_id') || '').trim();
    var companyName = String((profile && profile.company) || localStorage.getItem('zummee_active_company_name') || '').trim();
    if(companyId) tries.push({col:'company_id', val:companyId});
    if(companyName) tries.push({col:'company', val:companyName});
    var lastErr = null;
    for(var i=0;i<tries.length;i++){
      try{
        var t = tries[i];
        var res = await sb.from('MileageLogs').select('*').eq(t.col, t.val).limit(2000);
        if(!res.error) return res.data || [];
        lastErr = res.error;
      }catch(e){ lastErr = e; }
    }
    if(lastErr) console.warn('Mileage hub company query failed', lastErr);
    return [];
  }
  async function fetchLogsForUser(sb, authId){
    var cols = ['user_id','auth_user_id','auth_userid','authUserId'];
    var lastErr = null;
    for(var i=0;i<cols.length;i++){
      try{
        var res = await sb.from('MileageLogs').select('*').eq(cols[i], authId).limit(1000);
        if(!res.error) return res.data || [];
        lastErr = res.error;
      }catch(e){ lastErr = e; }
    }
    if(lastErr) console.warn('Mileage hub user query failed', lastErr);
    return [];
  }
  async function resolveNames(sb, ids){
    var out = {};
    var clean = (ids || []).filter(Boolean);
    if(!clean.length) return out;
    try{
      var res = await sb.from('userdirectory').select('auth_user_id,profile_name,profile_email').in('auth_user_id', clean);
      if(!res.error && Array.isArray(res.data)){
        res.data.forEach(function(r){
          var id = String(r && r.auth_user_id || '').trim();
          if(!id) return;
          out[id] = String(r && (r.profile_name || r.profile_email) || '').trim();
        });
      }
    }catch(_e){}
    return out;
  }
  function previousMonthRangeLocal(){
    var now = new Date();
    var start = new Date(now.getFullYear(), now.getMonth()-1, 1, 0, 0, 0, 0);
    var end = new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0, 0);
    return { start:start, end:end };
  }
  function totalMilesForRange(rows, rng){
    return (rows || []).reduce(function(sum, row){
      var d = parseRowDate(row);
      if(!d || d < rng.start || d >= rng.end) return sum;
      return sum + rowMiles(row);
    }, 0);
  }
  function setProgress(currentMiles, baselineMiles, entryCount){
    var fill = $('mileageHubProgressFill');
    var wrap = $('mileageHubProgress');
    var pace = $('mileageHubPace');
    if(!fill || !wrap) return;
    var current = Math.max(0, Number(currentMiles || 0));
    var baseline = Math.max(0, Number(baselineMiles || 0));
    var count = Math.max(0, Number(entryCount || 0));
    var ratio = 0;
    var title = '';
    var paceText = '';
    var paceClass = '';
    if(baseline > 0){
      ratio = Math.max(0, current / baseline);
      title = current.toFixed(0) + ' of ' + baseline.toFixed(0) + ' mi compared with last month';
      var now = new Date();
      var daysInMonth = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate() || 30;
      var expectedRatio = Math.max(0.05, now.getDate() / daysInMonth);
      if(ratio >= expectedRatio){
        paceText = 'On pace';
        paceClass = 'is-on-pace';
      } else if(ratio >= expectedRatio * 0.7){
        paceText = 'Slightly behind';
        paceClass = 'is-slightly-behind';
      } else {
        paceText = 'Behind pace';
        paceClass = 'is-behind';
      }
    } else {
      ratio = Math.max(0, Math.min(count / 20, 1));
      title = count + ' ' + (count === 1 ? 'entry' : 'entries') + ' recorded this month';
      if(count <= 2){
        paceText = 'Just getting started';
        paceClass = 'is-behind';
      } else if(count <= 7){
        paceText = 'Building momentum';
        paceClass = 'is-slightly-behind';
      } else {
        paceText = 'Strong activity';
        paceClass = 'is-on-pace';
      }
    }
    var percent = Math.max(0, Math.min(ratio, 1)) * 100;
    fill.style.width = percent + '%';
    var gradient = 'linear-gradient(90deg,#cf4a46,#ee7a74)';
    if(ratio >= 0.7){
      gradient = 'linear-gradient(90deg,#1e8d57,#43c97d)';
    } else if(ratio >= 0.3){
      gradient = 'linear-gradient(90deg,#d7a11d,#f0c84d)';
    }
    fill.style.background = gradient;
    fill.style.boxShadow = ratio < 0.3 ? '0 0 10px rgba(207,74,70,0.22)' : 'none';
    wrap.title = title;
    if(pace){
      pace.textContent = paceText;
      pace.className = 'mzHubPace' + (paceClass ? ' ' + paceClass : '');
      pace.title = baseline > 0 ? "Compared with expected progress for today based on last month's mileage." : "Using entry activity until a full prior month is available.";
    }
  }
  function renderHoverDetail(html, enabled){
    var card = $('mileageCard');
    var box = $('mileageHubHoverDetail');
    if(!card || !box) return;
    card.classList.toggle('has-hover-detail', !!enabled);
    box.setAttribute('aria-hidden', enabled ? 'false' : 'true');
    box.innerHTML = enabled ? (html || '') : '';
  }
  function renderSummary(summaryText, linesHtml, entryCount, currentMiles, baselineMiles, hoverHtml, hoverEnabled){
    var sum = $('mileageHubSummary');
    var box = $('mileageHubBreakdown');
    if(sum) sum.textContent = summaryText;
    if(box) box.innerHTML = linesHtml || '';
    renderHoverDetail(hoverHtml, hoverEnabled);
    setProgress(currentMiles, baselineMiles, entryCount);
  }
  async function refreshMileageHubCard(){
    var sumEl = $('mileageHubSummary');
    var boxEl = $('mileageHubBreakdown');
    if(!sumEl || !boxEl) return;
    renderSummary('Loading mileage…','', 0, 0, 0, '', false);
    var sb = await getSb();
    if(!sb){ renderSummary('Mileage unavailable','<div class="mzHubNote">Supabase is not ready yet.</div>', 0, 0, 0, '', false); return; }
    var profile = await getProfileSafe();
    var isCompanyView = roleAllowsCompanyView(profile);
    var authId = await getAuthUserId(sb);
    var rows = isCompanyView ? await fetchLogsForCompany(sb, profile) : await fetchLogsForUser(sb, authId);
    var rng = monthRangeLocal();
    rows = (rows || []).filter(function(row){
      var d = parseRowDate(row);
      return d && d >= rng.start && d < rng.end;
    });
    if(!rows.length){
      renderSummary((isCompanyView ? 'Company total' : 'Monthly Total') + ': 0 mi', '<div class="mzHubNote">No mileage recorded for ' + escapeHtml(monthLabel()) + '.</div>', 0, 0, 0, '', false);
      return;
    }
    if(isCompanyView){
      var ids = [];
      rows.forEach(function(r){ var id = rowUserId(r); if(id) ids.push(id); });
      var nameMap = await resolveNames(sb, Array.from(new Set(ids)));
      var groups = {};
      rows.forEach(function(r){
        var id = rowUserId(r) || '__unknown__';
        var nm = rowName(r) || nameMap[id] || 'Employee';
        if(!groups[id]) groups[id] = { name:nm, miles:0, entries:0 };
        groups[id].miles += rowMiles(r);
        groups[id].entries += 1;
      });
      var list = Object.keys(groups).map(function(k){ return groups[k]; }).sort(function(a,b){ return b.miles - a.miles; });
      var companyTotal = list.reduce(function(s, x){ return s + x.miles; }, 0);
      var previousRows = isCompanyView ? await fetchLogsForCompany(sb, profile) : [];
      var companyPrevTotal = totalMilesForRange(previousRows, previousMonthRangeLocal());
      var companyEntries = list.reduce(function(s, x){ return s + x.entries; }, 0);
      var html = '<div class="mzHubNote">' + companyEntries + ' ' + (companyEntries === 1 ? 'entry' : 'entries') + ' recorded in ' + escapeHtml(monthLabel()) + '</div>';
      var hoverRows = list.slice(0, 3).map(function(item){
        return '<div class="mzHubHoverRow"><span class="mzHubHoverName">' + escapeHtml(item.name || 'Employee') + '</span><span class="mzHubHoverValue">' + item.miles.toFixed(0) + ' mi</span></div>';
      }).join('');
      var hoverHtml = '<div class="mzHubHoverTitle">Top drivers this month</div>' + hoverRows + '<div class="mzHubHoverHint">Hover to preview the top employees without leaving the hub.</div>';
      renderSummary('Company total: ' + companyTotal.toFixed(0) + ' mi', html, companyEntries, companyTotal, companyPrevTotal, hoverHtml, list.length > 0);
      return;
    }
    var myTotal = rows.reduce(function(s, r){ return s + rowMiles(r); }, 0);
    var previousRows = await fetchLogsForUser(sb, authId);
    var previousTotal = totalMilesForRange(previousRows, previousMonthRangeLocal());
    var html = '<div class="mzHubNote">' + rows.length + ' ' + (rows.length === 1 ? 'entry' : 'entries') + ' recorded in ' + escapeHtml(monthLabel()) + '</div>';
    renderSummary('Monthly Total: ' + myTotal.toFixed(0) + ' mi', html, rows.length, myTotal, previousTotal, '', false);
  }

  async function refreshEmergencyTextingHubCard(){
    var wrapEl = $('emergencyTextingScheduleWrap');
    if(!wrapEl) return;
    wrapEl.innerHTML = '<div class="scheduled-preview" id="emergencyTextingScheduleLine">Checking scheduled alerts…</div>';
    var sb = await getSb();
    if(!sb){
      wrapEl.innerHTML = '<div class="scheduled-preview" id="emergencyTextingScheduleLine">Scheduled alerts unavailable</div>';
      return;
    }
    var profile = await getProfileSafe();
    try{
      var q = ({ error: null, data: [] })

      var companyId = String((profile && profile.company_id) || localStorage.getItem('zummee_active_company_id') || '').trim();
      if(companyId) q = q.eq('company_id', companyId);
      var res = await q;
      if(res.error){
        wrapEl.innerHTML = '<div class="scheduled-preview" id="emergencyTextingScheduleLine">No scheduled alerts</div>';
        return;
      }
      var rows = Array.isArray(res.data) ? res.data.filter(Boolean) : [];
      if(!rows.length){
        wrapEl.innerHTML = '<div class="scheduled-preview" id="emergencyTextingScheduleLine">No scheduled alerts</div>';
        return;
      }
      var next = rows[0] || {};
      var nextWhen = next.scheduled_for ? new Date(next.scheduled_for) : null;
      var nextLabel = nextWhen && !isNaN(nextWhen.getTime()) ? nextWhen.toLocaleString() : 'soon';
      var nextCommunity = String(next.community_name || 'Community').trim() || 'Community';
      var countText = rows.length + ' Scheduled Alert' + (rows.length === 1 ? '' : 's');
      var minutesAway = nextWhen && !isNaN(nextWhen.getTime()) ? Math.round((nextWhen.getTime() - Date.now()) / 60000) : null;
      var soonHtml = (minutesAway !== null && minutesAway >= 0 && minutesAway <= 60)
        ? '<div class="hub-alert-soon">🚨 Alert scheduled soon</div>'
        : '';
      wrapEl.innerHTML =
        '<div class="scheduled-preview">' +
          '<div class="scheduled-indicator">' +
            '<span class="clock-icon">⏰</span>' +
            '<span class="pulse-dot"></span>' +
            '<span class="scheduled-indicator-text">' +
              '<span class="scheduled-count">' + escapeHtml(countText) + '</span>' +
              '<span class="scheduled-next">Next: ' + escapeHtml(nextCommunity) + ' — ' + escapeHtml(nextLabel) + '</span>' +
            '</span>' +
          '</div>' +
          soonHtml +
        '</div>';
    }catch(_e){
      wrapEl.innerHTML = '<div class="scheduled-preview" id="emergencyTextingScheduleLine">No scheduled alerts</div>';
    }
  }
  window.addEventListener('profile:loaded', function(){ setTimeout(refreshMileageHubCard, 200); setTimeout(refreshEmergencyTextingHubCard, 250); });
  window.addEventListener('community:changed', function(){ setTimeout(refreshMileageHubCard, 200); setTimeout(refreshEmergencyTextingHubCard, 250); });
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){ setTimeout(refreshMileageHubCard, 500); setTimeout(refreshEmergencyTextingHubCard, 650); });
  } else {
    setTimeout(refreshMileageHubCard, 500);
    setTimeout(refreshEmergencyTextingHubCard, 650);
  }
})();
</script>

<script>
(function(){
  var DEFAULT_ZIP = '30303';
  var ZIP_KEY = 'zummee_weather_zip';
  var DRAFT_KEY = 'zummee_weather_alert_suggestion';
  var SUPABASE_URL = 'https://slcwuuwyrgnmlmxpcaim.supabase.co';
  var SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNsY3d1dXd5cmdubWxteHBjYWltIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkwMjI5MTAsImV4cCI6MjA4NDU5ODkxMH0.3pZZLufFv5SUHREjgPys-q8SnYVMzHona-yeXMVHuOg';
  function $(id){ return document.getElementById(id); }
  function escapeHtml(v){ return String(v == null ? '' : v).replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch] || ch; }); }
  function resolveCommunitySelect(){
    try{
      var nodes = Array.from(document.querySelectorAll('#zummeeCommunitySelect'));
      if(!nodes.length) return null;

      function isVisible(el){
        try{
          var r = el.getBoundingClientRect();
          return !!(r.width || r.height);
        }catch(_e){ return false; }
      }

      function selectedText(el){
        try{
          if(!el || !el.options || el.selectedIndex < 0) return '';
          return String(el.options[el.selectedIndex].text || '').trim();
        }catch(_e){ return ''; }
      }

      var visibleWithRealText = nodes.find(function(el){
        var txt = selectedText(el);
        return isVisible(el) && txt && !/^select/i.test(txt);
      });
      if(visibleWithRealText) return visibleWithRealText;

      var anyWithRealText = nodes.find(function(el){
        var txt = selectedText(el);
        return txt && !/^select/i.test(txt);
      });
      if(anyWithRealText) return anyWithRealText;

      var visibleWithValue = nodes.find(function(el){
        return isVisible(el) && String(el.value || '').trim();
      });
      if(visibleWithValue) return visibleWithValue;

      return nodes[0] || null;
    }catch(_e){ return null; }
  }
  function selectedCommunityLabel(){
    var sel = resolveCommunitySelect();
    if(sel && sel.options && sel.selectedIndex >= 0){
      var txt = String(sel.options[sel.selectedIndex].text || '').trim();
      if(txt && !/^select/i.test(txt)) return txt;
    }
    try{
      var val = String(localStorage.getItem('zummee_selected_community_id') || '').trim();
      if(val){
        var nodes = Array.from(document.querySelectorAll('#zummeeCommunitySelect'));
        var match = nodes.find(function(el){
          try{
            return Array.from(el.options || []).some(function(o){ return String(o.value) === val; });
          }catch(_e){ return false; }
        });
        if(match){
          var opt = Array.from(match.options || []).find(function(o){ return String(o.value) === val; });
          var txt2 = String((opt && opt.text) || '').trim();
          if(txt2 && !/^select/i.test(txt2)) return txt2;
        }
      }
    }catch(_e){}
    return 'Service Area';
  }
  function currentCommunityKey(){
    try{
      var sel = resolveCommunitySelect();
      return (sel && sel.value) ? sel.value : '';
    }catch(_e){ return ''; }
  }
  function weatherAuthToken(){
    try{
      var raw = localStorage.getItem('sb-zummee-auth') || localStorage.getItem('sb-slcwuuwyrgnmlmxpcaim-auth-token') || '';
      if(!raw) return '';
      var parsed = JSON.parse(raw);
      return String(
        (parsed && parsed.access_token) ||
        (parsed && parsed.currentSession && parsed.currentSession.access_token) ||
        (parsed && parsed.session && parsed.session.access_token) ||
        (parsed && parsed.data && parsed.data.session && parsed.data.session.access_token) ||
        ''
      ).trim();
    }catch(_e){ return ''; }
  }

  function weatherCacheKey(zip){
    return 'zummee_weather_cache_' + String(zip || '').replace(/\D+/g,'').slice(0,5);
  }
  function readWeatherCache(zip){
    try{
      var raw = localStorage.getItem(weatherCacheKey(zip));
      if(!raw) return null;
      var parsed = JSON.parse(raw);
      if(parsed && parsed.payload && parsed.payload.ok === true && parsed.payload.forecast){
        return parsed.payload;
      }
      if(parsed && parsed.ok === true && parsed.forecast){
        return parsed;
      }
      return null;
    }catch(_e){ return null; }
  }
  function writeWeatherCache(zip, payload){
    try{
      if(!payload || payload.ok !== true || !payload.forecast) return;
      localStorage.setItem(weatherCacheKey(zip), JSON.stringify({
        savedAt: Date.now(),
        payload: payload
      }));
    }catch(_e){}
  }
  var weatherAbortController = null;
  var weatherRequestSeq = 0;
  var weatherLastRequestedZip = '';
  var weatherLoadDebounce = null;
  var weatherLastRenderedZip = '';
  var weatherLastRenderedPayload = null;
  var weatherInFlightZip = '';
  var weatherInFlightPromise = null;
  var weatherLastFetchStartedAt = 0;
  var weatherLastSuccessAt = 0;

  async function fetchWeatherViaEdge(zip){
    var cleanZip = String(zip || '').replace(/\D+/g, '').slice(0,5);
    if(!cleanZip) cleanZip = DEFAULT_ZIP;

    if(weatherInFlightPromise && weatherInFlightZip === cleanZip){
      return weatherInFlightPromise;
    }

    if(weatherAbortController && weatherInFlightZip && weatherInFlightZip !== cleanZip){
      try{ weatherAbortController.abort(); }catch(_e){}
    }

    var controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
    weatherAbortController = controller;
    weatherInFlightZip = cleanZip;
    weatherLastFetchStartedAt = Date.now();

    weatherInFlightPromise = (async function(){
      var timeoutId = null;
      try{
        timeoutId = setTimeout(function(){ try{ controller && controller.abort(); }catch(_e){} }, 10000);
        var res = await fetch(SUPABASE_URL + '/functions/v1/get-weather', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ zip: cleanZip }),
          signal: controller ? controller.signal : undefined
        });

        var raw = await res.text();
        var payload = {};
        try{ payload = raw ? JSON.parse(raw) : {}; }catch(_e){ payload = { error: raw || 'Invalid weather response.' }; }
        console.log('EDGE WEATHER PAYLOAD:', payload);

        if(!res.ok || !payload || payload.ok !== true || !payload.forecast){
          throw new Error(String((payload && payload.error) || ('Unable to load the weather forecast.')));
        }

        writeWeatherCache(cleanZip, payload);
        weatherLastSuccessAt = Date.now();
        return payload;
      }catch(err){
        if(err && err.name === 'AbortError') throw new Error('Weather request timed out.');
        throw err;
      }finally{
        try{ clearTimeout(timeoutId); }catch(_e){}
        if(weatherAbortController === controller) weatherAbortController = null;
        if(weatherInFlightZip === cleanZip){
          weatherInFlightZip = '';
          weatherInFlightPromise = null;
        }
      }
    })();

    return weatherInFlightPromise;
  }
  async function resolveCommunitiesIdFromSelectedValue(selectedId){
    try{
      if(!selectedId) return '';
      var base = SUPABASE_URL;
      var anon = SUPABASE_ANON;
      var token = weatherAuthToken() || anon;

      var propRes = await fetch(base + '/rest/v1/PropertyCommunities?id=eq.' + encodeURIComponent(String(selectedId)) + '&select=id,name,company', {
        headers: {
          apikey: anon,
          Authorization: 'Bearer ' + token,
          Accept: 'application/json'
        }
      });
      if(!propRes.ok) return '';
      var propRows = await propRes.json();
      var prop = Array.isArray(propRows) ? propRows[0] : propRows;
      if(!prop) return '';

      var commRes = await fetch(base + '/rest/v1/Communities?name=eq.' + encodeURIComponent(String(prop.name || '')) + '&company=eq.' + encodeURIComponent(String(prop.company || '')) + '&select=id,weather_zip,company', {
        headers: {
          apikey: anon,
          Authorization: 'Bearer ' + token,
          Accept: 'application/json'
        }
      });
      var commRows = [];
      if(commRes.ok){
        commRows = await commRes.json();
      }
      var comm = Array.isArray(commRows) ? commRows[0] : commRows;

      if(!comm){
        var fallbackRes = await fetch(base + '/rest/v1/Communities?name=eq.' + encodeURIComponent(String(prop.name || '')) + '&select=id,weather_zip,company', {
          headers: {
            apikey: anon,
            Authorization: 'Bearer ' + token,
            Accept: 'application/json'
          }
        });
        if(fallbackRes.ok){
          var fallbackRows = await fallbackRes.json();
          if(Array.isArray(fallbackRows) && fallbackRows.length === 1){
            comm = fallbackRows[0];
          }
        }
      }

      return String((comm && comm.id) || '').trim();
    }catch(_e){ return ''; }
  }
  async function fetchCommunityWeatherZipBySelectedValue(selectedId){
    try{
      var communityId = await resolveCommunitiesIdFromSelectedValue(selectedId);
      if(!communityId) return '';
      var base = SUPABASE_URL;
      var anon = SUPABASE_ANON;
      var token = weatherAuthToken() || anon;
      var res = await fetch(base + '/rest/v1/Communities?id=eq.' + encodeURIComponent(String(communityId)) + '&select=weather_zip', {
        headers: {
          apikey: anon,
          Authorization: 'Bearer ' + token,
          Accept: 'application/json'
        }
      });
      if(!res.ok) return '';
      var rows = await res.json();
      var row = Array.isArray(rows) ? rows[0] : rows;
      return String((row && row.weather_zip) || '').trim();
    }catch(_e){ return ''; }
  }
  async function persistCommunityWeatherZipBySelectedValue(selectedId, zip){
    try{
      if(!selectedId || !zip) return false;
      var communityId = await resolveCommunitiesIdFromSelectedValue(selectedId);
      if(!communityId) return false;
      var base = SUPABASE_URL;
      var anon = SUPABASE_ANON;
      var token = weatherAuthToken() || anon;
      var res = await fetch(base + '/rest/v1/Communities?id=eq.' + encodeURIComponent(String(communityId)), {
        method: 'PATCH',
        headers: {
          apikey: anon,
          Authorization: 'Bearer ' + token,
          'Content-Type': 'application/json',
          Prefer: 'return=representation'
        },
        body: JSON.stringify({ weather_zip: String(zip).trim() })
      });
      return !!res.ok;
    }catch(_e){ return false; }
  }
  function readZip(){
    try{
      var key = currentCommunityKey();
      if(key){
        var map = JSON.parse(localStorage.getItem('zummee_zip_map')||'{}');
        if(map[key]) return map[key];
      }
      return String(localStorage.getItem(ZIP_KEY) || '').trim();
    }catch(_e){ return ''; }
  }
  function writeZip(zip){
    try{
      var key = currentCommunityKey();
      if(key){
        var map = JSON.parse(localStorage.getItem('zummee_zip_map')||'{}');
        map[key] = zip;
        localStorage.setItem('zummee_zip_map', JSON.stringify(map));
        try{
          Promise.resolve(persistCommunityWeatherZipBySelectedValue(key, zip)).catch(function(err){
            console.warn('weather_zip persist failed', err);
          });
        }catch(_e3){}
      }
      localStorage.setItem(ZIP_KEY, zip);
    }catch(_e){}
  }
  function weatherMeta(code, isDay){
    var map = {
      0:['☀️','Clear Sky'],1:['🌤️','Mainly Clear'],2:['⛅','Partly Cloudy'],3:['☁️','Overcast'],
      45:['🌫️','Fog'],48:['🌫️','Fog'],51:['🌦️','Light Drizzle'],53:['🌦️','Drizzle'],55:['🌧️','Dense Drizzle'],
      56:['🌧️','Freezing Drizzle'],57:['🌧️','Freezing Drizzle'],61:['🌦️','Light Rain'],63:['🌧️','Rain'],65:['🌧️','Heavy Rain'],
      66:['🌧️','Freezing Rain'],67:['🌧️','Freezing Rain'],71:['🌨️','Light Snow'],73:['🌨️','Snow'],75:['❄️','Heavy Snow'],77:['❄️','Snow Grains'],
      80:['🌦️','Rain Showers'],81:['🌧️','Rain Showers'],82:['⛈️','Violent Showers'],85:['🌨️','Snow Showers'],86:['❄️','Heavy Snow Showers'],
      95:['⛈️','Thunderstorm'],96:['⛈️','Storm With Hail'],99:['⛈️','Severe Storm']
    };
    var hit = map[Number(code)] || [isDay ? '🌤️' : '🌙','Weather'];
    if((Number(code) === 0 || Number(code) === 1) && !Number(isDay)) hit = ['🌙', hit[1]];
    return { icon: hit[0], label: hit[1] };
  }
  function gradientClassForRisk(level){ return level === 'High' ? 'high' : (level === 'Moderate' ? 'moderate' : 'low'); }
  function analyzeRisk(data){
    var daily = (data && data.daily) || {};
    var current = (data && data.current) || {};
    var hourly = (data && data.hourly) || {};
    var precipMax = Number((daily.precipitation_probability_max || [0])[0] || 0);
    var gustMax = Number((daily.wind_gusts_10m_max || [0])[0] || 0);
    var dailyCode = Number((daily.weather_code || [0])[0] || 0);
    var hourCodes = Array.isArray(hourly.weather_code) ? hourly.weather_code.slice(0, 12).map(Number) : [];
    var hourPrecip = Array.isArray(hourly.precipitation_probability) ? hourly.precipitation_probability.slice(0, 12).map(function(v){ return Number(v||0); }) : [];
    var strongStorm = [95,96,99].some(function(code){ return Number(current.weather_code) === code || dailyCode === code || hourCodes.indexOf(code) >= 0; });
    var heavyWx = [65,67,75,82,86].some(function(code){ return dailyCode === code || hourCodes.indexOf(code) >= 0; });
    var maxHourRain = hourPrecip.reduce(function(m,v){ return Math.max(m,v||0); }, 0);
    var level = 'Low';
    var reason = 'Little weather impact expected.';
    if(strongStorm || precipMax >= 75 || gustMax >= 40 || maxHourRain >= 70){
      level = 'High';
      reason = strongStorm ? 'Thunderstorms are in the forecast — consider a community alert.' : 'Weather may affect operations — review emergency texting.';
    }else if(heavyWx || precipMax >= 50 || gustMax >= 30 || maxHourRain >= 50){
      level = 'Moderate';
      reason = 'Conditions may disrupt services — keep communication ready.';
    }
    return { level: level, reason: reason, severeLikely: level === 'High' };
  }
  function to12HourLabel(iso){
    try{ return new Date(iso).toLocaleTimeString([], { hour:'numeric' }); }catch(_e){ return '--'; }
  }
  
function isNightForWeatherTime(iso, data, current){
    try{
      var daily = (data && data.daily) || {};
      var sunrise = (daily.sunrise || [null])[0];
      var sunset = (daily.sunset || [null])[0];
      if(iso && sunrise && sunset){
        var ts = new Date(iso);
        var sr = new Date(sunrise);
        var ss = new Date(sunset);
        if(ss > sr){
          return ts < sr || ts > ss;
        }
      }
    }catch(_e){}
    return Number((current || {}).is_day || 0) !== 1;
  }
  function buildHourly(data, current){
    var hourly = (data && data.hourly) || {};
    var times = Array.isArray(hourly.time) ? hourly.time.slice(0,6) : [];
    var temps = Array.isArray(hourly.temperature_2m) ? hourly.temperature_2m.slice(0,6) : [];
    var rain = Array.isArray(hourly.precipitation_probability) ? hourly.precipitation_probability.slice(0,6) : [];
    var codes = Array.isArray(hourly.weather_code) ? hourly.weather_code.slice(0,6) : [];
    return times.map(function(t, i){
      var meta = weatherMeta(codes[i], isNightForWeatherTime(t, data, current) ? 0 : 1);
      return '<div class="weather-hour">' +
        '<div class="weather-hour-time">' + escapeHtml(to12HourLabel(t)) + '</div>' +
        '<div class="weather-hour-icon">' + escapeHtml(meta.icon) + '</div>' +
        '<div class="weather-hour-temp">' + Math.round(Number(temps[i] || 0)) + '°</div>' +
        '<div class="weather-hour-rain">' + Math.round(Number(rain[i] || 0)) + '% rain</div>' +
      '</div>';
    }).join('');
  }

  function dayLabel(iso, index){
    try{
      if(index === 0) return 'Today';
      return new Date(iso).toLocaleDateString([], { weekday:'short' });
    }catch(_e){ return index === 0 ? 'Today' : '--'; }
  }

  function getWeatherStage(current, data){
    try{
      var now = new Date(); // use live browser local time for scene transitions
      var daily = (data && data.daily) || {};
      var sunrise = (daily.sunrise || [null])[0];
      var sunset = (daily.sunset || [null])[0];
      var sr = sunrise ? new Date(sunrise) : null;
      var ss = sunset ? new Date(sunset) : null;
      var isDay = Number((current || {}).is_day || 0) === 1;
      if(!(sr && ss && ss > sr)){
        return isDay ? 'day' : 'night';
      }
      var minutesFromSunrise = (now - sr) / 60000;
      var minutesFromSunset = (now - ss) / 60000;

      if(minutesFromSunrise >= -30 && minutesFromSunrise <= 70) return 'sunrise';
      if(minutesFromSunset >= -70 && minutesFromSunset <= 30) return 'sunset';
      return isDay ? 'day' : 'night';
    }catch(_e){
      return Number((current || {}).is_day || 0) === 1 ? 'day' : 'night';
    }
  }

  function applyWeatherStageClass(stage){
    var scene = $('managerWeatherScene');
    if(!scene) return;
    scene.classList.remove('sunrise','sunset');
    if(stage === 'sunrise' || stage === 'sunset'){
      scene.classList.add(stage);
    }
  }

  function getManagerWeatherSceneClass(conditionText, isDay, code, stage){
    var text = String(conditionText || '').toLowerCase();
    var numericCode = Number(code || 0);

    if(stage === 'sunrise') return 'sunrise';
    if(stage === 'sunset') return 'sunset';

    var isNight = !Boolean(isDay);
    var snowy = text.includes('snow') || text.includes('blizzard') || text.includes('ice') || [71,73,75,77,85,86].indexOf(numericCode) >= 0;
    var foggy = text.includes('fog') || text.includes('mist') || text.includes('haze') || [45,48].indexOf(numericCode) >= 0;
    var rainy = text.includes('rain') || text.includes('drizzle') || text.includes('shower') || [51,53,55,56,57,61,63,65,66,67,80,81,82].indexOf(numericCode) >= 0;
    var stormy = text.includes('storm') || text.includes('thunder') || [95,96,99].indexOf(numericCode) >= 0;
    var cloudy = text.includes('cloud') || text.includes('overcast') || text.includes('mostly cloudy');
    var partly = text.includes('partly') || text.includes('mostly sunny') || text.includes('scattered');
    if(isNight){
      if(stormy) return 'storm-night';
      if(snowy) return 'snow-night';
      if(rainy) return 'rain-night';
      if(foggy) return 'fog-night';
      if(cloudy || partly) return 'cloudy-night';
      return 'clear-night';
    }
    if(stormy) return 'storm';
    if(snowy) return 'snow-day';
    if(rainy) return 'rain';
    if(foggy) return 'fog-day';
    if(partly) return 'partly-cloudy';
    if(cloudy) return 'cloudy';
    return 'clear-day';
  }
  function applyManagerWeatherScene(conditionText, isDay, code, stage){
    var scene = $('managerWeatherScene');
    if(!scene) return;
    var nextClass = getManagerWeatherSceneClass(conditionText, isDay, code, stage);
    scene.classList.remove('clear-day','partly-cloudy','cloudy','rain','storm','fog-day','snow-day','clear-night','cloudy-night','rain-night','storm-night','fog-night','snow-night','sun-visible','sunrise','sunset');
    scene.classList.add(nextClass);
  }

  function getMoonPhaseInfo(dateValue){
    var date = dateValue ? new Date(dateValue) : new Date();
    var year = date.getUTCFullYear();
    var month = date.getUTCMonth() + 1;
    var day = date.getUTCDate();
    if(month < 3){
      year--;
      month += 12;
    }
    month += 1;
    var c = 365.25 * year;
    var e = 30.6 * month;
    var jd = c + e + day - 694039.09;
    jd /= 29.5305882;
    var phase = jd - Math.floor(jd);
    if(phase < 0) phase += 1;

    var names = [
      "New Moon",
      "Waxing Crescent",
      "First Quarter",
      "Waxing Gibbous",
      "Full Moon",
      "Waning Gibbous",
      "Last Quarter",
      "Waning Crescent"
    ];
    var index = Math.round(phase * 8) % 8;
    var illumination = 0.5 * (1 - Math.cos(2 * Math.PI * phase));

    return {
      phase: phase,
      illumination: illumination,
      name: names[index]
    };
  }

  function applyMoonPhaseToScene(current){
    var scene = $('managerWeatherScene');
    var moon = $('managerWeatherSun');
    if(!scene || !moon) return;
    if(scene.classList.contains('sunrise') || scene.classList.contains('sunset')) return;
    if(!(scene.classList.contains('clear-night') || scene.classList.contains('cloudy-night'))) return;

    var sourceDate = (current && current.time) ? new Date(current.time) : new Date();
    var info = getMoonPhaseInfo(sourceDate);

    // convert phase into a shadow position across the moon disc
    // 0=new, .25=first quarter, .5=full, .75=last quarter
    var phase = info.phase;
    var waxing = phase <= 0.5;
    var offset;
    if(phase <= 0.5){
      offset = 82 - (phase / 0.5) * 64;   // new -> far right shadow, full -> centered wide light
    } else {
      offset = 18 + ((phase - 0.5) / 0.5) * 64; // full -> centered, waning -> left shadow
    }

    moon.style.setProperty('--moon-shadow-x', offset.toFixed(2) + '%');

    // dim cloudier nights slightly
    var cloudMultiplier = scene.classList.contains('cloudy-night') ? 0.78 : 1;
    var glow1 = 0.26 * cloudMultiplier;
    var glow2 = 0.14 * cloudMultiplier;
    var glow3 = 0.08 * cloudMultiplier;
    moon.style.setProperty('--moon-glow-1', 'rgba(210,226,255,' + glow1.toFixed(3) + ')');
    moon.style.setProperty('--moon-glow-2', 'rgba(210,226,255,' + glow2.toFixed(3) + ')');
    moon.style.setProperty('--moon-glow-3', 'rgba(210,226,255,' + glow3.toFixed(3) + ')');

    // stronger darkness near new moon, softer at fuller phases
    var darkAlpha = 0.66 - (info.illumination * 0.36);
    moon.style.setProperty('--moon-darkness', 'rgba(7,14,28,' + Math.max(0.22, darkAlpha).toFixed(3) + ')');

    try{
      moon.setAttribute('data-moon-phase', info.name);
      moon.setAttribute('aria-label', info.name);
      moon.title = info.name;
    }catch(_e){}
  }

  function clampWeatherSun(v){ return Math.max(0, Math.min(1, Number(v || 0))); }
  function updateManagerWeatherSun(data, current, stage){
    var scene = $('managerWeatherScene');
    var sun = $('managerWeatherSun');
    if(!scene || !sun) return;
    var daily = (data && data.daily) || {};
    var sunrise = (daily.sunrise || [null])[0];
    var sunset = (daily.sunset || [null])[0];
    var sr = sunrise ? new Date(sunrise) : null;
    var ss = sunset ? new Date(sunset) : null;
    var now = (current && current.time) ? new Date(current.time) : new Date();
    var isDay = Number((current || {}).is_day || 0) === 1;

    if(!(sr && ss && ss > sr)){
      scene.classList.remove('sun-visible');
      sun.style.left = "78%";
      sun.style.top = "12%";
      return;
    }

    var progress = 0;

    if(stage === 'sunrise'){
      var sunriseProgress = Math.max(0, Math.min(1, (now - new Date(sr.getTime() - 20*60000)) / (75*60000)));
      var sx = 46 + (sunriseProgress * 10);
      var sy = 78 - (Math.sin(Math.PI * sunriseProgress) * 12);
      sun.style.left = sx.toFixed(2) + "%";
      sun.style.top = sy.toFixed(2) + "%";
      scene.classList.add('sun-visible');
      return;
    }

    if(stage === 'sunset'){
      var sunsetProgress = Math.max(0, Math.min(1, (now - new Date(ss.getTime() - 55*60000)) / (80*60000)));
      var x2 = 54 - (sunsetProgress * 8);
      var y2 = 74 + (Math.sin(Math.PI * sunsetProgress) * 10);
      sun.style.left = x2.toFixed(2) + "%";
      sun.style.top = y2.toFixed(2) + "%";
      scene.classList.add('sun-visible');
      return;
    }

    if(isDay){
      if(now <= sr) progress = 0;
      else if(now >= ss) progress = 1;
      else progress = (now - sr) / (ss - sr);
      progress = clampWeatherSun(progress);
      var x = 14 + (progress * 72);
      var arch = Math.sin(Math.PI * progress);
      var y = 34 - (arch * 22);
      sun.style.left = x.toFixed(2) + "%";
      sun.style.top = y.toFixed(2) + "%";
    } else {
      var nightStart = ss.getTime();
      var nextSunrise = sr.getTime() + (24 * 60 * 60 * 1000);
      var nowTs = now.getTime();
      if(nowTs < nightStart) nowTs += (24 * 60 * 60 * 1000);
      progress = clampWeatherSun((nowTs - nightStart) / (nextSunrise - nightStart));
      var nx = 18 + (progress * 64);
      var narch = Math.sin(Math.PI * progress);
      var ny = 36 - (narch * 16);
      sun.style.left = nx.toFixed(2) + "%";
      sun.style.top = ny.toFixed(2) + "%";
    }
    scene.classList.add('sun-visible');
  }
  function buildDailyForecast(data){
    var daily = (data && data.daily) || {};
    var times = Array.isArray(daily.time) ? daily.time.slice(0,5) : [];
    var hi = Array.isArray(daily.temperature_2m_max) ? daily.temperature_2m_max.slice(0,5) : [];
    var lo = Array.isArray(daily.temperature_2m_min) ? daily.temperature_2m_min.slice(0,5) : [];
    var codes = Array.isArray(daily.weather_code) ? daily.weather_code.slice(0,5) : [];
    return times.map(function(t, i){
      var meta = weatherMeta(codes[i], i === 0 ? (Number(((data && data.current) || {}).is_day || 0) === 1 ? 1 : 0) : 1);
      return '<div class="weather-day-card">' +
        '<div class="weather-day-name">' + escapeHtml(dayLabel(t, i)) + '</div>' +
        '<div class="weather-day-icon">' + escapeHtml(meta.icon) + '</div>' +
        '<div class="weather-day-hi">' + Math.round(Number(hi[i] || 0)) + '°</div>' +
        '<div class="weather-day-lo">Low ' + Math.round(Number(lo[i] || 0)) + '°</div>' +
      '</div>';
    }).join('');
  }

function detectWeatherThreat(weather){
    var label = String(weather.condition || '').toLowerCase();
    var gust = Number(weather.gustMax || 0);
    var precip = Number(weather.rainChance || 0);
    var lowTemp = Number(weather.lowTemp || 999);
    if(label.indexOf('thunder') >= 0 || label.indexOf('storm') >= 0) return 'storm';
    if(label.indexOf('snow') >= 0 || label.indexOf('blizzard') >= 0) return 'snow';
    if(label.indexOf('freez') >= 0 || lowTemp <= 34) return 'freeze';
    if(gust >= 35 || label.indexOf('wind') >= 0) return 'wind';
    if(precip >= 60 || label.indexOf('rain') >= 0 || label.indexOf('drizzle') >= 0 || label.indexOf('shower') >= 0) return 'rain';
    return 'general';
  }
  function buildSuggestion(weather){
    var community = selectedCommunityLabel();
    var risk = String((weather.risk && weather.risk.level) || 'Low');
    var condition = String(weather.condition || 'changing weather conditions');
    var chance = Number(weather.rainChance || 0);
    var when = String(weather.whenText || 'today');
    var threat = detectWeatherThreat(weather);
    var title = risk === 'High' ? 'Weather Alert' : 'Weather Advisory Draft';
    var actionLead = risk === 'High' ? 'Please use caution and watch for additional community updates.' : 'Please stay aware and be ready for additional community updates if conditions worsen.';
    var templates = {
      storm: 'Zummee Alert for ' + community + ': Strong storms are expected ' + when + '. Please secure outdoor items, avoid unnecessary travel during severe weather, and remain alert for additional community updates.',
      snow: 'Zummee Alert for ' + community + ': Snowy or icy conditions are expected ' + when + '. Please use caution on roads and walkways and watch for additional community updates.',
      freeze: 'Zummee Alert for ' + community + ': Freezing temperatures are expected ' + when + '. Please protect exposed pipes, pets, and plants, and use caution during the colder hours.',
      wind: 'Zummee Alert for ' + community + ': Strong winds are expected ' + when + '. Please secure outdoor items and use caution around trees, debris, and community common areas.',
      rain: 'Zummee Alert for ' + community + ': Heavy rain is expected ' + when + ' with up to ' + chance + '% precipitation chance. Please use caution and watch for possible service delays or standing water.',
      general: 'Zummee Alert for ' + community + ': ' + condition + ' may affect the community ' + when + '. Current weather risk is ' + risk.toLowerCase() + '. ' + actionLead
    };
    return {
      title: title,
      category: 'Weather',
      message: templates[threat] || templates.general
    };
  }
  function formatSunTime(value){
    if(!value) return '--:--';
    var d = new Date(value);
    return d.toLocaleTimeString([], { hour:'numeric', minute:'2-digit' });
  }
  
function updateSunArc(data){
    var daily = data.daily || {};
    var current = data.current || {};
    var sunrise = (daily.sunrise || [null])[0];
    var sunset = (daily.sunset || [null])[0];
    var riseEl = $('weatherSunrise');
    var setEl = $('weatherSunset');
    var labelEl = $('weatherDaylightLabel');
    var progEl = $('weatherSunProgress');
    var dotEl = $('weatherSunDot');
    var shell = document.querySelector('.weather-sun');
    var headLabel = document.querySelector('.weather-sun-head span:first-child');
    var isDay = Number(current.is_day || 0) === 1;
    if(riseEl) riseEl.textContent = 'Sunrise ' + formatSunTime(sunrise);
    if(setEl) setEl.textContent = 'Sunset ' + formatSunTime(sunset);
    if(shell) shell.classList.toggle('is-night', !isDay);
    if(headLabel) headLabel.textContent = isDay ? 'Sunrise to Sunset' : 'Sunset to Sunrise';
    var sr = sunrise ? new Date(sunrise) : null;
    var ss = sunset ? new Date(sunset) : null;
    var now = new Date();
    var progress = 0;
    if(sr && ss && ss > sr){
      if(isDay){
        if(now <= sr) progress = 0;
        else if(now >= ss) progress = 1;
        else progress = (now - sr) / (ss - sr);
        var dayMinutes = Math.round((ss - sr)/60000);
        var dayHrs = Math.floor(dayMinutes/60);
        var dayMins = dayMinutes % 60;
        if(labelEl) labelEl.textContent = dayHrs + 'h ' + String(dayMins).padStart(2,'0') + 'm daylight';
      } else {
        var nightMinutes = Math.round((((sr.getTime() + (24*60*60*1000)) - ss.getTime())/60000));
        var nightHrs = Math.floor(nightMinutes/60);
        var nightMins = nightMinutes % 60;
        var nowTs = now.getTime();
        var ssTs = ss.getTime();
        var nextSrTs = sr.getTime() + (24*60*60*1000);
        if(nowTs < ssTs) nowTs += (24*60*60*1000);
        progress = (nowTs - ssTs) / (nextSrTs - ssTs);
        if(labelEl) labelEl.textContent = nightHrs + 'h ' + String(nightMins).padStart(2,'0') + 'm night';
      }
    } else {
      if(labelEl) labelEl.textContent = isDay ? 'Daylight' : 'Night';
    }
    progress = Math.max(0, Math.min(1, progress));
    if(progEl) progEl.style.width = (progress * 100) + '%';
    if(dotEl){
      dotEl.textContent = isDay ? '☀️' : '🌙';
      var x = progress;
      var y = Math.sin(Math.PI * progress);
      dotEl.style.left = 'calc(' + (x * 100) + '% - 12px)';
      dotEl.style.bottom = (10 + y * (isDay ? 24 : 18)) + 'px';
    }
  }


  function renderWeatherPayload(payload, zip){
    var loc = (payload && payload.location) || {};
    var data = (payload && payload.forecast) || {};
    var current = data.current || {};
    var daily = data.daily || {};
    if(!loc || !data || !Object.keys(data).length) throw new Error('Unable to load the weather forecast.');
    writeZip(zip);
    var meta = weatherMeta(current.weather_code, current.is_day);
    var risk = analyzeRisk(data);
    var communityLabel = String(selectedCommunityLabel() || 'Service Area').trim();
    var locationLine = [loc.name, loc.admin1].filter(Boolean).join(', ');
    var suggestBtn = $('weatherSuggestBtn');
    if(suggestBtn){
      if(String(risk.level || '').toLowerCase() === 'low'){
        suggestBtn.classList.add('weather-hidden');
      } else {
        suggestBtn.classList.remove('weather-hidden');
      }
    }
    $('weatherPlace').textContent = communityLabel;
    var weatherLocationEl = $('weatherLocation'); if(weatherLocationEl) weatherLocationEl.textContent = locationLine || 'Location unavailable';
    $('weatherSubline').textContent = 'ZIP ' + zip + ' • Updated from live forecast';
    $('weatherTemp').textContent = Math.round(Number(current.temperature_2m || 0)) + '°';
    $('weatherCondition').textContent = meta.icon + ' ' + meta.label;
    var weatherStage = getWeatherStage(current, data);
    applyManagerWeatherScene(meta.label, Number(current.is_day || 0) === 1, current.weather_code, weatherStage);
    updateManagerWeatherSun(data, current, weatherStage);
    applyMoonPhaseToScene(current);
    var nightNow = Number(current.is_day || 0) !== 1;
    var hubCard = $('weatherHubCard');
    if(hubCard){
      hubCard.classList.toggle('weather-hub-card--night', nightNow);
      hubCard.classList.toggle('weather-hub-card--day', !nightNow);
    }
    $('weatherHighLow').textContent = 'High ' + Math.round(Number((daily.temperature_2m_max || [0])[0] || 0)) + '° • Low ' + Math.round(Number((daily.temperature_2m_min || [0])[0] || 0)) + '°';
    $('weatherRainChance').textContent = Math.round(Number((daily.precipitation_probability_max || [0])[0] || 0)) + '%';
    $('weatherWind').textContent = Math.round(Number(current.wind_speed_10m || 0)) + ' mph';
    $('weatherFeelsLike').textContent = Math.round(Number(current.apparent_temperature || 0)) + '°';
    $('weatherRiskBadge').className = 'weather-risk ' + gradientClassForRisk(risk.level).toLowerCase();
    $('weatherRiskBadge').textContent = 'Weather Risk • ' + risk.level;
    updateSunArc(data);
    $('weatherHourly').innerHTML = buildHourly(data, current) || '<div class="weather-hour"><div class="weather-hour-time">--</div><div class="weather-hour-icon">⛅</div><div class="weather-hour-temp">--°</div><div class="weather-hour-rain">--%</div></div>';
    $('weatherForecast').innerHTML = buildDailyForecast(data) || '<div class="weather-day-card"><div class="weather-day-name">Today</div><div class="weather-day-icon">⛅</div><div class="weather-day-hi">--°</div><div class="weather-day-lo">Low --°</div></div>';
    suggestBtn = $('weatherSuggestBtn');
    var precipToday = Math.round(Number((daily.precipitation_probability_max || [0])[0] || 0));
    var lowToday = Math.round(Number((daily.temperature_2m_min || [0])[0] || 0));
    var gustToday = Math.round(Number((daily.wind_gusts_10m_max || [0])[0] || 0));
    if(risk.level === 'High' || risk.level === 'Moderate'){
      suggestBtn.classList.remove('weather-hidden');
      suggestBtn.textContent = risk.level === 'High' ? 'Send Weather Alert' : 'Prepare Community Alert';
      var suggestion = buildSuggestion({
        risk:risk,
        condition:meta.label,
        rainChance:precipToday,
        lowTemp:lowToday,
        gustMax:gustToday,
        whenText:'today'
      });
      suggestBtn.onclick = function(){
        try{ localStorage.setItem(DRAFT_KEY, JSON.stringify({ title:suggestion.title, category:suggestion.category, message:suggestion.message, created_at: Date.now() })); }catch(_e){}
        window.location.href = 'emergency_texting.html';
      };
    }else{
      suggestBtn.classList.add('weather-hidden');
      suggestBtn.textContent = 'Suggest Emergency Text';
      suggestBtn.onclick = null;
    }
  }

  async function loadWeather(forceZip){
    var zip = String(forceZip || (($('weatherZipInput') && $('weatherZipInput').value) || readZip() || DEFAULT_ZIP)).trim();
    zip = String(zip || '').replace(/\D+/g,'').slice(0,5) || DEFAULT_ZIP;
    if($('weatherZipInput')) $('weatherZipInput').value = zip;

    var previousZip = weatherLastRequestedZip;
    weatherLastRequestedZip = zip;
    var requestSeq = ++weatherRequestSeq;

    var cachedPayload = readWeatherCache(zip);
    var previousPayload = weatherLastRenderedPayload;
    var hasRenderedSomething = false;

    if(cachedPayload){
      try{
        renderWeatherPayload(cachedPayload, zip);
        weatherLastRenderedPayload = cachedPayload;
        weatherLastRenderedZip = zip;
        hasRenderedSomething = true;
      }catch(_e){}
    } else if(previousPayload){
      try{
        $('weatherSubline').textContent = 'Updating weather for ZIP ' + zip + '…';
        hasRenderedSomething = true;
      }catch(_e){}
    } else {
      $('weatherPlace').textContent = 'Loading weather…';
      var weatherLocationEl = $('weatherLocation'); if(weatherLocationEl) weatherLocationEl.textContent = 'Loading location…';
      $('weatherSubline').textContent = 'Preparing the local forecast and weather risk.';
    }

    if(previousZip === zip && hasRenderedSomething && (Date.now() - weatherLastSuccessAt) < 30000){
      return;
    }

    try{
      var payload = await fetchWeatherViaEdge(zip);
      if(requestSeq !== weatherRequestSeq || zip !== weatherLastRequestedZip) return;
      renderWeatherPayload(payload, zip);
      weatherLastRenderedPayload = payload;
      weatherLastRenderedZip = zip;
    }catch(err){
      if(String((err && err.message) || '').toLowerCase().indexOf('aborted') >= 0) return;
      console.warn('loadWeather refresh failed, keeping last weather:', err);
      if(cachedPayload || previousPayload){
        try{
          $('weatherSubline').textContent = 'ZIP ' + zip + ' • Showing last saved weather';
        }catch(_e){}
        return;
      }
      $('weatherPlace').textContent = 'Weather unavailable';
      var weatherLocationEl = $('weatherLocation'); if(weatherLocationEl) weatherLocationEl.textContent = 'Try another ZIP code';
      $('weatherSubline').textContent = 'Try another ZIP code to load the forecast.';
      applyManagerWeatherScene('clear');
      $('weatherSuggestBtn').classList.add('weather-hidden');
      updateSunArc({daily:{}});
    }
  }
  function scheduleWeatherLoad(zip){
    var cleanZip = String(zip || '').replace(/\D+/g,'').slice(0,5) || DEFAULT_ZIP;
    try{ clearTimeout(weatherLoadDebounce); }catch(_e){}
    weatherLoadDebounce = setTimeout(function(){ loadWeather(cleanZip); }, 220);
  }
  function bindWeather(){
    if(window.__zummeeWeatherBound) return;
    window.__zummeeWeatherBound = true;
    var input = $('weatherZipInput');
    if(input) input.value = readZip() || DEFAULT_ZIP;

    function normalizeZip(v){
      return String(v || '').replace(/\D+/g,'').slice(0,5);
    }

    function maybeApplyZip(){
      if(!input) return;
      var zip = normalizeZip(input.value);
      input.value = zip;

      console.log('[ZIP CHECK]', zip);

      if(zip.length === 5){
        console.log('[ZIP SAVE TRIGGER]', zip);
        try{
          writeZip(zip);
        }catch(e){
          console.error('[ZIP WRITE ERROR]', e);
        }
        setTimeout(function(){
          scheduleWeatherLoad(zip);
        }, 50);
      }
    }

    if(input){
      input.addEventListener('keydown', function(e){
        if(e.key === 'Enter'){
          e.preventDefault();
          maybeApplyZip();
        }
      });
      input.addEventListener('blur', function(){ maybeApplyZip(); });
      input.addEventListener('change', function(){ maybeApplyZip(); });
    }

    document.addEventListener('community:changed', function(){
      var nextZip = readZip() || DEFAULT_ZIP;
      if(input) input.value = nextZip;
      scheduleWeatherLoad(nextZip);
    });
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){
      bindWeather();
      var input = $('weatherZipInput');
      var initialZip = readZip() || DEFAULT_ZIP;
      if(input) input.value = initialZip;
      scheduleWeatherLoad(initialZip);
    });
  } else {
    bindWeather();
    var input = $('weatherZipInput');
    var initialZip = readZip() || DEFAULT_ZIP;
    if(input) input.value = initialZip;
    scheduleWeatherLoad(initialZip);
  }
})();
</script>


<style id="glass-card-unify-fix">
/* unify all manager hub tiles to clean glass cards */
#dailyOpsCard,
#mileageCard,
#inspectionsCard,
#remindersCard,
#emergencyTextingCard,
#boardMemberHubCard,
#companyDirectoryCard,
#managerTrainingCard,
#boardMeetingsCard,
#preferredVendorsCard,
#residentWorkOrdersCard,
#residentDirectoryCard,
#maintenanceControlCenterCard,
#liveMaintenanceUpdatesCard,
#poolOpsCard{
  position:relative !important;
  overflow:hidden !important;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.34), rgba(255,255,255,0.14)),
    linear-gradient(135deg, rgba(255,255,255,0.26), rgba(255,255,255,0.12)) !important;
  border:1px solid rgba(255,255,255,0.38) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.35), 0 10px 28px rgba(15,47,74,0.12) !important;
}
#dailyOpsCard .title,
#mileageCard .title,
#inspectionsCard .title,
#remindersCard .title,
#emergencyTextingCard .title,
#boardMemberHubCard .title,
#companyDirectoryCard .title,
#managerTrainingCard .title,
#boardMeetingsCard .title,
#preferredVendorsCard .title,
#residentWorkOrdersCard .title,
#residentDirectoryCard .title,
#maintenanceControlCenterCard .title,
#liveMaintenanceUpdatesCard .title,
#poolOpsCard .title{
  color:#0f2139 !important;
  text-shadow:0 1px 0 rgba(255,255,255,0.35) !important;
}
#remindersCard .subtle,
#residentWorkOrdersCard .sub,
#liveMaintenanceUpdatesCard .sub,
#residentDirectoryCard .sub,
#maintenanceControlCenterCard .sub,
#emergencyTextingCard .scheduled-preview,
#emergencyTextingCard .scheduled-indicator,
#emergencyTextingCard .card-sub,
#residentWorkOrdersCard .card-sub,
#liveMaintenanceUpdatesCard .card-sub,
#residentDirectoryCard .card-sub,
#maintenanceControlCenterCard .card-sub{
  color:#43566f !important;
}
/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
