50%{
    box-shadow:
      0 0 0 10px rgba(56,184,106,0),
      0 12px 26px rgba(34,120,67,.28),
      inset 0 1px 0 rgba(255,255,255,.26);
    transform: translateY(-1px);
  }
  100%{
    box-shadow:
      0 0 0 0 rgba(56,184,106,0),
      0 10px 22px rgba(34,120,67,.22),
      inset 0 1px 0 rgba(255,255,255,.26);
    transform: translateY(0);
  }
}
/* Mobile inline ZIP + alert button */
@media (max-width: 768px){
  .weather-controls-right{
    display:grid !important;
    grid-template-columns: repeat(2, minmax(0,1fr)) !important;
    gap:8px !important;
    align-items:stretch !important;
  }
  .weather-risk.weather-risk-mobile{
    grid-column: 1 / -1 !important;
  }
  .weather-zip-input{
    grid-column: 1 / 2 !important;
    width:100% !important;
    min-width:0 !important;
    height:56px !important;
    border-radius:28px !important;
    text-align:center !important;
    font-size:16px !important;
    font-weight:800 !important;
    order: 1 !important;
  }
  #weatherSuggestBtn{
    grid-column: 2 / 3 !important;
    width:100% !important;
    min-width:0 !important;
    min-height:56px !important;
    height:56px !important;
    border-radius:28px !important;
    font-size:13px !important;
    line-height:1.15 !important;
    padding:10px 12px !important;
    justify-self:stretch !important;
    align-self:stretch !important;
    order: 2 !important;
  }
}
70%{ box-shadow: 0 0 0 12px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}
/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}
/* Mobile: ZIP and alert button same size side-by-side */
@media (max-width: 768px){
  .weather-controls-right{
    display:grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap:10px !important;
    align-items:stretch !important;
  }

  .weather-zip-input{
    grid-column:1 / 2 !important;
    width:100% !important;
    min-width:0 !important;
    height:56px !important;
    min-height:56px !important;
    border-radius:28px !important;
    box-sizing:border-box !important;
    text-align:center !important;
    font-size:16px !important;
    font-weight:800 !important;
    padding:0 12px !important;
    order:1 !important;
  }

  #weatherSuggestBtn{
    grid-column:2 / 3 !important;
    width:100% !important;
    min-width:0 !important;
    height:56px !important;
    min-height:56px !important;
    border-radius:28px !important;
    box-sizing:border-box !important;
    padding:0 12px !important;
    display:flex !important;
    align-items:center !important;
    justify-content:center !important;
    text-align:center !important;
    font-size:14px !important;
    font-weight:700 !important;
    line-height:1.1 !important;
    white-space:normal !important;
    order:2 !important;
  }
}
/* Ensure low-risk alert stays hidden and clickable state is preserved when shown */
#weatherSuggestBtn.weather-hidden{
  display: none !important;
  visibility: hidden !important;
  pointer-events: none !important;
}
/* Safe favorites star pass */
.card.clickable-card{
  position:relative !important;
}
.favorite-star-btn{
  position:absolute !important;
  top:12px !important;
  right:12px !important;
  width:32px !important;
  height:32px !important;
  border:none !important;
  border-radius:999px !important;
  background:rgba(255,255,255,.94) !important;
  color:#b7bcc4 !important;
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  font-size:16px !important;
  line-height:1 !important;
  box-shadow:0 4px 10px rgba(15,47,74,.14) !important;
  cursor:pointer !important;
  z-index:25 !important;
  padding:0 !important;
}
.favorite-star-btn.is-favorite{
  color:#f4b400 !important;
  background:#ffffff !important;
}
.favorite-star-btn:hover{
  transform:translateY(-1px) !important;
}
@media (max-width:768px){
  .favorite-star-btn{
    top:10px !important;
    right:10px !important;
    width:30px !important;
    height:30px !important;
    font-size:15px !important;
  }
}
/* More Tools collapsible section */
.more-tools-section{
  margin-top:20px;
}
.more-tools-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:14px 18px;
  border-radius:18px;
  background:rgba(255,255,255,0.18);
  border:1px solid rgba(255,255,255,0.34);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.26), 0 10px 24px rgba(15,47,74,0.10);
  cursor:pointer;
  user-select:none;
  transition:background .18s ease, box-shadow .18s ease, transform .18s ease;
}
.more-tools-header:hover{
  background:rgba(255,255,255,0.22);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.28), 0 14px 28px rgba(15,47,74,0.12);
}
.more-tools-header:active{
  transform:scale(0.995);
}
.more-tools-header__title{
  font-size:16px;
  font-weight:800;
  color:#0f2f4a;
}
.more-tools-header__arrow{
  margin-left:auto;
  font-size:14px;
  font-weight:900;
  color:rgba(15,47,74,0.72);
  transition:transform .2s ease, color .2s ease;
}
.more-tools-header[aria-expanded="true"] .more-tools-header__arrow{
  transform:rotate(180deg);
  color:#0f2f4a;
}

/* Remove leftover empty inline action pill from Supervisor Priority card */
.supervisor-priority-card div:empty,
.supervisor-priority-card span:empty,
#supervisorPriorityCard div:empty,
#supervisorPriorityCard span:empty{
  display:none !important;
}
.supervisor-priority-card .review-inline-pill,
.supervisor-priority-card .inline-action,
.supervisor-priority-card .action-pill,
#supervisorPriorityCard .review-inline-pill,
#supervisorPriorityCard .inline-action,
#supervisorPriorityCard .action-pill{
  display:none !important;
}
/* Zummee favorites limit modal */
.zm-fav-modal-backdrop{
  position:fixed;
  inset:0;
  background:rgba(15, 23, 42, 0.32);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
  display:none;
  align-items:center;
  justify-content:center;
  padding:24px;
  z-index:5000;
}
.zm-fav-modal-backdrop.is-open{ display:flex; }
.zm-fav-modal{
  width:min(520px, 92vw);
  background:rgba(255,255,255,0.98);
  border:1px solid rgba(15,47,74,0.10);
  border-radius:24px;
  box-shadow:0 24px 60px rgba(15,47,74,0.18);
  padding:26px 26px 22px;
  color:#0f2f4a;
  transform:translateY(6px) scale(0.985);
  opacity:0;
  transition:opacity .18s ease, transform .18s ease;
}
.zm-fav-modal-backdrop.is-open .zm-fav-modal{ opacity:1; transform:translateY(0) scale(1); }
.zm-fav-modal__pill{
  display:inline-flex;
  align-items:center;
  padding:8px 16px;
  border-radius:999px;
  background:linear-gradient(135deg, rgba(15,47,74,.10), rgba(70,120,180,.18));
  color:#53697f;
  font-size:12px;
  font-weight:800;
  letter-spacing:.14em;
  text-transform:uppercase;
}
.zm-fav-modal__title{
  margin:16px 0 10px;
  font-size:28px;
  line-height:1.05;
  font-weight:800;
  color:#0f2f4a;
}
.zm-fav-modal__text{
  margin:0;
  color:#45586d;
  font-size:18px;
  line-height:1.45;
}
.zm-fav-modal__actions{
  display:flex;
  justify-content:flex-end;
  margin-top:24px;
}
.zm-fav-modal__btn{
  appearance:none;
  border:none;
  border-radius:16px;
  background:#0f2f4a;
  color:#fff;
  font-weight:800;
  font-size:18px;
  padding:14px 28px;
  box-shadow:0 12px 24px rgba(15,47,74,.18);
  cursor:pointer;
}
.zm-fav-modal__btn:hover{ transform:translateY(-1px); }
@media (max-width:768px){
  .zm-fav-modal{ width:min(420px, 94vw); padding:22px 20px 18px; border-radius:20px; }
  .zm-fav-modal__title{ font-size:24px; }
  .zm-fav-modal__text{ font-size:16px; }
  .zm-fav-modal__btn{ width:100%; justify-content:center; }
  .zm-fav-modal__actions{ margin-top:20px; }
}

  font-size:13px;
  font-weight:700;
  color:#4e6785;
}
.more-tools-header__arrow{
  font-size:16px;
  font-weight:900;
  color:#0f2f4a;
  line-height:1;
}
.more-tools-container{
  display:none;
  margin-top:14px;
}
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}
@media (max-width:768px){
  .more-tools-header{
    padding:13px 16px;
    border-radius:16px;
  }
  .more-tools-header__title{
    font-size:15px;
  }
}

/* More Tools flex layout fix */
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}

.more-tools-container .card{
  flex: 1 1 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 900px){
  .more-tools-container .card{
    flex: 1 1 calc(50% - 16px);
    max-width: calc(50% - 16px);
  }
}

@media (max-width: 600px){
  .more-tools-container .card{
    flex: 1 1 100%;
    max-width: 100%;
  }
}


/* FINAL More Tools polish */

.more-tools-container .card {
  min-height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
}

/* FORCE title to be the only visible element */
.more-tools-container .card > *:not(.favorite-star-btn):not(.title) {
  display: none !important;
}

/* Ensure title is centered cleanly */
.more-tools-container .card .title {
  display: block !important;
  width: 100%;
  font-size: 16px;
  font-weight: 700;
  line-height: 1.2;
  margin: 0 !important;
  text-align: center !important;
}

/* Star spacing tweak */
.more-tools-container .favorite-star-btn {
  top: 14px !important;
  right: 14px !important;
}

/* Prevent favorites flash before layout init */
.favorites-pending #mainCardsGrid,
.favorites-pending #moreToolsContainer,
.favorites-pending #moreToolsSection{
  visibility: hidden !important;
}
/* Board Hub Status clear action */
.board-items-panel__actions{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
.board-items-panel__clear{
  appearance:none;
  border:none;
  border-radius:999px;
  padding:12px 18px;
  background:#fff;
  color:#9a3412;
  font-weight:800;
  font-size:14px;
  cursor:pointer;
  box-shadow:0 8px 18px rgba(15,47,74,.10);
  border:1px solid rgba(154,52,18,.18);
}
.board-items-panel__clear:hover{
  transform:translateY(-1px);
}
.zummee-modal-backdrop{
  position:fixed;
  inset:0;
  background:rgba(15,47,74,.42);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:9999;
  padding:20px;
}
.zummee-modal-backdrop.is-open{
  display:flex;
}
.zummee-modal{
  width:min(520px, 100%);
  border-radius:24px;
  background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(245,249,255,.98));
  border:1px solid rgba(255,255,255,.7);
  box-shadow:0 24px 60px rgba(15,47,74,.22);
  overflow:hidden;
}
.zummee-modal__header{
  padding:20px 22px 8px;
  color:#17324d;
  font-size:24px;
  font-weight:900;
}
.zummee-modal__body{
  padding:0 22px 8px;
  color:#35506c;
  font-size:15px;
  line-height:1.5;
}
.zummee-modal__footer{
  display:flex;
  justify-content:flex-end;
  gap:10px;
  padding:18px 22px 22px;
}
.zummee-modal__btn{
  appearance:none;
  border:none;
  border-radius:999px;
  padding:12px 18px;
  font-weight:800;
  font-size:14px;
  cursor:pointer;
}
.zummee-modal__btn--ghost{
  background:#ffffff;
  color:#17324d;
  border:1px solid rgba(23,50,77,.14);
}
.zummee-modal__btn--danger{
  background:linear-gradient(180deg,#ef4444,#dc2626);
  color:#ffffff;
}
@media (max-width: 768px){
  .board-items-panel__actions{
    width:100%;
  }
  .board-items-panel__actions .board-items-panel__link,
  .board-items-panel__actions .board-items-panel__clear{
    width:100%;
    text-align:center;
  }
}
/* Make Resident Portal + Annual Presentation cards match standard hub cards */
#residentPortalPreviewCard,
#annualPresentationHubCard{
  background: linear-gradient(180deg, rgba(173,211,255,0.38) 0%, rgba(147,197,253,0.28) 100%) !important;
  border: 1px solid rgba(255,255,255,0.34) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.20), 0 12px 26px rgba(15,47,74,0.10) !important;
  color: #17324d !important;
}

#residentPortalPreviewCard .title,
#annualPresentationHubCard .title,
#residentPortalPreviewCard .desc,
#annualPresentationHubCard .desc{
  color: #17324d !important;
  opacity: 1 !important;
}

#residentPortalPreviewCard:hover,
#annualPresentationHubCard:hover{
  transform: translateY(-1px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.22), 0 16px 30px rgba(15,47,74,0.12) !important;
}
/* Make Resident Portal + Annual Presentation use the same card animation feel */
#residentPortalPreviewCard,
#annualPresentationHubCard{
  transition:
    transform .22s ease,
    box-shadow .22s ease,
    border-color .22s ease,
    background .22s ease !important;
  overflow: hidden !important;
  position: relative !important;
}

#residentPortalPreviewCard::before,
#annualPresentationHubCard::before{
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(115deg,
    rgba(255,255,255,0) 0%,
    rgba(255,255,255,0.18) 38%,
    rgba(255,255,255,0.34) 50%,
    rgba(255,255,255,0.12) 62%,
    rgba(255,255,255,0) 100%);
  transform: translateX(-135%);
  pointer-events: none;
  z-index: 0;
}

#residentPortalPreviewCard > *,
#annualPresentationHubCard > *{
  position: relative;
  z-index: 1;
}

#residentPortalPreviewCard:hover::before,
#annualPresentationHubCard:hover::before{
  animation: hubCardShine 1.05s ease;
}

@keyframes hubCardShine{
  0%{ transform: translateX(-135%); }
  100%{ transform: translateX(135%); }
}
/* Fix remaining mismatched cards: Resident Work Orders + Online Voting */
#residentWorkOrdersCard,
{
  background: linear-gradient(180deg, rgba(173,211,255,0.38) 0%, rgba(147,197,253,0.28) 100%) !important;
  border: 1px solid rgba(255,255,255,0.34) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.20), 0 12px 26px rgba(15,47,74,0.10) !important;
  color: #17324d !important;
}

/* remove alert/red override */
#residentWorkOrdersCard.rwo-urgent{
  background: linear-gradient(180deg, rgba(173,211,255,0.38) 0%, rgba(147,197,253,0.28) 100%) !important;
  border-color: rgba(255,255,255,0.34) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.20), 0 12px 26px rgba(15,47,74,0.10) !important;
}

/* animation + shine */
#residentWorkOrdersCard,
{
  transition: transform .22s ease, box-shadow .22s ease !important;
  position: relative;
  overflow: hidden;
}

#residentWorkOrdersCard::before,
#onlineVotingCard::before,
.card[data-card-id="online_voting"]::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(115deg,
    rgba(255,255,255,0) 0%,
    rgba(255,255,255,0.18) 38%,
    rgba(255,255,255,0.34) 50%,
    rgba(255,255,255,0.12) 62%,
    rgba(255,255,255,0) 100%);
  transform:translateX(-135%);
  pointer-events:none;
}

#residentWorkOrdersCard:hover::before,
#onlineVotingCard:hover::before,
.card[data-card-id="online_voting"]:hover::before{
  animation: hubCardShine 1.05s ease;
}

#residentWorkOrdersCard > *,
#onlineVotingCard > *,
.card[data-card-id="online_voting"] > *{
  position:relative;
  z-index:1;
}
/* Online Voting: use the same standard card animation/style as the rest */
#onlineVotingCard,
.card[data-card-id="online_voting"]{
  background: linear-gradient(180deg, rgba(173,211,255,0.38) 0%, rgba(147,197,253,0.28) 100%) !important;
  border: 1px solid rgba(255,255,255,0.34) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.20), 0 12px 26px rgba(15,47,74,0.10) !important;
  color: #17324d !important;
}
#onlineVotingCard > *,
.card[data-card-id="online_voting"] > *{
  position: relative;
  z-index: 1;
}
/* Online Voting: force exact same shimmer behavior as standard hub cards */
#onlineVotingCard::before,
.card[data-card-id="online_voting"]::before{
  content: none !important;
  background: none !important;
  animation: none !important;
  transform: none !important;
}

#onlineVotingCard::after,
.card[data-card-id="online_voting"]::after{
  content: "" !important;
  position: absolute !important;
  top: -40% !important;
  left: -120% !important;
  width: 60% !important;
  height: 180% !important;
  display: block !important;
  background: linear-gradient(110deg,transparent 0%,rgba(255,255,255,.45) 50%,transparent 100%) !important;
  transform: skewX(-18deg) !important;
  transition: left .55s ease !important;
  pointer-events: none !important;
  z-index: 2 !important;
}

@media (prefers-reduced-motion:no-preference){
  #onlineVotingCard:hover::after,
  .card[data-card-id="online_voting"]:hover::after{
    left: 130% !important;
    animation: none !important;
  }
}


/* GLOBAL CARD TITLE STANDARD */
.card h3,
.card-title,
.card .title {
  font-size: 24px !important;
