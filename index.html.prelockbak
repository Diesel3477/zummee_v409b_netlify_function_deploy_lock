/* v287 flat navy header (remove all glass effects) */
.managerhub-hero{
  background: #0f2f4a !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
  box-shadow: none !important;
  border: none !important;
}

.managerhub-hero::before,
.managerhub-hero::after{
  content: none !important;
}


/* v292 Manager Hub gold card treatment */
.cards .card,
#mainCardsGrid .card,
#moreToolsContainer .card{
  background:
    linear-gradient(180deg, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.05) 18%, rgba(255,255,255,0.00) 38%),
    linear-gradient(180deg, #efd487 0%, #e0b648 52%, #cb9621 100%) !important;
  border:1px solid rgba(255,255,255,0.26) !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.28),
    0 14px 30px rgba(121,82,12,0.18) !important;
  position:relative !important;
  overflow:hidden !important;
}

.cards .card::before,
#mainCardsGrid .card::before,
#moreToolsContainer .card::before{
  content:"" !important;
  position:absolute !important;
  inset:0 !important;
  border-radius:inherit !important;
  background:
    radial-gradient(120% 90% at 0% 0%, rgba(255,255,255,0.18), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.02) 32%, rgba(255,255,255,0.00) 70%) !important;
  pointer-events:none !important;
  opacity:1 !important;
}

.cards .card::after,
#mainCardsGrid .card::after,
#moreToolsContainer .card::after{
  content:"" !important;
  position:absolute !important;
  top:-18% !important;
  left:-38% !important;
  width:64% !important;
  height:165% !important;
  background:linear-gradient(110deg,
    rgba(255,255,255,0.00) 0%,
    rgba(255,255,255,0.00) 35%,
    rgba(255,255,255,0.18) 48%,
    rgba(255,255,255,0.05) 56%,
    rgba(255,255,255,0.00) 68%) !important;
  transform:translateX(-135%) skewX(-18deg) !important;
  opacity:.95 !important;
  pointer-events:none !important;
}

.cards .card:hover::after,
#mainCardsGrid .card:hover::after,
#moreToolsContainer .card:hover::after,
.cards .card:focus-within::after,
#mainCardsGrid .card:focus-within::after,
#moreToolsContainer .card:focus-within::after{
  animation: managerHubGoldSweep 1.15s ease forwards !important;
}

@keyframes managerHubGoldSweep{
  0%{ transform:translateX(-135%) skewX(-18deg); opacity:0; }
  20%{ opacity:.9; }
  100%{ transform:translateX(265%) skewX(-18deg); opacity:0; }
}

.cards .card > *,
#mainCardsGrid .card > *,
#moreToolsContainer .card > *{
  position:relative !important;
  z-index:1 !important;
}

.cards .card .title,
.cards .card h3,
#mainCardsGrid .card .title,
#mainCardsGrid .card h3,
#moreToolsContainer .card .title,
#moreToolsContainer .card h3{
  color:#17324d !important;
  text-shadow:0 1px 0 rgba(255,255,255,0.18) !important;
}

.cards .card .sub,
.cards .card p,
#mainCardsGrid .card .sub,
#mainCardsGrid .card p,
#moreToolsContainer .card .sub,
#moreToolsContainer .card p{
  color:rgba(23,50,77,0.82) !important;
}

.cards .card .favorite-star-btn,
#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn{
  box-shadow:0 10px 20px rgba(15,47,74,0.14) !important;
}


/* v293 align favorite stars to top-right corners */
.cards .card .favorite-star-btn,
#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn{
  position:absolute !important;
  top:18px !important;
  right:18px !important;
  left:auto !important;
  bottom:auto !important;
  margin:0 !important;
  transform:none !important;
  z-index:5 !important;
}


/* v294 fix Mileage Tracker spacing */
.card:has(h3:contains("Mileage Tracker")),
.card.mileage-card{
  padding-top: 28px !important;
}

.card:has(h3:contains("Mileage Tracker")) h3,
.card.mileage-card h3{
  margin-top: 10px !important;
}

.card:has(h3:contains("Mileage Tracker")) .sub,
.card.mileage-card .sub{
  margin-top: 8px !important;
}

/* v294 fallback spacing for mileage card (second card on row) */
#mainCardsGrid .card:nth-child(2){
  padding-top: 28px !important;
}
#mainCardsGrid .card:nth-child(2) h3{
  margin-top: 10px !important;
}


/* v296 TRUE RED using the existing alert classes already applied by JS */
#dailyOpsCard.ops-alert,
.cards .card#dailyOpsCard.ops-alert,
#boardMemberHubCard.bm-alert,
.cards .card#boardMemberHubCard.bm-alert{
  background: linear-gradient(180deg, #ff3b30 0%, #d10000 100%) !important;
  border: 2px solid #ff1f1f !important;
  box-shadow:
    0 12px 30px rgba(209,0,0,0.34),
    inset 0 1px 0 rgba(255,255,255,0.22) !important;
}

#dailyOpsCard.ops-alert::before,
#dailyOpsCard.ops-alert::after,
#boardMemberHubCard.bm-alert::before,
#boardMemberHubCard.bm-alert::after{
  display:none !important;
  content:none !important;
}

#dailyOpsCard.ops-alert .title,
#dailyOpsCard.ops-alert h2,
#dailyOpsCard.ops-alert h3,
#dailyOpsCard.ops-alert p,
#dailyOpsCard.ops-alert .sub,
#boardMemberHubCard.bm-alert .title,
#boardMemberHubCard.bm-alert h2,
#boardMemberHubCard.bm-alert h3,
#boardMemberHubCard.bm-alert p,
#boardMemberHubCard.bm-alert .sub,
#boardMemberHubCard.bm-alert .bm-alert-badge{
  color:#ffffff !important;
  text-shadow:0 1px 2px rgba(0,0,0,0.25) !important;
}

#boardMemberHubCard.bm-alert .bm-alert-badge{
  background: rgba(255,255,255,0.16) !important;
  border: 1px solid rgba(255,255,255,0.34) !important;
}

@keyframes zummeeTrueRedPulse {
  0% { box-shadow: 0 0 0 0 rgba(255,59,48,0.42), 0 12px 30px rgba(209,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.22); }
  70% { box-shadow: 0 0 0 12px rgba(255,59,48,0), 0 12px 30px rgba(209,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.22); }
  100% { box-shadow: 0 0 0 0 rgba(255,59,48,0), 0 12px 30px rgba(209,0,0,0.34), inset 0 1px 0 rgba(255,255,255,0.22); }
}

#dailyOpsCard.ops-alert,
#boardMemberHubCard.bm-alert{
  animation: zummeeTrueRedPulse 2.2s infinite !important;
}


/* v297 Daily Ops COMPLETE = Gold Success State */
#dailyOpsCard.ops-complete,
.cards .card#dailyOpsCard.ops-complete{
  background: linear-gradient(180deg, #f6d365 0%, #d4a017 100%) !important;
  border: 2px solid #e6b800 !important;
  box-shadow:
    0 10px 30px rgba(212,160,23,0.35),
    inset 0 1px 0 rgba(255,255,255,0.3) !important;
}

#dailyOpsCard.ops-complete::before,
#dailyOpsCard.ops-complete::after{
  display:none !important;
  content:none !important;
}

#dailyOpsCard.ops-complete h2,
#dailyOpsCard.ops-complete h3,
#dailyOpsCard.ops-complete p,
#dailyOpsCard.ops-complete .sub,
#dailyOpsCard.ops-complete .title{
  color: #2a1a00 !important;
  text-shadow:none !important;
}


/* v397 corner tab from existing star button */
#mainCardsGrid .card,
#moreToolsContainer .card,
.cards .card{
  position: relative !important;
  overflow: hidden !important;
}

#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn,
.cards .card .favorite-star-btn{
  position: absolute !important;
  top: 0 !important;
  right: 0 !important;
  left: auto !important;
  bottom: auto !important;
  margin: 0 !important;
  transform: none !important;

  width: 54px !important;
  height: 54px !important;
  min-width: 54px !important;
  min-height: 54px !important;
  border-radius: 0 !important;
  padding: 0 !important;

  display: flex !important;
  align-items: flex-start !important;
  justify-content: flex-end !important;

  background: linear-gradient(135deg, #f6d365 0%, #f1b90b 100%) !important;
  color: #1f2a37 !important;
  border: none !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.16) !important;

  clip-path: polygon(0 0, 100% 0, 100% 100%) !important;
  z-index: 8 !important;
}

#mainCardsGrid .card .favorite-star-btn svg,
#moreToolsContainer .card .favorite-star-btn svg,
.cards .card .favorite-star-btn svg{
  width: 16px !important;
  height: 16px !important;
  margin: 9px 9px 0 0 !important;
  color: #1f2a37 !important;
  fill: currentColor !important;
  stroke: currentColor !important;
}

#mainCardsGrid .card .favorite-star-btn .star,
#moreToolsContainer .card .favorite-star-btn .star,
.cards .card .favorite-star-btn .star{
  margin: 9px 9px 0 0 !important;
  font-size: 16px !important;
  line-height: 1 !important;
  color: #1f2a37 !important;
}

/* non-favorited cards should keep a faint outline corner tab */
#mainCardsGrid .card .favorite-star-btn:not(.is-favorite),
#moreToolsContainer .card .favorite-star-btn:not(.is-favorite),
.cards .card .favorite-star-btn:not(.is-favorite){
  background: linear-gradient(135deg, rgba(255,255,255,0.85), rgba(245,245,245,0.92)) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  color: rgba(31,42,55,0.40) !important;
}

#mainCardsGrid .card .favorite-star-btn:not(.is-favorite) svg,
#moreToolsContainer .card .favorite-star-btn:not(.is-favorite) svg,
.cards .card .favorite-star-btn:not(.is-favorite) svg{
  color: rgba(31,42,55,0.40) !important;
  fill: currentColor !important;
  stroke: currentColor !important;
}

#mainCardsGrid .card .favorite-star-btn:hover,
#moreToolsContainer .card .favorite-star-btn:hover,
.cards .card .favorite-star-btn:hover{
  filter: brightness(1.03) !important;
}


/* v399 force corner-tab star inward */
#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn,
.cards .card .favorite-star-btn{
  align-items: flex-start !important;
  justify-content: flex-end !important;
  padding: 0 !important;
}

#mainCardsGrid .card .favorite-star-btn svg,
#moreToolsContainer .card .favorite-star-btn svg,
.cards .card .favorite-star-btn svg,
#mainCardsGrid .card .favorite-star-btn .star,
#moreToolsContainer .card .favorite-star-btn .star,
.cards .card .favorite-star-btn .star{
  margin: 0 !important;
  transform: translate(-10px, 10px) !important;
  transform-origin: center !important;
}

#mainCardsGrid .card .favorite-star-btn .star,
#moreToolsContainer .card .favorite-star-btn .star,
.cards .card .favorite-star-btn .star{
  display: inline-block !important;
}


/* v400 remove star keep clean corner */
#mainCardsGrid .card .favorite-star-btn svg,
#moreToolsContainer .card .favorite-star-btn svg,
.cards .card .favorite-star-btn svg,
#mainCardsGrid .card .favorite-star-btn .star,
#moreToolsContainer .card .favorite-star-btn .star,
.cards .card .favorite-star-btn .star{
  display: none !important;
}

#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn,
.cards .card .favorite-star-btn{
  justify-content: center !important;
  align-items: center !important;
}


/* v401 HARD REMOVE STAR - guaranteed */

#mainCardsGrid .card .favorite-star-btn,
#moreToolsContainer .card .favorite-star-btn,
.cards .card .favorite-star-btn{
  position: absolute !important;
  top: 0 !important;
  right: 0 !important;

  width: 54px !important;
  height: 54px !important;

  background: linear-gradient(135deg, #f6d365 0%, #f1b90b 100%) !important;
  clip-path: polygon(0 0, 100% 0, 100% 100%) !important;

  display: block !important;
  padding: 0 !important;

  font-size: 0 !important;
  color: transparent !important;
}

/* remove all inner content */
#mainCardsGrid .card .favorite-star-btn *,
#moreToolsContainer .card .favorite-star-btn *,
.cards .card .favorite-star-btn *{
  display: none !important;
}

/* remove pseudo elements */
#mainCardsGrid .card .favorite-star-btn::before,
#mainCardsGrid .card .favorite-star-btn::after,
#moreToolsContainer .card .favorite-star-btn::before,
#moreToolsContainer .card .favorite-star-btn::after,
.cards .card .favorite-star-btn::before,
.cards .card .favorite-star-btn::after{
  content: none !important;
  display: none !important;
}


/* === Apple-style subtle cloud rebuild === */
.weather-scene__clouds{
  position:absolute;
  inset:0;
  pointer-events:none;
  overflow:hidden;
}
.weather-scene__clouds .cloud{
  border-radius:999px;
  background:
    radial-gradient(ellipse at 30% 35%, rgba(255,255,255,.92) 0%, rgba(255,255,255,.78) 34%, rgba(255,255,255,.38) 66%, rgba(255,255,255,0) 100%);
  box-shadow:
    inset 0 -10px 18px rgba(74,99,128,.08),
    0 10px 24px rgba(34,57,86,.06);
  filter:none !important;
  opacity:0;
  transform:translate3d(0,0,0);
}
.weather-scene__clouds .cloud::before,
.weather-scene__clouds .cloud::after{
  content:"";
  position:absolute;
  border-radius:999px;
  background:inherit;
}
.weather-scene__clouds .cloud::before{
  width:58%;
  height:78%;
  left:8%;
  top:-22%;
}
.weather-scene__clouds .cloud::after{
  width:46%;
  height:68%;
  right:10%;
  top:-16%;
}

/* calmer sizes/positions */
.cloud--1{width:260px; height:78px; top:13%; left:-10%;}
.cloud--2{width:300px; height:88px; top:11%; left:72%;}
.cloud--3{width:210px; height:64px; top:18%; left:46%;}
.cloud--4{width:220px; height:66px; top:56%; left:-8%;}
.cloud--5{width:240px; height:72px; top:62%; left:74%;}
.cloud--6{width:220px; height:68px; top:28%; left:80%;}
.cloud--7{width:250px; height:72px; top:34%; left:-10%;}

/* much slower and subtler drift */
.weather-scene__clouds--back .cloud{animation:weatherCloudDriftBackA 110s linear infinite; transform:scale(1.06);}
.weather-scene__clouds--mid .cloud{animation:weatherCloudDriftMidA 86s linear infinite; transform:scale(1);}
.weather-scene__clouds--front .cloud{animation:weatherCloudDriftFrontA 68s linear infinite; transform:scale(.97);}
@keyframes weatherCloudDriftBackA{0%{transform:translate3d(0,0,0) scale(1.06);}50%{transform:translate3d(12px,-2px,0) scale(1.065);}100%{transform:translate3d(0,0,0) scale(1.06);}}
@keyframes weatherCloudDriftMidA{0%{transform:translate3d(0,0,0) scale(1);}50%{transform:translate3d(16px,-2px,0) scale(1.01);}100%{transform:translate3d(0,0,0) scale(1);}}
@keyframes weatherCloudDriftFrontA{0%{transform:translate3d(0,0,0) scale(.97);}50%{transform:translate3d(20px,-3px,0) scale(.98);}100%{transform:translate3d(0,0,0) scale(.97);}}

/* clear scenes keep clouds nearly gone */
.weather-scene.clear-day .weather-scene__clouds .cloud{opacity:0 !important;}
.weather-scene.clear-night .weather-scene__clouds .cloud{opacity:0 !important;}

/* partly cloudy: soft, sparse, sun/moon still dominant */
.weather-scene.partly-cloudy .weather-scene__clouds--back .cloud{opacity:.10 !important;}
.weather-scene.partly-cloudy .weather-scene__clouds--mid .cloud{opacity:.16 !important;}
.weather-scene.partly-cloudy .weather-scene__clouds--front .cloud{opacity:.22 !important;}
.weather-scene.partly-cloudy .weather-scene__sky{
  background:
    radial-gradient(circle at 78% 18%, rgba(255,236,192,.10), transparent 18%),
    linear-gradient(180deg, #4d94d5 0%, #7eb7e1 42%, #dceaf2 100%) !important;
}

/* overcast: flatter, cooler, denser, but still structured */
.weather-scene.cloudy .weather-scene__sky{
  background:
    linear-gradient(180deg, #62768a 0%, #8598a8 36%, #adc0cb 70%, #dce6eb 100%) !important;
}
.weather-scene.cloudy .weather-scene__glow{
  opacity:.03 !important;
  background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,0) 48%) !important;
}
.weather-scene.cloudy .weather-scene__clouds--back .cloud{
  opacity:.18 !important;
  box-shadow: inset 0 -12px 20px rgba(69,86,105,.10), 0 10px 24px rgba(39,56,77,.05);
}
.weather-scene.cloudy .weather-scene__clouds--mid .cloud{
  opacity:.26 !important;
  box-shadow: inset 0 -12px 20px rgba(69,86,105,.11), 0 10px 24px rgba(39,56,77,.06);
}
.weather-scene.cloudy .weather-scene__clouds--front .cloud{
  opacity:.34 !important;
  box-shadow: inset 0 -14px 20px rgba(69,86,105,.12), 0 10px 24px rgba(39,56,77,.07);
}
.weather-scene.cloudy .weather-scene__sun{opacity:0 !important;}

/* cloudy night: moon visible, clouds softer and dimmer */
.weather-scene.cloudy-night .weather-scene__clouds--back .cloud{opacity:.11 !important; background:radial-gradient(ellipse at 30% 35%, rgba(233,241,255,.38) 0%, rgba(233,241,255,.28) 35%, rgba(233,241,255,.12) 68%, rgba(233,241,255,0) 100%);}
.weather-scene.cloudy-night .weather-scene__clouds--mid .cloud{opacity:.18 !important; background:radial-gradient(ellipse at 30% 35%, rgba(233,241,255,.44) 0%, rgba(233,241,255,.32) 35%, rgba(233,241,255,.14) 68%, rgba(233,241,255,0) 100%);}
.weather-scene.cloudy-night .weather-scene__clouds--front .cloud{opacity:.24 !important; background:radial-gradient(ellipse at 30% 35%, rgba(233,241,255,.48) 0%, rgba(233,241,255,.34) 35%, rgba(233,241,255,.16) 68%, rgba(233,241,255,0) 100%);}
.weather-scene.cloudy-night .weather-scene__sun{opacity:.52 !important;}

/* rain/storm still keep cloud structure but darker */
.weather-scene.rain .weather-scene__clouds--back .cloud,
.weather-scene.rain-night .weather-scene__clouds--back .cloud{opacity:.18 !important;}
.weather-scene.rain .weather-scene__clouds--mid .cloud,
.weather-scene.rain-night .weather-scene__clouds--mid .cloud{opacity:.26 !important;}
.weather-scene.rain .weather-scene__clouds--front .cloud,
.weather-scene.rain-night .weather-scene__clouds--front .cloud{opacity:.34 !important;}

.weather-scene.storm .weather-scene__clouds--back .cloud,
.weather-scene.storm-night .weather-scene__clouds--back .cloud{opacity:.20 !important;}
.weather-scene.storm .weather-scene__clouds--mid .cloud,
.weather-scene.storm-night .weather-scene__clouds--mid .cloud{opacity:.30 !important;}
.weather-scene.storm .weather-scene__clouds--front .cloud,
.weather-scene.storm-night .weather-scene__clouds--front .cloud{opacity:.38 !important;}


/* 🌙 Night mode contrast polish */
.weather-scene.clear-night ~ .weather-content .weather-risk,
.weather-scene.cloudy-night ~ .weather-content .weather-risk,
.weather-scene.rain-night ~ .weather-content .weather-risk,
.weather-scene.storm-night ~ .weather-content .weather-risk,
.weather-hub-card--night .weather-risk{
  background: rgba(0, 200, 120, 0.24) !important;
  border: 1px solid rgba(0, 255, 150, 0.34) !important;
  color: #ffffff !important;
  box-shadow: 0 0 14px rgba(0, 255, 150, 0.18) !important;
}

.weather-scene.clear-night ~ .weather-content .weather-risk * ,
.weather-scene.cloudy-night ~ .weather-content .weather-risk * ,
.weather-scene.rain-night ~ .weather-content .weather-risk * ,
.weather-scene.storm-night ~ .weather-content .weather-risk * ,
.weather-hub-card--night .weather-risk *{
  color:#ffffff !important;
}

.weather-scene.clear-night ~ .weather-content .weather-zip,
.weather-scene.cloudy-night ~ .weather-content .weather-zip,
.weather-scene.rain-night ~ .weather-content .weather-zip,
.weather-scene.storm-night ~ .weather-content .weather-zip,
.weather-hub-card--night .weather-zip,
.weather-hub-card--night #weatherZipInput,
.weather-hub-card--night .weather-zip-pill{
  color: #ffffff !important;
  background: rgba(255,255,255,0.14) !important;
  border-color: rgba(255,255,255,0.26) !important;
}

.weather-hub-card--night .weather-zip,
.weather-hub-card--night .weather-zip-pill{
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.weather-hub-card--night .weather-zip::placeholder,
.weather-hub-card--night #weatherZipInput::placeholder{
  color: rgba(255,255,255,0.68) !important;
}



/* ✨ Clear-night stars — actual rendered layer */
.weather-scene__stars{
  position:absolute;
  inset:0;
  z-index:1;
  pointer-events:none;
  opacity:0;
  transition:opacity 700ms ease;
}
.weather-scene.clear-night .weather-scene__stars{
  opacity:.9;
}
.weather-scene.cloudy-night .weather-scene__stars,
.weather-scene.rain-night .weather-scene__stars,
.weather-scene.storm-night .weather-scene__stars,
.weather-scene.fog-night .weather-scene__stars,
.weather-scene.snow-night .weather-scene__stars{
  opacity:0 !important;
}
.weather-scene__stars::before,
.weather-scene__stars::after{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
}
.weather-scene__stars::before{
  background-image:
    radial-gradient(circle at 6% 16%, rgba(255,255,255,.95) 0 1.2px, transparent 2.1px),
    radial-gradient(circle at 14% 28%, rgba(255,255,255,.75) 0 1px, transparent 1.9px),
    radial-gradient(circle at 22% 10%, rgba(255,255,255,.88) 0 1.2px, transparent 2.1px),
    radial-gradient(circle at 30% 22%, rgba(255,255,255,.78) 0 1.05px, transparent 1.9px),
    radial-gradient(circle at 38% 8%, rgba(255,255,255,.90) 0 1.15px, transparent 2.05px),
    radial-gradient(circle at 46% 18%, rgba(255,255,255,.74) 0 1px, transparent 1.9px),
    radial-gradient(circle at 54% 10%, rgba(255,255,255,.96) 0 1.25px, transparent 2.15px),
    radial-gradient(circle at 62% 24%, rgba(255,255,255,.72) 0 1px, transparent 1.9px),
    radial-gradient(circle at 70% 12%, rgba(255,255,255,.88) 0 1.1px, transparent 2px),
    radial-gradient(circle at 78% 20%, rgba(255,255,255,.82) 0 1.1px, transparent 2px),
    radial-gradient(circle at 86% 8%, rgba(255,255,255,.92) 0 1.2px, transparent 2.1px),
    radial-gradient(circle at 92% 18%, rgba(255,255,255,.70) 0 .95px, transparent 1.8px),
    radial-gradient(circle at 10% 42%, rgba(255,255,255,.78) 0 1.05px, transparent 1.95px),
    radial-gradient(circle at 26% 46%, rgba(255,255,255,.88) 0 1.1px, transparent 2px),
    radial-gradient(circle at 42% 40%, rgba(255,255,255,.72) 0 1px, transparent 1.9px),
    radial-gradient(circle at 58% 44%, rgba(255,255,255,.90) 0 1.1px, transparent 2px),
    radial-gradient(circle at 74% 38%, rgba(255,255,255,.80) 0 1.05px, transparent 1.95px),
    radial-gradient(circle at 88% 42%, rgba(255,255,255,.94) 0 1.18px, transparent 2.08px);
  opacity:.78;
  animation:weatherStarsTwinkleA 8s ease-in-out infinite alternate;
}
.weather-scene__stars::after{
  background-image:
    radial-gradient(circle at 12% 12%, rgba(255,255,255,.98) 0 1.45px, transparent 2.3px),
    radial-gradient(circle at 34% 14%, rgba(255,255,255,.88) 0 1.3px, transparent 2.15px),
    radial-gradient(circle at 52% 30%, rgba(255,255,255,.98) 0 1.5px, transparent 2.35px),
    radial-gradient(circle at 68% 16%, rgba(255,255,255,.90) 0 1.32px, transparent 2.18px),
    radial-gradient(circle at 84% 28%, rgba(255,255,255,.96) 0 1.42px, transparent 2.28px),
    radial-gradient(circle at 20% 34%, rgba(255,255,255,.86) 0 1.2px, transparent 2.05px),
    radial-gradient(circle at 44% 22%, rgba(255,255,255,.94) 0 1.38px, transparent 2.22px),
    radial-gradient(circle at 76% 34%, rgba(255,255,255,.88) 0 1.24px, transparent 2.08px);
  opacity:.5;
  animation:weatherStarsTwinkleB 11s ease-in-out infinite alternate;
}
@keyframes weatherStarsTwinkleA{
  0%{opacity:.58; transform:translate3d(0,0,0);}
  50%{opacity:.78; transform:translate3d(0,-1px,0);}
  100%{opacity:.9; transform:translate3d(0,0,0);}
}
@keyframes weatherStarsTwinkleB{
  0%{opacity:.3; transform:translate3d(0,0,0);}
  50%{opacity:.5; transform:translate3d(1px,-1px,0);}
  100%{opacity:.62; transform:translate3d(0,0,0);}
}


/* === Accurate moon phase rendering === */
.weather-scene.clear-night .weather-scene__sun,
.weather-scene.cloudy-night .weather-scene__sun{
  --moon-shadow-x: 18%;
  --moon-shadow-blur: 0px;
  --moon-darkness: rgba(7,14,28,0.52);
  --moon-glow-1: rgba(210,226,255,.26);
  --moon-glow-2: rgba(210,226,255,.14);
  --moon-glow-3: rgba(210,226,255,.08);
}
.weather-scene.clear-night .weather-scene__sun::before,
.weather-scene.cloudy-night .weather-scene__sun::before{
  content:"";
  position:absolute;
  inset:12%;
  border-radius:50%;
  background:
    radial-gradient(circle at 36% 34%, rgba(255,255,255,.98) 0%, rgba(231,239,255,.96) 40%, rgba(198,213,245,.92) 74%, rgba(169,188,226,.84) 100%) !important;
  box-shadow:
    inset -10px -8px 14px rgba(113,136,179,.16),
    inset 0 0 0 1px rgba(255,255,255,.14);
}
.weather-scene.clear-night .weather-scene__sun::after,
.weather-scene.cloudy-night .weather-scene__sun::after{
  content:"";
  position:absolute;
  inset:10%;
  border-radius:50%;
  background:
    radial-gradient(circle at var(--moon-shadow-x) 50%, rgba(7,14,28,0) 0 38%, var(--moon-darkness) 58%, rgba(7,14,28,0) 78%),
    radial-gradient(circle, var(--moon-glow-1) 0%, var(--moon-glow-2) 34%, var(--moon-glow-3) 56%, rgba(210,226,255,0) 74%);
}
.weather-scene.clear-night .weather-scene__sun{
  filter:
    drop-shadow(0 8px 18px rgba(210,226,255,.25))
    drop-shadow(0 0 40px rgba(210,226,255,.18))
    drop-shadow(0 0 80px rgba(210,226,255,.10)) !important;
}
.weather-scene.cloudy-night .weather-scene__sun{
  filter:
    drop-shadow(0 6px 14px rgba(210,226,255,.16))
    drop-shadow(0 0 26px rgba(210,226,255,.10)) !important;
}


/* === Sunrise / Sunset stage system === */
.weather-scene.sunrise .weather-scene__sky{
  background:
    radial-gradient(circle at 50% 88%, rgba(255,196,126,.78), rgba(255,150,108,.34) 20%, rgba(255,150,108,0) 42%),
    linear-gradient(180deg, #1a2d59 0%, #4a5fa0 34%, #ff9c73 72%, #ffc47a 100%) !important;
}
.weather-scene.sunrise .weather-scene__glow{
  opacity:.88 !important;
  background:
    radial-gradient(circle at 50% 86%, rgba(255,196,122,.82) 0%, rgba(255,156,110,.46) 18%, rgba(255,156,110,.14) 34%, rgba(255,156,110,0) 58%),
    radial-gradient(circle at 50% 74%, rgba(255,220,180,.12), rgba(255,220,180,0) 28%) !important;
}
.weather-scene.sunrise .weather-scene__stars{
  opacity:.08 !important;
}
.weather-scene.sunrise .weather-scene__sun{
  opacity:.94 !important;
  filter:
    drop-shadow(0 0 26px rgba(255,184,98,.42))
    drop-shadow(0 0 60px rgba(255,145,95,.24)) !important;
}
.weather-scene.sunrise .cloud{
  background:
    radial-gradient(ellipse at 42% 38%, rgba(255,233,214,.98) 0%, rgba(255,216,184,.84) 34%, rgba(255,185,156,.38) 66%, rgba(255,255,255,0) 100%) !important;
  box-shadow:
    inset 0 -10px 18px rgba(148,99,82,.08),
    0 10px 24px rgba(76,58,66,.05) !important;
}
.weather-scene.sunrise .weather-scene__clouds--back .cloud{opacity:.14 !important;}
.weather-scene.sunrise .weather-scene__clouds--mid .cloud{opacity:.22 !important;}
.weather-scene.sunrise .weather-scene__clouds--front .cloud{opacity:.28 !important;}

.weather-scene.sunset .weather-scene__sky{
  background:
    radial-gradient(circle at 52% 88%, rgba(255,176,92,.82), rgba(255,118,94,.36) 20%, rgba(255,118,94,0) 44%),
    linear-gradient(180deg, #21407a 0%, #6b5aa6 30%, #ff8f6c 68%, #ffbb72 100%) !important;
}
.weather-scene.sunset .weather-scene__glow{
  opacity:.92 !important;
  background:
    radial-gradient(circle at 52% 86%, rgba(255,176,92,.86) 0%, rgba(255,122,92,.48) 18%, rgba(255,122,92,.16) 34%, rgba(255,122,92,0) 58%),
    radial-gradient(circle at 50% 74%, rgba(255,212,170,.12), rgba(255,212,170,0) 28%) !important;
}
.weather-scene.sunset .weather-scene__stars{
  opacity:.12 !important;
}
.weather-scene.sunset .weather-scene__sun{
  opacity:.95 !important;
  filter:
    drop-shadow(0 0 26px rgba(255,164,90,.46))
    drop-shadow(0 0 64px rgba(255,112,86,.26)) !important;
}
.weather-scene.sunset .cloud{
  background:
    radial-gradient(ellipse at 42% 38%, rgba(255,228,206,.98) 0%, rgba(255,198,170,.82) 34%, rgba(255,150,126,.36) 66%, rgba(255,255,255,0) 100%) !important;
  box-shadow:
    inset 0 -10px 18px rgba(138,88,76,.10),
    0 10px 24px rgba(72,52,64,.06) !important;
}
.weather-scene.sunset .weather-scene__clouds--back .cloud{opacity:.16 !important;}
.weather-scene.sunset .weather-scene__clouds--mid .cloud{opacity:.24 !important;}
.weather-scene.sunset .weather-scene__clouds--front .cloud{opacity:.30 !important;}

/* keep transitions smooth */
.weather-scene,
.weather-scene__sky,
.weather-scene__glow,
.weather-scene__sun,
.weather-scene__stars,
.weather-scene__clouds .cloud{
  transition:
    background 1200ms ease,
    opacity 900ms ease,
    filter 900ms ease,
    transform 900ms ease,
    left 900ms ease,
    top 900ms ease;
}


/* Live Activity priority system */
#activityFeedCard .activity-feed-item{
  position: relative !important;
}
#activityFeedCard .activity-feed-item::before{
  content:"";
  position:absolute;
  left:0;
  top:10px;
  bottom:10px;
  width:6px;
  border-radius:999px;
  background: rgba(255,255,255,0.18);
}
#activityFeedCard .activity-feed-item.activity-priority-urgent{
  background: rgba(185,28,28,0.10) !important;
  border-color: rgba(185,28,28,0.22) !important;
}
#activityFeedCard .activity-feed-item.activity-priority-urgent::before{
  background:#dc2626;
  box-shadow:0 0 0 4px rgba(220,38,38,0.12), 0 0 18px rgba(220,38,38,0.20);
}
#activityFeedCard .activity-feed-item.activity-priority-urgent .activity-feed-text{
  color:#7f1d1d !important;
}
#activityFeedCard .activity-feed-item.activity-priority-attention{
  background: rgba(217,119,6,0.10) !important;
  border-color: rgba(217,119,6,0.20) !important;
}
#activityFeedCard .activity-feed-item.activity-priority-attention::before{
  background:#d97706;
  box-shadow:0 0 0 4px rgba(217,119,6,0.12);
}
#activityFeedCard .activity-feed-item.activity-priority-attention .activity-feed-text{
  color:#8a4b00 !important;
}
#activityFeedCard .activity-feed-item.activity-priority-active{
  background: rgba(22,163,74,0.10) !important;
  border-color: rgba(22,163,74,0.20) !important;
}
#activityFeedCard .activity-feed-item.activity-priority-active::before{
  background:#16a34a;
  box-shadow:0 0 0 4px rgba(22,163,74,0.12), 0 0 14px rgba(22,163,74,0.18);
  animation: liveActivityPulse 1.8s ease-in-out infinite;
}
#activityFeedCard .activity-feed-item.activity-priority-active .activity-feed-text{
  color:#166534 !important;
}
#activityFeedCard .activity-feed-item.activity-priority-neutral{
  background: rgba(255,255,255,0.08) !important;
  border-color: rgba(255,255,255,0.16) !important;
}
#activityFeedCard .activity-feed-item.activity-priority-neutral::before{
  background: rgba(37,99,235,0.45);
}
#activityFeedCard .activity-feed-item.activity-priority-neutral .activity-feed-text{
  color:#17324d !important;
}
#activityFeedCard .activity-feed-item .activity-feed-link{
  padding-left: 10px !important;
}
#activityFeedCard .activity-priority-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:84px;
  padding:6px 10px;
  border-radius:999px;
  font-size:11px;
  font-weight:900;
  letter-spacing:.04em;
  text-transform:uppercase;
  line-height:1;
}
#activityFeedCard .activity-priority-badge.priority-urgent{
  background: rgba(220,38,38,0.12);
  color:#b91c1c;
}
#activityFeedCard .activity-priority-badge.priority-attention{
  background: rgba(217,119,6,0.12);
  color:#a16207;
}
#activityFeedCard .activity-priority-badge.priority-active{
  background: rgba(22,163,74,0.12);
  color:#15803d;
}
#activityFeedCard .activity-priority-badge.priority-neutral{
  background: rgba(37,99,235,0.10);
  color:#1d4ed8;
}
@keyframes liveActivityPulse{
  0%,100%{ box-shadow:0 0 0 4px rgba(22,163,74,0.12), 0 0 14px rgba(22,163,74,0.18); }
  50%{ box-shadow:0 0 0 6px rgba(22,163,74,0.16), 0 0 22px rgba(22,163,74,0.24); }
}
@media (max-width: 860px){
  #activityFeedCard .activity-priority-badge{
    min-width:auto;
    padding:5px 9px;
  }
}


/* === Manager Hub top-of-page polish === */
.weather-hub-card{
  margin: 10px 0 12px !important;
}
#smartAlertStrip.smart-alert-strip{
  margin: 8px auto 18px auto !important;
  padding: 8px 12px !important;
}
#smartAlertContent{
  gap: 8px !important;
}
#smartAlertStrip .smart-alert-board{
  min-height: 0 !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-label{
  margin-bottom: 2px !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-headline{
  font-size: 20px !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-sub{
  font-size: 12px !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-cta{
  min-width: 108px !important;
  padding: 11px 14px !important;
}
.activity-feed-card,
#activityFeedCard,
#activityFeedSection{
  margin: 0 auto 20px auto !important;
}
.activity-feed-header{
  margin-bottom: 8px !important;
  align-items: center !important;
}
.activity-feed-title{
  font-size: 26px !important;
  line-height: 1.05 !important;
}
.activity-feed-sub{
  font-size: 13px !important;
  margin-top: 2px !important;
}
#activityFeedCard .activity-feed,
.live-activity-card .activity-feed,
#activityFeedSection .activity-feed,
#activityFeedCard .feed-list,
.live-activity-card .feed-list,
#activityFeedSection .feed-list,
#activityFeedCard .activity-list,
.live-activity-card .activity-list,
#activityFeedSection .activity-list{
  max-height: 300px !important;
}
#activityFeedCard .activity-feed-item,
.live-activity-card .activity-feed-item,
#activityFeedSection .activity-feed-item{
  padding: 12px 14px 12px 18px !important;
}
#activityFeedCard .activity-feed-time{
  display:flex !important;
  align-items:center !important;
  gap:8px !important;
}
#activityFeedCard .activity-feed-text{
  line-height: 1.35 !important;
}
#activityFeedCard .activity-priority-badge{
  font-size: 10px !important;
  padding: 5px 8px !important;
}

@media (max-width: 1024px){
  .weather-hub-card{
    margin: 8px 0 10px !important;
  }
  #smartAlertStrip.smart-alert-strip{
    margin: 6px auto 14px auto !important;
    padding: 8px 10px !important;
  }
  #smartAlertStrip .smart-alert-board{
    border-radius: 22px !important;
    padding: 14px 16px !important;
  }
  #smartAlertStrip .smart-alert-board .smart-alert-headline{
    font-size: 18px !important;
  }
  #smartAlertStrip .smart-alert-board .smart-alert-sub{
    font-size: 12px !important;
  }
  .activity-feed-card,
  #activityFeedCard,
  #activityFeedSection{
    margin: 0 auto 16px auto !important;
    padding: 18px 18px !important;
  }
  .activity-feed-title{
    font-size: 24px !important;
  }
}

@media (max-width: 768px){
  #smartAlertStrip .smart-alert-board .smart-alert-main{
    gap: 10px !important;
  }
  #smartAlertStrip .smart-alert-board .smart-alert-copy{
    gap: 3px !important;
  }
  .activity-feed-header{
    gap: 8px !important;
  }
  .activity-feed-title{
    font-size: 22px !important;
  }
  .activity-feed-sub{
    font-size: 12px !important;
  }
}


/* === Live Activity hard no-flash gate === */
body.manager-live-activity-pending #activityFeedList .activity-feed-item{
  opacity: 0 !important;
  visibility: hidden !important;
}
body.manager-live-activity-pending #activityFeedCard .activity-feed-empty,
body.manager-live-activity-pending .live-activity-card .activity-feed-empty,
body.manager-live-activity-pending #activityFeedSection .activity-feed-empty{
  opacity: 1 !important;
  visibility: visible !important;
}
body.manager-live-activity-ready #activityFeedList .activity-feed-item{
  opacity: 1 !important;
  visibility: visible !important;
  transition: opacity 160ms ease !important;
}
#activityFeedCard .activity-feed-loading-shell{
  display:grid !important;
  gap:12px !important;
}
#activityFeedCard .activity-feed-loading-shell .activity-feed-loading-row{
  min-height:72px !important;
  border-radius:18px !important;
  background: rgba(255,255,255,0.16) !important;
  border:1px solid rgba(255,255,255,0.22) !important;
  box-shadow:none !important;
  position:relative !important;
  overflow:hidden !important;
}
#activityFeedCard .activity-feed-loading-shell .activity-feed-loading-row::before{
  content:"" !important;
  position:absolute !important;
  left:0 !important;
  top:10px !important;
  bottom:10px !important;
  width:6px !important;
  border-radius:999px !important;
  background: rgba(255,255,255,0.24) !important;
}
#activityFeedCard .activity-feed-loading-shell .activity-feed-loading-row::after{
  content:"" !important;
  position:absolute !important;
  inset:0 !important;
  background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.16) 45%, rgba(255,255,255,0) 100%) !important;
  transform: translateX(-100%) !important;
  animation: activityFeedLoadingSweep 1.1s ease-in-out infinite !important;
}
@keyframes activityFeedLoadingSweep{
  to { transform: translateX(100%); }
}

</style>
<script>
(() => {
  const SESSION_KEY = "zummee_session_v1";

  function getSupabaseSession(){
    function extract(o){
      try{
        if(!o) return null;
        if(o.user && o.user.id) return { id:o.user.id, email:(o.user.email||"") };
        if(o.currentSession && o.currentSession.user && o.currentSession.user.id) return { id:o.currentSession.user.id, email:(o.currentSession.user.email||"") };
        if(o.session && o.session.user && o.session.user.id) return { id:o.session.user.id, email:(o.session.user.email||"") };
      }catch(_e){}
      return null;
    }
    function scan(store){
      try{
        for(var i=0;i<store.length;i++){
          var key = store.key(i);
          if(!key) continue;
          if(!(key === 'sb-zummee-auth' || /^sb-.*-auth-token$/.test(key))) continue;
          var raw = null;
          try{ raw = store.getItem(key); }catch(_e){}
          if(!raw) continue;
          var obj = null;
          try{ obj = JSON.parse(raw); }catch(_e2){}
          var ex = extract(obj);
          if(ex && ex.id) return ex;
        }
      }catch(_e3){}
      return null;
    }
    try{
      var a = scan(localStorage) || scan(sessionStorage);
      if(a && a.id){
        return { provider:"supabase", userId:a.id, email:(a.email||""), supabase:true };
      }
    }catch(_e4){}
    return null;
  }

  let SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || "zummee_selected_community_v1";

  function safeParse(raw){ try { return JSON.parse(raw); } catch(e){ return null; } }
  function getSession(){
    var ses = safeParse((sessionStorage.getItem(SESSION_KEY) || localStorage.getItem(SESSION_KEY) || ""));
    if(ses && ses.userId){
      try{ if(window.ZUMMEE_applyUserScope){ window.ZUMMEE_applyUserScope(ses.userId); } }catch(_e){}
      try{ SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || SELECTED_COMMUNITY_KEY; }catch(_e){}
      try{ COMMUNITIES_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || COMMUNITIES_KEY; }catch(_e){}
      return ses;
    }
    var sbSes = getSupabaseSession();
    if(sbSes){
      try{ if(window.ZUMMEE_applyUserScope){ window.ZUMMEE_applyUserScope(sbSes.userId); } }catch(_e){}
      try{ SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || SELECTED_COMMUNITY_KEY; }catch(_e){}
      try{ COMMUNITIES_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || COMMUNITIES_KEY; }catch(_e){}
      return sbSes;
    }
    return null;
  }

  function requireAuth(){
    const ses = getSession();
    if(!ses || !ses.userId){
      window.location.href = "login.html";
      return null;
    }
    return ses;
  }

  window.ZummeeAuth = {
    requireAuth,
    getSession,
    getUserId: () => (getSession() && getSession().userId) || "",
    getSelectedCommunityId: () => {
      try { return localStorage.getItem(SELECTED_COMMUNITY_KEY) || ""; } catch(e){ return ""; }
    },
    scopedKey: (baseKey) => {
      const ses = getSession();
      const u = (ses && ses.userId) ? ses.userId : "";
      const c = (() => { try { return localStorage.getItem(SELECTED_COMMUNITY_KEY) || ""; } catch(e){ return ""; } })();
      if(u && c) return `${baseKey}::${u}::${c}`;
      if(u) return `${baseKey}::${u}`;
      return baseKey;
    },
	    signOut: () => { try{sessionStorage.removeItem(SESSION_KEY);}catch(e){}
	      try{localStorage.removeItem(SESSION_KEY);}catch(e2){}
	      // Supabase auth cleanup (support default sb-*-auth-token and custom sb-zummee-auth)
	      try{
	        [localStorage, sessionStorage].forEach(function(store){
	          try{
	            for(var i=store.length-1;i>=0;i--){
	              var k = store.key(i);
	              if(!k) continue;
	              if(k === 'sb-zummee-auth' || /^sb-.*-auth-token$/.test(k) || /^sb-zummee-auth/.test(k)){
	                try{ store.removeItem(k); }catch(_e){}
	              }
	            }
	          }catch(_e2){}
	        });
	      }catch(_e3){}
	      try{ if(window.sb && window.sb.auth && window.sb.auth.signOut){ window.sb.auth.signOut(); } }catch(e5){}
	      window.location.replace("login.html"); }
  };
})();
</script>
<style>
.hub-card{
  min-height: 160px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* Ensure community dropdown text is dark and readable */
#zummeeCommunitySelect{
  color:#0f2f4a !important;
  font-weight:700 !important;
}
.zummee-modern-picker__button,
.zummee-modern-picker__item{
  color:#0f2f4a !important;
}

/* Force subpage dropdown to match Manager Hub */
#zummeeCommunitySelect{
  background:#ffffff !important;
  color:#000000 !important;
  font-weight:700 !important;
}

.zummee-modern-picker__button{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

.zummee-modern-picker__menu{
  background:#ffffff !important;
}

.zummee-modern-picker__item{
  color:#000000 !important;
}

/* Match Manager Hub community picker styling (white dropdown, black text) */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communityBtn span{
  color:#000000 !important;
}
.zummee-communityMenu{
  background:#ffffff !important;
  border:1px solid rgba(15,47,74,0.18) !important;
}
.zummee-communitySearch{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communitySearch::placeholder{
  color: rgba(0,0,0,0.55) !important;
}
.zummee-communityItem{
  color:#000000 !important;
}

/* Force dropdown button background to white */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Override header generic button styling for community picker */
.zummee-header .zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Remove bullet points from modern community dropdown */
.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
  padding-left:0 !important;
  margin-left:0 !important;
}

.zummee-communityItem::before{
  content:none !important;
  display:none !important;
}

/* FORCE remove bullets everywhere inside community dropdown */
.zummee-communityMenu,
.zummee-communityMenu *{
  list-style-type:none !important;
  list-style:none !important;
}

.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
}

.zummee-communityMenu li::marker{
  content:"" !important;
}

.zummee-communityMenu li::before{
  content:none !important;
  display:none !important;
}

/* Subpage Hub button — match Manager Hub */
.zummee-header .zummee-hubBtn {
  background: #ffffff !important;
  color: #0f2f4a !important;
  border-radius: 28px !important;
  padding: 10px 22px !important;
  font-weight: 700 !important;
  font-size: 16px !important;
  border: 1px solid rgba(15,47,74,0.15) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  transition: all .2s ease;
  text-decoration:none !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
}

.zummee-header .zummee-hubBtn:hover {
  background: #f4f6f8 !important;
}

/* Fix Hub button text color + alignment under dropdown */
.zummee-header .zummee-hubBtn {
  color: #000000 !important;
  display: block !important;
  margin-left: auto !important;
  margin-top: 10px !important;
}

.zummee-header .community-header-right {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important;
}

/* Correct Hub button sizing and force black text */
.zummee-header .zummee-hubBtn {
  background:#ffffff !important;
  color:#000000 !important;
  border-radius:28px !important;
  padding:8px 18px !important;
  font-weight:700 !important;
  font-size:15px !important;
  border:1px solid rgba(15,47,74,0.15) !important;
  box-shadow:0 4px 10px rgba(0,0,0,0.08) !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:auto !important;
  min-width:auto !important;
  margin-top:8px !important;
  align-self:flex-end !important;
}

/* Ensure container stacks properly */
.zummee-header .community-header-right {
  display:flex !important;
  flex-direction:column !important;
  align-items:flex-end !important;
}

/* Force Hub button text to true black */
.zummee-header .zummee-hubBtn,
.zummee-header .zummee-hubBtn:visited,
.zummee-header .zummee-hubBtn span {
  color:#000000 !important;
}

/* Align page titles (like Daily Ops) to the left */
.page-title,
