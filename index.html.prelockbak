<script src="shared/header.js?v=2026-04-08-2"></script>
<!-- Page-aware header title helper -->
<script>
(function(){
  function applyPageTitle(){
    try{
      var t = (document.body && document.body.dataset && document.body.dataset.pageTitle) ? document.body.dataset.pageTitle : "";
      if(!t) return;
      document.title = t;
      var h1 = document.querySelector('.wrap > h1') || document.querySelector('.wrap h1');
      if(h1) h1.textContent = t;
    }catch(e){ /* no-op */ }
  }
  document.addEventListener('DOMContentLoaded', applyPageTitle);
})();
</script>
<script>
  // --- Cloud Communities (company-wide) ---
  (function(){
    const SUPABASE_URL = "https://slcwuuwyrgnmlmxpcaim.supabase.co";
    const SUPABASE_KEY = "sb_publishable_DqOtjzlLWph7-bFjKlFN0w_kSpPI864";

    async function ensureSupabase() {
      if(window.sb) return window.sb;
      if(!window.supabase) throw new Error("Supabase library not loaded");
      window.sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, {
        auth: { storageKey:'sb-zummee-auth', storage: window.localStorage, persistSession:true, autoRefreshToken:true, detectSessionInUrl:true  }
      });

      // --- Auth bootstrap fallback ---
      // If the auth payload exists but supabase-js hasn't hydrated a session yet,
      // force-hydrate using access_token + refresh_token so requests include auth.
      try{
        const raw = localStorage.getItem('sb-zummee-auth');
        if(raw){
          const s = JSON.parse(raw);
          const at = s?.access_token || s?.currentSession?.access_token;
          const rt = s?.refresh_token || s?.currentSession?.refresh_token;
          if(at && rt){
            await window.sb.auth.setSession({ access_token: at, refresh_token: rt });
          }
          // Also seed our legacy uid cache if missing.
          if(!localStorage.getItem('zummee_user_id_v1') && at){
            const payload = JSON.parse(atob(at.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));
            if(payload?.sub) localStorage.setItem('zummee_user_id_v1', payload.sub);
          }
        }
      }catch(_e){}
      return window.sb;
    }

    async function getSessionSafe(sb, ms){
      ms = ms || 5000;
      return await Promise.race([
        sb.auth.getSession(),
        new Promise((resolve) => {
          let done = false;
          const sub = sb.auth.onAuthStateChange((event, session) => {
            if(done) return;
            if(event === 'INITIAL_SESSION' || session){
              done = true;
              try{ sub.data.subscription.unsubscribe(); }catch(_e){}
              resolve({ data: { session } });
            }
          });
          setTimeout(() => {
            if(done) return;
            done = true;
            try{ sub.data.subscription.unsubscribe(); }catch(_e){}
            resolve({ data: { session: null }, error: new Error('session timeout') });
          }, ms);
        })
      ]);
    }

    function safeLocalSet(k,v){ try{ localStorage.setItem(k,v); }catch(_e){} }
    function safeLocalGet(k){ try{ return localStorage.getItem(k)||""; }catch(_e){ return ""; } }

    async function requireUid() {
      const sb = await ensureSupabase();
      const s = await getSessionSafe(sb, 5000);
      const uid = s.data?.session?.user?.id;
      if(uid) return uid;

	      // Fallback 1: cached uid
	      const cached = localStorage.getItem("zummee_user_id_v1");
	      if (cached) {
	        console.warn("Auth session missing; using cached uid from localStorage.");
	        return cached;
	      }

	      // Fallback 2: decode uid from sb-zummee-auth payload
	      try{
	        const raw = localStorage.getItem("sb-zummee-auth");
	        if(raw){
	          const st = JSON.parse(raw);
	          const token = st?.access_token || st?.currentSession?.access_token;
	          if(token){
	            const payload = JSON.parse(atob(token.split(".")[1].replace(/-/g,'+').replace(/_/g,'/')));
	            const sub = payload?.sub;
	            if(sub){
	              safeLocalSet("zummee_user_id_v1", sub);
	              console.warn("Auth session missing; derived uid from sb-zummee-auth.");
	              return sub;
	            }
	          }
	        }
	      }catch(_e){}

	      throw new Error("Not signed in");
    }

    async function getProfile() {
      const sb = await ensureSupabase();
      const uid = await requireUid();

      // Defaults from session (works even if Profiles table read fails)
      let company0 = "";
      let company_id0 = "";
      let selected0 = "";
      let dept = "";
      let role = "";
      let name = "";

      let email = "";
      try{
        const sess = (await sb.auth.getSession()).data?.session;
        email = String(sess?.user?.email||"").toLowerCase();
      }catch(_e){}

      // Try Profiles table (best source of truth)
      // NOTE: Some databases don't have selected_community_id yet; request it separately to avoid 400s.
      try{
        const q = await sb.from("profiles").select("*").eq("id", uid).maybeSingle();
        if(!q.error && q.data){
          company0 = (q.data.company||"").trim();
          company_id0 = String(q.data.company_id||"").trim();
          dept = (q.data.department||"").trim();
          role = (q.data.role||"").trim();
          name = (q.data.name||"").trim();
        }
      }catch(_e){ /* fall back to session + local */ }

      // Role/Company source-of-truth: userdirectory (keeps UI gates accurate even if Profiles is stale)
      // Fixes cases where an admin promotes a user to Supervisor but their Profiles row still says Employee.
      try{
        const udq = await sb
          .from('userdirectory')
          .select('role,company_id,company_name,profile_name,profile_email,created_at')
          .eq('auth_user_id', uid)
          .order('created_at', { ascending: false })
          .limit(1);

        if(udq && !udq.error && Array.isArray(udq.data) && udq.data.length){
          const r = udq.data[0] || {};
          const udRole = String(r.role || '').trim();
          if(udRole){
            role = udRole;
            // Keep dept consistent with Supervisor UI gates.
            if(!dept && (udRole === 'Supervisor' || udRole === 'Admin' || udRole === 'CompanyAdmin')) dept = 'Supervisor';
          }
          if(!company_id0 && r.company_id) company_id0 = String(r.company_id||'').trim();
          if(!company0 && r.company_name) company0 = String(r.company_name||'').trim();
          if(!name && r.profile_name) name = String(r.profile_name||'').trim();
          if(!email && r.profile_email) email = String(r.profile_email||'').trim().toLowerCase();

          // Best-effort: write back to Profiles so future reads are consistent.
          try{
            const patch = {};
            if(role) patch.role = role;
            if(dept) patch.department = dept;
            if(company_id0) patch.company_id = company_id0;
            if(company0) patch.company = company0;
            if(company0) patch.company = company0;
            if(name) patch.name = name;
            if(Object.keys(patch).length){
              await sb.from('profiles').update(patch).eq('id', uid);
            }
          }catch(_e2){ /* ignore */ }
        }
      }catch(_e){ /* ignore */ }

      // selected community (optional column)
      // If your Profiles table doesn't have this column yet, PostgREST will return 400.
      // We memoize that and stop requesting it to avoid noisy console errors.
      try{
        const hasCol = safeLocalGet('zummee_profiles_has_selected_community_id');
        if(hasCol !== '0'){
          const q2 = await sb.from("profiles").select("*").eq("id", uid).maybeSingle();
          if(!q2.error && q2.data){
            selected0 = (q2.data.selected_community_id||"").trim();
            safeLocalSet('zummee_profiles_has_selected_community_id','1');
          } else if(q2.error){
            safeLocalSet('zummee_profiles_has_selected_community_id','0');
          }
        }
      }catch(_e){ safeLocalSet('zummee_profiles_has_selected_community_id','0'); }

      // Fallback to local selected community if DB column isn't present
      if(!selected0){
        try{ selected0 = String(localStorage.getItem("zummee_selected_community_id")||"").trim(); }catch(_e){}
      }

      // Bootstrap Admin fallback + local company fallback
      if(email === "companyadmin@zummee.local"){
        if(!role) role = "Admin";
        if(!dept) dept = "Supervisor";
        if(!name) name = "CompanyAdmin";
      }

      let company = company0;
      if(!company){
        try{ company = String(localStorage.getItem("zummee_company")||"").trim(); }catch(_e){}
      }

      // Global auth state: single source of truth for UI gates
      try{
        window.ZUMMEE_AUTH = window.ZUMMEE_AUTH || {};
        window.ZUMMEE_AUTH.isLoggedIn = true;
        window.ZUMMEE_AUTH.userId = uid;
        window.ZUMMEE_AUTH.email = email;
        // IMPORTANT: Never keep previous user's role/department/company.
        // Logging in/out in the same browser shares localStorage; these must be overwritten.
        window.ZUMMEE_AUTH.name = name || "";
        window.ZUMMEE_AUTH.company = company || "";
        window.ZUMMEE_AUTH.department = dept || "";
        window.ZUMMEE_AUTH.role = role || "";
      }catch(_e){}

      // Persist minimal context for page-level gating (Supervisor Access can load before globals are ready)
      // localStorage is shared across logins in the same browser; always overwrite on login.
      try{ localStorage.setItem('zummee_role', String(role||'')); }catch(_e){}
      try{ localStorage.setItem('zummee_department', String(dept||'')); }catch(_e){}
      try{ localStorage.setItem('zummee_company', String(company||'')); }catch(_e){}
      try{ if(company_id0) localStorage.setItem('zummee_company_id', String(company_id0||'')); }catch(_e){}

      // Expose legacy globals + notify listeners (Supervisor Access, badges, etc.)
      try{
        window.__zummeeCompany = company;
        window.__zummeeUserDepartment = dept;
        window.__zummeeUserRole = role;
        window.__zummeeUserName = name;
        window.dispatchEvent(new CustomEvent("profile:loaded", { detail: { userId: uid, company: company, department: dept, role: role, name: name, id: uid } }));
        window.dispatchEvent(new CustomEvent("auth:ready", { detail: window.ZUMMEE_AUTH }));
      }catch(_e){}

      return { uid, company: company, company_id: company_id0, selected: selected0, department: dept, role: role, name: name };
    }

    function els() {
      return {
        select: document.getElementById("zummeeCommunitySelect"),
        swatch: document.getElementById("zummeeCommunitySwatch"),
        btnAdd: document.getElementById("zummeeCommunityAdd"),
        btnRename: document.getElementById("zummeeCommunityRename"),
        btnRemove: document.getElementById("zummeeCommunityRemove"),
      };
    }

    function setSwatch(company){
      const e = els().swatch;
      if(!e) return;
      let h=0; for(let i=0;i<company.length;i++) h=(h*31 + company.charCodeAt(i))>>>0;
      const hue = h % 360;
      e.style.background = `hsl(${hue} 70% 45%)`;
      e.title = company || "No company";
    }

    function rebindButton(btn, handler){
      if(!btn || !btn.parentNode) return btn;
      const clone = btn.cloneNode(true);
      btn.parentNode.replaceChild(clone, btn);
      clone.onclick = handler;
      return clone;
    }

    function hardBind(btn, handler){
      if(!btn) return btn;
      // remove inline onclick if any
      try{ btn.onclick = null; btn.removeAttribute("onclick"); }catch(_e){}
      // Remove any previously attached listeners by replacing node (inline attrs will be re-applied below if present in HTML, so also remove onclick)
      const clone = btn.cloneNode(true);
      try{ clone.onclick = null; clone.removeAttribute("onclick"); }catch(_e){}
      btn.parentNode && btn.parentNode.replaceChild(clone, btn);
      // Capture-phase handler to prevent any other handlers from firing (old + new)
      clone.addEventListener("click", function(ev){
        try{ ev.preventDefault(); }catch(_e){}
        try{ ev.stopImmediatePropagation(); }catch(_e){}
        return handler();
      }, true);
      return clone;
    }

    function bindSelect(select) {
      if(!select) return;
    // Attach modern UI wrapper once (keeps existing select behavior)
    initModernCommunityPicker(select);
      select.onchange = async ()=>{
        const val = String(select.value||"").trim();
        safeLocalSet("zummee_selected_community_id", val);
        safeLocalSet("activeCommunityId", val);
        safeLocalSet("zummeeActiveCommunityId", val);
        safeLocalSet("currentCommunityId", val);
        try{ localStorage.setItem("zummee_selected_community_v1", val); }catch(_e){}
        try{
          const sb = await ensureSupabase();
          const uid = await requireUid();
          await sb.from("profiles").update({ selected_community_id: val || null }).eq("id", uid);
        }catch(_e){}
        document.dispatchEvent(new CustomEvent("community:changed", { detail: { community_id: val } }));
      };
    }

    function getLocalCommunitiesKey(profile){
      // Communities are stored per-user (scoped via ZUMMEE_applyUserScope).
      return (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || window.COMMUNITIES_KEY || ("zummee_communities_v1__user__" + profile.uid);
    }

    function readLocalCommunities(profile){
      try{
        const raw = localStorage.getItem(getLocalCommunitiesKey(profile)) || "[]";
        const arr = JSON.parse(raw);
        return Array.isArray(arr) ? arr : [];
      }catch(_e){
        return [];
      }
    }

    function writeLocalCommunities(profile, list){
      try{ localStorage.setItem(getLocalCommunitiesKey(profile), JSON.stringify(list||[])); }catch(_e){}
    }

    async function listCommunities(profile) {
  // Cloud-first: use company-wide communities; employees see only assigned communities.
  profile = profile || {};
  const company = String(profile.company || profile.company_name || "").trim();
  const companyIdProfile = String(profile.company_id || profile.companyId || localStorage.getItem('zummee_active_company_id') || '').trim();
  if(!company && !companyIdProfile) return [];

  let companyList = [];
  try{
    if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
          if(!sb){ alert('Supabase client not initialized. Please refresh and try again.'); return; }
if(sb){
      // Pull from cloud (PropertyCommunities), then cache.
      let qBuilder = window.sb
        .from('PropertyCommunities')
        .select('id,name,created_at');

      // Prefer company_id when available (PropertyCommunities schema uses company_id as the true FK)
      if(companyIdProfile){
        qBuilder = qBuilder.eq('company_id', companyIdProfile);
      }else if(company){
        // Use a pattern match as company names may include suffix/prefix variations.
        // (Avoid exact-match cache clobbering when employee profile company differs slightly.)
        qBuilder = qBuilder.ilike('company', '%'+company+'%');
      }

      const q = await qBuilder.order('name', {ascending:true});
      if(!q.error && Array.isArray(q.data)){
        companyList = q.data
          .filter(r=>r && r.id && r.name)
          .map(r=>({id:String(r.id), name:String(r.name)}));
        // IMPORTANT: do NOT overwrite a previously-good cache with an empty list.
        // This can happen when a non-privileged user has a slightly different company string.
        if(companyList.length){
          try{
            const cacheKeyBase = company || companyIdProfile;
            localStorage.setItem("zummee_company_communities_v1__"+cacheKeyBase, JSON.stringify(companyList));
            if(company){
              // case-insensitive helper cache
              localStorage.setItem("zummee_company_communities_v1__"+company.toLowerCase(), JSON.stringify(companyList));
            }
          }catch(_e){}
        }
      }
    }
  }catch(e){
    console.warn("listCommunities cloud fetch failed:", e);
  }

  // Fallback to cached company list
  if(!companyList.length){
    try{
      const cacheKeyBase = company || companyIdProfile;
      const raw = localStorage.getItem("zummee_company_communities_v1__"+cacheKeyBase) ||
                  (company ? localStorage.getItem("zummee_company_communities_v1__"+company.toLowerCase()) : null) || "[]";
      const arr = JSON.parse(raw) || [];
      companyList = arr.filter(c=>c && c.id && c.name).map(c=>({id:String(c.id), name:String(c.name)}));
    }catch(_e){ companyList=[]; }
  }

  // As a last fallback, keep legacy local communities (admin-only historical behavior)
  if(!companyList.length){
    const legacy = readLocalCommunities(profile) || [];
    companyList = legacy.filter(c=>c && c.id && c.name).map(c=>({id:String(c.id), name:String(c.name)}));
  }

  // If employee (or non-privileged), filter to assigned communities only.
    // For employees (or non-privileged), return ONLY communities explicitly assigned to them.
  const role = String(profile.role||"").trim().toLowerCase();
  const dept = String(profile.department||profile.dept||"").trim().toLowerCase();
  const isPriv = role.includes("admin") || role.includes("supervisor") || role.includes("companyadmin") ||
                 dept.includes("admin") || dept.includes("supervisor") || dept.includes("companyadmin");

  if(!isPriv){
    // Employees (and other non-privileged roles) must ONLY see communities explicitly assigned to them.
    const uid = String(profile.uid || profile.auth_user_id || profile.user_id || profile.id || '').trim();
    if(!uid) return [];

    // Resolve UUID company_id (CommunityAssignments uses company_id uuid)
    let companyId = (profile && (profile.company_id || profile.companyId)) || localStorage.getItem('zummee_active_company_id') || null;
    try{
      if(!companyId){
        if(typeof window.getCompanyRow==='function'){
          const crow = await window.getCompanyRow(company);
          companyId = (crow && crow.id) ? crow.id : null;
        }
      }
    }catch(_e){}

    // 1) Fetch assigned community IDs for this user in this company
    let assignedIds = [];
    try{
      if(typeof window.ensureSupabase==='function') await window.ensureSupabase();
      const sb = window.sb || null;
      if(sb && companyId){
        const qa = await sb
          .from('CommunityAssignments')
          .select('community_id')
          .eq('user_id', uid)
          .eq('company_id', companyId);

        if(!qa.error && Array.isArray(qa.data)){
          assignedIds = qa.data.map(r=>String(r.community_id||'').trim()).filter(Boolean);
          try{
            const k = 'zummee_assigned_community_ids_v1__'+uid+'__'+String(companyId);
            localStorage.setItem(k, JSON.stringify(assignedIds));
          }catch(_e){}
        }else if(qa.error){
          console.warn('CommunityAssignments read blocked or failed:', qa.error);
        }
      }
    }catch(e){
      console.warn('CommunityAssignments fetch failed:', e);
    }

    // Cache fallback if cloud call couldn't run
    if(!assignedIds.length){
      try{
        const k = 'zummee_assigned_community_ids_v1__'+uid+'__'+String(companyId||company);
        assignedIds = JSON.parse(localStorage.getItem(k)||'[]') || [];
      }catch(_e){ assignedIds=[]; }
    }

    // If nothing is assigned, show nothing (prevents unassigned communities leaking into employee dropdown).
    if(!assignedIds.length) return [];

    // 2) Prefer fetching names from PropertyCommunities using the assigned IDs
    try{
      if(typeof window.ensureSupabase==='function') await window.ensureSupabase();
      const sb = window.sb || null;
      if(sb){
        let qb = sb.from('PropertyCommunities').select('id,name').in('id', assignedIds);
        if(companyId) qb = qb.eq('company_id', companyId);
        else if(company) qb = qb.eq('company', company);

        const qc = await qb.order('name', {ascending:true});
        if(!qc.error && Array.isArray(qc.data)){
          companyList = qc.data.filter(r=>r && r.id && r.name).map(r=>({id:String(r.id), name:String(r.name)}));
        }else if(qc && qc.error){
          console.warn('PropertyCommunities fetch (assigned-only) failed:', qc.error);
        }
      }
    }catch(e){
      console.warn('PropertyCommunities assigned-only fetch failed:', e);
    }

    // 3) Always enforce assignment filtering (even if we already had a companyList from cache)
    const set = new Set(assignedIds.map(String));
    companyList = (companyList||[]).filter(c=>c && set.has(String(c.id)));
  }

  // Ensure stable shape + sort by name
  return companyList
    .filter(c=>c && c.id && c.name)
    .map(c=>({ id:String(c.id), name:String(c.name) }))
    .sort((a,b)=>a.name.localeCompare(b.name));
}

    function renderSelect(select, list, selectedId) {
      if(!select) return;
      const desired = safeLocalGet("zummee_selected_community_id") || safeLocalGet("activeCommunityId") || safeLocalGet("zummeeActiveCommunityId") || safeLocalGet("currentCommunityId") || String(selectedId||"").trim();
      select.innerHTML = "";
      const o0 = document.createElement("option");
      o0.value = "";
      o0.textContent = list.length ? "Select a community" : ((window.__zummeeIsPriv===false) ? "No assigned communities" : "No communities yet");
      select.appendChild(o0);

      list.forEach(c=>{
        const o=document.createElement("option");
        o.value = String(c.id);
        o.textContent = c.name;
        select.appendChild(o);
      });

      if(desired && list.some(c=>String(c.id)===String(desired))) {
        select.value = String(desired);
      } else if (list.length) {
        select.value = String(list[0].id);
        safeLocalSet("zummee_selected_community_id", String(list[0].id));
        safeLocalSet("activeCommunityId", String(list[0].id));
        safeLocalSet("zummeeActiveCommunityId", String(list[0].id));
        safeLocalSet("currentCommunityId", String(list[0].id));
      } else if(!events.length) {
        select.value = "";
        safeLocalSet("zummee_selected_community_id","");
      }
      select.disabled = false;
      bindSelect(select);
    }

    async function refreshUI() {
      const {select} = els();
      if(!select) return;
      try{
        const profile = await getProfile();
        setSwatch(profile.company);

const role = String(profile.role||"").trim().toLowerCase();
window.__zummeeIsPriv = (role.includes("admin") || role.includes("supervisor"));
        if(!(profile.company || profile.company_name) && !profile.company_id){
          renderSelect(select, [], "");
          return;
        }
        const list = await listCommunities(profile);
        renderSelect(select, list, profile.selected);
      }catch(e){
        console.error(e);
        renderSelect(select, [], "");
      }
    }

    
// --- Active Company Context (Privileged users) ---
async function __getActiveCompanyContext(profile){
  if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
  if(!sb) return { company_id: (profile.company_id||"").trim(), company_name: (profile.company||"").trim() };

  // Prefer profile.company_id if present
  let company_id = String(profile.company_id||"").trim();
  let company_name = String(profile.company||"").trim();

  // LocalStorage fallback for privileged users (remember last active company)
  const ls_id = String(localStorage.getItem("zummee_active_company_id")||"").trim();
  const ls_name = String(localStorage.getItem("zummee_active_company_name")||"").trim();
  if(!company_id && ls_id) company_id = ls_id;
  if(!company_name && ls_name) company_name = ls_name;

  if(company_id) {
    // Keep remembered
    localStorage.setItem("zummee_active_company_id", company_id);
    if(company_name) localStorage.setItem("zummee_active_company_name", company_name);
    return { company_id, company_name };
  }

  // v786 hotfix: Supervisors are scoped to their own company; never prompt them with the full Companies list.
  // If company_id is missing for a Supervisor, attempt to resolve it by company name; otherwise fail-closed.
  const roleLower = String(profile.role||"").trim().toLowerCase();
  const deptLower = '';
  const isAdminLike = (roleLower.includes("admin") || roleLower.includes("companyadmin"));
  const isSupervisor = (roleLower.includes("supervisor") || deptLower.includes("supervisor"));
  if(isSupervisor && !isAdminLike){
    if(company_name){
      try{
        const r = await sb.from("Companies").select("id,name").eq("name", company_name).maybeSingle();
        if(r && r.data && r.data.id){
          company_id = String(r.data.id);
          localStorage.setItem("zummee_active_company_id", company_id);
          localStorage.setItem("zummee_active_company_name", company_name);
          return { company_id, company_name };
        }
      }catch(_e){}
    }
    console.warn("Supervisor missing company_id; cannot select arbitrary company. Please set company_id on the profile.");
    return { company_id:"", company_name: company_name||"" };
  }
  // No company_id available: fetch Companies and ask once
  const { data, error } = await sb.from("Companies").select("id,name").order("name",{ascending:true});
  if(error || !data || !data.length){
    console.warn("Companies list unavailable for active company selection:", error);
    return { company_id:"", company_name:"" };
  }

  // Build a simple numbered prompt
  const lines = data.slice(0, 50).map((c,i)=>`${i+1}. ${c.name}`).join("\n");
  const choice = prompt("Select Active Company (enter number):\n\n" + lines);
  const n = parseInt(String(choice||"").trim(),10);
  if(!n || n<1 || n>data.length) return { company_id:"", company_name:"" };

  company_id = String(data[n-1].id);
  company_name = String(data[n-1].name||"").trim();

  localStorage.setItem("zummee_active_company_id", company_id);
  localStorage.setItem("zummee_active_company_name", company_name);
  return { company_id, company_name };
}

async function addCommunity(){  const profile = await getProfile();

  // Resolve active company context (CompanyAdmin/Admin/Supervisor)
  const ctx = await __getActiveCompanyContext(profile);
  if(ctx.company_id) profile.company_id = ctx.company_id;
  if(ctx.company_name) profile.company = ctx.company_name;
  // Employees should not be able to add communities
  const role = String(profile.role||"").trim().toLowerCase();
  const isPriv = role.includes("companyadmin") || role.includes("admin") || role.includes("supervisor");
  if(!isPriv) return alert("Only CompanyAdmin/Admin/Supervisor can add communities.");

  const companyIdForInsert = String(profile.company_id||"").trim();
  if(!companyIdForInsert){
    return alert("No Active Company selected. Please select a company when prompted, then try again.");
  }

  const name = prompt("Community name:");
  if(!name) return;
  const clean = name.trim();
  if(!clean) return;

  // Avoid duplicates (cloud + cache)
  const existing = await listCommunities(profile);
  const exists = existing.some(c=>String(c.name||"").trim().toLowerCase() === clean.toLowerCase());
  if(exists) return alert("That community already exists.");

  let newId = "";

  // Cloud-first: write to PropertyCommunities (requires company_id FK)
  try{
    if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb){
      const companyId = companyIdForInsert;
      if(!companyId){
        alert("Your profile is missing company_id. Open Profile and re-save your Management Company, then try again.");
        return;
      }

      // Prefer upsert on (company_id,name) if that unique constraint exists, else fall back to insert.
      let q = await sb
        .from('PropertyCommunities')
        .upsert([{ company_id: companyId, company: String(profile.company).trim(), name: clean }], { onConflict: 'company_id,name' })
        .select('id,name')
        .maybeSingle();

      if(q && q.error){
        q = await sb
          .from('PropertyCommunities')
          .insert([{ company_id: companyId, company: String(profile.company).trim(), name: clean }])
          .select('id,name')
          .maybeSingle();
      }

      if(q && !q.error && q.data && q.data.id){
        newId = String(q.data.id);
      }else if(q && q.error){
        console.warn("PropertyCommunities insert/upsert failed:", q.error);
        alert("Could not create community in cloud: " + (q.error.message || q.error.details || JSON.stringify(q.error)));
        return; // do NOT create local-only ghost communities
      }else{
        alert("Could not create community in cloud (unknown response).");
        return;
      }
    }
  }catch(e){
    console.warn("PropertyCommunities write failed:", e);
    alert("Could not create community in cloud: " + (e.message || e));
    return; // do NOT create local-only ghost communities
  }

  // Update company cache immediately so the new community appears without a reload
  try{
    const company = String(profile.company || profile.company_name || "").trim();
    const k1 = "zummee_company_communities_v1__"+company;
    const k2 = "zummee_company_communities_v1__"+company.toLowerCase();
    const arr = JSON.parse(localStorage.getItem(k1)||localStorage.getItem(k2)||"[]")||[];
    if(newId && !arr.some(x=>String(x.id)===String(newId))){
      arr.push({id:String(newId), name: clean});
      arr.sort((a,b)=>String(a.name).localeCompare(String(b.name)));
      localStorage.setItem(k1, JSON.stringify(arr));
      localStorage.setItem(k2, JSON.stringify(arr));
    }
  }catch(_e){}

  // Update local user cache (legacy) so older pages still see it
  try{
    const list = readLocalCommunities(profile);
    const idToUse = newId || (String(Date.now()) + "_" + Math.random().toString(16).slice(2));
    list.push({ id: idToUse, name: clean });
    writeLocalCommunities(profile, list);
  }catch(_e){}

  document.dispatchEvent(new CustomEvent("communities:changed"));
  await refreshUI();
  const {select} = els();
  if(select){
    if(newId) select.value = String(newId);
    select.dispatchEvent(new Event("change"));
  }
}

async function renameCommunity(){
  const e = els();
  const profile = await getProfile();
  const id = String(e.select?.value||"").trim();
  if(!id) return alert("Select a community first.");

  const role = String(profile.role||"").trim().toLowerCase();
  const isPriv = role.includes("admin") || role.includes("supervisor");
  if(!isPriv) return alert("Only Admin/Supervisor can rename communities.");

  const cur = e.select.options[e.select.selectedIndex]?.textContent || "";
  const name = prompt("New community name:", cur);
  if(!name) return;
  const clean = name.trim();
  if(!clean) return;

  // Cloud-first rename
  try{
    if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb && profile.company){
      const q = await sb
        .from('PropertyCommunities')
        .update({ name: clean })
        .eq('id', id)
        .ilike('company', String(profile.company).trim())
        .select('id,name')
        .maybeSingle();
      if(q && q.error){
        console.warn("PropertyCommunities rename failed:", q.error);
      }
    }
  }catch(err){
    console.warn("PropertyCommunities rename exception:", err);
  }

  // Update local legacy list if present
  try{
    const list = readLocalCommunities(profile);
    const idx = list.findIndex(c=>String(c.id)===String(id));
    if(idx !== -1){
      list[idx].name = clean;
      writeLocalCommunities(profile, list);
    }
  }catch(_e){}

  document.dispatchEvent(new CustomEvent("communities:changed"));
  await refreshUI();
  if(e.select) e.select.value = id;
}

    async function removeCommunity(){
  const e = els();
  const profile = await getProfile();
  const id = String(e.select?.value||"").trim();
  if(!id) return alert("Select a community first.");

  const role = String(profile.role||"").trim().toLowerCase();
  const isPriv = role.includes("admin") || role.includes("supervisor");
  if(!isPriv) return alert("Only Admin/Supervisor can remove communities.");

  if(!confirm("Remove this community? This will remove it for the company and unassign it from employees.")) return;

  // Cloud-first delete
  try{
    if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb && profile.company){
      // Remove assignments referencing this community (best-effort)
      try{
        await window.sb
          .from('CommunityAssignments')
          .delete()
          .eq('community_id', id)
          .ilike('company', String(profile.company).trim());
      }catch(_e){}

      const q = await sb
        .from('PropertyCommunities')
        .delete()
        .eq('id', id)
        .ilike('company', String(profile.company).trim());
      if(q && q.error){
        console.warn("PropertyCommunities delete failed:", q.error);
      }
    }
  }catch(err){
    console.warn("PropertyCommunities delete exception:", err);
  }

  // Update local legacy list
  try{
    const list = readLocalCommunities(profile).filter(c=>String(c.id)!==String(id));
    writeLocalCommunities(profile, list);
  }catch(_e){}

  document.dispatchEvent(new CustomEvent("communities:changed"));
  await refreshUI();
}

    document.addEventListener("DOMContentLoaded", ()=>{
      const e = els();
      bindSelect(e.select);
      if(e.btnAdd) e.btnAdd = rebindButton(e.btnAdd, addCommunity);
      if(e.btnRename) e.btnRename = rebindButton(e.btnRename, renameCommunity);
      if(e.btnRemove) e.btnRemove = rebindButton(e.btnRemove, removeCommunity);
      refreshUI();
      try{ window.__zummeeCommunityMgmtV2Bound = true; }catch(_e){}
    });

    document.addEventListener("communities:changed", ()=>refreshUI());
  })();
</script>
