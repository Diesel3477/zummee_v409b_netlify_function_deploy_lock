  } else {
    applyLiveActivityTitle();
  }
  window.addEventListener('load', applyLiveActivityTitle);
})();
</script>


<script id="supervisor-missing-compliance-phase1">
(function(){
  function $(id){ return document.getElementById(id); }
  function isSupervisorRole(){
    try{
      var role = String(document.documentElement.getAttribute('data-staff-role') || window.__zummeeUserRole || '').toLowerCase();
      return role.indexOf('supervisor') !== -1;
    }catch(_e){ return false; }
  }
  function currentMonthKey(){
    var d = new Date();
    var m = String(d.getMonth() + 1).padStart(2, '0');
    return String(d.getFullYear()) + '-' + m;
  }
  function afterMidMonth(){
    try{ return (new Date()).getDate() >= 16; }catch(_e){ return false; }
  }
  function getCompanyNameSafe(){
    var keys = ['zummee_active_company_name', 'activeCompanyName'];
    for(var i=0;i<keys.length;i++){
      try{
        var v = String(localStorage.getItem(keys[i]) || '').trim();
        if(v) return v;
      }catch(_e){}
    }
    return '';
  }
  function getCommunityNameMap(companyName){
    var out = {};
    var keys = [];
    if(companyName) keys.push('zummee_company_communities_v1__' + companyName);
    keys.push('zummee_communities_v1');
    keys.forEach(function(key){
      try{
        var arr = JSON.parse(localStorage.getItem(key) || '[]') || [];
        (Array.isArray(arr) ? arr : []).forEach(function(c){
          if(!c) return;
          var id = String(c.id || c.communityId || c.value || '').trim();
          var name = String(c.name || c.communityName || c.label || '').trim();
          if(id && name && !out[id]) out[id] = name;
        });
      }catch(_e){}
    });
    return out;
  }
  async function getSb(){
    try{
      if(window.sb && typeof window.sb.from === 'function') return window.sb;
      if(window.ensureSupabase) return await window.ensureSupabase();
    }catch(_e){}
    return null;
  }
  async function getSupervisorId(sb){
    try{
      if(sb && sb.auth && typeof sb.auth.getUser === 'function'){
        var r = await sb.auth.getUser();
        return String(r && r.data && r.data.user && r.data.user.id || '').trim();
      }
    }catch(_e){}
    try{ return String((window.ZUMMEE_AUTH && window.ZUMMEE_AUTH.userId) || localStorage.getItem('zummee_user_id_v1') || '').trim(); }catch(_e2){}
    return '';
  }
  async function getCompanyId(sb){
    try{
      if(typeof window.getProfile === 'function'){
        var p = await window.getProfile();
        var id = String((p && (p.company_id || (p.company && p.company.id))) || '').trim();
        if(id) return id;
      }
    }catch(_e){}
    try{ return String(localStorage.getItem('zummee_active_company_id') || localStorage.getItem('activeCompanyId') || '').trim(); }catch(_e2){}
    return '';
  }
  async function getTeamAssignments(sb, supervisorId, companyId){
    var ids = [];
    try{
      var localMap = JSON.parse(localStorage.getItem('zummee_supervisor_team_map_v1') || '{}') || {};
      if(companyId && localMap[companyId]){
        Object.keys(localMap[companyId]).forEach(function(employeeId){
          var rec = localMap[companyId][employeeId] || {};
          if(String(rec.supervisor_user_id || '').trim() === supervisorId) ids.push(String(employeeId));
        });
      }
    }catch(_e){}
    try{
      if(sb && sb.from && supervisorId){
        var q = sb.from('supervisor_team_members').select('employee_user_id, company_id, supervisor_user_id').eq('supervisor_user_id', supervisorId);
        if(companyId) q = q.eq('company_id', companyId);
        var res = await q;
        if(!res.error && Array.isArray(res.data)){
          res.data.forEach(function(row){
            var id = String((row && row.employee_user_id) || '').trim();
            if(id) ids.push(id);
          });
        }
      }
    }catch(_e2){}
    var out = [], seen = {};
    ids.forEach(function(id){ if(id && !seen[id]){ seen[id]=1; out.push(id); } });
    return out;
  }
  async function getEmployeeDirectory(sb, ids){
    var out = {};
    if(!ids || !ids.length) return out;
    try{
      var res = await sb.from('userdirectory').select('auth_user_id,profile_name,profile_email').in('auth_user_id', ids);
      if(!res.error && Array.isArray(res.data)){
        res.data.forEach(function(row){
          var id = String((row && row.auth_user_id) || '').trim();
          if(!id) return;
          out[id] = {
            name: String((row && row.profile_name) || (row && row.profile_email) || 'Employee').trim(),
            email: String((row && row.profile_email) || '').trim().toLowerCase()
          };
        });
      }
    }catch(_e){}
    ids.forEach(function(id){
      if(!out[id]) out[id] = { name: 'Employee', email: '' };
    });
    return out;
  }
  function getCommunityAssignments(companyName){
    try{
      var raw = localStorage.getItem('zummee_company_assignments_v2__' + companyName) || '{}';
      var map = JSON.parse(raw) || {};
      return map && typeof map === 'object' ? map : {};
    }catch(_e){ return {}; }
  }
  function renderCard(items){
    var card = $('supervisorMissingComplianceCard');
    var sub = $('supervisorMissingComplianceSub');
    var count = $('supervisorMissingComplianceCount');
    var list = $('supervisorMissingComplianceList');
    if(!card || !sub || !count || !list) return;

    if(!isSupervisorRole() || !afterMidMonth()){
      card.hidden = true;
      return;
    }

    card.hidden = false;
    count.textContent = String(items.length || 0);

    if(!items.length){
      sub.textContent = 'All assigned communities have reported a compliance drive this month.';
      list.innerHTML = '<div class="supervisor-missing-compliance__empty">No missing compliance drives for your team.</div>';
      return;
    }

    sub.textContent = 'Assigned communities still missing a compliance drive for ' + new Date().toLocaleDateString([], { month:'long' }) + '.';
    list.innerHTML = items.map(function(item){
      return ''
        + '<div class="supervisor-missing-compliance__row">'
        +   '<div class="supervisor-missing-compliance__row-left">'
        +     '<div class="supervisor-missing-compliance__row-community">' + String(item.community_name || 'Community').replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch]; }) + '</div>'
        +     '<div class="supervisor-missing-compliance__row-employee">' + String(item.employee_name || 'Employee').replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch]; }) + '</div>'
        +   '</div>'
        +   '<div class="supervisor-missing-compliance__row-status">Missing this month</div>'
        + '</div>';
    }).join('');
  }

  async function loadSupervisorMissingCompliance(){
    var card = $('supervisorMissingComplianceCard');
    var list = $('supervisorMissingComplianceList');
    var sub = $('supervisorMissingComplianceSub');
    if(!card || !list || !sub) return;

    if(!isSupervisorRole() || !afterMidMonth()){
      card.hidden = true;
      return;
    }

    card.hidden = false;
    list.innerHTML = '<div class="supervisor-missing-compliance__empty">Checking assigned communities…</div>';

    var sb = await getSb();
    if(!sb){
      sub.textContent = 'Compliance visibility is unavailable right now.';
      list.innerHTML = '<div class="supervisor-missing-compliance__empty">Unable to load compliance data.</div>';
      return;
    }

    var supervisorId = await getSupervisorId(sb);
    var companyId = await getCompanyId(sb);
    var companyName = getCompanyNameSafe();
    if(!supervisorId){
      sub.textContent = 'Supervisor identity is unavailable right now.';
      list.innerHTML = '<div class="supervisor-missing-compliance__empty">Unable to resolve assigned team.</div>';
      return;
    }

    var teamIds = await getTeamAssignments(sb, supervisorId, companyId);
    if(!teamIds.length){
      renderCard([]);
      sub.textContent = 'No team assignments found yet.';
      list.innerHTML = '<div class="supervisor-missing-compliance__empty">Assign employees to your team to track missing compliance drives.</div>';
      return;
    }

    var employeeDirectory = await getEmployeeDirectory(sb, teamIds);
    var assignmentMap = getCommunityAssignments(companyName);
    var communityNameMap = getCommunityNameMap(companyName);
    var assignedPairs = [];

    Object.keys(assignmentMap || {}).forEach(function(communityId){
      var employeeId = String((assignmentMap && assignmentMap[communityId]) || '').trim();
      if(!employeeId) return;
      if(teamIds.indexOf(employeeId) === -1) return;
      assignedPairs.push({
        employee_user_id: employeeId,
        employee_name: String((employeeDirectory[employeeId] && employeeDirectory[employeeId].name) || 'Employee').trim(),
        community_id: String(communityId || '').trim(),
        community_name: String((communityNameMap && communityNameMap[String(communityId || '').trim()]) || communityId || 'Community').trim()
      });
    });

    if(!assignedPairs.length){
      renderCard([]);
      sub.textContent = 'No assigned communities found for your team.';
      list.innerHTML = '<div class="supervisor-missing-compliance__empty">Community assignments are needed before missing compliance can be tracked.</div>';
      return;
    }

    var monthKey = currentMonthKey();
    var completions = [];
    try{
      var res = await sb.from('mileage_compliance_completions').select('employee_user_id,community_id,month_key').eq('month_key', monthKey).in('employee_user_id', teamIds);
      if(!res.error && Array.isArray(res.data)) completions = res.data;
    }catch(_e){}

    var completedSet = {};
    (completions || []).forEach(function(row){
      var key = String((row && row.employee_user_id) || '').trim() + '|' + String((row && row.community_id) || '').trim() + '|' + String((row && row.month_key) || '').trim();
      completedSet[key] = true;
    });

    var missing = assignedPairs.filter(function(item){
      var key = String(item.employee_user_id) + '|' + String(item.community_id) + '|' + monthKey;
      return !completedSet[key];
    });

    missing.sort(function(a,b){
      return String(a.community_name || '').localeCompare(String(b.community_name || '')) || String(a.employee_name || '').localeCompare(String(b.employee_name || ''));
    });

    renderCard(missing);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', loadSupervisorMissingCompliance, { once:true });
  } else {
    loadSupervisorMissingCompliance();
  }
  window.addEventListener('load', loadSupervisorMissingCompliance);
  document.addEventListener('community:changed', loadSupervisorMissingCompliance);
  window.addEventListener('focus', loadSupervisorMissingCompliance);
})();
</script>


<script id="hub-role-card-registry-v247">
(function(){
  var EMPLOYEE_ALLOWED = [
    'dailyOpsCard',
    'mileageCard',
    'inspectionsCard',
    'communityInspectionsCard',
    'communityInspectionsHubCard',
    'boardMemberHubCard',
    'boardMeetingsCard',
    'companyDirectoryCard',
    'residentDirectoryCard',
    'managerTrainingCard',
    'managerInfoTrainingCard',
    'trainingCard',
    'preferredVendorsCard',
    'poolOpsCard',
    'residentWorkOrdersCard',
    'residentPortalPreviewCard',
    'annualPresentationHubCard',
    'annualMeetingRecordsCard',
    'onlineVotingCard',
    'maintenanceControlCard',
    'maintenanceControlCenterCard',
    'liveMaintenanceUpdatesCard',
    'weatherCard',
    'emergencyTextingCard',
    'remindersCard'
  ];

  var SUPERVISOR_ONLY = [
    'employeePerformanceCard',
    'annualMeetingApprovalsCard',
    'dailyTasksCard',
    'communityAssignmentsCard',
    'employeeAccountActivationsCard',
    'companyBrandingTextingCard',
    'supervisorHubMainCard',
    'supervisorAccessCard'
  ];

  function roleValue(){
    try{
      return String(
        document.documentElement.getAttribute('data-staff-role') ||
        document.body.getAttribute('data-staff-role') ||
        window.__zummeeUserRole ||
        ''
      ).trim().toLowerCase();
    }catch(_e){ return ''; }
  }

  function isSupervisorLike(){
    var role = roleValue();
    return role === 'supervisor' || role === 'admin' || role === 'companyadmin';
  }

  function markCardAllowed(card, allowed){
    if(!card) return;
    card.dataset.roleAllowed = allowed ? '1' : '0';
    if(allowed){
      card.classList.remove('role-card-hidden');
      card.style.display = '';
      card.style.visibility = '';
      card.style.pointerEvents = '';
      card.setAttribute('aria-hidden', 'false');
    }else{
      card.classList.add('role-card-hidden');
      card.style.display = 'none';
      card.style.visibility = 'hidden';
      card.style.pointerEvents = 'none';
      card.setAttribute('aria-hidden', 'true');
    }
  }

  function applyRoleRegistry(){
    var sup = isSupervisorLike();

    SUPERVISOR_ONLY.forEach(function(id){
      markCardAllowed(document.getElementById(id), sup);
    });

    if(!sup){
      EMPLOYEE_ALLOWED.forEach(function(id){
        markCardAllowed(document.getElementById(id), true);
      });
    }

    window.__zummeeAllowedHubCardIds = sup
      ? null
      : EMPLOYEE_ALLOWED.slice();
  }

  function schedule(){
    applyRoleRegistry();
    setTimeout(applyRoleRegistry, 150);
    setTimeout(applyRoleRegistry, 800);
    setTimeout(applyRoleRegistry, 1600);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', schedule, { once:true });
  }else{
    schedule();
  }
  window.addEventListener('load', schedule);
  document.addEventListener('community:changed', function(){ setTimeout(applyRoleRegistry, 120); });
  window.addEventListener('focus', function(){ setTimeout(applyRoleRegistry, 120); });
})();
</script>


