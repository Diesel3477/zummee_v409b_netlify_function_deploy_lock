<script id="activity-feed-collapse-v256">
(function(){
  var STORAGE_KEY = 'zummee_activity_feed_collapsed_v1';

  function applyState(collapsed){
    var card = document.getElementById('activityFeedCard');
    var header = document.getElementById('activityFeedHeader');
    if(!card || !header) return;
    card.classList.toggle('is-collapsed', !!collapsed);
    header.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    try{ localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0'); }catch(_e){}
  }

  function toggleState(){
    var card = document.getElementById('activityFeedCard');
    if(!card) return;
    applyState(!card.classList.contains('is-collapsed'));
  }

  function init(){
    var header = document.getElementById('activityFeedHeader');
    if(!header || header.dataset.boundCollapse === '1') return;
    header.dataset.boundCollapse = '1';

    var collapsed = true;
    try{
      var saved = localStorage.getItem(STORAGE_KEY);
      collapsed = (saved === null) ? true : (saved === '1');
    }catch(_e){}
    applyState(collapsed);

    header.addEventListener('click', function(e){
      var interactive = e.target && e.target.closest ? e.target.closest('a,button,input,select,textarea') : null;
      if(interactive) return;
      toggleState();
    });
    header.addEventListener('keydown', function(e){
      if(e.key === 'Enter' || e.key === ' '){
        e.preventDefault();
        toggleState();
      }
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', init, { once:true });
  } else {
    init();
  }
  window.addEventListener('load', init);
})();
</script>


<script id="v297-daily-ops-complete-sync">
(function(){
  function syncDailyOpsCardState(){
    try{
      var card = document.getElementById('dailyOpsCard');
      if(!card) return;

      // Preserve alert priority
      if(card.classList.contains('ops-alert')) {
        card.classList.remove('ops-complete');
        return;
      }

      // Try to infer completion from existing summary text/badges
      var txt = (card.textContent || '').toLowerCase();

      // If card says all complete/completed or shows no open/overdue, mark complete
      var completeHints = (
        txt.includes('all complete') ||
        txt.includes('all completed') ||
        txt.includes('0 overdue') ||
        txt.includes('overdue 0')
      );
      var notOpen = (
        txt.includes('open 0') ||
        txt.includes('0 open')
      );

      if(completeHints || notOpen){
        card.classList.add('ops-complete');
      } else {
        card.classList.remove('ops-complete');
      }
    }catch(e){}
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', syncDailyOpsCardState, { once:true });
  } else {
    syncDailyOpsCardState();
  }
  window.addEventListener('load', syncDailyOpsCardState);
  setTimeout(syncDailyOpsCardState, 400);
  setTimeout(syncDailyOpsCardState, 1200);
})();
</script>


