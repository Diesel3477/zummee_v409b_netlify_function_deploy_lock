    flex: 1 1 100%;
    max-width: 100%;
  }
}

</style>


<style id="glass-card-animation-fix">
/* Final unified Apple-glass manager cards */
:root{
  --hubGlassBgA: rgba(255,255,255,0.30);
  --hubGlassBgB: rgba(255,255,255,0.14);
  --hubGlassBorder: rgba(255,255,255,0.42);
  --hubGlassText: #0f2139;
  --hubGlassSub: #44586f;
  --hubGlassShadow: 0 14px 34px rgba(15,47,74,0.16), inset 0 1px 0 rgba(255,255,255,0.35);
}
#dailyOpsCard,
#mileageCard,
#inspectionsCard,
#remindersCard,
#emergencyTextingCard,
#boardMemberHubCard,
#companyDirectoryCard,
#managerTrainingCard,
#boardMeetingsCard,
#preferredVendorsCard,
#residentWorkOrdersCard,
#residentDirectoryCard,
#maintenanceControlCenterCard,
#liveMaintenanceUpdatesCard,
#poolOpsCard{
  position: relative !important;
  overflow: hidden !important;
  isolation: isolate !important;
  background:
    linear-gradient(160deg, var(--hubGlassBgA), var(--hubGlassBgB)) !important;
  border: 1px solid var(--hubGlassBorder) !important;
  box-shadow: var(--hubGlassShadow) !important;
  backdrop-filter: blur(14px) saturate(1.08) !important;
  -webkit-backdrop-filter: blur(14px) saturate(1.08) !important;
  transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease, background .28s ease !important;
}
#dailyOpsCard::before,#dailyOpsCard::after,
#boardMemberHubCard::before,#boardMemberHubCard::after,
#companyDirectoryCard::before,#companyDirectoryCard::after,
#boardMeetingsCard::before,#boardMeetingsCard::after,
#preferredVendorsCard::before,#preferredVendorsCard::after,
#managerTrainingCard::before,#managerTrainingCard::after,
#poolOpsCard::before,#poolOpsCard::after,
#dailyOpsCard::marker,
#boardMemberHubCard::marker,
#companyDirectoryCard::marker,
#boardMeetingsCard::marker,
#preferredVendorsCard::marker,
#managerTrainingCard::marker,
#poolOpsCard::marker{display:none !important;}
#dailyOpsCard > *,
#mileageCard > *,
#inspectionsCard > *,
#remindersCard > *,
#emergencyTextingCard > *,
#boardMemberHubCard > *,
#companyDirectoryCard > *,
#managerTrainingCard > *,
#boardMeetingsCard > *,
#preferredVendorsCard > *,
#residentWorkOrdersCard > *,
#residentDirectoryCard > *,
#maintenanceControlCenterCard > *,
#liveMaintenanceUpdatesCard > *,
#poolOpsCard > *{
  position: relative;
  z-index: 4;
}
#dailyOpsCard .title,
#mileageCard .title,
#inspectionsCard .title,
#remindersCard .title,
#emergencyTextingCard .title,
#boardMemberHubCard .title,
#companyDirectoryCard .title,
#managerTrainingCard .title,
#boardMeetingsCard .title,
#preferredVendorsCard .title,
#residentWorkOrdersCard .title,
#residentDirectoryCard .title,
#maintenanceControlCenterCard .title,
#liveMaintenanceUpdatesCard .title,
#poolOpsCard .title{
  color: var(--hubGlassText) !important;
  text-shadow: 0 1px 0 rgba(255,255,255,0.35) !important;
}
#remindersCard .subtle,
#residentWorkOrdersCard .sub,
#liveMaintenanceUpdatesCard .sub,
#residentDirectoryCard .sub,
#maintenanceControlCenterCard .sub,
#emergencyTextingCard .scheduled-preview,
#emergencyTextingCard .scheduled-indicator,
#emergencyTextingCard .card-sub,
#residentWorkOrdersCard .card-sub,
#liveMaintenanceUpdatesCard .card-sub,
#residentDirectoryCard .card-sub,
#maintenanceControlCenterCard .card-sub{
  color: var(--hubGlassSub) !important;
}
#dailyOpsCard:hover,
#mileageCard:hover,
#inspectionsCard:hover,
#remindersCard:hover,
#emergencyTextingCard:hover,
#boardMemberHubCard:hover,
#companyDirectoryCard:hover,
#managerTrainingCard:hover,
#boardMeetingsCard:hover,
#preferredVendorsCard:hover,
#residentWorkOrdersCard:hover,
#residentDirectoryCard:hover,
#maintenanceControlCenterCard:hover,
#liveMaintenanceUpdatesCard:hover,
#poolOpsCard:hover{
  transform: translateY(-4px) scale(1.012) !important;
  border-color: rgba(255,255,255,0.58) !important;
  box-shadow: 0 18px 42px rgba(15,47,74,0.20), inset 0 1px 0 rgba(255,255,255,0.48) !important;
}
#dailyOpsCard::after,
#mileageCard::after,
#inspectionsCard::after,
#remindersCard::after,
#emergencyTextingCard::after,
#boardMemberHubCard::after,
#companyDirectoryCard::after,
#managerTrainingCard::after,
#boardMeetingsCard::after,
#preferredVendorsCard::after,
#residentWorkOrdersCard::after,
#residentDirectoryCard::after,
#maintenanceControlCenterCard::after,
#liveMaintenanceUpdatesCard::after,
#poolOpsCard::after{
  content:"" !important;
  position:absolute;
  top:-20%;
  left:-40%;
  width:60%;
  height:160%;
  background:linear-gradient(115deg, transparent 0%, rgba(255,255,255,0) 35%, rgba(255,255,255,.35) 50%, rgba(255,255,255,0) 65%, transparent 100%) !important;
  transform:translateX(-180%) skewX(-18deg);
  pointer-events:none;
  z-index:3;
  display:block !important;
  opacity:1;
}
#dailyOpsCard:hover::after,
#mileageCard:hover::after,
#inspectionsCard:hover::after,
#remindersCard:hover::after,
#emergencyTextingCard:hover::after,
#boardMemberHubCard:hover::after,
#companyDirectoryCard:hover::after,
#managerTrainingCard:hover::after,
#boardMeetingsCard:hover::after,
#preferredVendorsCard:hover::after,
#residentWorkOrdersCard:hover::after,
#residentDirectoryCard:hover::after,
#maintenanceControlCenterCard:hover::after,
#liveMaintenanceUpdatesCard:hover::after,
#poolOpsCard:hover::after{
  animation: glassSweep .9s ease forwards;
}
@keyframes glassSweep{
  0%{ transform:translateX(-180%) skewX(-18deg); }
  100%{ transform:translateX(300%) skewX(-18deg); }
}
/* subtle dashboard-wide glass response */
body{
  background:
    radial-gradient(1200px 700px at 10% 0%, rgba(112,180,255,.16), transparent 60%),
    radial-gradient(1000px 600px at 90% 8%, rgba(255,215,150,.14), transparent 58%),
    radial-gradient(900px 520px at 50% 100%, rgba(150,210,255,.12), transparent 60%),
    linear-gradient(180deg, #eaf3ff 0%, #f5f8fd 46%, #eef4fb 100%) !important;
  background-size: 140% 140%, 140% 140%, 140% 140%, 100% 100% !important;
  animation: hubBgShift 24s ease-in-out infinite alternate;
}
@keyframes hubBgShift{
  0%{ background-position: 0% 0%, 100% 0%, 50% 100%, 0 0; }
  100%{ background-position: 8% 4%, 92% 2%, 46% 96%, 0 0; }
}
.wrap{
  perspective: 1400px;
}
.hub-glass-tilt{
  transform-style: preserve-3d;
}
/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}

/* More Tools flex layout fix */
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}

.more-tools-container .card{
  flex: 1 1 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 900px){
  .more-tools-container .card{
    flex: 1 1 calc(50% - 16px);
    max-width: calc(50% - 16px);
  }
}

@media (max-width: 600px){
  .more-tools-container .card{
    flex: 1 1 100%;
    max-width: 100%;
  }
}

</style>
<script id="glass-card-polish-script">
(function(){
  function bindGlassTilt(){
    var ids = [
      "dailyOpsCard","mileageCard","inspectionsCard","remindersCard","emergencyTextingCard",
      "boardMemberHubCard","companyDirectoryCard","managerTrainingCard","boardMeetingsCard",
      "preferredVendorsCard","residentWorkOrdersCard","residentDirectoryCard",
      "maintenanceControlCenterCard","liveMaintenanceUpdatesCard","poolOpsCard"
    ];
    ids.forEach(function(id){
      var el = document.getElementById(id);
      if(!el || el.dataset.glassTiltBound === "1") return;
      el.dataset.glassTiltBound = "1";
      el.classList.add("hub-glass-tilt");
      el.addEventListener("mousemove", function(ev){
        var r = el.getBoundingClientRect();
        var x = ((ev.clientX - r.left) / r.width) - 0.5;
        var y = ((ev.clientY - r.top) / r.height) - 0.5;
        el.style.transform = "translateY(-4px) scale(1.012) rotateX(" + (-y * 2.2) + "deg) rotateY(" + (x * 2.2) + "deg)";
      });
      el.addEventListener("mouseleave", function(){
        el.style.transform = "";
      });
    });
  }
  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", bindGlassTilt);
  }else{
    bindGlassTilt();
  }
})();
</script>


<style id="supervisor-priority-strips-style">
.supervisor-priority-strips{
  max-width:1200px;
  margin:12px auto 18px auto;
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:14px;
}
.supervisor-priority-strip{
  cursor:pointer;
  position:relative;
  width:100%;
  border:none;
  text-align:left;
  cursor:pointer;
  padding:18px 22px 18px 20px;
  border-radius:22px;
  color:#14345f;
  background:linear-gradient(180deg,#efd993 0%,#ddb246 100%);
  box-shadow:0 14px 28px rgba(116,82,10,.18), inset 0 1px 0 rgba(255,255,255,.58);
  border:1px solid rgba(255,255,255,.55);
  overflow:hidden;
  transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;
}
.supervisor-priority-strip::before{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(120deg,rgba(255,255,255,.06) 18%, rgba(255,255,255,.42) 48%, rgba(255,255,255,.08) 78%);
  transform:translateX(-135%);
  transition:transform .65s ease;
  pointer-events:none;
}
.supervisor-priority-strip:hover,
.supervisor-priority-strip:focus-visible{
  transform:translateY(-2px);
  box-shadow:0 18px 30px rgba(116,82,10,.22), inset 0 1px 0 rgba(255,255,255,.62);
  filter:brightness(1.01);
  outline:none;
}
.supervisor-priority-strip:hover::before,
.supervisor-priority-strip:focus-visible::before,
.supervisor-priority-strip.is-shimmering::before{
  transform:translateX(135%);
}
.supervisor-priority-strip__eyebrow{
  display:block;
  font-size:11px;
  font-weight:800;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:rgba(20,52,95,.72);
  margin-bottom:8px;
}
.supervisor-priority-strip__title{
  display:block;
  font-size:28px;
  line-height:.98;
  font-weight:900;
  letter-spacing:-.03em;
  max-width:80%;
}
.supervisor-priority-strip__sub{
  display:block;
  margin-top:8px;
  max-width:82%;
  font-size:13px;
  line-height:1.3;
  color:rgba(20,52,95,.88);
  font-weight:600;
}
.supervisor-priority-strip__count{
  position:absolute;
  top:16px;
  right:16px;
  min-width:44px;
  height:44px;
  padding:0 10px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  background:rgba(255,255,255,.86);
  color:#14345f;
  font-size:18px;
  font-weight:900;
  box-shadow:0 8px 18px rgba(20,52,95,.12);
}
.supervisor-inline-approvals{
  grid-column:1 / -1;
  margin-top:-2px;
  padding:16px;
  border-radius:22px;
  background:rgba(255,255,255,.20);
  border:1px solid rgba(255,255,255,.48);
  box-shadow:0 12px 26px rgba(20,52,95,.10);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
}
.supervisor-inline-approvals.is-hidden{ display:none; }
.supervisor-inline-approvals__header{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
  margin-bottom:12px;
}
.supervisor-inline-approvals__title{
  font-size:22px;
  line-height:1;
  font-weight:900;
  color:#14345f;
  letter-spacing:-.02em;
}
.supervisor-inline-approvals__sub{
  margin-top:6px;
  font-size:13px;
  line-height:1.35;
  font-weight:600;
  color:rgba(20,52,95,.82);
}
.supervisor-inline-approvals__link{
  align-self:center;
  white-space:nowrap;
  color:#14345f;
  font-weight:800;
  text-decoration:none;
}
.supervisor-inline-approvals__link:hover{ text-decoration:underline; }
.supervisor-inline-approvals__list{ display:grid; gap:10px; }

.supervisor-inline-approval{
  position:relative;
  overflow:hidden;
  transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease, opacity .18s ease;
}
.supervisor-inline-approval:hover{
  transform:translateY(-1px);
  box-shadow:0 12px 24px rgba(15,47,74,.10);
}
.supervisor-inline-approval.is-processing{
  opacity:.72;
  pointer-events:none;
}
.supervisor-inline-approval.is-approved{
  background:linear-gradient(180deg, rgba(76,175,80,.16), rgba(255,255,255,.94));
  border-color:rgba(76,175,80,.30);
}
.supervisor-inline-approval.is-rejected{
  background:linear-gradient(180deg, rgba(201,71,71,.16), rgba(255,255,255,.94));
  border-color:rgba(201,71,71,.28);
}
.supervisor-inline-approval__statusbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-top:12px;
  flex-wrap:wrap;
}
.supervisor-inline-approval__statuscopy{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
.supervisor-inline-approval__badge{
  display:inline-flex;
  align-items:center;
  min-height:34px;
  padding:0 12px;
  border-radius:999px;
  background:rgba(15,47,74,.08);
  color:#17395a;
  font-size:12px;
  font-weight:900;
  letter-spacing:.04em;
  text-transform:uppercase;
}
.supervisor-inline-approval__note{
  font-size:13px;
  line-height:1.35;
  color:#5b728a;
  font-weight:700;
}
.supervisor-inline-approval.is-approved .supervisor-inline-approval__badge{
  background:rgba(76,175,80,.18);
  color:#226a2e;
}
.supervisor-inline-approval.is-rejected .supervisor-inline-approval__badge{
  background:rgba(201,71,71,.18);
  color:#8e2030;
}
.supervisor-inline-approval.is-approved .supervisor-inline-approval__note{
  color:#226a2e;
}
.supervisor-inline-approval.is-rejected .supervisor-inline-approval__note{
  color:#8e2030;
}
.supervisor-inline-approval__btn{
  transition:transform .16s ease, box-shadow .16s ease, opacity .16s ease;
}
.supervisor-inline-approval__btn:active{ transform:scale(.98); }
.supervisor-inline-approval.is-approved .supervisor-inline-approval__btn,
.supervisor-inline-approval.is-rejected .supervisor-inline-approval__btn{
  pointer-events:none;
}
.supervisor-inline-approval{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
  padding:14px 16px;
  border-radius:18px;
  background:rgba(255,255,255,.30);
  border:1px solid rgba(255,255,255,.54);
}
.supervisor-inline-approval__title{
  font-size:18px;
  line-height:1.05;
  font-weight:900;
  color:#14345f;
}
.supervisor-inline-approval__meta,
.supervisor-inline-approval__detail{
  margin-top:5px;
  font-size:13px;
  line-height:1.35;
  color:rgba(20,52,95,.84);
  font-weight:600;
}
.supervisor-inline-approval__actions{
  display:flex;
  flex-wrap:wrap;
  justify-content:flex-end;
  gap:8px;
}
.supervisor-inline-approval__btn{
  border:none;
  border-radius:999px;
  padding:10px 14px;
  cursor:pointer;
  font-size:13px;
  font-weight:800;
  color:#14345f;
  background:rgba(255,255,255,.92);
  box-shadow:0 8px 18px rgba(20,52,95,.10);
}
.supervisor-inline-approval__btn:hover,
.supervisor-inline-approval__btn:focus-visible{ transform:translateY(-1px); outline:none; }
.supervisor-inline-approval__btn.primary{ background:#14345f; color:#fff; }
.supervisor-inline-approval__btn.danger{ background:#9f1239; color:#fff; }

.supervisor-priority-strip--approvals.is-urgent{
  background:linear-gradient(135deg,#c94747 0%, #a83232 100%);
  color:#fff;
  box-shadow:0 18px 34px rgba(159,18,57,.26), inset 0 1px 0 rgba(255,255,255,.22);
  animation:supervisorPriorityPulse 2.2s ease-in-out infinite;
}
.supervisor-priority-strip--approvals.is-urgent .supervisor-priority-strip__eyebrow,
.supervisor-priority-strip--approvals.is-urgent .supervisor-priority-strip__sub,
.supervisor-priority-strip--approvals.is-urgent .supervisor-priority-strip__title{
  color:#fff;
}
.supervisor-priority-strip--approvals.is-urgent .supervisor-priority-strip__count{
  background:rgba(255,255,255,.92);
  color:#8e2030;
}
.supervisor-priority-strip--approvals.is-urgent .supervisor-priority-strip__arrow{
  display:inline-block;
  font-size:14px;
  line-height:1;
}
@keyframes supervisorPriorityPulse{
  0%,100%{ box-shadow:0 18px 34px rgba(159,18,57,.18), inset 0 1px 0 rgba(255,255,255,.18); }
  50%{ box-shadow:0 18px 38px rgba(159,18,57,.34), inset 0 1px 0 rgba(255,255,255,.24); }
}
.supervisor-inline-approvals__empty{
  padding:16px;
  text-align:center;
  border-radius:18px;
  background:rgba(255,255,255,.24);
  color:rgba(20,52,95,.82);
  font-weight:700;
}
@media (max-width: 900px){
  .supervisor-inline-approvals{ margin:0 12px 0 12px; padding:14px; border-radius:20px; }
  .supervisor-priority-strip__title,
  .supervisor-priority-strip__sub{ max-width:100%; }
  .supervisor-inline-approvals__header,
  .supervisor-inline-approval{ display:block; }
  .supervisor-inline-approvals__link{ display:inline-block; margin-top:8px; }
  .supervisor-inline-approval__actions{ margin-top:12px; justify-content:flex-start; }
}
@media (max-width: 900px){
  .supervisor-priority-strips{ grid-template-columns:1fr; gap:12px; margin:10px 12px 16px 12px; }
  .supervisor-priority-strip{ padding:16px 18px 16px 18px; border-radius:20px; }
  .supervisor-priority-strip__title{ font-size:24px; max-width:78%; }
  .supervisor-priority-strip__sub{ max-width:78%; }
}
</style>

<style id="smart-alert-strip-and-badges">
.smart-alert-strip{
  max-width:1200px;
  margin:12px auto 22px auto;
  padding:14px 18px;
  border-radius:16px;
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  background:rgba(255,255,255,.35);
  border:1px solid rgba(255,255,255,.45);
  box-shadow:0 8px 20px rgba(0,0,0,.08);
  font-weight:600;
  color:#1a1a1a;
  animation:alertFade .4s ease;
}
.smart-alert{ display:flex; align-items:center; justify-content:space-between; gap:12px; margin:8px 0; line-height:1.35; }
.smart-alert-main{ min-width:0; }
.smart-alert-action,
.smart-alert a{ color:#0a66ff; text-decoration:none; font-weight:700; }
.smart-alert-action:hover,
.smart-alert a:hover{ text-decoration:underline; }
@media (max-width: 768px){
  .smart-alert-strip{
    padding:12px 14px;
    margin:10px 12px 18px 12px;
    border-radius:18px;
  }
  .smart-alert{
    display:block;
    margin:0;
    padding:8px 0;
    line-height:1.22;
  }
  .smart-alert + .smart-alert{
    border-top:1px solid rgba(255,255,255,.35);
    margin-top:8px;
    padding-top:12px;
  }
  .smart-alert-main{
    display:block;
    font-size:15px;
    font-weight:700;
    letter-spacing:-0.01em;
  }
  .smart-alert-action,
  .smart-alert a{
    display:inline-block;
    margin-top:6px;
    font-size:15px;
    line-height:1.2;
  }
}
@keyframes alertFade{ from{opacity:0; transform:translateY(-6px);} to{opacity:1; transform:translateY(0);} }

.card-status-badge{
  position:absolute;
  top:14px;
  right:14px;
  z-index:5;
  font-size:12px;
  font-weight:800;
  line-height:1;
  padding:7px 10px;
  border-radius:999px;
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
  box-shadow:0 4px 12px rgba(0,0,0,.12);
}
.card-status-badge.green{ background:rgba(34,197,94,.88); color:#fff; }
.card-status-badge.yellow{ background:rgba(250,204,21,.90); color:#222; }
.card-status-badge.red{ background:rgba(239,68,68,.90); color:#fff; }
.card-status-badge.blue{ background:rgba(59,130,246,.88); color:#fff; }
/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}

/* More Tools flex layout fix */
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}

.more-tools-container .card{
  flex: 1 1 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 900px){
  .more-tools-container .card{
    flex: 1 1 calc(50% - 16px);
    max-width: calc(50% - 16px);
  }
}

@media (max-width: 600px){
  .more-tools-container .card{
    flex: 1 1 100%;
    max-width: 100%;
  }
}


/* force-clear weather scene overrides */
#managerWeatherScene::before,
#managerWeatherScene::after,
.weather-hub-shell > div:nth-child(2)::before,
.weather-hub-shell > div:nth-child(2)::after,
.weather-panel::after {
  content: none !important;
  display: none !important;
  background: none !important;
}
.weather-hub-shell > div:nth-child(2){
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}
.weather-hub-shell > div:nth-child(2) *{
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}
.weather-panel{
  background: rgba(255,255,255,0.015) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.10) !important;
}
.weather-side{
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}
.weather-scene .cloud{
  filter: blur(1px) !important;
  background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.96) 0%, rgba(255,255,255,0.84) 32%, rgba(255,255,255,0.46) 64%, rgba(255,255,255,0.12) 100%) !important;
  box-shadow: 0 6px 14px rgba(0,0,0,0.06), inset 0 -6px 10px rgba(0,0,0,0.06) !important;
}
.weather-scene__clouds--back .cloud{
  opacity:.10 !important;
  filter:blur(2.8px) !important;
}
.weather-scene__clouds--mid .cloud{
  opacity:.20 !important;
  filter:blur(1.5px) !important;
}
.weather-scene__clouds--front .cloud{
  opacity:.30 !important;
  filter:blur(.6px) !important;
}

.cloud::before,.cloud::after{content:"";position:absolute;border-radius:50%;background:inherit;}
.cloud::before{width:70%;height:70%;top:-18%;left:8%;}
.cloud::after{width:60%;height:60%;top:-8%;right:6%;}



</style>

<script id="smart-alert-strip-script">
(function(){
  function $(id){ return document.getElementById(id); }
  function escapeHtml(v){
    return String(v == null ? '' : v).replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch] || ch; });
  }
  function upsertBadge(cardId, text, tone){
    var card = $(cardId);
    if(!card) return;
    var badge = card.querySelector('.card-status-badge');
    if(!text){ if(badge) badge.remove(); return; }
    if(!badge){ badge = document.createElement('div'); badge.className = 'card-status-badge'; card.appendChild(badge); }
    badge.className = 'card-status-badge ' + (tone || 'blue');
    badge.textContent = text;
  }
  function firstNumber(text){ var m = String(text || '').match(/(\d+)/); return m ? parseInt(m[1], 10) : 0; }
  function loadOperationalSignals(){
    var strip = $('smartAlertStrip');
    var content = $('smartAlertContent');
    if(!strip || !content) return;
    var alerts = [];
    function safeGetLS(k){ try{ return String(localStorage.getItem(k)||'').trim(); }catch(_e){ return ''; } }
    function getActiveCommunityScope(){
      var sel = null;
      var id = '';
      var name = '';
      try{
        sel = document.getElementById('zummeeCommunitySelect');
        if(sel && sel.value) id = String(sel.value).trim();
        if(sel && sel.selectedOptions && sel.selectedOptions[0]) name = String(sel.selectedOptions[0].textContent || '').trim();
      }catch(_e0){}
      if(!id) id = safeGetLS('zummee_selected_community_id') || safeGetLS('activeCommunityId') || safeGetLS('zummee_community_id') || safeGetLS('zummeeActiveCommunityId');
      if(!name) name = safeGetLS('zummee_selected_community_name') || safeGetLS('selectedCommunityName') || safeGetLS('zummee_selected_community');
      return { id: String(id || '').trim(), name: String(name || '').trim().toLowerCase() };
    }
    function readReminderStore(){
      try { return JSON.parse(localStorage.getItem('zummee_reminders_v1') || '[]'); } catch(_e){ return []; }
    }
    function classifyReminder(reminder, now){
      var status = String((reminder && reminder.status) || 'open').toLowerCase().trim();
      if (status === 'done' || status === 'completed' || status === 'complete' || status === 'closed') return 'completed';
      var rawDue = reminder && (reminder.dueAt || reminder.due_at || reminder.reminderAt || reminder.reminder_at || '');
      if (!rawDue) return 'scheduled';
      var due = new Date(rawDue);
      if (isNaN(due.getTime())) return 'scheduled';
      if (due.getTime() <= now.getTime()) return 'overdue';
      var endToday = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59, 999);
      if (due.getTime() <= endToday.getTime()) return 'dueToday';
      return 'scheduled';
    }
    function reminderBucketsForActiveCommunity(){
      var buckets = null;
      try {
        if (window.__zummeeHubReminderBuckets && typeof window.__zummeeHubReminderBuckets === 'object') {
          buckets = {
            overdue: parseInt(window.__zummeeHubReminderBuckets.overdue || 0, 10) || 0,
            dueToday: parseInt(window.__zummeeHubReminderBuckets.dueToday || 0, 10) || 0,
            scheduled: parseInt(window.__zummeeHubReminderBuckets.scheduled || 0, 10) || 0,
            completed: parseInt(window.__zummeeHubReminderBuckets.completed || 0, 10) || 0
          };
        }
      } catch(_e) {}
      if (!buckets) {
        var scope = getActiveCommunityScope();
        var all = readReminderStore();
        if (scope.id || scope.name) {
          var matched = all.filter(function(reminder){
            var reminderCommunityId = String(reminder && (reminder.communityId || reminder.community_id || reminder.communityID || '')).trim();
            var reminderCommunityName = String(reminder && (reminder.communityName || reminder.community_name || reminder.community || '')).trim().toLowerCase();
            if (scope.id && reminderCommunityId && reminderCommunityId === scope.id) return true;
            if (scope.name && reminderCommunityName && reminderCommunityName === scope.name) return true;
            return false;
          });
          if (matched.length) all = matched;
        }
        var now = new Date();
        buckets = (all || []).reduce(function(acc, reminder){
          var bucket = classifyReminder(reminder, now);
          acc[bucket] = (acc[bucket] || 0) + 1;
          return acc;
        }, { overdue: 0, dueToday: 0, scheduled: 0, completed: 0 });
      }

      try {
        var sub = $('remindersCardSub');
        var visibleText = String((sub && (sub.textContent || sub.innerText)) || '').toLowerCase().trim();
        var visibleCount = firstNumber(visibleText);
        if (/overdue/.test(visibleText)) {
          buckets.overdue = Math.max(parseInt(buckets.overdue || 0, 10) || 0, visibleCount || 1);
          buckets.dueToday = 0;
        } else if (/due\s*today|today/.test(visibleText)) {
          buckets.dueToday = Math.max(parseInt(buckets.dueToday || 0, 10) || 0, visibleCount || 1);
        }
      } catch(_e2) {}

      return {
        overdue: parseInt(buckets.overdue || 0, 10) || 0,
        dueToday: parseInt(buckets.dueToday || 0, 10) || 0,
        scheduled: parseInt(buckets.scheduled || 0, 10) || 0,
        completed: parseInt(buckets.completed || 0, 10) || 0
      };
    }
    var weatherRisk = $('weatherRiskBadge') ? $('weatherRiskBadge').textContent : '';
    if(/high/i.test(weatherRisk)){ alerts.push('<div class="smart-alert smart-alert-weather"><div class="smart-alert-main">⚠️ Severe weather risk</div></div>'); }
    else if(/moderate/i.test(weatherRisk)){ alerts.push('<div class="smart-alert">🌦️ Weather could affect operations today — keep community texting ready.</div>'); }
    var schedText = $('emergencyTextingScheduleLine') ? $('emergencyTextingScheduleLine').textContent : '';
    var scheduledCount = /No scheduled alerts/i.test(schedText) ? 0 : firstNumber(schedText);
    if(scheduledCount > 0){ alerts.push('<div class="smart-alert">📢 ' + escapeHtml(schedText.trim()) + '</div>'); upsertBadge('emergencyTextingCard', scheduledCount + ' scheduled', 'green'); } else { upsertBadge('emergencyTextingCard', '', ''); }
    var reminderBuckets = reminderBucketsForActiveCommunity();
    var overdue = parseInt(reminderBuckets.overdue || 0, 10) || 0;
    var dueToday = parseInt(reminderBuckets.dueToday || 0, 10) || 0;
    var remindersCard = $('remindersCard');
    var remindersSub = $('remindersCardSub');
    if (remindersCard) {
      remindersCard.classList.remove('red','gold','yellow');
    }
    if(overdue > 0){
      alerts.push('<div class="smart-alert">⏰ ' + overdue + ' reminders overdue</div>');
      if (remindersCard) remindersCard.classList.add('red');
      if (remindersSub) remindersSub.textContent = overdue + ' overdue';
      upsertBadge('remindersCard', overdue + ' overdue', 'red');
    }
    else if(dueToday > 0){
      if (remindersCard) remindersCard.classList.add('gold');
      if (remindersSub) remindersSub.textContent = dueToday + ' due today';
      upsertBadge('remindersCard', dueToday + ' today', 'yellow');
    }
    else {
      if (remindersSub) remindersSub.textContent = 'No reminders due';
      upsertBadge('remindersCard', '', '');
    }
    var rwoBadge = $('residentRwoAlertBadge');
    var rwoText = rwoBadge && rwoBadge.style.display !== 'none' ? rwoBadge.textContent : '';
    if(rwoText){ alerts.push('<div class="smart-alert">🔧 Resident work orders need attention — ' + escapeHtml(rwoText.trim()) + '</div>'); upsertBadge('residentWorkOrdersCard', rwoText.trim(), /urgent/i.test(rwoText) ? 'red' : 'yellow'); }
    else { upsertBadge('residentWorkOrdersCard', '', ''); }
    var maintSummary = $('liveMaintenanceSummary') ? $('liveMaintenanceSummary').textContent : '';
    var recentMatch = String(maintSummary).match(/🔔\s*(\d+)\s*recent/i);
    var recentCount = recentMatch ? parseInt(recentMatch[1],10) : 0;
    var maintPills = $('liveMaintenancePills') ? $('liveMaintenancePills').textContent : '';
    var maintReminderMatch = String(maintPills).match(/Reminders\s+(\d+)/i);
    var maintReminderCount = maintReminderMatch ? parseInt(maintReminderMatch[1],10) : 0;
    if(maintReminderCount > 0){ alerts.push('<div class="smart-alert">🛠️ Maintenance follow-ups pending — ' + maintReminderCount + ' reminder' + (maintReminderCount===1?'':'s') + '</div>'); upsertBadge('liveMaintenanceUpdatesCard', maintReminderCount + ' reminders', 'red'); upsertBadge('maintenanceControlCenterCard', maintReminderCount + ' urgent', 'red'); }
    else if(recentCount > 0){ upsertBadge('liveMaintenanceUpdatesCard', recentCount + ' recent', 'blue'); upsertBadge('maintenanceControlCenterCard', recentCount + ' active', 'yellow'); }
    else { upsertBadge('liveMaintenanceUpdatesCard', '', ''); upsertBadge('maintenanceControlCenterCard', '', ''); }
    var bmBadge = document.querySelector('#boardMemberHubCard .bm-alert-badge');
    var bmText = bmBadge && bmBadge.style.display !== 'none' ? bmBadge.textContent : '';
    if(bmText){
      var bmCount = 0;
      try{
        var m = String(bmText || '').match(/(\d+)/);
        bmCount = m ? parseInt(m[1], 10) || 0 : 0;
      }catch(_e){}
      var headline = bmCount === 1 ? '1 Action Needs Review' : (bmCount > 1 ? (bmCount + ' Actions Need Review') : 'Board Action Needs Review');
      var sub = bmCount > 0
        ? 'Board-submitted items are waiting for employee review.'
        : 'Open the Board Member Hub to review the latest submitted items.';
      alerts.push(
        '<a class="smart-alert smart-alert-board" href="board_member_hub.html?view=submitted">' +
          '<div class="smart-alert-main">' +
            '<div class="smart-alert-copy">' +
              '<div class="smart-alert-label">Board Member Items</div>' +
              '<div class="smart-alert-headline">' + escapeHtml(headline) + '</div>' +
              '<div class="smart-alert-sub">' + escapeHtml(sub) + '</div>' +
            '</div>' +
            '<span class="smart-alert-cta">Review →</span>' +
          '</div>' +
        '</a>'
      );
    }
    if(!alerts.length){ strip.style.display = 'none'; content.innerHTML = ''; return; }
    content.innerHTML = alerts.join('');
    strip.style.display = 'block';
  }
  function runSoon(){ setTimeout(loadOperationalSignals, 120); }
  if(document.readyState === 'loading'){ document.addEventListener('DOMContentLoaded', runSoon); } else { runSoon(); }
  ['focus','community:changed','profile:loaded','resident-work-orders:changed','zummee:reminders-changed','zummee:hub-reminders-updated'].forEach(function(evt){ window.addEventListener(evt, runSoon); document.addEventListener(evt, runSoon); });
  setTimeout(runSoon, 800); setTimeout(runSoon, 1600); setInterval(loadOperationalSignals, 15000);
})();
</script>


<script id="supervisor-priority-strips-script">
(function(){
  function $(id){ return document.getElementById(id); }
  function safeTrim(v){ return String(v == null ? '' : v).trim(); }
  function getSB(){ try{ return window.sb || window.supabase || window.supabaseClient || null; }catch(_e){ return null; } }
  function getSelectedCommunityId(){
    try{
      var sel = document.getElementById('zummeeCommunitySelect');
      if(sel && sel.value) return safeTrim(sel.value);
    }catch(_e){}
    try{ if(window.__zummeeSelectedCommunityId) return safeTrim(window.__zummeeSelectedCommunityId); }catch(_e){}
    var keys=['zummee_selected_community_id','zummee_selected_community_v1','activeCommunityId','zummeeActiveCommunityId'];
    for(var i=0;i<keys.length;i++){
      try{ var v=localStorage.getItem(keys[i]); if(v) return safeTrim(v); }catch(_e2){}
    }
    return '';
  }
  function getScopedCompany(){
    try{ if(window.__zummeeCompany) return safeTrim(window.__zummeeCompany); }catch(_e){}
    var keys=['zummee_company','zummee_selected_company','zummee_management_company','selectedCompany','zummee_company_name','managementCompanyName'];
    for(var i=0;i<keys.length;i++){
      try{ var v=localStorage.getItem(keys[i]); if(v) return safeTrim(v); }catch(_e2){}
    }
    return '';
  }
  function getScopedCompanyId(){
    try{ if(window.__supCompanyId) return safeTrim(window.__supCompanyId); }catch(_e){}
    try{ if(window.__zummeeProfile && window.__zummeeProfile.company_id) return safeTrim(window.__zummeeProfile.company_id); }catch(_e2){}
    var keys=['activeCompanyId','zummee_company_id'];
    for(var i=0;i<keys.length;i++){
      try{ var v=localStorage.getItem(keys[i]); if(v) return safeTrim(v); }catch(_e3){}
    }
    return '';
  }
  function getCurrentUserId(){
    try{ if(window.__zummeeProfile && window.__zummeeProfile.id) return safeTrim(window.__zummeeProfile.id); }catch(_e){}
    try{ if(window.ZummeeAuth && typeof window.ZummeeAuth.getUserId === 'function') return safeTrim(window.ZummeeAuth.getUserId()); }catch(_e2){}
    return '';
  }
  function truthyApproved(v){
    if(v === true) return true;
    if(v === false) return false;
    var s=safeTrim(v).toLowerCase();
    if(!s) return null;
    if(['true','1','yes','approved'].indexOf(s) >= 0) return true;
    if(['false','0','no','pending','unapproved'].indexOf(s) >= 0) return false;
    return null;
  }
  function isSupervisorRole(){
    try{
      var profile = window.__zummeeProfile || null;
      var role = safeTrim((profile && profile.role) || window.__zummeeUserRole || document.body.getAttribute('data-role')).toLowerCase();
      var approved = profile && typeof profile.approved !== 'undefined' ? !!profile.approved : true;
      return approved && (role === 'supervisor' || role === 'admin' || role === 'companyadmin');
    }catch(_e){ return false; }
  }
  function esc(v){ return String(v == null ? '' : v).replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[ch] || ch; }); }
  function formatDate(v){
    if(!v) return 'Meeting date not set';
    try{
      var d = new Date(v);
      if(Number.isNaN(d.getTime())) return String(v);
      return d.toLocaleDateString([], { month:'short', day:'numeric', year:'numeric' });
    }catch(_e){ return String(v); }
  }
  function formatSubmitted(v){
    if(!v) return 'Recently submitted';
    try{
      var d = new Date(v);
      if(Number.isNaN(d.getTime())) return 'Recently submitted';
      return d.toLocaleString([], { month:'short', day:'numeric', hour:'numeric', minute:'2-digit' });
    }catch(_e){ return 'Recently submitted'; }
  }
  function getMeetingDate(item){
    try{
      var payload = item && item.packet_payload ? item.packet_payload : {};
      if(typeof payload === 'string') payload = JSON.parse(payload || '{}');
      return safeTrim((payload && (payload.nextAnnualMeetingDate || payload.meetingDate || payload.meeting_date)) || item.meeting_date || '');
    }catch(_e){ return safeTrim(item && item.meeting_date); }
  }
  function previewApproval(id){
    var list = Array.isArray(window.__supervisorInlineApprovals) ? window.__supervisorInlineApprovals : [];
    var item = null;
    for(var i=0;i<list.length;i++){ if(String(list[i] && list[i].id) === String(id)){ item = list[i]; break; } }
    if(!item || !item.preview_html) return;
    var win = window.open('', '_blank');
    if(!win) return;
    win.document.open();
    win.document.write(String(item.preview_html || ''));
    win.document.close();
  }
  function setCount(id, count){
    var el=$(id);
    if(el) el.textContent = String(Math.max(0, Number(count)||0));
  }
  function setSub(id, text){ var el=$(id); if(el) el.textContent = text; }
  function updateSupervisorApprovalsStripState(count){
    var strip = $('supervisorApprovalsStrip');
    var action = $('supervisorApprovalsStripAction');
    if(strip) strip.classList.toggle('is-urgent', Number(count || 0) > 0);
    if(action){
      action.textContent = Number(count || 0) > 0 ? 'Review now' : 'Review inline';
    }
  }
  function renderInlineApprovals(rows){
    var listEl = $('supervisorApprovalsInlineList');
    var subEl = $('supervisorApprovalsInlineSub');
    if(!listEl) return;
    rows = Array.isArray(rows) ? rows : [];
    window.__supervisorInlineApprovals = rows;
    if(subEl){
      subEl.textContent = rows.length ? (rows.length + ' annual meeting packet' + (rows.length === 1 ? '' : 's') + ' waiting for supervisor action.') : 'Review and act on annual meeting packets without leaving the hub.';
    }
    if(!rows.length){
      listEl.innerHTML = '<div class="supervisor-inline-approvals__empty">No annual meeting packets are currently waiting for supervisor approval.</div>';
      return;
    }
    listEl.innerHTML = rows.map(function(item){
      var community = esc(item.community_name || 'Community');
      var submittedBy = esc(item.employee_name || item.employee_email || 'Employee');
      var meetingDate = esc(formatDate(getMeetingDate(item)));
      var submittedAt = esc(formatSubmitted(item.submitted_at));
      var itemId = esc(item.id);
      return '<div class="supervisor-inline-approval" data-inline-item="' + itemId + '">'
        + '<div class="supervisor-inline-approval__main">'
        + '<div class="supervisor-inline-approval__title">' + community + '</div>'
        + '<div class="supervisor-inline-approval__meta">Meeting date: ' + meetingDate + '</div>'
        + '<div class="supervisor-inline-approval__detail">Submitted by ' + submittedBy + ' • ' + submittedAt + '</div>'
        + '<div class="supervisor-inline-approval__statusbar">'
        + '<div class="supervisor-inline-approval__statuscopy">'
        + '<span class="supervisor-inline-approval__badge" data-inline-badge="' + itemId + '">Waiting</span>'
        + '<span class="supervisor-inline-approval__note" data-inline-note="' + itemId + '">Ready for supervisor action.</span>'
        + '</div>'
        + '<div class="supervisor-inline-approval__actions">'
        + '<button class="supervisor-inline-approval__btn" type="button" data-inline-preview="' + itemId + '">Preview</button>'
        + '<button class="supervisor-inline-approval__btn primary" type="button" data-inline-approve="' + itemId + '">Approve</button>'
        + '<button class="supervisor-inline-approval__btn danger" type="button" data-inline-reject="' + itemId + '">Reject</button>'
        + '</div>'
        + '</div>'
        + '</div>'
        + '</div>';
    }).join('');
  }
  function toggleApprovals(forceOpen){
    var panel = $('supervisorApprovalsInline');
    var strip = $('supervisorApprovalsStrip');
    if(!panel || !strip) return;
    var shouldOpen = typeof forceOpen === 'boolean' ? forceOpen : panel.classList.contains('is-hidden');
    panel.classList.toggle('is-hidden', !shouldOpen);
    panel.setAttribute('aria-hidden', shouldOpen ? 'false' : 'true');
    strip.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
  }
  async function resolveAssistantEmailForApproval(sb, row){
    try{
      if(!(sb && sb.from) || !row) return safeTrim(row && row.assistant_email);
      var companyId = safeTrim(row.company_id);
      var communityId = safeTrim(row.community_id);
      var companyName = safeTrim(row.company_name || row.company);
      var communityName = safeTrim(row.community_name);
      async function tryAssignment(filters){
        try{
          var q = sb.from('community_assignments').select('assistant_email,updated_at').limit(1);
          Object.keys(filters || {}).forEach(function(key){
            var val = safeTrim(filters[key]);
            if(val) q = q.eq(key, val);
          });
          q = q.order('updated_at', { ascending:false });
          var res = await q.maybeSingle();
          return safeTrim(res && res.data && res.data.assistant_email);
        }catch(_e){ return ''; }
      }
      var email = '';
      if(companyId && communityId) email = await tryAssignment({ company_id: companyId, community_id: communityId });
      if(!email && companyName && communityName) email = await tryAssignment({ company_name: companyName, community_name: communityName });
      if(!email && companyName && communityId) email = await tryAssignment({ company_name: companyName, community_id: communityId });
      if(!email && communityId) email = await tryAssignment({ community_id: communityId });
      if(email) return email;
      email = safeTrim(row.assistant_email);
      if(email) return email;
      var employeeUserId = safeTrim(row.employee_user_id);
      if(!employeeUserId) return '';
      var q = await sb.from('userdirectory').select('assistant_email').eq('auth_user_id', employeeUserId).maybeSingle();
      return safeTrim(q && q.data && q.data.assistant_email);
    }catch(_e){ return ''; }
  }
  async function sendAnnualMailingEmailInline(sb, row, assistantEmail){
    try{
      if(!(sb && sb.from) || !row) return { ok:false, reason:'missing_context' };
      assistantEmail = safeTrim(assistantEmail || row.assistant_email);
      if(!assistantEmail) return { ok:false, reason:'missing_assistant_email' };
      var token = '';
      try{
        if(sb && sb.auth && typeof sb.auth.getSession === 'function'){
          var s = await sb.auth.getSession();
          token = safeTrim(s && s.data && s.data.session && s.data.session.access_token);
        }
      }catch(_eToken){}
      var anon = '';
      try{ anon = safeTrim(window.SUPABASE_ANON_KEY || localStorage.getItem('SUPABASE_ANON_KEY') || localStorage.getItem('supabase.anon.key') || ''); }catch(_eAnon){}
      var confirmToken = '';
      try{ confirmToken = String(Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2)).trim(); }catch(_eTok){}
      if(!confirmToken) confirmToken = String(Date.now());
      var base = '';
      try{ base = safeTrim(window.SUPABASE_URL || localStorage.getItem('SUPABASE_URL') || ''); }catch(_eBase){}
      try{ if(!base && window.sb && window.sb.supabaseUrl) base = safeTrim(window.sb.supabaseUrl); }catch(_eBase2){}
      if(!base) return { ok:false, reason:'missing_supabase_url' };
      var origin = '';
      try{ origin = safeTrim(window.location && window.location.origin); }catch(_eOrigin){}
      if(!origin){ try{ origin = String(base || '').replace(/\/$/, ''); }catch(_eOrigin2){} }
      var confirmUrl = origin ? (origin.replace(/\/$/, '') + '/annual_mailing_confirm.html?request_id=' + encodeURIComponent(String(row.id || '')) + '&token=' + encodeURIComponent(confirmToken)) : '';
      try{
        var updToken = await sb.from('annual_meeting_packet_requests').update({ mailing_confirm_token: confirmToken }).eq('id', row.id);
        if(updToken && updToken.error) throw updToken.error;
      }catch(_eUpd){ return { ok:false, reason:String((_eUpd && _eUpd.message) || 'Could not save mailing confirmation token') }; }
      var payload = {
        request_id: row.id,
        assistant_email: assistantEmail,
        community_name: row.community_name || row.communityName || ((row.packet_payload || {}).communityName) || '',
        resident_count: Number(row.resident_count || 0),
        preview_html: String(row.preview_html || ''),
        packet_payload: row.packet_payload || {},
        confirm_url: confirmUrl,
        confirm_token: confirmToken,
        attachments: (row.packet_payload && row.packet_payload.pdf_attachment) ? [row.packet_payload.pdf_attachment] : []
      };
      var headers = { 'Content-Type':'application/json' };
      if(anon) headers.apikey = anon;
      if(token) headers.Authorization = 'Bearer ' + token;
      var res = await fetch(base + '/functions/v1/send-annual-mailing-email', { method:'POST', headers:headers, body:JSON.stringify(payload) });
      var raw = null;
      try{ raw = await res.text(); }catch(_eRaw){}
      var data = null;
      try{ data = raw ? JSON.parse(raw) : null; }catch(_eJson){ data = raw; }
      if(!res.ok){
        var reason = '';
        try{ reason = String((data && (data.message || data.error || data.details)) || raw || ('HTTP ' + res.status)).trim(); }catch(_eReason){ reason = 'HTTP ' + res.status; }
        return { ok:false, reason: reason || ('HTTP ' + res.status) };
      }
      try{ await sb.from('annual_meeting_packet_requests').update({ mailing_email_sent_at: new Date().toISOString() }).eq('id', row.id); }catch(_eSent){}
      return { ok:true, data:data, assistant_email:assistantEmail };
    }catch(err){
      try{ console.warn('inline assistant mailing email failed', err); }catch(_eWarn){}
      return { ok:false, reason:String((err && err.message) || err || 'send_failed') };
    }
  }
  async function updateInlineApprovalStatus(id, status){
    var sb = getSB();
    if(!(sb && sb.from)) return { ok:false };
    try{
      var req = await sb.from('annual_meeting_packet_requests').select('*').eq('id', id).limit(1).maybeSingle();
      if(req && req.error) throw req.error;
      var row = req && req.data ? req.data : null;
      if(!row) throw new Error('Approval request not found');
      var approvedAt = new Date().toISOString();
      var payload = { status: status };
      if(status === 'approved_ready_to_send'){
        payload.approved_at = approvedAt;
        payload.approved_by = getCurrentUserId() || null;
        payload.rejection_reason = null;
      }
      if(status === 'rejected'){
        payload.approved_at = null;
        payload.approved_by = null;
        payload.rejection_reason = 'Rejected by supervisor';
      }
      var res = await sb.from('annual_meeting_packet_requests').update(payload).eq('id', id);
      if(res && res.error) throw res.error;
      var emailResult = null;
      if(status === 'approved_ready_to_send'){
        var assistantEmail = await resolveAssistantEmailForApproval(sb, row);
        emailResult = await sendAnnualMailingEmailInline(sb, row, assistantEmail);
        try{
          await sb.from('annual_meeting_activity_events').insert([{
            event_type: emailResult && emailResult.ok ? 'annual_packet_emailed_for_mailing' : 'annual_packet_approved',
            title: emailResult && emailResult.ok ? 'Annual Meeting packet emailed for mailing' : 'Annual Meeting Documents approved',
            detail: emailResult && emailResult.ok ? ((row.community_name || 'Community') + ' packet emailed to ' + (emailResult.assistant_email || assistantEmail || 'the assigned assistant') + ' for printing and mailing.') : ((row.community_name || 'Community') + ' documents approved.'),
            company_id: row.company_id || null,
            community_id: row.community_id || null,
            community_name: row.community_name || null,
            actor_user_id: getCurrentUserId() || null,
            actor_name: safeTrim((window.ZUMMEE_AUTH && (window.ZUMMEE_AUTH.name || window.ZUMMEE_AUTH.full_name || window.ZUMMEE_AUTH.email)) || '') || 'Supervisor',
            target_user_id: row.employee_user_id || null,
            created_at: approvedAt
          }]);
        }catch(_eInsert){}
      }
      return { ok:true, emailResult:emailResult };
    }catch(err){
      try{ console.warn('inline approval update failed', err); }catch(_e){}
      return { ok:false, reason:String((err && err.message) || err || 'update_failed') };
    }
  }
  function bindClicks(){
    var approvals = $('supervisorApprovalsStrip');
    if(approvals && approvals.dataset.bound !== '1'){
      approvals.dataset.bound='1';
      approvals.addEventListener('click', function(){
        approvals.classList.remove('is-shimmering');
        void approvals.offsetWidth;
        approvals.classList.add('is-shimmering');
        setTimeout(function(){ approvals.classList.remove('is-shimmering'); }, 750);
      });
    }
    var activations = $('supervisorActivationsStrip');
    if(activations && activations.dataset.bound !== '1'){
      activations.dataset.bound='1';
      activations.addEventListener('click', function(){
        var href = activations.getAttribute('data-href');
        if(href) window.location.href = href;
      });
      activations.addEventListener('pointerdown', function(){
        activations.classList.remove('is-shimmering');
        void activations.offsetWidth;
        activations.classList.add('is-shimmering');
        setTimeout(function(){ activations.classList.remove('is-shimmering'); }, 750);
      });
    }
  }
  async function loadCounts(){
    var wrap = $('supervisorPriorityStrips');
    if(!wrap) return;
    if(!isSupervisorRole()){
      wrap.style.display='none';
      return;
    }
    wrap.style.display='grid';
    bindClicks();
    var sb = getSB();
    var approvalsRows = [];
    var approvalsCount = 0;
    var activationsCount = 0;
    try{
      if(sb && sb.from){
        var communityId = getSelectedCommunityId();
        var approvalQuery = sb.from('annual_meeting_packet_requests').select('id,community_id,community_name,employee_name,employee_email,submitted_at,preview_html,packet_payload,status', { count:'exact' }).eq('status','pending_supervisor_approval').order('submitted_at', { ascending:false }).limit(8);
        if(communityId) approvalQuery = approvalQuery.eq('community_id', communityId);
        var approvalRes = await approvalQuery;
        approvalsRows = Array.isArray(approvalRes && approvalRes.data) ? approvalRes.data : [];
        approvalsCount = Number((approvalRes && approvalRes.count) || approvalsRows.length || 0);

        var companyId = getScopedCompanyId();
        var company = getScopedCompany().toLowerCase();
        var direct = await sb.from('userdirectory').select('id,role,approved,company_id,company_name,company').limit(500);
        var rows = Array.isArray(direct && direct.data) ? direct.data : [];
        activationsCount = rows.filter(function(r){
          if(!r) return false;
          var role = safeTrim(r.role).toLowerCase();
          if(!role || role.indexOf('admin') >= 0 || role.indexOf('supervisor') >= 0 || role.indexOf('assistant') >= 0 || role.indexOf('resident') >= 0 || role.indexOf('board') >= 0 || role.indexOf('vendor') >= 0) return false;
          var approved = truthyApproved(r.approved);
          if(approved !== false) return false;
          var rowCid = safeTrim(r.company_id);
          var rowCompany = safeTrim(r.company_name || r.company).toLowerCase();
          if(companyId && rowCid) return rowCid === companyId;
          if(company && rowCompany) return rowCompany === company;
          return true;
        }).length;
      }
    }catch(err){
      try{ console.warn('supervisor priority strip counts failed', err); }catch(_e){}
    }
    renderInlineApprovals(approvalsRows);
    setCount('supervisorApprovalsStripCount', approvalsCount);
    setCount('supervisorActivationsStripCount', activationsCount);
    updateSupervisorApprovalsStripState(approvalsCount);
    setSub('supervisorApprovalsStripSub', approvalsCount > 0 ? ('Tap to review ' + approvalsCount + ' annual meeting packet' + (approvalsCount === 1 ? '' : 's') + ' waiting for supervisor approval.') : 'No annual meeting packets are currently waiting for supervisor approval.');
    setSub('supervisorActivationsStripSub', activationsCount > 0 ? (activationsCount + ' employee account request' + (activationsCount === 1 ? '' : 's') + ' waiting for approval.') : 'No employee account activations are currently waiting.');
  }
  function showInlineApprovalResult(title, body){
    var modal = document.getElementById('inlineApprovalResultModal');
    var titleEl = document.getElementById('inlineApprovalResultModalTitle');
    var bodyEl = document.getElementById('inlineApprovalResultModalBody');
    var okBtn = document.getElementById('inlineApprovalResultOkBtn');
    if(!modal || !titleEl || !bodyEl || !okBtn){
      try{ alert(body || title || 'Update saved.'); }catch(_e0){}
      return;
    }
    titleEl.textContent = title || 'Approval updated';
    bodyEl.textContent = body || 'Your change has been saved.';
    function closeModal(){
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden','true');
    }
    if(!modal.dataset.bound){
      modal.dataset.bound = '1';
      modal.addEventListener('click', function(e){ if(e.target === modal) closeModal(); });
      okBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', function(e){
        if(e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
      });
    }
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden','false');
    setTimeout(function(){ try{ okBtn.focus(); }catch(_e1){} }, 10);
  }

  var approvalsStripEl = $('supervisorApprovalsStrip');
  if(approvalsStripEl && !approvalsStripEl.dataset.boundPriority){
    approvalsStripEl.dataset.boundPriority = '1';
    approvalsStripEl.addEventListener('click', function(e){
      var fullLink = e.target && e.target.closest ? e.target.closest('.supervisor-inline-approvals__link') : null;
      if(fullLink) return;
      window.location.href = 'annual_meeting_approvals.html';
    });
  }
  var activationsStripEl = $('supervisorActivationsStrip');
  if(activationsStripEl && !activationsStripEl.dataset.boundPriority){
    activationsStripEl.dataset.boundPriority = '1';
    activationsStripEl.addEventListener('click', function(){
      var href = safeTrim(activationsStripEl.getAttribute('data-href'));
      if(href) window.location.href = href;
    });
  }


  function updateInlineApprovalVisualState(id, stateName, noteText){
    var row = document.querySelector('[data-inline-item="' + String(id) + '"]');
    if(!row) return;
    row.classList.remove('is-processing','is-approved','is-rejected');
    if(stateName) row.classList.add(stateName);
    var badge = document.querySelector('[data-inline-badge="' + String(id) + '"]');
    var note = document.querySelector('[data-inline-note="' + String(id) + '"]');
    if(badge){
      if(stateName === 'is-processing') badge.textContent = 'Saving';
      else if(stateName === 'is-approved') badge.textContent = 'Approved';
      else if(stateName === 'is-rejected') badge.textContent = 'Rejected';
      else badge.textContent = 'Waiting';
    }
    if(note){
      if(noteText) note.textContent = noteText;
      else if(stateName === 'is-processing') note.textContent = 'Saving your update…';
      else if(stateName === 'is-approved') note.textContent = 'Packet approved and moved to mailing.';
      else if(stateName === 'is-rejected') note.textContent = 'Packet rejected and removed from pending approvals.';
      else note.textContent = 'Ready for supervisor action.';
    }
  }
  function removeInlineApprovalFromCache(id){
    var list = Array.isArray(window.__supervisorInlineApprovals) ? window.__supervisorInlineApprovals : [];
    window.__supervisorInlineApprovals = list.filter(function(item){ return String(item && item.id) !== String(id); });
  }
  function removeInlineApprovalRow(id){
    var row = document.querySelector('[data-inline-item="' + String(id) + '"]');
    if(!row) return;
    row.style.transition = 'opacity .22s ease, transform .22s ease, max-height .22s ease, margin .22s ease, padding .22s ease';
    row.style.opacity = '0';
    row.style.transform = 'translateY(-6px)';
    row.style.maxHeight = row.offsetHeight + 'px';
    requestAnimationFrame(function(){
      row.style.maxHeight = '0px';
      row.style.marginTop = '0px';
      row.style.paddingTop = '0px';
      row.style.paddingBottom = '0px';
      row.style.borderWidth = '0px';
    });
    setTimeout(function(){
      try{ row.remove(); }catch(_e){}
      var listEl = $('supervisorApprovalsInlineList');
      if(listEl && !listEl.querySelector('[data-inline-item]')){
        listEl.innerHTML = '<div class="supervisor-inline-approvals__empty">No annual meeting packets are currently waiting for supervisor approval.</div>';
      }
    }, 260);
  }

  async function handleInlineAction(type, id){
    if(!id) return;
    if(type === 'preview'){
      previewApproval(id);
      return;
    }
    updateInlineApprovalVisualState(id, 'is-processing');
    var result = await updateInlineApprovalStatus(id, type === 'approve' ? 'approved_ready_to_send' : 'rejected');
    if(result && result.ok){
      var successNote = '';
      if(type === 'approve'){
        if(result.emailResult && result.emailResult.ok) successNote = 'Packet approved and emailed for mailing.';
        else if(result.emailResult && result.emailResult.reason === 'missing_assistant_email') successNote = 'Packet approved, but no assistant email was found on Community Assignments.';
        else if(result.emailResult && !result.emailResult.ok) successNote = 'Packet approved, but the mailing email needs attention.';
        else successNote = 'Packet approved.';
        updateInlineApprovalVisualState(id, 'is-approved', successNote);
      }else{
        successNote = 'Packet rejected and removed from pending approvals.';
        updateInlineApprovalVisualState(id, 'is-rejected', successNote);
      }
      removeInlineApprovalFromCache(id);
      try{ window.dispatchEvent(new CustomEvent('zummee:annual-approval-updated', { detail:{ id:id, action:type } })); }catch(_e){}
      setTimeout(async function(){
        removeInlineApprovalRow(id);
        await loadCounts();
        toggleApprovals(true);
      }, 900);
    } else {
      updateInlineApprovalVisualState(id, '', 'Could not save this change. Please try again.');
    }
    var msg = '';
    var title = '';
    if(result && result.ok){
      if(type === 'approve'){
        title = 'Packet approved';
        if(result.emailResult && result.emailResult.ok) msg = 'Annual meeting packet approved and emailed for mailing.';
        else if(result.emailResult && result.emailResult.reason === 'missing_assistant_email') msg = 'Annual meeting packet approved, but no assistant email was found on Community Assignments.';
        else if(result.emailResult && !result.emailResult.ok) msg = 'Annual meeting packet approved, but the mailing email failed: ' + String(result.emailResult.reason || 'send_failed');
        else msg = 'Annual meeting packet approved.';
      }else{
        title = 'Packet rejected';
        msg = 'Annual meeting packet rejected.';
      }
    }else{
      title = 'Update failed';
      msg = 'Could not ' + (type === 'approve' ? 'approve' : 'reject') + ' packet.';
      if(result && result.reason) msg += ' ' + String(result.reason);
    }
    showInlineApprovalResult(title, msg);
  }
  document.addEventListener('click', function(e){
    var preview = e.target && e.target.closest ? e.target.closest('[data-inline-preview]') : null;
    if(preview){ e.preventDefault(); e.stopPropagation(); handleInlineAction('preview', preview.getAttribute('data-inline-preview')); return; }
    var approve = e.target && e.target.closest ? e.target.closest('[data-inline-approve]') : null;
    if(approve){ e.preventDefault(); e.stopPropagation(); handleInlineAction('approve', approve.getAttribute('data-inline-approve')); return; }
    var reject = e.target && e.target.closest ? e.target.closest('[data-inline-reject]') : null;
    if(reject){ e.preventDefault(); e.stopPropagation(); handleInlineAction('reject', reject.getAttribute('data-inline-reject')); return; }
  });
  function runSoon(){ setTimeout(loadCounts, 120); }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', runSoon); else runSoon();
  ['community:changed','profile:loaded','focus','zummee:annual-approval-updated'].forEach(function(evt){ window.addEventListener(evt, runSoon); document.addEventListener(evt, runSoon); });
  setTimeout(runSoon, 800); setTimeout(runSoon, 1800); setInterval(loadCounts, 30000);
})();
</script>

<script id="live-activity-feed-script">
(function(){
  function $(id){ return document.getElementById(id); }
  function escapeHtml(v){
    return String(v == null ? '' : v).replace(/[&<>"']/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'})[ch] || ch; });
  }
  function formatClock(ts){
    try{ return new Date(ts).toLocaleTimeString([], { hour:'numeric', minute:'2-digit' }); }catch(_e){ return ''; }
  }
  function formatActivityDateTime(ts){
    try{
      var d = new Date(ts);
      if(Number.isNaN(d.getTime())) return '';
      var now = new Date();
      var startToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      var startTarget = new Date(d.getFullYear(), d.getMonth(), d.getDate());
      var diffDays = Math.round((startToday - startTarget) / 86400000);
      var dateLabel = '';
      if(diffDays === 0) dateLabel = 'Today';
      else if(diffDays === 1) dateLabel = 'Yesterday';
      else dateLabel = d.toLocaleDateString([], { month:'short', day:'numeric' });
      return dateLabel + ' • ' + d.toLocaleTimeString([], { hour:'numeric', minute:'2-digit' });
    }catch(_e){ return ''; }
  }
  async function getSupabase(){
    try{
      if(typeof ensureSupabase === 'function') return await ensureSupabase();
      if(window.supabaseClient && typeof window.supabaseClient.from === 'function') return window.supabaseClient;
      if(window.sb && typeof window.sb.from === 'function') return window.sb;
    }catch(_e){}
    return null;
  }
  function pushEvent(events, time, message, extra){
  if(!time || !message) return;
  var event = { time: time, message: message };
  if(extra && typeof extra === 'object'){
    Object.keys(extra).forEach(function(k){ event[k] = extra[k]; });
  }
  events.push(event);
}

async function openBoardItemFromLiveActivity(event){
  try{
    if(!event || !event.board_item_id) return;
    var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
    if(!sb) return;

    var q = await sb.from('BoardMemberActionItems')
      .select('id,community_id,title,details,due_date,created_at')
      .eq('id', event.board_item_id)
      .maybeSingle();

    if(q && q.error) throw q.error;
    var row = q && q.data ? q.data : null;
    if(!row) return;

    var existingId = parseConverted(row.details || '');
    if(existingId){
      window.location.href = 'resident_work_orders.html?open_work_order_id=' + encodeURIComponent(String(existingId));
      return;
    }

    await createWorkOrderFromBoardItem(row);
  }catch(_e){}
}

async function appendBoardItemsToLiveActivity(items){
  try{
    var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
    if(!sb) return items || [];

    var liveSelect = document.getElementById('zummeeCommunitySelect');
  var activeCommunityId = String((liveSelect && liveSelect.value) || localStorage.getItem('zummee_selected_community_id') || localStorage.getItem('activeCommunityId') || localStorage.getItem('zummeeActiveCommunityId') || localStorage.getItem('currentCommunityId') || '').trim();
    if(!activeCommunityId) return items || [];

    var q = await sb.from('BoardMemberActionItems')
      .select('id,title,created_at,community_id')
      .eq('community_id', activeCommunityId)
      .order('created_at', { ascending: false })
      .limit(5);

    if(q && !q.error && Array.isArray(q.data)){
      var boardEvents = q.data.map(function(r){
        return {
          time: r.created_at,
          message: '📝 Board item submitted — ' + (r.title || 'New item') + ' · Open work order',
          type: 'board_item',
          board_item_id: r.id,
          community_id: r.community_id
        };
      });
      return boardEvents.concat(items || []);
    }
  }catch(_e){}
  return items || [];
}


function currentStaffRole(){
  try{
    return String(document.documentElement.getAttribute('data-staff-role') || window.__zummeeUserRole || '').trim();
  }catch(_e){ return ''; }
}
function isSupervisorLiveFeedScope(){
  var role = currentStaffRole().toLowerCase();
  return role.indexOf('supervisor') !== -1;
}
async function getAuthUserIdSafe(sb){
  try{
    if(sb && sb.auth && typeof sb.auth.getUser === 'function'){
      var r = await sb.auth.getUser();
      return String(r && r.data && r.data.user && r.data.user.id || '').trim();
    }
  }catch(_e){}
  try{ return String((window.ZUMMEE_AUTH && window.ZUMMEE_AUTH.userId) || localStorage.getItem('zummee_user_id_v1') || localStorage.getItem('zummee_user_id') || '').trim(); }catch(_e2){}
  return '';
}
async function getCompanyIdSafe(sb){
  try{
    if(typeof window.getProfile === 'function'){
      var p = await window.getProfile();
      var id = String((p && (p.company_id || (p.company && p.company.id))) || '').trim();
      if(id) return id;
    }
  }catch(_e){}
  try{ return String(localStorage.getItem('zummee_active_company_id') || localStorage.getItem('activeCompanyId') || '').trim(); }catch(_e2){}
  return '';
}
function getCommunityNameByIdMap(){
  var out = {};
  try{
    var companyName = String(localStorage.getItem('zummee_active_company_name') || '').trim();
    var keys = [];
    if(companyName) keys.push('zummee_company_communities_v1__' + companyName);
    keys.push('zummee_communities_v1');
    keys.forEach(function(key){
      try{
        var arr = JSON.parse(localStorage.getItem(key) || '[]') || [];
        arr.forEach(function(c){
          if(!c) return;
          var id = String(c.id || c.communityId || c.value || '').trim();
          var name = String(c.name || c.communityName || c.label || '').trim();
          if(id && name && !out[id]) out[id] = name;
        });
      }catch(_e){}
    });
  }catch(_e2){}
  return out;
}
async function loadSupervisorTeamAssignments(sb, supervisorId, companyId){
  var ids = [];
  var localMap = {};
  try{ localMap = JSON.parse(localStorage.getItem('zummee_supervisor_team_map_v1') || '{}') || {}; }catch(_e){ localMap = {}; }
  try{
    if(companyId && localMap[companyId]){
      Object.keys(localMap[companyId]).forEach(function(employeeId){
        var rec = localMap[companyId][employeeId] || {};
        if(String(rec.supervisor_user_id || '').trim() === supervisorId) ids.push(String(employeeId));
      });
    }
  }catch(_e2){}
  try{
    if(sb && sb.from && supervisorId){
      var q = sb.from('supervisor_team_members').select('employee_user_id,company_id,supervisor_user_id').eq('supervisor_user_id', supervisorId);
      if(companyId) q = q.eq('company_id', companyId);
      var res = await q;
      if(!res.error && Array.isArray(res.data)){
        res.data.forEach(function(row){
          var id = String((row && row.employee_user_id) || '').trim();
          if(id) ids.push(id);
        });
      }
    }
  }catch(_e3){}
  var uniq = [];
  var seen = {};
  ids.forEach(function(id){ if(id && !seen[id]){ seen[id]=true; uniq.push(id); } });
  return { ids: uniq, localMap: localMap };
}
async function resolveEmployeeDirectoryForFeed(sb, ids, localMap, companyId){
  var out = {};
  try{
    if(companyId && localMap && localMap[companyId]){
      Object.keys(localMap[companyId]).forEach(function(employeeId){
        var rec = localMap[companyId][employeeId] || {};
        var id = String(employeeId || '').trim();
        if(!id) return;
        out[id] = out[id] || {};
        if(rec && rec.employee_name) out[id].name = String(rec.employee_name).trim();
      });
    }
  }catch(_e){}
  var missing = (ids || []).filter(function(id){ return id && !(out[id] && out[id].name && out[id].email); });
  if(missing.length){
    try{
      var res = await sb.from('userdirectory').select('auth_user_id,profile_name,profile_email').in('auth_user_id', missing);
      if(!res.error && Array.isArray(res.data)){
        res.data.forEach(function(row){
          var id = String((row && row.auth_user_id) || '').trim();
          if(!id) return;
          out[id] = out[id] || {};
          if(row && row.profile_name) out[id].name = String(row.profile_name).trim();
          if(row && row.profile_email) out[id].email = String(row.profile_email).trim().toLowerCase();
        });
      }
    }catch(_e2){}
  }
  (ids || []).forEach(function(id){
    if(!out[id]) out[id] = {};
    if(!out[id].name) out[id].name = 'Employee';
  });
  return out;
}
function rowUserIdForFeed(row){
  var keys = ['employee_user_id','user_id','auth_user_id','actor_user_id','created_by','submitted_by','updated_by'];
  for(var i=0;i<keys.length;i++){
    var v = row && row[keys[i]];
    if(v && String(v).trim()) return String(v).trim();
  }
  return '';
}
function rowCommunityIdForFeed(row){
  var keys = ['community_id','property_community_id'];
  for(var i=0;i<keys.length;i++){
    var v = row && row[keys[i]];
    if(v && String(v).trim()) return String(v).trim();
  }
  return '';
}
function rowCommunityNameForFeed(row, map){
  var keys = ['community_name','property_name'];
  for(var i=0;i<keys.length;i++){
    var v = row && row[keys[i]];
    if(v && String(v).trim()) return String(v).trim();
  }
  var cid = rowCommunityIdForFeed(row);
  return String((map && map[cid]) || '').trim();
}
function decorateFeedMessage(event){
  var employee = String((event && event.employee_name) || '').trim();
  var community = String((event && event.community_name) || '').trim();
  var type = String((event && event.type) || '').trim().toLowerCase();
  var cleanMessage = String((event && event.message) || '').replace(/^\s*[\u2600-\u27BF\uD83C-\uDBFF\uDC00-\uDFFF]+\s*/g, '').trim();
  var icon = '•';
  if(type === 'maintenance' || type === 'resident_work_order') icon = '🔧';
  else if(type === 'board_item') icon = '📋';
  else if(type === 'meeting' || type === 'meeting_approval') icon = '📅';
  else if(type === 'annual_meeting') icon = '🗂️';
  else if(type === 'compliance_drive') icon = '✅';
  else if(type === 'community_alert') icon = '📢';
  var metaParts = [];
  if(employee) metaParts.push(employee);
  if(community) metaParts.push(community);
  var meta = metaParts.length ? '<span class="activity-feed-meta">' + escapeHtml(metaParts.join(' • ')) + '</span>' : '';
  return meta + '<span class="activity-feed-text-main"><span class="activity-feed-icon-inline">' + escapeHtml(icon) + '</span>' + escapeHtml(cleanMessage) + '</span>' + ((event && event.type === 'board_item') ? '<span class="activity-feed-open">Open</span>' : '');
}
async function appendSupervisorTeamEvents(sb, events, activeCommunityId){
  if(!isSupervisorLiveFeedScope()) return events || [];
  var supervisorId = await getAuthUserIdSafe(sb);
  var companyId = await getCompanyIdSafe(sb);
  if(!supervisorId) return events || [];
  var teamInfo = await loadSupervisorTeamAssignments(sb, supervisorId, companyId);
  var teamIds = teamInfo.ids || [];
  if(!teamIds.length) return events || [];
  var employeeDirectory = await resolveEmployeeDirectoryForFeed(sb, teamIds, teamInfo.localMap, companyId);
  var communityMap = getCommunityNameByIdMap();

  function isTeamRow(row){
    var uid = rowUserIdForFeed(row);
    if(uid && teamIds.indexOf(uid) !== -1) return true;

    var rowEmail = String((row && (row.employee_email || row.actor_email || row.resident_email || row.profile_email)) || '').trim().toLowerCase();
    if(rowEmail){
      for(var i=0;i<teamIds.length;i++){
        var tid = teamIds[i];
        var rec = employeeDirectory && employeeDirectory[tid] ? employeeDirectory[tid] : null;
        var email = String((rec && rec.email) || '').trim().toLowerCase();
        if(email && email === rowEmail) return true;
      }
    }

    var rowName = String((row && (row.employee_name || row.actor_name || row.profile_name || row.resident_name)) || '').trim().toLowerCase();
    if(rowName){
      for(var j=0;j<teamIds.length;j++){
        var tid2 = teamIds[j];
        var rec2 = employeeDirectory && employeeDirectory[tid2] ? employeeDirectory[tid2] : null;
        var nm = String((rec2 && rec2.name) || '').trim().toLowerCase();
        if(nm && nm === rowName) return true;
      }
    }
    return false;
  }
  function teamName(row){
    var uid = rowUserIdForFeed(row);
    return String((employeeDirectory && employeeDirectory[uid] && employeeDirectory[uid].name) || (row && (row.employee_name || row.actor_name || row.profile_name || row.resident_name)) || 'Employee').trim();
  }
  function commName(row){
    return rowCommunityNameForFeed(row, communityMap);
  }
  function maybePush(time, message, extra){
    pushEvent(events, time, message, extra);
  }

  try{
    var complianceRes = await sb.from('mileage_compliance_completions').select('*').order('completed_at', { ascending:false }).limit(30);
    if(!complianceRes.error && Array.isArray(complianceRes.data)){
      complianceRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        maybePush(row.completed_at || row.created_at, 'Compliance Drive Completed', {
          type: 'compliance_drive',
          employee_name: String((row && row.employee_name) || teamName(row) || 'Employee').trim(),
          community_name: String((row && row.community_name) || commName(row) || '').trim()
        });
      });
    }
  }catch(_e){}

  try{
    var annualRes = await sb.from('annual_meeting_packet_requests').select('*').order('submitted_at', { ascending:false }).limit(20);
    if(!annualRes.error && Array.isArray(annualRes.data)){
      annualRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        maybePush(row.submitted_at || row.created_at, 'Annual meeting packet submitted', {
          type: 'annual_meeting',
          employee_name: teamName(row),
          community_name: commName(row)
        });
      });
    }
  }catch(_e){}

  try{
    var eventRes = await sb.from('annual_meeting_activity_events').select('*').order('created_at', { ascending:false }).limit(30);
    if(!eventRes.error && Array.isArray(eventRes.data)){
      eventRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        var msg = String(row.title || row.detail || row.event_type || 'Annual meeting update').trim();
        maybePush(row.created_at, msg, {
          type: 'annual_meeting',
          employee_name: teamName(row),
          community_name: commName(row)
        });
      });
    }
  }catch(_e2){}

  try{
    var rwoRes = await sb.from('resident_work_orders').select('*').order('submitted_at', { ascending:false }).limit(40);
    if(!rwoRes.error && Array.isArray(rwoRes.data)){
      rwoRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        var priority = String(row.priority || '').toLowerCase();
        var status = String(row.status || '').toLowerCase();
        var unit = String((row && row.unit_number) || '').trim().toLowerCase();
        var label = 'Employee Work Order Created';
        if(unit === 'inspection'){
          label = 'Inspection Work Order Created';
        }
        if(priority === 'urgent') label = 'Urgent ' + label;
        else if(status === 'in_progress' || status === 'assigned_to_vendor' || status === 'active') label = 'Employee Work Order In Progress';
        maybePush(row.submitted_at || row.created_at, label, {
          type: 'resident_work_order',
          employee_name: teamName(row),
          community_name: commName(row)
        });
      });
    }
  }catch(_e3){}

  try{
    var maintRes = await sb.from('maintenance_request_events').select('*').order('created_at', { ascending:false }).limit(30);
    if(!maintRes.error && Array.isArray(maintRes.data)){
      maintRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        var eventType = String(row.event_type || '').toLowerCase();
        var label = 'Maintenance update';
        if(eventType === 'created') label = 'Maintenance request created';
        else if(eventType === 'updated') label = 'Maintenance request updated';
        else if(eventType === 'completed') label = 'Maintenance request completed';
        maybePush(row.created_at || row.submitted_at, label, {
          type: 'maintenance',
          employee_name: teamName(row),
          community_name: commName(row)
        });
      });
    }
  }catch(_e4){}

  try{
    var boardRes = await sb.from('BoardMemberActionItems').select('*').order('created_at', { ascending:false }).limit(20);
    if(!boardRes.error && Array.isArray(boardRes.data)){
      boardRes.data.forEach(function(row){
        if(!isTeamRow(row)) return;
        if(activeCommunityId && String(rowCommunityIdForFeed(row)) !== activeCommunityId) return;
        maybePush(row.created_at, 'Board item submitted — ' + String(row.title || 'New item').trim() + ' · Open work order', {
          type: 'board_item',
          board_item_id: row.id,
          employee_name: teamName(row),
          community_name: commName(row),
          community_id: rowCommunityIdForFeed(row)
        });
      });
    }
  }catch(_e5){}

  return events || [];
}

var __liveActivityLastHtml = '';
var __liveActivityRefreshTimer = null;
var __liveActivityLoading = false;
var __liveActivityQueued = false;
function scheduleLiveActivityRefresh(delay){
  try{ clearTimeout(__liveActivityRefreshTimer); }catch(_e){}
  __liveActivityRefreshTimer = setTimeout(function(){
    loadLiveActivity();
  }, Math.max(150, Number(delay || 450)));
}


async function appendNotificationEventsToLiveActivity(sb, items, activeCommunityId){
  try{
    var q = sb
      .from('notification_events')
      .select('id, created_at, event_type, priority, title, message, link_url, community_id, source_table, source_id, metadata')
      .order('created_at', { ascending:false })
      .limit(20);
    if(activeCommunityId) q = q.eq('community_id', activeCommunityId);

    var res = await q;
    if(res && !res.error && Array.isArray(res.data)){
      var mapped = res.data.map(function(row){
        var md = (row && row.metadata && typeof row.metadata === 'object') ? row.metadata : {};
        return {
          time: row.created_at,
          message: row.message || row.title || 'Notification update',
          title: row.title || '',
          type: String(row.event_type || '').toLowerCase(),
          priority: String(row.priority || '').toLowerCase(),
          community_id: row.community_id || null,
          notification_id: row.id,
          link_url: row.link_url || null,
          source_table: row.source_table || null,
          source_id: row.source_id || null,
          request_id: md.work_order_id || md.request_id || null,
          board_item_id: md.board_item_id || null,
          meeting_id: md.meeting_id || null,
          metadata: md
        };
      });
      return mapped.concat(items || []);
    }
  }catch(_e){}
  return items || [];
}


async function loadLiveActivity(){
  var list = $('activityFeedList');
  if(!list) return;
  if(__liveActivityLoading){
    __liveActivityQueued = true;
    return;
  }
  __liveActivityLoading = true;
  var hadContent = !!String(list.innerHTML || '').trim();
  if(!hadContent){
    list.innerHTML = '<div class="activity-feed-empty activity-feed-loading-shell"><div class="activity-feed-loading-row"></div><div class="activity-feed-loading-row"></div><div class="activity-feed-loading-row"></div></div>';
  }
  var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
  if(!sb){
    var unavailableHtml = '<div class="activity-feed-empty">Live activity is unavailable right now.</div>';
    if(unavailableHtml !== __liveActivityLastHtml){
      list.innerHTML = unavailableHtml;
      __liveActivityLastHtml = unavailableHtml;
    }
    try{ if(window.__zummeeMarkLiveActivityReady) window.__zummeeMarkLiveActivityReady(); }catch(_e0){}
    __liveActivityLoading = false;
    return;
  }
  function resolveLiveActivityCommunityId(){
    try{
      var sel = document.getElementById('zummeeCommunitySelect');
      var liveVal = String(sel && sel.value || '').trim();
      if(liveVal) return liveVal;
    }catch(_e){}
    try{
      return String(
        localStorage.getItem('zummee_selected_community_id') ||
        localStorage.getItem('activeCommunityId') ||
        localStorage.getItem('zummeeActiveCommunityId') ||
        localStorage.getItem('currentCommunityId') ||
        ''
      ).trim();
    }catch(_e2){
      return '';
    }
  }
  var activeCommunityId = resolveLiveActivityCommunityId();
  var events = [];

  events = await appendNotificationEventsToLiveActivity(sb, events, activeCommunityId);

  if(!events.length && isSupervisorLiveFeedScope()){
    events = await appendSupervisorTeamEvents(sb, events, activeCommunityId);
  } else {
    try{
      var textQuery = sb.from('EmergencyTextLogs').select('community_id,community_name,template_title,status,recipient_count,sent_at,created_at').order('sent_at', { ascending:false }).limit(6);
      if(activeCommunityId) textQuery = textQuery.eq('community_id', activeCommunityId);
      var textRes = await textQuery;
      if(!textRes.error && Array.isArray(textRes.data)){
        textRes.data.forEach(function(row){
          var when = row.sent_at || row.created_at;
          var comm = row.community_name || 'Community';
          var template = row.template_title ? ' · ' + row.template_title : '';
          var status = String(row.status || '').toLowerCase();
          var message = '📢 Community alert sent — ' + comm + template;
          if(status === 'twilio_not_configured'){
            message = '📢 Community alert prepared — ' + comm + template;
          } else if(status === 'partial_success'){
            message = '📢 Community alert partially sent — ' + comm + template;
          } else if(status === 'scheduled'){
            message = '📢 Community alert scheduled — ' + comm + template;
          } else if(status && status !== 'sent'){
            message = '📢 Community alert update — ' + comm + template;
          }
          pushEvent(events, when, message, { type: 'community_alert', community_id: row.community_id, community_name: comm });
        });
      }
    }catch(_e){}

    try{
      var approvalQuery = sb.from('BoardMeetingMinutesApprovals').select('meeting_id,community_id,community_name,approval_status,approved_by_name,rejected_by_name,approved_at,rejected_at,created_at').order('created_at', { ascending:false }).limit(6);
      if(activeCommunityId) approvalQuery = approvalQuery.eq('community_id', activeCommunityId);
      var approvalRes = await approvalQuery;
      if(!approvalRes.error && Array.isArray(approvalRes.data)){
        approvalRes.data.forEach(function(row){
          var status = String(row.approval_status || '').toLowerCase();
          var comm = row.community_name || 'Board meeting';
          if(status === 'approved'){
            var approver = row.approved_by_name ? ' by ' + row.approved_by_name : '';
            pushEvent(events, row.approved_at || row.created_at, 'Minutes approved — ' + comm + approver, { type: 'meeting_approval', community_name: comm, meeting_id: row.meeting_id });
          } else if(status === 'rejected'){
            var rejector = row.rejected_by_name ? ' by ' + row.rejected_by_name : '';
            pushEvent(events, row.rejected_at || row.created_at, 'Minutes rejected — ' + comm + rejector, { type: 'meeting_approval', community_name: comm, meeting_id: row.meeting_id });
          } else if(status === 'pending_board_approval'){
            pushEvent(events, row.created_at, 'Minutes sent for approval — ' + comm, { type: 'meeting_approval', community_name: comm, meeting_id: row.meeting_id });
          }
        });
      }
    }catch(_e){}

    try{
      var rwoQuery = sb.from('resident_work_orders').select('id,community_id,submitted_at,status,priority').order('submitted_at', { ascending:false }).limit(6);
      if(activeCommunityId) rwoQuery = rwoQuery.eq('community_id', activeCommunityId);
      var rwoRes = await rwoQuery;
      if(!rwoRes.error && Array.isArray(rwoRes.data)){
        rwoRes.data.forEach(function(row){
          var priority = String(row.priority || '').toLowerCase();
          var status = String(row.status || '').toLowerCase();
          var label = '🧾 Resident work order submitted';
          if(priority === 'urgent') label = '🚨 Urgent resident work order submitted';
          else if(status === 'in_progress' || status === 'assigned_to_vendor') label = '🔧 Resident work order in progress';
          pushEvent(events, row.submitted_at, label, { type: 'resident_work_order', community_id: row.community_id, request_id: row.id });
        });
      }
    }catch(_e){}

    events = await appendBoardItemsToLiveActivity(events);

    try {
      var maintQuery = sb.from('maintenance_request_events').select('*').order('created_at', { ascending: false }).limit(30);
      var maintRes = await maintQuery;
      if (!maintRes.error && Array.isArray(maintRes.data)) {
        maintRes.data.filter(function(row){
          if(!activeCommunityId) return true;
          return String(rowCommunityIdForFeed(row) || '').trim() === activeCommunityId;
        }).forEach(function(row) {
          var eventType = String((row && row.event_type) || '').toLowerCase();
          var label = 'Maintenance update';
          if (eventType === 'created') label = 'Maintenance request created';
          else if (eventType === 'updated') label = 'Maintenance request updated';
          else if (eventType === 'completed') label = 'Maintenance request completed';
          else if (eventType === 'accepted') label = 'Vendor accepted maintenance request';
          else if (eventType === 'scheduled') label = 'Vendor scheduled maintenance request';
          else if (eventType === 'in_progress') label = 'Maintenance request in progress';
          else if (eventType === 'sent_to_vendor' || eventType === 'assigned_to_vendor') label = 'Maintenance request sent to vendor';
          pushEvent(events, row.created_at, label, { type: 'maintenance', community_id: row.community_id, request_id: row.request_id });
        });
      }
    } catch (_e) {}
  }

  if(!events.length){
    var fallback = [];
    var smartAlertNodes = document.querySelectorAll('#smartAlertContent .smart-alert');
    smartAlertNodes.forEach(function(node){ fallback.push(node.textContent.trim()); });
    if(fallback.length){
      var fallbackVisible = fallback.slice(0,3).map(function(msg){
        return '<div class="activity-feed-item"><div class="activity-feed-time">Now</div><div class="activity-feed-text">' + escapeHtml(msg) + '</div></div>';
      }).join('');
      if(fallbackVisible !== __liveActivityLastHtml){
        list.innerHTML = fallbackVisible;
        __liveActivityLastHtml = fallbackVisible;
      }
    } else {
      var emptyHtml = '<div class="activity-feed-empty">' + (isSupervisorLiveFeedScope() ? 'No recent team activity' : 'No recent activity') + '</div>';
      if(emptyHtml !== __liveActivityLastHtml){
        list.innerHTML = emptyHtml;
        __liveActivityLastHtml = emptyHtml;
      }
    }
    return;
  }

  function getActivityHref(event){
    if(event && event.link_url){
      return String(event.link_url);
    }
    var type = String((event && event.type) || '').toLowerCase();
    if(type === 'board_item' && event && event.board_item_id){
      return 'board_member_hub.html?open_item_id=' + encodeURIComponent(String(event.board_item_id));
    }
    if((type === 'maintenance' || type === 'resident_work_order' || type === 'new_work_order' || type === 'work_order_sent_to_vendor' || type === 'vendor_accepted_job' || type === 'vendor_scheduled_job' || type === 'vendor_in_progress' || type === 'vendor_completed_job') && event && event.request_id){
      return 'resident_work_orders.html?open_work_order_id=' + encodeURIComponent(String(event.request_id));
    }
    if(type === 'maintenance' || type === 'resident_work_order'){
      return 'resident_work_orders.html';
    }
    if((type === 'meeting' || type === 'meeting_approval' || type === 'minutes_sent_for_approval' || type === 'minutes_approved' || type === 'agenda_sent') && event && event.meeting_id){
      return 'board_meetings.html?open_meeting_id=' + encodeURIComponent(String(event.meeting_id)) + '&focus=minutes';
    }
    if(type === 'meeting' || type === 'meeting_approval'){
      return 'board_meetings.html';
    }
    if(type === 'annual_meeting'){
      return 'annual_meetings.html';
    }
    if(type === 'compliance_drive'){
      return 'mileage.html';
    }
    if(type === 'community_alert'){
      return 'emergency_texting.html';
    }
    var msg = String((event && event.message) || '').toLowerCase();
    if(msg.indexOf('employee work order') !== -1 || msg.indexOf('inspection work order') !== -1 || msg.indexOf('resident work order') !== -1 || msg.indexOf('maintenance request') !== -1 || msg.indexOf('work order') !== -1){
      return 'resident_work_orders.html';
    }
    if(msg.indexOf('board item') !== -1 || msg.indexOf('board member') !== -1){
      return 'board_member_hub.html';
    }
    if(msg.indexOf('minutes') !== -1 || msg.indexOf('agenda') !== -1 || msg.indexOf('meeting') !== -1){
      return 'board_meetings.html';
    }
    if(msg.indexOf('annual meeting') !== -1){
      return 'annual_meetings.html';
    }
    if(msg.indexOf('compliance drive') !== -1){
      return 'mileage.html';
    }
    if(msg.indexOf('activation') !== -1 || msg.indexOf('employee account') !== -1){
      return 'employee_account_activations.html';
    }
    if(msg.indexOf('community alert') !== -1 || msg.indexOf('text') !== -1){
      return 'emergency_texting.html';
    }
    return null;
  }


  function getActivityPriority(event){
    var type = String((event && event.type) || '').toLowerCase();
    var msg = String((event && event.message) || '').toLowerCase();
    var explicitPriority = String((event && event.priority) || '').toLowerCase();

    if(explicitPriority === 'urgent' || explicitPriority === 'high'){
      return explicitPriority === 'urgent' ? 'urgent' : 'attention';
    }
    if(explicitPriority === 'normal'){
      return 'neutral';
    }
    if(explicitPriority === 'info'){
      return 'neutral';
    }

    if(msg.indexOf('overdue') !== -1 || msg.indexOf('urgent') !== -1 || msg.indexOf('error') !== -1 || msg.indexOf('failed') !== -1){
      return 'urgent';
    }

    if(msg.indexOf('sent to vendor') !== -1 || msg.indexOf('awaiting') !== -1 || msg.indexOf('new board item') !== -1 || msg.indexOf('submitted') !== -1 || msg.indexOf('approval') !== -1){
      return 'attention';
    }

    if(msg.indexOf('accepted') !== -1 || msg.indexOf('active') !== -1 || msg.indexOf('in progress') !== -1 || msg.indexOf('scheduled') !== -1 || msg.indexOf('completed') !== -1){
      return 'active';
    }

    if(type === 'maintenance' || type === 'resident_work_order'){
      return 'attention';
    }
    if(type === 'board_item' || type === 'meeting_approval'){
      return 'attention';
    }
    if(type === 'meeting'){
      return 'neutral';
    }
    return 'neutral';
  }

  function getActivityPriorityLabel(priority){
    if(priority === 'urgent') return 'Urgent';
    if(priority === 'attention') return 'Needs Attention';
    if(priority === 'active') return 'Active';
    return 'Info';
  }


  events.sort(function(a,b){ return new Date(b.time).getTime() - new Date(a.time).getTime(); });
  var visibleEvents = events.slice(0,8);
  var visible = visibleEvents.map(function(event){
    var href = getActivityHref(event);
    var priority = getActivityPriority(event);
    var badge = '<span class="activity-priority-badge priority-' + escapeHtml(priority) + '">' + escapeHtml(getActivityPriorityLabel(priority)) + '</span>';
    var content = '<div class="activity-feed-time">' + badge + '</div><div class="activity-feed-text">' + decorateFeedMessage(event) + '</div>';
    if(href){
      return '<div class="activity-feed-item activity-feed-item--clickable activity-priority-' + escapeHtml(priority) + '" role="link" tabindex="0" data-href="' + escapeHtml(href) + '"><a class="activity-feed-link" href="' + escapeHtml(href) + '">' + content + '</a></div>';
    }
    return '<div class="activity-feed-item activity-priority-' + escapeHtml(priority) + '">' + content + '</div>';
  }).join('');
  if(visible !== __liveActivityLastHtml){
    list.innerHTML = visible;
    __liveActivityLastHtml = visible;
  }
  try{ if(window.__zummeeMarkLiveActivityReady) window.__zummeeMarkLiveActivityReady(); }catch(_e0){}

  try{
    Array.prototype.forEach.call(list.querySelectorAll('.activity-feed-item--clickable'), function(row){
      if(row.dataset.boundClick === '1') return;
      row.dataset.boundClick = '1';
      row.addEventListener('click', function(e){
        if(e.target && e.target.closest('a')) return;
        var href = row.getAttribute('data-href');
        if(href) window.location.href = href;
      });
      row.addEventListener('keydown', function(e){
        if(e.key === 'Enter' || e.key === ' '){
          e.preventDefault();
          var href = row.getAttribute('data-href');
          if(href) window.location.href = href;
        }
      });
    });
  }catch(_e){}

  var footer = document.getElementById('activityFeedFooter');
  if(footer && !footer.dataset.boundLiveActivity){
    footer.dataset.boundLiveActivity = '1';
    footer.addEventListener('click', function(){
      window.location.href = 'activity_history.html';
    });
  }
  __liveActivityLoading = false;
  if(__liveActivityQueued){
    __liveActivityQueued = false;
    scheduleLiveActivityRefresh(220);
  }
}

var activityChannel = null;
  async function setupLiveActivityRealtime(){
    try{
      var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
      if(!sb || typeof sb.channel !== 'function') return;
      if(activityChannel && typeof sb.removeChannel === 'function'){
        try{ sb.removeChannel(activityChannel); }catch(_e){}
      }
      activityChannel = sb.channel('manager-hub-live-activity');
      ['notification_events','EmergencyTextLogs','BoardMeetingMinutesApprovals','resident_work_orders'].forEach(function(table){
        try{
          activityChannel.on('postgres_changes', { event:'*', schema:'public', table:table }, function(){ scheduleLiveActivityRefresh(300); });
        }catch(_e){}
      });
      if(typeof activityChannel.subscribe === 'function') activityChannel.subscribe();
    }catch(_e){}
  }

  function schedule(){
    if(window.__liveActivityInitDone) return;
    window.__liveActivityInitDone = true;
    loadLiveActivity();
    setupLiveActivityRealtime();
    setInterval(function(){ scheduleLiveActivityRefresh(300); }, 300000);
    ['focus','community:changed','profile:loaded','resident-work-orders:changed'].forEach(function(evt){
      window.addEventListener(evt, function(){ scheduleLiveActivityRefresh(evt === 'focus' ? 200 : 450); });
      document.addEventListener(evt, function(){ scheduleLiveActivityRefresh(450); });
    });
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', schedule, { once:true });
  else schedule();

  document.addEventListener('change', function(e){
    try{
      if(e && e.target && e.target.id === 'zummeeCommunitySelect'){
        scheduleLiveActivityRefresh(120);
        setTimeout(function(){
          try{ scheduleLiveActivityRefresh(420); }catch(_e2){}
        }, 420);
      }
    }catch(_e){}
  });
})();
</script>


<script>
(function(){
  var WEATHER_VIEW_KEY = 'zummee_manager_hub_weather_view';

  function defaultWeatherView(){
    var width = window.innerWidth || document.documentElement.clientWidth || 0;
    if(width >= 760 && width <= 1180) return 'compact';
    return 'expanded';
  }

  function readWeatherView(){
    try{
      var saved = localStorage.getItem(WEATHER_VIEW_KEY);
      if(saved === 'compact' || saved === 'expanded') return saved;
    }catch(_e){}
    return defaultWeatherView();
  }

  function writeWeatherView(view){
    try{ localStorage.setItem(WEATHER_VIEW_KEY, view); }catch(_e){}
  }

  function applyWeatherView(view){
    var card = document.getElementById('weatherHubCard');
    var compactBtn = document.getElementById('weatherCompactBtn');
    var expandedBtn = document.getElementById('weatherExpandedBtn');
    if(!card || !compactBtn || !expandedBtn) return;
    var nextView = view === 'compact' ? 'compact' : 'expanded';
    card.classList.toggle('weather-view-compact', nextView === 'compact');
    card.classList.toggle('weather-view-expanded', nextView === 'expanded');
    compactBtn.classList.toggle('is-active', nextView === 'compact');
    expandedBtn.classList.toggle('is-active', nextView === 'expanded');
    compactBtn.setAttribute('aria-pressed', nextView === 'compact' ? 'true' : 'false');
    expandedBtn.setAttribute('aria-pressed', nextView === 'expanded' ? 'true' : 'false');
  }

  function bindWeatherViewToggle(){
    var compactBtn = document.getElementById('weatherCompactBtn');
    var expandedBtn = document.getElementById('weatherExpandedBtn');
    if(!compactBtn || !expandedBtn) return;
    compactBtn.addEventListener('click', function(){ writeWeatherView('compact'); applyWeatherView('compact'); });
    expandedBtn.addEventListener('click', function(){ writeWeatherView('expanded'); applyWeatherView('expanded'); });
    applyWeatherView(readWeatherView());
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', bindWeatherViewToggle, { once:true });
  } else {
    bindWeatherViewToggle();
  }
})();
</script>

<script>
(function(){
  function syncWeatherMobileLayout(){
    var metaRow = document.querySelector('.weather-meta-row');
    var controls = document.querySelector('.weather-controls-right');
    var risk = document.getElementById('weatherRiskBadge');
    if(!metaRow || !controls || !risk) return;

    var mobileClone = document.getElementById('weatherRiskBadgeMobile');
    var isMobile = window.matchMedia('(max-width: 760px)').matches;

    if(isMobile){
      if(!mobileClone){
        mobileClone = risk.cloneNode(true);
        mobileClone.id = 'weatherRiskBadgeMobile';
        mobileClone.classList.add('weather-risk-mobile');
      }
      if(metaRow.lastElementChild !== mobileClone){
        metaRow.appendChild(mobileClone);
      }
      if(risk.style.display !== 'none') risk.style.display = 'none';
    } else {
      if(mobileClone && mobileClone.parentNode) mobileClone.parentNode.removeChild(mobileClone);
      risk.style.display = '';
    }
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', syncWeatherMobileLayout, {once:true});
  } else {
    syncWeatherMobileLayout();
  }
  window.addEventListener('resize', syncWeatherMobileLayout);
})();
</script>

<script id="manager-board-items-panel-script">
(function(){
  function safeGetLS(k){ try{ return String(localStorage.getItem(k)||'').trim(); }catch(_e){ return ''; } }
  function getActiveCommunityId(){
    return (window.getActiveCommunityId && window.getActiveCommunityId()) || safeGetLS('zummee_selected_community_id') || safeGetLS('activeCommunityId') || safeGetLS('zummeeActiveCommunityId') || safeGetLS('currentCommunityId') || safeGetLS('zummee_community_id');
  }
  function getActiveCompanyId(){
    return safeGetLS('zummee_selected_company_id') || safeGetLS('activeCompanyId') || safeGetLS('zummee_company_id');
  }
  function esc(v){
    return String(v == null ? '' : v)
      .replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;')
      .replaceAll('"','&quot;').replaceAll("'",'&#39;');
  }
  function stripMarkers(details){
    var t = String(details || '');
    t = t.replace(/\n\n__ZUMMEE_BM_STATUS__:[\s\S]*$/i,'');
    t = t.replace(/\n\n__ZUMMEE_BM_PHOTO__:[^\n]+\s*/ig,'');
    t = t.replace(/\n\n__ZUMMEE_BM_CONVERTED__:[^\n]+\s*/ig,'');
    return t.trim();
  }
  function parsePhoto(details){
    try{
      var t = String(details||'');
      var m = t.match(/__ZUMMEE_BM_PHOTO__:\s*([^\n]+)\s*/i);
      if(!m) return null;
      var obj = JSON.parse(String(m[1]||'').trim());
      if(!obj || !obj.bucket || !obj.path) return null;
      return { bucket:String(obj.bucket), path:String(obj.path) };
    }catch(_e){ return null; }
  }
  function parseConverted(details){
    try{
      var t = String(details||'');
      var m = t.match(/__ZUMMEE_BM_CONVERTED__:\s*RWO\|([^|\n]+)\|([^\n]+)/i);
      if(!m) return null;
      return { work_order_id:String(m[1]||''), iso:String(m[2]||'') };
    }catch(_e){ return null; }
  }
  function withConverted(details, workOrderId){
    var base = String(details || '').replace(/\n\n__ZUMMEE_BM_CONVERTED__:[^\n]+\s*/ig,'').trimEnd();
    return base + "\n\n__ZUMMEE_BM_CONVERTED__:RWO|" + String(workOrderId||'') + "|" + new Date().toISOString() + "\n";
  }
  function isCompleteRow(r){
    try{
      if(r && r.completed_at) return true;
      var st = String((r && r.status) || '').trim().toLowerCase();
      if(st && ['complete','completed','closed','done','resolved'].includes(st)) return true;
      return /__ZUMMEE_BM_STATUS__:\s*COMPLETE\|/i.test(String((r && r.details)||''));
    }catch(_e){ return false; }
  }
  function photoPublicUrl(meta){
    try{
      if(!meta || !meta.bucket || !meta.path) return '';
      var base = (window.sb && window.sb.supabaseUrl) ? String(window.sb.supabaseUrl) : 'https://slcwuuwyrgnmlmxpcaim.supabase.co';
      return base.replace(/\/$/,'') + '/storage/v1/object/public/' + encodeURIComponent(String(meta.bucket)) + '/' + String(meta.path).split('/').map(encodeURIComponent).join('/');
    }catch(_e){ return ''; }
  }
  async function createWorkOrderFromBoardItem(row){
    var btn = document.querySelector('[data-create-board-item="'+String(row.id)+'"]');
    try{
      if(btn){ btn.disabled = true; btn.textContent = 'Creating…'; }
      var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
      if(!sb || typeof sb.from !== 'function') throw new Error('Supabase client unavailable.');
      var session = await sb.auth.getSession();
      var user = session && session.data && session.data.session ? session.data.session.user : null;

      var currentEmployeeEmail = String((user && user.email) || '').trim();
      var currentEmployeeName = String((user && user.email) || 'Manager').trim();
      if(user && user.id){
        try{
          var profRes = await sb
            .from('userdirectory')
            .select('profile_name, profile_email')
            .eq('auth_user_id', user.id)
            .maybeSingle();
          if(profRes && !profRes.error && profRes.data){
            currentEmployeeEmail = String(profRes.data.profile_email || currentEmployeeEmail || '').trim();
            currentEmployeeName = String(profRes.data.profile_name || currentEmployeeName || '').trim();
          }
        }catch(_employeeSnapshotErr){}
      }

      var companyId = getActiveCompanyId();
      if(!companyId){
        try{
          var q = await sb.from('PropertyCommunities').select('company_id').eq('id', row.community_id).maybeSingle();
          companyId = q && q.data && q.data.company_id ? String(q.data.company_id) : '';
        }catch(_e){}
      }

      var photoMeta = parsePhoto(row.details);
      var photoUrl = photoPublicUrl(photoMeta);
      var description = stripMarkers(row.details || '');
      if(photoUrl){
        description += (description ? "\n\n" : '') + 'Board photo: ' + photoUrl;
      }

      var payload = {
        company_id: companyId || null,
        community_id: row.community_id,
        resident_name: 'Board Member Request',
        unit_number: 'Board',
        resident_email: ('board-item+' + String(row.id || Date.now()) + '@zummee.local'),
        resident_phone: '',
        internal_notes: ('Created from Board Member Action Item ' + String(row.id || '') + (photoUrl ? ('\nBoard photo: ' + photoUrl) : '')),
        subject: row.title || 'Board Member Action Item',
        description: description,
        category: 'general',
        priority: 'normal',
        status: 'submitted',

        // Employee reporting snapshot (long-term fix)
        employee_user_id: (user && user.id) || null,
        employee_email: currentEmployeeEmail || null,
        employee_name: currentEmployeeName || null
      };

      var ins = await sb.from('resident_work_orders').insert([payload]).select().single();
      if(ins && ins.error) throw ins.error;
      var created = ins && ins.data ? ins.data : null;

      var nextDetails = withConverted(String(row.details||''), created && created.id ? created.id : '');
      var upd = await sb.from('BoardMemberActionItems').update({ details: nextDetails }).eq('id', row.id).eq('community_id', row.community_id);
      if(upd && upd.error) throw upd.error;

      try{
        if(created && created.id){
          window.location.href = 'resident_work_orders.html?open_work_order_id=' + encodeURIComponent(String(created.id));
          return;
        }
      }catch(_e){}
      await loadBoardItemsPanel();
    }catch(err){
      alert('Could not create work order. ' + ((err && (err.message||err.details||err.hint||err.code)) ? (err.message||err.details||err.hint||err.code) : 'Unknown error'));
      if(btn){ btn.disabled = false; btn.textContent = 'Create Work Order'; }
    }
  }
  function renderBoardItemsPanel(rows){
    var body = document.getElementById('managerBoardItemsBody');
    if(!body) return;
    var active = (rows || []).filter(function(r){
      return !isCompleteRow(r) && !parseConverted(r.details || '');
    });
    if(!active.length){
      body.innerHTML = '<div class="board-items-panel__empty">No new board-submitted items for this community.</div>';
      return;
    }
    body.innerHTML = active.slice(0,5).map(function(row){
      var meta = [];
      if(row.created_at) {
        try{ meta.push('Submitted: ' + new Date(row.created_at).toLocaleString()); }catch(_e){}
      }
      if(row.due_date) meta.push('Due: ' + String(row.due_date));
      var desc = esc(stripMarkers(row.details||'')).slice(0,220);
      if(desc.length >= 220) desc += '…';
      return '<div class="board-items-row">' +
        '<div>' +
          '<div class="board-items-row__title">' + esc(row.title || 'Untitled Item') + '</div>' +
          '<div class="board-items-row__meta">' + esc(meta.join(' • ')) + '</div>' +
          (desc ? '<div class="board-items-row__desc">' + desc + '</div>' : '') +
        '</div>' +
        '<div class="board-items-row__actions">' +
          '<a class="board-items-btn" href="board_member_hub.html">View Item</a>' +
          '<button type="button" class="board-items-btn primary" data-create-board-item="' + esc(String(row.id)) + '">Create Work Order</button>' +
        '</div>' +
      '</div>';
    }).join('');
    body.querySelectorAll('[data-create-board-item]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var id = String(btn.getAttribute('data-create-board-item') || '');
        var row = (rows || []).find(function(r){ return String(r.id) === id; });
        if(row) createWorkOrderFromBoardItem(row);
      });
    });
  }
  async function loadBoardItemsPanel(){
    var body = document.getElementById('managerBoardItemsBody');
    if(!body) return;
    var communityId = getActiveCommunityId();
    if(!communityId){
      body.innerHTML = '<div class="board-items-panel__empty">Select a community in the header to see board-submitted items.</div>';
      return;
    }
    try{
      var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
      if(!sb || typeof sb.from !== 'function'){
        body.innerHTML = '<div class="board-items-panel__empty">Unable to load board items right now.</div>';
        return;
      }
      var q = await sb.from('BoardMemberActionItems').select('id,community_id,title,details,due_date,created_at,status,completed_at').eq('community_id', communityId).order('created_at', { ascending:false }).limit(50);
      if(q && q.error) throw q.error;
      renderBoardItemsPanel((q && q.data) ? q.data : []);
    }catch(err){
      body.innerHTML = '<div class="board-items-panel__empty">Unable to load board items.</div>';
    }
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', loadBoardItemsPanel);
  else loadBoardItemsPanel();
  document.addEventListener('community:changed', function(){ setTimeout(loadBoardItemsPanel, 150); });
  window.addEventListener('focus', function(){ setTimeout(loadBoardItemsPanel, 150); });
})();
</script>

<!-- MANAGER BOARD ITEM CREATE WORK ORDER EMAIL FIX -->

<!-- LIVE ACTIVITY BOARD CLICKABLE REPAIR -->

<!-- FIX_MAINTENANCE_REQUEST_EVENTS_V2 -->

<!-- FIX_RESIDENT_WORK_ORDERS_SUBMITTED_AT -->

<!-- FIX_EMERGENCY_SCHEDULED_ALERTS_404 -->

<!-- LIVE_ACTIVITY_TO_WORK_ORDER -->
<script id="live-activity-board-click-hardfix">
window.__openBoardLiveActivityWorkOrder = async function(boardItemId){
  try{
    if(!boardItemId) return;
    var sb = window.sb || (window.ensureSupabase ? await window.ensureSupabase() : null);
    if(!sb) return;

    var q = await sb.from('BoardMemberActionItems')
      .select('id,community_id,title,details,due_date,created_at')
      .eq('id', boardItemId)
      .maybeSingle();

    if(q && q.error) throw q.error;
    var row = q && q.data ? q.data : null;
    if(!row) return;

    var existingId = null;
    try{
      existingId = parseConverted(row.details || '');
    }catch(_e){}

    if(existingId){
      window.location.href = 'resident_work_orders.html?open_work_order_id=' + encodeURIComponent(String(existingId));
      return;
    }

    if (typeof createWorkOrderFromBoardItem === 'function') {
      await createWorkOrderFromBoardItem(row);
      return;
    }

    // fallback: go to board panel if creator is unavailable
    window.location.href = 'index.html#managerBoardItemsPanel';
  }catch(err){
    try{ alert('Could not open board work order. ' + ((err && (err.message||err.details||err.hint||err.code)) ? (err.message||err.details||err.hint||err.code) : 'Unknown error')); }catch(_e){}
  }
};
</script>

<!-- LIVE_ACTIVITY_BOARD_CLICK_HARDFIX -->

<!-- LIVE_ACTIVITY_BOARD_CLICK_HARDFIX_V2 -->

<!-- LIVE_ACTIVITY_BOARD_CLICK_HARDFIX_V3 -->

<script>
(function(){
  function getSbClient(){ try{ return window.sb || window.supabaseClient || window.supabase || null; }catch(_e){ return null; } }
  function parseSupabaseSession(){
    function extract(o){
      try{
        if(!o) return null;
        if(o.user && o.user.id) return { id:o.user.id, email:(o.user.email||'') };
        if(o.currentSession && o.currentSession.user && o.currentSession.user.id) return { id:o.currentSession.user.id, email:(o.currentSession.user.email||'') };
        if(o.session && o.session.user && o.session.user.id) return { id:o.session.user.id, email:(o.session.user.email||'') };
      }catch(_e){}
      return null;
    }
    function scan(store){
      try{
        for(var i=0;i<store.length;i++){
          var key = store.key(i);
          if(!key) continue;
          if(!(key === 'sb-zummee-auth' || /^sb-.*-auth-token$/.test(key))) continue;
          var raw = null;
          try{ raw = store.getItem(key); }catch(_e){}
          if(!raw) continue;
          var obj = null;
          try{ obj = JSON.parse(raw); }catch(_e2){}
          var ex = extract(obj);
          if(ex && ex.id) return ex;
        }
      }catch(_e3){}
      return null;
    }
    try{ return scan(localStorage) || scan(sessionStorage) || { id:'', email:'' }; }catch(_e4){ return { id:'', email:'' }; }
  }
  function esc(v){ return String(v || '').replace(/[&<>"]/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[ch]; }); }
  function getApprovalQueueKey(){ return 'zummee_annual_packet_approval_queue_v1'; }
  function getActivityKey(){ return 'zummee_manager_live_activity_v1'; }
  function getAnnouncementsKey(communityId){ return 'zummee_resident_announcements_v1__' + String(communityId || '').trim(); }
  function loadLocalQueue(){ try{ return JSON.parse(localStorage.getItem(getApprovalQueueKey()) || '[]') || []; }catch(_e){ return []; } }
  function saveLocalQueue(list){ try{ localStorage.setItem(getApprovalQueueKey(), JSON.stringify(Array.isArray(list)?list:[])); }catch(_e){} }
  function pushLocalActivity(item){ try{ var list = JSON.parse(localStorage.getItem(getActivityKey()) || '[]') || []; list.unshift(item); localStorage.setItem(getActivityKey(), JSON.stringify(list.slice(0,30))); }catch(_e){} }
  async function loadPendingApprovals(){
    var sb = getSbClient();
    var activeCommunityId = String(localStorage.getItem('zummeeActiveCommunityId') || localStorage.getItem('activeCommunityId') || '').trim();
    var allowed = ['approved_ready_to_send','sent_to_admin','mailed'];
    if(sb && sb.from){
      try{
        var q = await sb.from('annual_meeting_packet_requests').select('*').in('status', allowed).order('submitted_at', {ascending:false});
        var rows = (q && Array.isArray(q.data)) ? q.data : [];
        if(activeCommunityId){
          rows = rows.filter(function(item){
            return String((item && item.community_id) || '') === activeCommunityId;
          });
        }
        return rows;
      }catch(_e){}
    }
    return loadLocalQueue().filter(function(item){
      var st = String((item && item.status) || '').toLowerCase();
      var ok = allowed.indexOf(st) !== -1;
      if(!ok) return false;
      if(!activeCommunityId) return true;
      return String((item && item.community_id) || '') === activeCommunityId;
    });
  }
  async function loadActivityEventsForCurrentUser(){
    var me = parseSupabaseSession();
    var sb = getSbClient();
    if(sb && sb.from && me.id){
      try{
        var q = await sb.from('annual_meeting_activity_events').select('*').eq('target_user_id', me.id).order('created_at', {ascending:false}).limit(5);
        if(q && Array.isArray(q.data)) return q.data;
      }catch(_e){}
    }
    return (JSON.parse(localStorage.getItem(getActivityKey()) || '[]') || []).filter(function(item){ return !item.target_user_id || String(item.target_user_id) === String(me.id || ''); }).slice(0,5);
  }
  async function publishApprovedAnnouncement(item){
    var payload = item && item.packet_payload ? item.packet_payload : {};
    var record = {
      type: 'annual_meeting_notice',
      community_id: item.community_id,
      title: 'Annual Meeting Notice',
      body: 'The Annual Meeting has been approved and posted. Residents can view the notice details and join the meeting from the portal.',
      meeting_link: String((payload && payload.meetingLink) || '').trim(),
      meeting_date: String((payload && payload.nextAnnualMeetingDate) || '').trim(),
      meeting_time: String((payload && payload.meetingTime) || '').trim(),
      nomination_deadline: String((payload && payload.nominationDeadline) || '').trim(),
      proxy_return_deadline: String((payload && payload.proxyReturnDeadline) || '').trim(),
      association_legal_name: String((payload && payload.associationLegalName) || (payload && payload.communityName) || '').trim(),
      community_name: String((payload && payload.communityName) || '').trim(),
      meeting_format: String((payload && payload.meetingFormat) || '').trim(),
      meeting_location: String((payload && payload.meetingLocation) || '').trim(),
      created_at: new Date().toISOString(),
      expires_at: String((payload && payload.nextAnnualMeetingDate) || '').trim()
    };
    try{
      var list = JSON.parse(localStorage.getItem(getAnnouncementsKey(item.community_id)) || '[]') || [];
      list = Array.isArray(list) ? list.filter(function(x){ return String((x && x.type) || '') !== 'annual_meeting_notice'; }) : [];
      list.unshift(record);
      localStorage.setItem(getAnnouncementsKey(item.community_id), JSON.stringify(list.slice(0,10)));
    }catch(_e){}
    var sb = getSbClient();
    if(sb && sb.from){
      try{
        await sb.from('community_announcements').delete().eq('community_id', item.community_id).eq('type', 'annual_meeting_notice');
      }catch(_e2){}
      try{
        await sb.from('community_announcements').insert([record]);
      }catch(_e3){}
    }
  }
  async function writeApprovedActivity(item){
    var event = {
      event_type: 'annual_packet_approved',
      title: 'Annual Meeting Documents approved by supervisor',
      detail: String(item.community_name || 'Community') + ' documents approved and resident packet set created.',
      company_id: item.company_id || null,
      community_id: item.community_id || null,
      community_name: item.community_name || '',
      actor_user_id: parseSupabaseSession().id || '',
      actor_name: 'Supervisor Approval',
      target_user_id: item.employee_user_id || '',
      created_at: new Date().toISOString()
    };
    pushLocalActivity(event);
    var sb = getSbClient();
    if(sb && sb.from){
      try{ await sb.from('annual_meeting_activity_events').insert([event]); }catch(_e){}
    }
    try{
      var feed = document.getElementById('activityFeedList');
      if(feed){
        feed.innerHTML = '<div class="activity-feed-item"><div class="activity-feed-time">Just now</div><div class="activity-feed-text">Annual Meeting Documents approved for ' + esc(item.community_name || 'Community') + '</div></div>' + feed.innerHTML;
      }
    }catch(_e2){}
  }
  async function renderCustomActivityFeed(){
    try{
      var feed = document.getElementById('activityFeedList');
      if(!feed) return;
      var events = await loadActivityEventsForCurrentUser();
      if(!events.length) return;
      var html = events.map(function(ev){
        var ts = '';
        try{ ts = new Date(ev.created_at || Date.now()).toLocaleString(); }catch(_e){ ts = 'Recent'; }
        return '<div class="activity-feed-item"><div class="activity-feed-time">' + esc(ts) + '</div><div class="activity-feed-text">' + esc(ev.title || ev.detail || 'Activity update') + '</div></div>';
      }).join('');
      feed.innerHTML = html + feed.innerHTML;
    }catch(_e){}
  }
  async function renderAnnualApprovalQueue(){
    try{
      var body = document.getElementById('annualApprovalBody');
      if(!body) return;
      var rows = await loadPendingApprovals();
      if(!rows.length){
        body.innerHTML = '<div class="board-items-panel__empty">No annual meeting approvals pending.</div>';
        return;
      }
      body.innerHTML = rows.map(function(item){
        var when = '';
        try{ when = new Date(item.submitted_at || Date.now()).toLocaleString(); }catch(_e){ when = 'Recent'; }
        return '<div class="annual-approval-row"><div><div class="annual-approval-row__title">' + esc(item.community_name || 'Community') + '</div><div class="annual-approval-row__meta">Submitted by ' + esc(item.employee_name || item.employee_email || 'Employee') + ' • ' + esc(when) + '</div><div class="annual-approval-row__desc">Review the draft packet, then approve to generate resident-ready documents for ' + esc(item.resident_count || 0) + ' resident' + (Number(item.resident_count || 0)===1?'':'s') + '.</div></div><div class="annual-approval-row__actions"><button class="board-items-btn" type="button" data-annual-preview="' + esc(item.id) + '">Preview Draft TEST</button><button class="board-items-btn primary" type="button" data-annual-approve="' + esc(item.id) + '">Approve Documents</button></div></div>';
      }).join('');
    }catch(_e){}
  }
  async function getApprovalById(id){
    var sb = getSbClient();
    if(sb && sb.from){
      try{
        var q = await sb.from('annual_meeting_packet_requests').select('*').eq('id', id).maybeSingle();
        if(q && q.data) return q.data;
      }catch(_e){}
    }
    return loadLocalQueue().find(function(item){ return String(item.id) === String(id); }) || null;
  }
  function ensureAnnualApprovalPreviewModal(){
    var modal = document.getElementById('annualApprovalPreviewModal');
    if(modal) return modal;
    modal = document.createElement('div');
    modal.id = 'annualApprovalPreviewModal';
    modal.setAttribute('aria-hidden', 'true');
    modal.style.cssText = 'position:fixed;inset:0;z-index:100000;display:none;align-items:center;justify-content:center;background:rgba(8,20,35,.62);backdrop-filter:blur(6px);padding:24px;';
    modal.innerHTML = ''
      + '<div style="width:min(1120px,100%);height:min(88vh,900px);background:#fff;border-radius:26px;overflow:hidden;box-shadow:0 26px 70px rgba(8,20,35,.35);display:flex;flex-direction:column;">'
      +   '<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(15,47,74,.08);background:linear-gradient(180deg,#f7fbff,#eef5fb);">'
      +     '<div>'
      +       '<div style="font:800 11px/1.2 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;letter-spacing:.12em;text-transform:uppercase;color:#6a8198;">Annual Meeting</div>'
      +       '<div id="annualApprovalPreviewModalTitle" style="font:800 24px/1.15 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#17324d;">Packet Preview</div>'
      +     '</div>'
      +     '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">'
      +       '<button id="annualApprovalPreviewOpenTab" type="button" style="border:1px solid rgba(15,47,74,.12);background:#fff;color:#17324d;border-radius:999px;padding:10px 16px;font:800 14px/1 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;cursor:pointer;">Open in New Tab</button>'
      +       '<button id="annualApprovalPreviewClose" type="button" style="border:0;background:#17324d;color:#fff;border-radius:999px;padding:10px 16px;font:800 14px/1 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;cursor:pointer;">Close</button>'
      +     '</div>'
      +   '</div>'
      +   '<div id="annualApprovalPreviewStatus" style="display:none;padding:12px 18px;border-bottom:1px solid rgba(15,47,74,.08);font:700 14px/1.3 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#17324d;background:#f6fbff;"></div>'
      +   '<iframe id="annualApprovalPreviewFrame" title="Annual Meeting Packet Preview" style="width:100%;height:100%;border:0;background:#fff;"></iframe>'
      + '</div>';
    document.body.appendChild(modal);

    function closeModal(){
      modal.style.display = 'none';
      modal.setAttribute('aria-hidden', 'true');
      try{ document.getElementById('annualApprovalPreviewFrame').srcdoc = ''; }catch(_e){}
    }

    modal.addEventListener('click', function(e){ if(e.target === modal) closeModal(); });
    document.getElementById('annualApprovalPreviewClose').addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape' && modal.style.display !== 'none') closeModal();
    });

    modal.__open = function(html, title){
      document.getElementById('annualApprovalPreviewModalTitle').textContent = title || 'Packet Preview';
      var status = document.getElementById('annualApprovalPreviewStatus');
      var frame = document.getElementById('annualApprovalPreviewFrame');
      status.style.display = 'none';
      status.textContent = '';
      frame.srcdoc = String(html || '');
      modal.style.display = 'flex';
      modal.setAttribute('aria-hidden', 'false');
      try{ document.getElementById('annualApprovalPreviewClose').focus(); }catch(_e){}
    };

    return modal;
  }


  function parseApprovalPayload(item){
    try{
      var payload = item && item.packet_payload ? item.packet_payload : {};
      if(typeof payload === 'string') payload = JSON.parse(payload || '{}');
      return payload && typeof payload === 'object' ? payload : {};
    }catch(_e){ return {}; }
  }
  function buildPreviewDataFromItem(item){
    var payload = parseApprovalPayload(item);
    var html = '';
    if(item && item.preview_html) html = String(item.preview_html || '').trim();
    if(!html && payload){
      html = String(
        payload.preview_html ||
        payload.previewHtml ||
        payload.html_preview ||
        payload.htmlPreview ||
        payload.packet_html ||
        payload.packetHtml ||
        ''
      ).trim();
    }

    var pdfData = '';
    var pdfName = '';
    if(payload){
      var pdfAttachment = payload.pdf_attachment || payload.pdfAttachment || payload.attachment || null;
      if(typeof pdfAttachment === 'string'){
        pdfData = String(pdfAttachment).trim();
      }else if(pdfAttachment && typeof pdfAttachment === 'object'){
        pdfData = String(pdfAttachment.base64 || pdfAttachment.data || pdfAttachment.content || pdfAttachment.url || '').trim();
        pdfName = String(pdfAttachment.filename || pdfAttachment.name || '').trim();
      }
      if(!pdfData){
        pdfData = String(
          payload.packet_base64 ||
          payload.packetBase64 ||
          payload.pdf_base64 ||
          payload.pdfBase64 ||
          payload.base64 ||
          ''
        ).trim();
      }
      if(!pdfName){
        pdfName = String(payload.packet_filename || payload.packetFilename || payload.pdf_filename || payload.pdfFilename || '').trim();
      }
    }

    return { html: html, pdfData: pdfData, pdfName: pdfName };
  }
  function normalizeDataUrl(input, mime){
    var raw = String(input || '').trim();
    if(!raw) return '';
    if(/^data:/i.test(raw)) return raw;
    return 'data:' + (mime || 'application/pdf') + ';base64,' + raw.replace(/\s+/g,'');
  }

  async function openApprovalPreview(id){
    var item = await getApprovalById(id);
    if(!item){
      try{ alert('Preview is not available for this approval.'); }catch(_e){}
      return;
    }

    var modal = ensureAnnualApprovalPreviewModal();
    var title = (item.community_name || 'Community') + ' Packet Preview';
    var openBtn = document.getElementById('annualApprovalPreviewOpenTab');
    var frame = document.getElementById('annualApprovalPreviewFrame');
    var status = document.getElementById('annualApprovalPreviewStatus');
    var previewData = buildPreviewDataFromItem(item);
    var html = String(previewData.html || '').trim();
    var pdfData = String(previewData.pdfData || '').trim();

    function setOpenTabHandler(fn){
      if(!openBtn) return;
      openBtn.onclick = fn || function(){};
    }

    modal.style.display = 'flex';
    modal.setAttribute('aria-hidden', 'false');
    document.getElementById('annualApprovalPreviewModalTitle').textContent = title;

    if(html){
      if(status){ status.style.display = 'none'; status.textContent = ''; }
      if(frame){
        frame.removeAttribute('src');
        frame.srcdoc = html;
      }
      setOpenTabHandler(function(){
        try{
          var blob = new Blob([html], { type:'text/html' });
          var url = URL.createObjectURL(blob);
          window.open(url, '_blank', 'noopener');
          setTimeout(function(){ try{ URL.revokeObjectURL(url); }catch(_e){} }, 60000);
        }catch(_e){
          try{
            var win = window.open('', '_blank');
            if(win){
              win.document.open();
              win.document.write(html);
              win.document.close();
            }
          }catch(_e2){}
        }
      });
      try{ document.getElementById('annualApprovalPreviewClose').focus(); }catch(_eFocus){}
      return;
    }

    if(pdfData){
      var dataUrl = normalizeDataUrl(pdfData, 'application/pdf');
      if(status){
        status.style.display = 'block';
        status.textContent = 'Showing the stored PDF packet for this approval.';
      }
      if(frame){
        frame.srcdoc = '';
        frame.src = dataUrl;
      }
      setOpenTabHandler(function(){
        try{ window.open(dataUrl, '_blank', 'noopener'); }catch(_e){}
      });
      try{ document.getElementById('annualApprovalPreviewClose').focus(); }catch(_eFocus2){}
      return;
    }

    if(status){
      status.style.display = 'block';
      status.textContent = 'Preview is not available for this approval yet.';
    }
    if(frame){
      frame.removeAttribute('src');
      frame.srcdoc = '<div style="padding:32px;font:700 16px/1.5 system-ui,-apple-system,Segoe UI,Roboto,sans-serif;color:#17324d;">Preview is not available for this approval yet.</div>';
    }
    setOpenTabHandler(function(){});
    try{ document.getElementById('annualApprovalPreviewClose').focus(); }catch(_eFocus3){}
  }
  async function approveRequest(id){
    var item = await getApprovalById(id);
    if(!item) return;
    var sb = getSbClient();
    if(sb && sb.from){
      try{
        await sb.from('annual_meeting_packet_requests').update({
          status:'approved',
          approved_at:new Date().toISOString(),
          approved_by: parseSupabaseSession().id || null
        }).eq('id', id);
      }catch(_e){}
    }
    try{
      var local = loadLocalQueue();
      local = local.map(function(x){ if(String(x.id)===String(id)){ x.status='approved'; x.approved_at=new Date().toISOString(); x.approved_by=parseSupabaseSession().id || ''; } return x; });
      saveLocalQueue(local);
      var packets = JSON.parse(localStorage.getItem('zummee_resident_packets_v1') || '{}') || {};
      packets[String(item.community_id)] = {
        approved_at: new Date().toISOString(),
        approved_by: parseSupabaseSession().id || '',
        resident_count: Number(item.resident_count || 0),
        community_name: item.community_name || '',
        employee_user_id: item.employee_user_id || '',
        packet_payload: item.packet_payload || {}
      };
      localStorage.setItem('zummee_resident_packets_v1', JSON.stringify(packets));
    }catch(_e2){}
    await publishApprovedAnnouncement(item);
    await writeApprovedActivity(item);
    await renderAnnualApprovalQueue();
    try{ alert('Annual Meeting Documents approved.'); }catch(_e3){}
  }
  document.addEventListener('click', function(e){
    var preview = e.target && e.target.closest ? e.target.closest('[data-annual-preview]') : null;
    if(preview){ e.preventDefault(); openAnnualMeetingPacketPreviewForRecord(preview.getAttribute('data-annual-preview')); return; }
    var approve = e.target && e.target.closest ? e.target.closest('[data-annual-approve]') : null;
    if(approve){ e.preventDefault(); approveRequest(approve.getAttribute('data-annual-approve')); return; }
  });
  document.addEventListener('DOMContentLoaded', function(){
    renderAnnualApprovalQueue();
    renderCustomActivityFeed();
  });
})();
</script>


<script id="manager-board-hub-status-v78">
(function(){
  function esc(v){
    return String(v || '').replace(/[&<>"]/g, function(ch){
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[ch];
    });
  }
  function getSb(){
    try{
      if(typeof ensureSupabaseSync === 'function'){
        var sb0 = ensureSupabaseSync();
        if(sb0 && typeof sb0.from === 'function') return sb0;
      }
    }catch(_e){}
    try{
      var sb = window.sb || window.supabaseClient || window.supabase;
      if(sb && typeof sb.from === 'function') return sb;
    }catch(_e2){}
    return null;
  }
  function getSelectedCommunityId(){
    try{
      if(window.ZummeeAuth && typeof window.ZummeeAuth.getSelectedCommunityId === 'function'){
        var zid = String(window.ZummeeAuth.getSelectedCommunityId() || '').trim();
        if(zid) return zid;
      }
    }catch(_e){}
    try{
      return String(
        localStorage.getItem('activeCommunityId')
        || localStorage.getItem('zummee_selected_community_v1')
        || localStorage.getItem('currentCommunityId')
        || ''
      ).trim();
    }catch(_e2){
      return '';
    }
  }
  function statusPill(status){
    var st = String(status || '').toLowerCase();
    if(st === 'pending_board_approval'){
      return '<span class="pill" style="background:rgba(185,28,28,.10);color:#9a3412;border:1px solid rgba(185,28,28,.18);">Awaiting Board</span>';
    }
    if(st === 'pending_supervisor_approval'){
      return '<span class="pill" style="background:#dbeafe;color:#17324d;border:1px solid #bfdbfe;">Awaiting Supervisor</span>';
    }
    if(st === 'approved_ready_to_send'){
      return '<span class="pill" style="background:#fef3c7;color:#92400e;border:1px solid #fde68a;">Awaiting Mailing</span>';
    }
    if(st === 'mailed'){
      return '<span class="pill" style="background:#dcfce7;color:#166534;border:1px solid #bbf7d0;">Mailed</span>';
    }
    return '<span class="pill">' + esc(status || 'Unknown') + '</span>';
  }
  function requiredCountFromRow(row){
    try{
      var payload = row && row.packet_payload ? row.packet_payload : {};
      if(typeof payload === 'string'){ try{ payload = JSON.parse(payload); }catch(_e){ payload = {}; } }
      var n = Number((payload && payload.boardApprovalRequired) || 0);
      if(n > 0) return n;
      var rosterLen = Array.isArray(payload && payload.boardRoster) ? payload.boardRoster.length : 0;
      return Math.max(1, Math.floor((rosterLen || 1) / 2) + 1);
    }catch(_e){
      return 1;
    }
  }
  async function loadVoteMap(requestIds){
    var out = {};
    try{
      var sb = getSb();
      if(!(sb && sb.from) || !requestIds.length) return out;
      var q = await sb.from('annual_meeting_board_approvals')
        .select('request_id,board_user_id,decision,created_at')
        .in('request_id', requestIds);
      var rows = Array.isArray(q && q.data) ? q.data : [];
      rows.forEach(function(r){
        var rid = String(r.request_id || '').trim();
        if(!rid) return;
        if(!out[rid]) out[rid] = [];
        out[rid].push(r);
      });
    }catch(_e){}
    return out;
  }
  async function openPacketPreview(requestId){
    try{
      var sb = getSb();
      if(!(sb && sb.from) || !requestId) return;

      var q = await sb
        .from('annual_meeting_packet_requests')
        .select('*')
        .eq('id', requestId)
        .maybeSingle();

      var row = q && q.data ? q.data : null;
      if(!row) return;

      var payload = row.packet_payload || {};
      if(typeof payload === 'string'){
        try{ payload = JSON.parse(payload); }catch(_e){ payload = {}; }
      }

      var attachment = payload && payload.pdf_attachment ? payload.pdf_attachment : null;
      var mime = String((attachment && attachment.type) || 'application/pdf');
      var b64 = String((attachment && attachment.content) || '').replace(/\s+/g, '').trim();

      if(b64){
        var binary = atob(b64);
        var len = binary.length;
        var bytes = new Uint8Array(len);
        for(var i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);
        var blob = new Blob([bytes], { type: mime });
        var url = URL.createObjectURL(blob);
        var win = window.open(url, '_blank');
        if(!win) window.location.href = url;
        setTimeout(function(){ try{ URL.revokeObjectURL(url); }catch(_e){} }, 60000);
        return;
      }

      var html = String(row.preview_html || '').trim();
      if(!html) return;
      var win2 = window.open('', '_blank');
      if(!win2) return;
      win2.document.open();
      win2.document.write(html);
      win2.document.close();
    }catch(_e){}
  }
  async function renderManagerBoardHubStatus(){
    try{
      var body = document.getElementById('managerBoardHubStatusBody');
      if(!body) return;
      var sb = getSb();
      if(!(sb && sb.from)){
        body.innerHTML = '<div class="board-items-panel__empty">Database connection unavailable.</div>';
        return;
      }
      var communityId = getSelectedCommunityId();
      if(!communityId){
        body.innerHTML = '<div class="board-items-panel__empty">Select a community to see board hub status.</div>';
        return;
      }
      body.innerHTML = '<div class="board-items-panel__empty">Loading board member hub status…</div>';
      var q = await sb.from('annual_meeting_packet_requests')
        .select('*')
        .eq('community_id', communityId)
        .in('status', ['pending_board_approval','pending_supervisor_approval','approved_ready_to_send','mailed'])
        .order('submitted_at', { ascending:false })
        .limit(12);
      var rows = Array.isArray(q && q.data) ? q.data : [];
      if(!rows.length){
        body.innerHTML = '<div class="board-items-panel__empty">No annual meeting routing activity is active for this community.</div>';
        return;
      }
      var voteMap = await loadVoteMap(rows.map(function(r){ return r && r.id; }).filter(Boolean));
      body.innerHTML = rows.map(function(r){
        var rid = String(r.id || '');
        var payload = r.packet_payload || {};
        if(typeof payload === 'string'){ try{ payload = JSON.parse(payload); }catch(_e){ payload = {}; } }
        var community = String(r.community_name || payload.communityName || 'Community').trim();
        var employee = String(r.employee_name || r.employee_email || 'Employee').trim();
        var meetingDate = String((payload && payload.nextAnnualMeetingDate) || '').trim();
        var votes = Array.isArray(voteMap[rid]) ? voteMap[rid] : [];
        var approvals = votes.filter(function(v){ return String(v.decision || '').toLowerCase() === 'approved'; }).length;
        var required = requiredCountFromRow(r);
        var statusText = '';
        var st = String(r.status || '').toLowerCase();
        if(st === 'pending_board_approval'){
          statusText = 'Board approvals: <strong>' + esc(String(approvals)) + '</strong> of <strong>' + esc(String(required)) + '</strong> needed for majority.';
        }else if(st === 'pending_supervisor_approval'){
          statusText = 'Board majority reached. This notice is waiting for supervisor approval.';
        }else if(st === 'approved_ready_to_send'){
          statusText = 'Supervisor approved. The packet has been emailed to the employee\'s assistant for mailing.';
        }else if(st === 'mailed'){
          statusText = 'Mailing has been confirmed for this annual meeting packet.';
        }else{
          statusText = 'Routing is in progress.';
        }
        return '<div class="board-items-row">'
          + '<div>'
          +   '<div class="board-items-row__title">' + esc(community) + '</div>'
          +   '<div class="board-items-row__meta">Prepared by ' + esc(employee) + (meetingDate ? (' • Meeting ' + esc(meetingDate)) : '') + '</div>'
          +   '<div class="board-items-row__desc">' + statusText + '</div>'
          + '</div>'
          + '<div class="board-items-row__actions">'
          +   statusPill(r.status)
          +   '<button class="board-items-btn" type="button" data-manager-board-preview="' + esc(rid) + '">Preview Packet</button>'
          + '</div>'
          + '</div>';
      }).join('');
    }catch(e){
      var body = document.getElementById('managerBoardHubStatusBody');
      if(body) body.innerHTML = '<div class="board-items-panel__empty">Board hub status unavailable right now.</div>';
      try{ console.warn('manager board hub status failed', e); }catch(_e){}
    }
  }
  document.addEventListener('click', function(e){
    var btn = e.target && e.target.closest ? e.target.closest('[data-manager-board-preview]') : null;
    if(!btn) return;
    e.preventDefault();
    openPacketPreview(btn.getAttribute('data-manager-board-preview'));
  });
  function boot(){
    renderManagerBoardHubStatus();
    try{
      document.addEventListener('change', function(e){
        if(e && e.target && e.target.id === 'zummeeCommunitySelect'){
          setTimeout(renderManagerBoardHubStatus, 150);
        }
      });
    }catch(_e){}
    try{ setInterval(renderManagerBoardHubStatus, 30000); }catch(_e2){}
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', boot);
  }else{
    boot();
  }
})();
</script>





<script id="zummeeMoveRealSelect_mobileSafe">
(function(){

  function hasRealData(sel){
    return !!(sel && (
      ((sel.options && sel.options.length > 1)) ||
      (sel.value && sel.value !== "")
    ));
  }

  function rectVisible(el){
    try{
      const r = el.getBoundingClientRect();
      return r.width > 0 && r.height > 0;
    }catch(_e){ return false; }
  }

  function moveWhenReady(){
    const nodes = Array.from(document.querySelectorAll('#zummeeCommunitySelect'));
    if(nodes.length < 2) return false;

    const visible = nodes.find(n => rectVisible(n));
    const real = nodes.find(n => n !== visible && hasRealData(n));
    const slot = document.querySelector('.managerhub-hero__community-top');

    if(!visible || !real || !slot) return false;
    if(!hasRealData(real)) return false;

    try{
      if(visible.parentNode) visible.parentNode.removeChild(visible);
    }catch(_e){}

    slot.appendChild(real);
    real.id = 'zummeeCommunitySelect';

    return true;
  }

  document.addEventListener('DOMContentLoaded', function(){
    let tries = 0;
    const t = setInterval(function(){
      tries++;
      if(moveWhenReady() || tries > 50){
        clearInterval(t);
      }
    }, 250);
  });

})();
</script>


<script id="zummeeCommunityMobileRepaint_v22">
(function(){
  function repaintCommunitySelect(){
    try{
      const sel = document.getElementById('zummeeCommunitySelect');
      if(!sel) return false;

      const opts = Array.from(sel.options || []);
      if(!opts.length) return false;

      const realOpts = opts.filter(o => String(o.value || '').trim());
      if(!realOpts.length) return false;

      let selected = opts.find(o => o.selected && String(o.value || '').trim());
      if(!selected && sel.value){
        selected = opts.find(o => String(o.value) === String(sel.value));
      }
      if(!selected){
        selected = realOpts[0];
        sel.value = selected.value;
      }

      opts.forEach(o => o.selected = false);
      selected.selected = true;
      sel.value = selected.value;

      // Remove placeholder once a real option is selected to prevent iOS Safari
      // from continuing to paint the first option text.
      const first = sel.options[0];
      if(first && !String(first.value || '').trim() && String(selected.value || '').trim()){
        sel.remove(0);
      }

      // Replace node once to force native mobile repaint while preserving visual position.
      const clone = sel.cloneNode(true);
      clone.value = sel.value;
      const parent = sel.parentNode;
      if(!parent) return true;

      parent.replaceChild(clone, sel);

      // Preserve current selected state explicitly after clone.
      const cloneOpts = Array.from(clone.options || []);
      cloneOpts.forEach(o => o.selected = false);
      const match = cloneOpts.find(o => String(o.value) === String(clone.value)) || cloneOpts[0];
      if(match){
        match.selected = true;
        clone.value = match.value;
      }

      clone.dispatchEvent(new Event('change', { bubbles:true }));
      return true;
    }catch(_e){
      return false;
    }
  }

  document.addEventListener('DOMContentLoaded', function(){
    let tries = 0;
    const t = setInterval(function(){
      tries++;
      if(repaintCommunitySelect() || tries > 40){
        clearInterval(t);
      }
    }, 250);
  });
})();
</script>


<script id="zummeeCommunitySelectLabelOverlay_v23">
(function(){
  function escapeForCssContent(text){
    return '"' + String(text || '')
      .replace(/\\/g, '\\\\')
      .replace(/"/g, '\\\"') + '"';
  }

  function updateCommunityLabel(){
    try{
      const s = document.getElementById('zummeeCommunitySelect');
      if(!s) return false;
      const text = s.options && s.options[s.selectedIndex]
        ? s.options[s.selectedIndex].text
        : 'Select Community';
      s.style.setProperty('--selected-label', escapeForCssContent(text || 'Select Community'));
      return true;
    }catch(_e){
      return false;
    }
  }

  document.addEventListener('DOMContentLoaded', function(){
    let tries = 0;
    const t = setInterval(function(){
      tries++;
      updateCommunityLabel();
      if(tries > 30) clearInterval(t);
    }, 250);

    const s = document.getElementById('zummeeCommunitySelect');
    if(s){
      s.addEventListener('change', updateCommunityLabel);
    }

    setTimeout(updateCommunityLabel, 800);
    setTimeout(updateCommunityLabel, 1600);
  });
})();
</script>


<script id="supervisor-manager-hub-v1">
(function(){
  function isSupervisorProfile(profile){
    var role = String((profile && profile.role) || window.__zummeeUserRole || "").trim().toLowerCase();
    var approved = (profile && typeof profile.approved !== "undefined") ? !!profile.approved : true;
    return approved && (role === "supervisor" || role === "admin" || role === "companyadmin");
  }

  function setCardTitle(card, title){
    if(!card) return;
    var titleEl = card.querySelector('.title');
    if(titleEl) titleEl.textContent = title;
    card.setAttribute('aria-label', 'Open ' + title);
  }

  function setCardDesc(card, desc){
    if(!card) return;
    var descEl = card.querySelector('.desc');
    if(descEl) descEl.textContent = desc;
  }

  function hideCard(card){ if(card) card.style.display = 'none'; }
  function showCard(card){ if(card) card.style.display = ''; }
  function moveCard(grid, card){ if(grid && card) grid.appendChild(card); }

  window.configureSupervisorManagerHub = function(profile){
    var isSup = isSupervisorProfile(profile);
    var grid = document.getElementById('hubCards');
    if(!grid || !isSup) return;

    var cards = {
      dailyOps: document.getElementById('dailyOpsCard'),
      inspections: document.getElementById('inspectionsCard'),
      reminders: document.getElementById('remindersCard'),
      emergencyTexting: document.getElementById('emergencyTextingCard'),
      boardMemberHub: document.getElementById('boardMemberHubCard'),
      companyDirectory: document.getElementById('companyDirectoryCard'),
      training: document.getElementById('managerTrainingCard'),
      onlineVoting: document.getElementById('onlineVotingCard'),
      boardMeetings: document.getElementById('boardMeetingsCard'),
      preferredVendors: document.getElementById('preferredVendorsCard'),
      residentWorkOrders: document.getElementById('residentWorkOrdersCard'),
      residentPortal: document.getElementById('residentPortalPreviewCard'),
      residentDirectory: document.getElementById('residentDirectoryCard'),
      annualPresentation: document.getElementById('annualPresentationHubCard'),
      annualMeetingRecords: document.getElementById('annualMeetingRecordsCard'),
      supervisorMain: document.getElementById('supervisorHubMainCard'),
      employeePerformance: document.getElementById('employeePerformanceCard'),
      dailyTasks: document.getElementById('dailyTasksCard'),
      communityAssignments: document.getElementById('communityAssignmentsCard'),
      employeeAccountActivations: document.getElementById('employeeAccountActivationsCard'),
      companyBrandingTexting: document.getElementById('companyBrandingTextingCard'),
      maintenanceControl: document.getElementById('maintenanceControlCenterCard'),
      liveMaintenance: document.getElementById('liveMaintenanceUpdatesCard'),
      mileage: document.getElementById('mileageCard'),
      poolOps: document.getElementById('poolOpsCard')
    };

    hideCard(cards.mileage);
    hideCard(cards.residentPortal);
    hideCard(cards.residentDirectory);

    [cards.supervisorMain,cards.employeePerformance,cards.dailyTasks,cards.communityAssignments,cards.employeeAccountActivations,cards.companyBrandingTexting,cards.companyDirectory,cards.training,cards.onlineVoting,cards.boardMeetings,cards.annualPresentation,cards.liveMaintenance,cards.maintenanceControl,cards.inspections,cards.dailyOps,cards.boardMemberHub].forEach(showCard);

    setCardTitle(cards.employeePerformance, 'Employee Performance');
    setCardDesc(cards.employeePerformance, 'Review monthly rankings, scorecards, and employee-level performance trends.');

    setCardTitle(cards.dailyTasks, 'Daily Tasks');
    cards.dailyTasks && cards.dailyTasks.setAttribute('data-href', 'daily_tasks.html');
    setCardDesc(cards.dailyTasks, 'Manage recurring daily tasks, timed tasks, and compliance from one supervisor workspace.');

    setCardTitle(cards.communityAssignments, 'Community Assignments');
    cards.communityAssignments && cards.communityAssignments.setAttribute('data-href', 'community_assignments.html');
    setCardDesc(cards.communityAssignments, 'Assign employees and assistants by community from one supervisor workspace.');

    setCardTitle(cards.employeeAccountActivations, 'Employee Account Activations');
    cards.employeeAccountActivations && cards.employeeAccountActivations.setAttribute('data-href', 'employee_account_activations.html');
    setCardDesc(cards.employeeAccountActivations, 'Review and approve new employee account requests for your company.');

    setCardTitle(cards.companyBrandingTexting, 'Company Branding & Texting');
    cards.companyBrandingTexting && cards.companyBrandingTexting.setAttribute('data-href', 'company_branding_texting.html');
    setCardDesc(cards.companyBrandingTexting, 'Manage company branding details and emergency texting from one supervisor workspace.');

    setCardTitle(cards.training, 'Property Management Teams');
    cards.training && cards.training.setAttribute('data-href', 'supervisor_access.html#sup_teamAssignments');
    setCardDesc(cards.training, 'Build supervisor teams, assign employees, and manage staffing structure.');

    setCardTitle(cards.onlineVoting, 'Compliance Review');
    cards.onlineVoting && cards.onlineVoting.setAttribute('data-href', 'employee_performance_report.html');
    setCardDesc(cards.onlineVoting, 'See who is complete, who is missing items, and where compliance needs attention.');

    setCardTitle(cards.boardMeetings, 'Board Meeting Oversight');
    cards.boardMeetings && cards.boardMeetings.setAttribute('data-href', 'board_meetings.html');

    setCardTitle(cards.annualPresentation, 'Annual Meeting Oversight');
    cards.annualPresentation && cards.annualPresentation.setAttribute('data-href', 'supervisor_access.html#annual-approvals-section');
    setCardDesc(cards.annualPresentation, 'Track approval progress and annual meeting readiness across communities.');

    setCardTitle(cards.annualMeetingRecords, 'Annual Meeting Records');
    cards.annualMeetingRecords && cards.annualMeetingRecords.setAttribute('data-href', 'annual_meeting_records.html');
    setCardDesc(cards.annualMeetingRecords, 'Open mailed annual meeting packets by community and year across your company.');

    setCardTitle(cards.liveMaintenance, 'Live Maintenance Oversight');
    cards.liveMaintenance && cards.liveMaintenance.setAttribute('data-href', 'maintenance_updates.html');
    setCardDesc(cards.liveMaintenance, 'Watch active maintenance movement, aging items, and vendor updates.');

    setCardTitle(cards.supervisorMain, 'Approvals Center');
    cards.supervisorMain && cards.supervisorMain.setAttribute('data-href', 'supervisor_access.html');
    setCardDesc(cards.supervisorMain, 'Open pending approvals, annual meeting reviews, and supervisor controls.');

    setCardTitle(cards.companyDirectory, 'Staffing & Directory');
    cards.companyDirectory && cards.companyDirectory.setAttribute('data-href', 'company_directory.html');

    [
      cards.employeePerformance,
      cards.dailyTasks,
      cards.communityAssignments,
      cards.training,
      cards.onlineVoting,
      cards.boardMeetings,
      cards.annualPresentation,
      cards.annualMeetingRecords,
      cards.liveMaintenance,
      cards.supervisorMain,
      cards.companyDirectory,
      cards.maintenanceControl,
      cards.inspections,
      cards.dailyOps,
      cards.boardMemberHub,
      cards.reminders,
      cards.emergencyTexting,
      cards.preferredVendors,
      cards.residentWorkOrders,
      cards.poolOps
    ].forEach(function(card){ moveCard(grid, card); });
  };

  function kick(){
    try{
      var role = String(window.__zummeeUserRole || '').trim();
      if(role) window.configureSupervisorManagerHub({ role: role, approved: true });
    }catch(_e){}
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', kick);
  else kick();
  setTimeout(kick, 300);
  setTimeout(kick, 1200);
})();
</script>
<script id="safe-favorites-stars-v9">
(function(){
  try{ document.documentElement.classList.add('favorites-pending'); }catch(_e){}
  const MAX_STORED_FAVORITES = 6;
  const GENERIC_KEY = 'zummee_hub_favorites_v1';

  function isMobileDevice(){
    try{
      var ua = navigator.userAgent || '';
      return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua);
    }catch(_e){
      return false;
    }
  }

  function displayLimit(){
    return isMobileDevice() ? 3 : 6;
  }

  function getUserId(){
    try{
      return String((window.ZUMMEE_AUTH && window.ZUMMEE_AUTH.userId) || localStorage.getItem('zummee_user_id') || '').trim();
    }catch(_e){ return ''; }
  }

  function userKey(uid){
    return GENERIC_KEY + (uid ? '__' + uid : '');
  }

  function activeLocalKey(){
    const uid = getUserId();
    return uid ? userKey(uid) : GENERIC_KEY;
  }

  function looksLikeCardId(id){
    return typeof id === 'string' && /Card$/.test(id);
  }

  function readKey(key){
    try{
      const raw = localStorage.getItem(key);
      const arr = JSON.parse(raw || '[]');
      return (Array.isArray(arr) ? arr : []).filter(looksLikeCardId);
    }catch(_e){ return []; }
  }

  function writeKey(key, ids){
    try{ localStorage.setItem(key, JSON.stringify(ids || [])); }catch(_e){}
  }

  function readFavorites(){
    const uid = getUserId();
    const userIds = uid ? readKey(userKey(uid)) : [];
    const genericIds = readKey(GENERIC_KEY);
    if(userIds.length) return userIds;
    if(genericIds.length) return genericIds;
    return [];
  }

  function writeFavorites(ids){
    const clean = ids || [];
    const uid = getUserId();
    writeKey(GENERIC_KEY, clean);
    if(uid) writeKey(userKey(uid), clean);
  }

  function clearLegacyFavoriteKeys(){
    try{
      Object.keys(localStorage)
        .filter(function(k){
          return k.includes('zummee_hub_favorites') && k !== GENERIC_KEY && !/^zummee_hub_favorites_v1__/.test(k);
        })
        .forEach(function(k){ localStorage.removeItem(k); });
    }catch(_e){}
  }

  async function saveFavoritesSupabase(ids){
    try{
      const uid = getUserId();
      if(!uid || !(window.sb && typeof window.sb.from === 'function')) return;
      await window.sb.from('user_ui_prefs').upsert({
        user_id: uid,
        pref_key: 'manager_hub_favorites',
        pref_value: { favorites: ids || [] }
      }, { onConflict: 'user_id,pref_key' });
    }catch(_e){}
  }

  async function loadFavoritesSupabase(){
    try{
      const uid = getUserId();
      if(!uid || !(window.sb && typeof window.sb.from === 'function')) return null;
      const res = await window.sb.from('user_ui_prefs')
        .select('pref_value')
        .eq('user_id', uid)
        .eq('pref_key', 'manager_hub_favorites')
        .maybeSingle();
      const value = res && res.data && res.data.pref_value;
      return (value && Array.isArray(value.favorites)) ? value.favorites.filter(looksLikeCardId) : null;
    }catch(_e){ return null; }
  }

  function cardId(card){
    return card.id || card.getAttribute('data-card-id') || '';
  }

  function getMainGrid(){ return document.getElementById('mainCardsGrid'); }
  function getMoreToolsContainer(){ return document.getElementById('moreToolsContainer'); }

  function isRoleAllowedCard(card){
    if(!card) return false;
    if(card.dataset && card.dataset.roleAllowed === '0') return false;
    var allowedList = Array.isArray(window.__zummeeAllowedHubCardIds) ? window.__zummeeAllowedHubCardIds : null;
    var id = cardId(card);
    if(allowedList && allowedList.length){
      return allowedList.indexOf(id) !== -1;
    }
    return !!id;
  }

  function getManagedCards(){
    return Array.from(document.querySelectorAll('.card.clickable-card')).filter(function(card){
      return !!cardId(card) && isRoleAllowedCard(card);
    });
  }

  function validCardIds(){
    return new Set(getManagedCards().map(cardId).filter(Boolean));
  }

  function sanitizeFavorites(ids){
    const valid = validCardIds();
    const seen = new Set();
    return (ids || []).filter(looksLikeCardId).filter(function(id){
      if(!valid.has(id) || seen.has(id)) return false;
      seen.add(id);
      return true;
    }).slice(0, MAX_STORED_FAVORITES);
  }

  function visibleFavorites(ids){
    return sanitizeFavorites(ids).slice(0, displayLimit());
  }

  function assignOriginalOrder(){
    getManagedCards().forEach(function(card, idx){
      if(!card.dataset.originalIndex){
        card.dataset.originalIndex = String(idx);
      }
    });
  }

  function sortedCards(){
    return getManagedCards().slice().sort(function(a,b){
      return Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0);
    });
  }

  function updateCount(){
    var countEl = document.getElementById('moreToolsCount');
    var more = getMoreToolsContainer();
    if(countEl && more){
      var visibleCards = Array.from(more.querySelectorAll('.card.clickable-card')).filter(function(card){
        return !!(card.offsetParent || (window.getComputedStyle(card).display !== 'none' && window.getComputedStyle(card).visibility !== 'hidden'));
      });
      countEl.textContent = visibleCards.length + ' cards';
    }
  }

  function applyVisuals(favorites){
    const activeSet = new Set(sanitizeFavorites(favorites));
    document.querySelectorAll('.card.clickable-card').forEach(function(card){
      const btn = card.querySelector('.favorite-star-btn');
      if(!btn) return;
      const active = activeSet.has(cardId(card));
      btn.classList.toggle('is-favorite', active);
      btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      btn.setAttribute('title', active ? 'Remove favorite' : 'Add favorite');
    });
  }

  function renderFavorites(favorites){
    const main = getMainGrid();
    const more = getMoreToolsContainer();
    if(!main || !more) return;

    const storedFavorites = sanitizeFavorites(favorites || []);
    const visible = visibleFavorites(storedFavorites);
    const visibleSet = new Set(visible);
    const all = sortedCards();

    while(main.firstChild) main.removeChild(main.firstChild);
    while(more.firstChild) more.removeChild(more.firstChild);

    visible.forEach(function(id){
      const card = all.find(function(c){ return cardId(c) === id; });
      if(card) main.appendChild(card);
    });

    all.forEach(function(card){
      const id = cardId(card);
      if(!visibleSet.has(id)){
        more.appendChild(card);
      }
    });

    applyVisuals(storedFavorites);
    updateCount();
  }

  function addStars(favorites){
    document.querySelectorAll('.card.clickable-card').forEach(function(card){
      var existing = card.querySelector('.favorite-star-btn');
      if(existing){
        existing.style.display = isRoleAllowedCard(card) ? '' : 'none';
        return;
      }
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'favorite-star-btn';
      btn.innerHTML = '★';
      btn.setAttribute('aria-label', 'Favorite card');
      btn.style.display = isRoleAllowedCard(card) ? '' : 'none';
      btn.addEventListener('click', async function(ev){
        ev.preventDefault();
        ev.stopPropagation();
        if(!isRoleAllowedCard(card)) return;

        const id = cardId(card);
        let next = sanitizeFavorites(readFavorites());

        if(next.includes(id)){
          next = next.filter(function(x){ return x !== id; });
        } else {
          const limit = displayLimit();
          if(next.length >= limit){
            openFavoritesLimitModal(limit);
            return;
          }
          next.push(id);
        }

        next = sanitizeFavorites(next);
        writeFavorites(next);
        renderFavorites(next);
        await saveFavoritesSupabase(next);
      });
      card.appendChild(btn);
    });
    applyVisuals(favorites);
  }


  function ensureFavoritesLimitModal(){
    return document.getElementById('favoritesLimitModal');
  }

  function closeFavoritesLimitModal(){
    var backdrop = ensureFavoritesLimitModal();
    if(!backdrop) return;
    backdrop.classList.remove('is-open');
    backdrop.setAttribute('aria-hidden','true');
  }
  window.closeFavoritesLimitModal = closeFavoritesLimitModal;

  function openFavoritesLimitModal(limit){
    var backdrop = ensureFavoritesLimitModal();
    if(!backdrop){
      alert('You can keep up to ' + limit + ' favorites on ' + (isMobileDevice() ? 'mobile' : 'desktop') + '.');
      return;
    }
    var msg = backdrop.querySelector('[data-favorites-limit-message]');
    if(msg){
      msg.textContent = 'You can keep up to ' + limit + ' favorites on ' + (isMobileDevice() ? 'mobile' : 'desktop') + '.';
    }
    backdrop.classList.add('is-open');
    backdrop.setAttribute('aria-hidden','false');
    var btn = backdrop.querySelector('.zm-fav-modal__btn');
    if(btn){ setTimeout(function(){ try{ btn.focus(); }catch(_e){} }, 0); }
  }

  function defaultFavoritesFromVisibleTop(){
    const main = getMainGrid();
    if(!main) return [];
    return Array.from(main.querySelectorAll('.card.clickable-card')).slice(0, MAX_STORED_FAVORITES).map(cardId).filter(Boolean);
  }

  function isSupervisorRole(){
    try{
      var bodyRole = String((document.body && document.body.getAttribute('data-staff-role')) || '').trim().toLowerCase();
      var globalRole = String(window.__zummeeUserRole || '').trim().toLowerCase();
      return bodyRole === 'supervisor' || bodyRole === 'admin' || bodyRole === 'companyadmin' || globalRole === 'supervisor' || globalRole === 'admin' || globalRole === 'companyadmin';
    }catch(_e){ return false; }
  }

  function ensureSupervisorMobileFavorites(ids){
    var next = Array.isArray(ids) ? ids.slice() : [];
    if(!isMobileDevice() || !isSupervisorRole()) return next;
    var mustShow = ['communityAssignmentsCard','dailyTasksCard','employeePerformanceCard'];
    mustShow.slice().reverse().forEach(function(id){
      if(document.getElementById(id)){
        next = next.filter(function(x){ return x !== id; });
        next.unshift(id);
      }
    });
    return sanitizeFavorites(next);
  }

  async function waitForUserContext(){
    let tries = 0;
    while(!getUserId() && tries < 40){
      await new Promise(function(r){ setTimeout(r, 100); });
      tries++;
    }
  }

  async function init(){
    let tries = 0;
    while((!getMainGrid() || !getMoreToolsContainer()) && tries < 40){
      await new Promise(function(r){ setTimeout(r, 100); });
      tries++;
    }

    clearLegacyFavoriteKeys();
    assignOriginalOrder();
    await waitForUserContext();

    let favorites = sanitizeFavorites(readFavorites());
    const remote = await loadFavoritesSupabase();

    // Priority: local (generic or user-specific) -> remote -> current visible top
    if(favorites.length){
      writeFavorites(favorites); // mirror to user key once auth is ready
    } else if(remote && remote.length){
      favorites = sanitizeFavorites(remote);
      writeFavorites(favorites);
    } else {
      favorites = sanitizeFavorites(defaultFavoritesFromVisibleTop());
      writeFavorites(favorites);
      await saveFavoritesSupabase(favorites);
    }

    favorites = ensureSupervisorMobileFavorites(favorites);
    writeFavorites(favorites);
    try{ await saveFavoritesSupabase(favorites); }catch(_e){}

    addStars(favorites);
    renderFavorites(favorites);
    try{ document.documentElement.classList.remove('favorites-pending'); }catch(_e){}
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){ init().catch(function(){}).finally(function(){ try{ document.documentElement.classList.remove('favorites-pending'); }catch(_e){}; }); });
  } else {
    Promise.resolve(init()).catch(function(){}).finally(function(){ try{ document.documentElement.classList.remove('favorites-pending'); }catch(_e){}; });
  }
})();
</script>

<script id="more-tools-section-v1">
(function(){
  function buildMoreTools(){
    var hubCards = document.getElementById('hubCards');
    if(!hubCards || document.getElementById('moreToolsSection')) return;

    var cards = Array.from(hubCards.querySelectorAll('.card.clickable-card'));
    if(cards.length <= 5) return;

    var mainCards = cards.slice(0, 5);
    var extraCards = cards.slice(5);

    var mainGrid = document.createElement('div');
    mainGrid.id = 'mainCardsGrid';
    mainGrid.className = hubCards.className || 'cards';

    mainCards.forEach(function(card){ mainGrid.appendChild(card); });

    hubCards.parentNode.insertBefore(mainGrid, hubCards);

    var section = document.createElement('div');
    section.id = 'moreToolsSection';
    section.className = 'more-tools-section';
    section.innerHTML = ''
      + '<div class="more-tools-header" id="moreToolsHeader" role="button" tabindex="0" aria-expanded="false">'
      +   '<span class="more-tools-header__title">More Tools</span>'
      +   '<span class="more-tools-header__arrow" id="moreToolsArrow">▾</span>'
      + '</div>'
      + '<div id="moreToolsContainer" class="more-tools-container"></div>';

    var container = section.querySelector('#moreToolsContainer');
    extraCards.forEach(function(card){ container.appendChild(card); });

    hubCards.parentNode.insertBefore(section, hubCards);
    hubCards.remove();

    var header = section.querySelector('#moreToolsHeader');
    var arrow = section.querySelector('#moreToolsArrow');

    function toggleMoreTools(){
      var open = container.classList.toggle('open');
      header.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    header.addEventListener('click', toggleMoreTools);
    header.addEventListener('keydown', function(e){
      if(e.key === 'Enter' || e.key === ' '){
        e.preventDefault();
        toggleMoreTools();
      }
    });
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', buildMoreTools);
  } else {
    buildMoreTools();
  }
})();
</script>

