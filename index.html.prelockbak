}

@media (max-width: 860px){
  .managerhub-hero__logo{
    width:88px;
  }
  .managerhub-title span{
    font-size:30px;
    text-align:center;
  }
}


.title-inline{
  display:flex;
  align-items:center;
  gap:16px;
}
.inline-dd{
  width:180px;
  height:40px;
  border-radius:10px;
  padding:6px 10px;
  font-size:14px;
}


.managerhub-hero__left{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:14px;
}
.managerhub-title-inline{
  font-size:29px;
  font-weight:400;
  color:#ffffff;
  margin:0;
  letter-spacing:0;
  line-height:1.1;
}
.managerhub-hero__actions{
  align-items:flex-start;
  padding-top:8px;
}
.managerhub-hero__community{
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:10px;
  margin-top:-8px;
}
.managerhub-hero__community-top{
  display:flex;
  align-items:center;
  gap:10px;
}
.managerhub-hero__community #zummeeCommunitySelect{
  width:210px !important;
  min-width:210px !important;
  max-width:210px !important;
  height:38px;
  padding:6px 12px;
  font-size:14px;
  border-radius:12px;
}
.managerhub-hero__account-row{
  display:flex;
  align-items:center;
  gap:10px;
}
.managerhub-signout-wrap{
  position:relative;
  display:inline-flex;
}
.managerhub-signout-pop{
  position:absolute;
  top:calc(100% + 8px);
  right:0;
  width:min(260px, calc(100vw - 32px));
  background:rgba(255,255,255,0.98);
  color:#17324d;
  border:1px solid rgba(15,47,74,0.14);
  border-radius:16px;
  box-shadow:0 18px 40px rgba(15,47,74,0.18);
  padding:12px;
  z-index:10020;
  display:none;
}
.managerhub-signout-pop.is-open{
  display:block;
}
.managerhub-signout-pop__title{
  font-size:15px;
  font-weight:800;
  line-height:1.3;
  margin:0 0 6px;
  color:#0f2f4a;
}
.managerhub-signout-pop__body{
  font-size:13px;
  line-height:1.45;
  color:#546577;
  margin:0 0 12px;
}
.managerhub-signout-pop__actions{
  display:flex;
  justify-content:flex-end;
  gap:8px;
  flex-wrap:wrap;
}
.managerhub-signout-pop__btn{
  min-height:38px;
  padding:0 14px;
  border-radius:999px;
  border:1px solid rgba(15,47,74,0.14);
  background:#fff;
  color:#17324d;
  font-size:13px;
  font-weight:700;
  cursor:pointer;
}
.managerhub-signout-pop__btn--confirm{
  background:#0f2f4a;
  border-color:#0f2f4a;
  color:#fff;
}
.managerhub-hero__account-btn{
  min-width:100px;
  height:36px;
  padding:0 14px;
  border:none;
  border-radius:999px;
  background:#ffffff;
  color:#17324d;
  font-size:14px;
  font-weight:700;
  box-shadow:0 4px 10px rgba(0,0,0,0.08);
  cursor:pointer;
}
.managerhub-hero__account-btn:hover{
  transform:translateY(-1px);
}
@media (max-width: 860px){
  .managerhub-title-inline{
    font-size:24px;
  }
  .managerhub-hero__community{
    align-items:center;
    margin-top:0;
