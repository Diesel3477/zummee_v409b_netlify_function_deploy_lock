/* =========================
   MANAGER HUB — TITLE LOWER, HEADER SAME HEIGHT
   ========================= */
.managerhub-hero{
  min-height: 250px !important;
  height: 250px !important;
  max-height: 250px !important;
  overflow: hidden !important;
}

.managerhub-hero__left{
  height: 100% !important;
  align-self: stretch !important;
}

.managerhub-hero__copy{
  margin-top: 0 !important;
  padding-top: 0 !important;
  transform: translateY(44px) !important;
}

.managerhub-hero__copy h1,
.managerhub-hero__copy h2,
.managerhub-hero__copy .managerhub-title,
.managerhub-hero__copy .managerhub-title-inline{
  margin-top: 0 !important;
}


/* =========================
   MANAGER HUB — KEEP CONTROLS VISIBLE
   ========================= */
.managerhub-hero{
  overflow: visible !important;
}

.managerhub-hero__actions{
  position: absolute !important;
  right: 28px !important;
  bottom: 18px !important;
  top: auto !important;
  margin: 0 !important;
  z-index: 3 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important;
  gap: 10px !important;
}

.managerhub-hero{
  position: relative !important;
}


/* Forced supervisor gold cards via inline-like override */
.card.supervisor-card, .clickable-card.supervisor-card {
  background: linear-gradient(145deg, #f3d98a 0%, #e2b84f 52%, #cb9932 100%) !important;
  border: 1px solid rgba(132, 95, 18, 0.42) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.36), 0 12px 24px rgba(110, 78, 15, 0.16) !important;
}
.card.supervisor-card .title, .card.supervisor-card .desc, .card.supervisor-card .tiny, .card.supervisor-card .mini, .card.supervisor-card .muted {
  color:#17324d !important;
}
.card.supervisor-card.supervisor-shimmer-on::after {
  opacity: 1 !important;
  animation: goldTouchShimmer 0.95s ease-out 1 !important;
}
/* final clarity fix */
.weather-hub-card::before,
.weather-scene::before,
.weather-scene::after,
.weather-panel::after{content:none !important;display:none !important;background:none !important;}
.weather-hub-shell{border:none !important;box-shadow:none !important;background:transparent !important;}
.weather-scene .cloud{filter:blur(0.8px) !important;box-shadow:0 4px 10px rgba(0,0,0,0.04), inset 0 -4px 8px rgba(0,0,0,0.04) !important;}
.weather-scene__clouds--back .cloud{opacity:.08 !important;filter:blur(2.2px) !important;}
.weather-scene__clouds--mid .cloud{opacity:.16 !important;filter:blur(1.2px) !important;}
.weather-scene__clouds--front .cloud{opacity:.24 !important;filter:blur(.45px) !important;}
.cloud::before,.cloud::after{content:"" !important;position:absolute;border-radius:50%;background:inherit;}
.cloud::before{width:70% !important;height:70% !important;top:-18% !important;left:8% !important;}
.cloud::after{width:60% !important;height:60% !important;top:-8% !important;right:6% !important;}


/* Hard remove Supervisor Priority CTA pill */
.supervisor-priority-strip__cta,
#supervisorApprovalsStrip .supervisor-priority-strip__cta,
#supervisorActivationsStrip .supervisor-priority-strip__cta{
  display:none !important;
  visibility:hidden !important;
  width:0 !important;
  height:0 !important;
  margin:0 !important;
  padding:0 !important;
  border:0 !important;
  opacity:0 !important;
  overflow:hidden !important;
}


/* Apple-ish live activity refresh + scroll fade */
#activityFeedCard,
.live-activity-card,
#activityFeedSection{
  position: relative;
  overflow: hidden;
  border-radius: 28px !important;
  background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.12)) !important;
  border: 1px solid rgba(255,255,255,0.26) !important;
  box-shadow: 0 12px 30px rgba(15,47,74,0.10) !important;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

#activityFeedCard::after,
.live-activity-card::after,
#activityFeedSection::after{
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 54px;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(126,168,222,0) 0%, rgba(126,168,222,0.72) 55%, rgba(126,168,222,0.96) 100%);
  z-index: 3;
}

#activityFeedCard .activity-feed,
.live-activity-card .activity-feed,
#activityFeedSection .activity-feed,
#activityFeedCard .feed-list,
.live-activity-card .feed-list,
#activityFeedSection .feed-list,
#activityFeedCard .activity-list,
.live-activity-card .activity-list,
#activityFeedSection .activity-list{
  position: relative;
  z-index: 1;
  max-height: 320px;
  overflow-y: auto;
  padding-right: 6px;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.45) transparent;
}

#activityFeedCard .activity-feed::-webkit-scrollbar,
.live-activity-card .activity-feed::-webkit-scrollbar,
#activityFeedSection .activity-feed::-webkit-scrollbar,
#activityFeedCard .feed-list::-webkit-scrollbar,
.live-activity-card .feed-list::-webkit-scrollbar,
#activityFeedSection .feed-list::-webkit-scrollbar,
#activityFeedCard .activity-list::-webkit-scrollbar,
.live-activity-card .activity-list::-webkit-scrollbar,
#activityFeedSection .activity-list::-webkit-scrollbar{
  width: 8px;
}

#activityFeedCard .activity-feed::-webkit-scrollbar-thumb,
.live-activity-card .activity-feed::-webkit-scrollbar-thumb,
#activityFeedSection .activity-feed::-webkit-scrollbar-thumb,
#activityFeedCard .feed-list::-webkit-scrollbar-thumb,
.live-activity-card .feed-list::-webkit-scrollbar-thumb,
#activityFeedSection .feed-list::-webkit-scrollbar-thumb,
#activityFeedCard .activity-list::-webkit-scrollbar-thumb,
.live-activity-card .activity-list::-webkit-scrollbar-thumb,
#activityFeedSection .activity-list::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.42);
  border-radius: 999px;
}

#activityFeedCard .activity-item,
.live-activity-card .activity-item,
#activityFeedSection .activity-item,
#activityFeedCard .activity-row,
.live-activity-card .activity-row,
#activityFeedSection .activity-row{
  border-radius: 20px !important;
  background: rgba(255,255,255,0.10) !important;
  border: 1px solid rgba(255,255,255,0.18) !important;
  box-shadow: none !important;
}

#activityFeedCard .activity-item + .activity-item,
.live-activity-card .activity-item + .activity-item,
#activityFeedSection .activity-item + .activity-item,
#activityFeedCard .activity-row + .activity-row,
.live-activity-card .activity-row + .activity-row,
#activityFeedSection .activity-row + .activity-row{
  margin-top: 14px;
}


/* Apple-ish redesign: overdue strip + live activity */
#smartAlertStrip.smart-alert-strip{
  max-width: 1180px !important;
  margin: 14px auto 26px auto !important;
  padding: 10px 14px !important;
  border-radius: 28px !important;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.24), rgba(255,255,255,0.14)) !important;
  border: 1px solid rgba(255,255,255,0.34) !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.28),
    0 18px 38px rgba(15,47,74,0.10) !important;
  backdrop-filter: blur(18px) saturate(120%) !important;
  -webkit-backdrop-filter: blur(18px) saturate(120%) !important;
}

#smartAlertContent{
  display: grid !important;
  gap: 10px !important;
}

#smartAlertStrip .smart-alert{
  display: flex !important;
  align-items: center !important;
  gap: 12px !important;
  margin: 0 !important;
  padding: 14px 16px !important;
  border-radius: 20px !important;
  background: #ffffff !important;
  border: 1px solid rgba(22,50,77,0.10) !important;
  box-shadow: 0 10px 24px rgba(22,50,77,0.10), inset 0 1px 0 rgba(255,255,255,0.92) !important;
  line-height: 1.3 !important;
  min-height: 56px !important;
}

#smartAlertStrip .smart-alert::before{
  content: "" !important;
  width: 10px !important;
  height: 10px !important;
  border-radius: 999px !important;
  flex: 0 0 10px !important;
  background: linear-gradient(180deg, #f59e0b, #d97706) !important;
  box-shadow: 0 0 0 6px rgba(245,158,11,0.14) !important;
}

#smartAlertStrip .smart-alert-board{
  position: relative !important;
  padding: 16px 18px !important;
  border-radius: 24px !important;
  background: linear-gradient(135deg, rgba(255,255,255,0.98), rgba(244,249,255,0.98)) !important;
  border: 1px solid rgba(96,165,250,0.24) !important;
  box-shadow:
    0 14px 30px rgba(37,99,235,0.10),
    inset 0 1px 0 rgba(255,255,255,0.92) !important;
  cursor: pointer !important;
  overflow: hidden !important;
}
#smartAlertStrip .smart-alert-board::after{
  content: "" !important;
  position: absolute !important;
  right: -18px !important;
  top: -18px !important;
  width: 120px !important;
  height: 120px !important;
  border-radius: 999px !important;
  background: radial-gradient(circle, rgba(96,165,250,0.18) 0%, rgba(96,165,250,0.06) 45%, rgba(96,165,250,0) 70%) !important;
  pointer-events: none !important;
}
#smartAlertStrip .smart-alert-board::before{
  background: linear-gradient(180deg, #60a5fa, #2563eb) !important;
  box-shadow: 0 0 0 7px rgba(96,165,250,0.16), 0 0 18px rgba(37,99,235,0.18) !important;
  animation: boardAttentionPulse 1.9s ease-in-out infinite !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-main{
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 14px !important;
  width: 100% !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-copy{
  display: flex !important;
  flex-direction: column !important;
  gap: 4px !important;
  min-width: 0 !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-label{
  font-size: 11px !important;
  font-weight: 900 !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  color: #5d7ea6 !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-headline{
  font-size: 22px !important;
  line-height: 1.05 !important;
  font-weight: 900 !important;
  color: #16324d !important;
  letter-spacing: -0.03em !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-sub{
  font-size: 13px !important;
  line-height: 1.3 !important;
  font-weight: 700 !important;
  color: #526a84 !important;
}
#smartAlertStrip .smart-alert-board .smart-alert-cta{
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-width: 120px !important;
  padding: 12px 16px !important;
  border-radius: 999px !important;
  background: linear-gradient(180deg, #2d67af, #214f88) !important;
  color: #ffffff !important;
  font-size: 14px !important;
  font-weight: 900 !important;
  text-decoration: none !important;
  box-shadow: 0 10px 20px rgba(33,79,136,0.22) !important;
}
#smartAlertStrip .smart-alert-main,
#smartAlertStrip .smart-alert{
  font-size: 16px !important;
  font-weight: 700 !important;
  color: #16324d !important;
  letter-spacing: -0.01em !important;
}

#smartAlertStrip .smart-alert a,
#smartAlertStrip .smart-alert-action{
  color: #204f87 !important;
  font-weight: 800 !important;
  text-decoration: none !important;
}
@keyframes boardAttentionPulse{
  0%,100%{ box-shadow: 0 0 0 7px rgba(96,165,250,0.16), 0 0 18px rgba(37,99,235,0.18); }
  50%{ box-shadow: 0 0 0 10px rgba(96,165,250,0.20), 0 0 26px rgba(37,99,235,0.24); }
}
@media (max-width: 900px){
  #smartAlertStrip .smart-alert-board .smart-alert-main{
    flex-direction: column !important;
    align-items: stretch !important;
  }
  #smartAlertStrip .smart-alert-board .smart-alert-headline{
    font-size: 20px !important;
  }
  #smartAlertStrip .smart-alert-board .smart-alert-cta{
    width: 100% !important;
    min-width: 0 !important;
  }
}

#smartAlertStrip .smart-alert a:hover,
#smartAlertStrip .smart-alert-action:hover{
  text-decoration: underline !important;
}

#activityFeedCard.activity-feed-card{
  max-width: 1180px !important;
  margin: 0 auto 26px auto !important;
  padding: 22px 22px 14px 22px !important;
  border-radius: 32px !important;
  background:
    radial-gradient(circle at top, rgba(255,255,255,0.16), rgba(255,255,255,0) 46%),
    linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.12)) !important;
  border: 1px solid rgba(255,255,255,0.32) !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.24),
    0 18px 40px rgba(15,47,74,0.10) !important;
  backdrop-filter: blur(18px) saturate(120%) !important;
  -webkit-backdrop-filter: blur(18px) saturate(120%) !important;
  overflow: hidden !important;
}

#activityFeedCard::after{
  content: "" !important;
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  height: 82px !important;
  pointer-events: none !important;
  background: linear-gradient(180deg, rgba(123,167,222,0) 0%, rgba(123,167,222,0.28) 45%, rgba(123,167,222,0.88) 100%) !important;
  z-index: 4 !important;
}

#activityFeedCard .activity-feed-header{
  display: flex !important;
  align-items: flex-end !important;
  justify-content: space-between !important;
  gap: 12px !important;
  margin-bottom: 14px !important;
  padding: 0 2px !important;
}

#activityFeedCard .activity-feed-title{
  font-size: 30px !important;
  line-height: 1.02 !important;
  font-weight: 800 !important;
  letter-spacing: -0.03em !important;
  color: #16324d !important;
}

#activityFeedCard .activity-feed-list{
  display: grid !important;
  gap: 0 !important;
  max-height: 340px !important;
  overflow-y: auto !important;
  padding-right: 6px !important;
  position: relative !important;
  z-index: 2 !important;
}

#activityFeedCard .activity-feed-item{
  display: grid !important;
  grid-template-columns: 150px 1fr !important;
  align-items: center !important;
  gap: 14px !important;
  padding: 18px 10px 18px 8px !important;
  border-radius: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-top: 1px solid rgba(255,255,255,0.18) !important;
  box-shadow: none !important;
  min-height: 74px !important;
}

#activityFeedCard .activity-feed-item:first-child{
  border-top: 0 !important;
}

#activityFeedCard .activity-feed-time{
  min-width: 0 !important;
  font-size: 14px !important;
  font-weight: 800 !important;
  color: rgba(22,50,77,0.64) !important;
  letter-spacing: -0.01em !important;
}

#activityFeedCard .activity-feed-text{
  font-size: 18px !important;
  line-height: 1.28 !important;
  font-weight: 700 !important;
  color: #16324d !important;
}

#activityFeedCard .activity-feed-text a{
  color: #28578f !important;
  font-weight: 800 !important;
  text-decoration-thickness: 2px !important;
  text-underline-offset: 2px !important;
}

#activityFeedCard .activity-feed-empty{
  padding: 18px 8px 22px 8px !important;
  border-radius: 0 !important;
  background: transparent !important;
  color: rgba(22,50,77,0.68) !important;
  font-size: 16px !important;
  font-weight: 700 !important;
}

#activityFeedCard .activity-feed-list::-webkit-scrollbar{
  width: 8px !important;
}
#activityFeedCard .activity-feed-list::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,0.34) !important;
  border-radius: 999px !important;
}
#activityFeedCard .activity-feed-list{
  scrollbar-width: thin !important;
  scrollbar-color: rgba(255,255,255,0.34) transparent !important;
}

@media (max-width: 860px){
  #smartAlertStrip.smart-alert-strip{
    padding: 10px 12px !important;
    border-radius: 24px !important;
    margin: 12px 12px 22px 12px !important;
  }
  #smartAlertStrip .smart-alert{
    padding: 13px 14px !important;
    border-radius: 18px !important;
    align-items: flex-start !important;
  }
  #activityFeedCard.activity-feed-card{
    margin: 0 12px 22px 12px !important;
    padding: 18px 16px 12px 16px !important;
    border-radius: 26px !important;
  }
  #activityFeedCard .activity-feed-title{
    font-size: 28px !important;
  }
  #activityFeedCard .activity-feed-item{
    grid-template-columns: 1fr !important;
    gap: 6px !important;
    padding: 16px 6px !important;
  }
  #activityFeedCard .activity-feed-time{
    font-size: 13px !important;
  }
  #activityFeedCard .activity-feed-text{
    font-size: 17px !important;
  }
}


/* Live Team Activity final scroll + click fix */
#activityFeedCard .activity-feed-list,
#activityFeedList{
  max-height: 300px !important;
  min-height: 0 !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  padding-right: 8px !important;
  overscroll-behavior: contain !important;
}

#activityFeedCard .activity-feed-item{
  cursor: pointer !important;
  transition: background .18s ease, transform .18s ease !important;
}
#activityFeedCard .activity-feed-item:hover{
  background: rgba(255,255,255,0.10) !important;
}
#activityFeedCard .activity-feed-item:active{
  transform: scale(0.995) !important;
}
#activityFeedCard .activity-feed-link{
  display: grid !important;
  grid-template-columns: 150px 1fr !important;
  align-items: center !important;
  gap: 14px !important;
  width: 100% !important;
  color: inherit !important;
  text-decoration: none !important;
}
@media (max-width: 860px){
  #activityFeedCard .activity-feed-link{
    grid-template-columns: 1fr !important;
    gap: 6px !important;
  }
}


/* Live Team Activity compact row restore */
#activityFeedCard .activity-feed-list{
  max-height: 300px !important;
  overflow-y: auto !important;
  overflow-x: hidden !important;
  padding-right: 8px !important;
}

#activityFeedCard .activity-feed-item{
  display: block !important;
  padding: 14px 8px !important;
  min-height: 0 !important;
  border-top: 1px solid rgba(255,255,255,0.18) !important;
  background: transparent !important;
}

#activityFeedCard .activity-feed-item:first-child{
  border-top: 0 !important;
}

#activityFeedCard .activity-feed-link{
  display: flex !important;
  align-items: center !important;
  gap: 18px !important;
  width: 100% !important;
  color: inherit !important;
  text-decoration: none !important;
}

#activityFeedCard .activity-feed-time{
  flex: 0 0 190px !important;
  min-width: 190px !important;
  font-size: 14px !important;
  font-weight: 800 !important;
  color: rgba(22,50,77,0.64) !important;
  white-space: nowrap !important;
}

#activityFeedCard .activity-feed-text{
  flex: 1 1 auto !important;
  min-width: 0 !important;
  font-size: 17px !important;
