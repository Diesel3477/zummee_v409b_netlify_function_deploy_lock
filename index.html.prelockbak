  <link rel="stylesheet" href="shared/header.css?v=2026-03-27-1">

  <script id="zummeeStaffGuard">
  (async () => {
    if (window.__zummeeStaffGuardRan) return;
    window.__zummeeStaffGuardRan = true;

    async function getClient(){
      try{ if(typeof ensureSupabase === 'function'){ const c = await ensureSupabase(); if(c && c.auth && typeof c.auth.getSession === 'function') return c; } }catch(_e){}
      try{ if(window.supabaseClient && window.supabaseClient.auth && typeof window.supabaseClient.auth.getSession === 'function') return window.supabaseClient; }catch(_e){}
      try{ if(window.sb && window.sb.auth && typeof window.sb.auth.getSession === 'function') return window.sb; }catch(_e){}
      return null;
    }

    const go = (target) => {
      try{ window.location.replace(target); }catch(_e){ window.location.href = target; }
    };

    const sb = await getClient();
    if(!sb){ go('login.html'); return; }

    const sessionRes = await sb.auth.getSession();
    const user = sessionRes && sessionRes.data && sessionRes.data.session ? sessionRes.data.session.user : null;
    if(!user){ go('login.html'); return; }

    const ud = await sb
      .from('userdirectory')
      .select('role')
      .eq('auth_user_id', user.id)
      .single();

    const role = String((ud && ud.data && ud.data.role) || '').trim();
    if(role === 'Resident'){ go('resident_portal.html'); return; }

    document.documentElement.setAttribute('data-staff-role', role || '');
  })();
  </script>
