/* V9 remove community dot */
.zummeeCommunitySwatch{
  display:none !important;
}


/* V10 hard remove community swatch */
#zummeeCommunitySwatch,
.zummeeCommunitySwatch{
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  overflow: hidden !important;
  opacity: 0 !important;
  visibility: hidden !important;
  position: absolute !important;
  pointer-events: none !important;
}


/* V11 community dropdown population fix */
#zummeeCommunitySelect:disabled{
  opacity: 1 !important;
}


/* V12 company_name profile normalization fix */

/* V13 getProfile company_name fix */

/* Move the real populated select into the visible header slot */
.managerhub-hero__community-top{
  display:flex;
  align-items:center;
  justify-content:flex-end;
}
.managerhub-hero__community-top > label{ display:none !important; }
#zummeeCommunitySwatch,.zummeeCommunitySwatch{ display:none !important; }

.managerhub-hero__community-top #zummeeCommunitySelect,
.managerhub-hero__community-top #zummeeCommunitySelectReal{
  position:relative !important;
  display:block !important;
  visibility:visible !important;
  opacity:1 !important;
  pointer-events:auto !important;
  appearance:auto !important;
  -webkit-appearance:menulist !important;
  width:210px !important;
  max-width:210px !important;
  height:42px !important;
  min-height:42px !important;
  margin:0 !important;
  padding:8px 12px !important;
  border:none !important;
  border-radius:12px !important;
  background:#ffffff !important;
  color:#111827 !important;
  font-size:14px !important;
  font-weight:700 !important;
  line-height:20px !important;
  box-sizing:border-box !important;
  z-index:3 !important;
}

/* Final mobile Safari community label fix */
.managerhub-hero__community-top{
  position: relative;
}

#zummeeCommunitySelect{
  position: relative !important;
  color: transparent !important;
  text-shadow: 0 0 0 transparent !important;
}

#zummeeCommunitySelect::after{
  content: var(--selected-label, "Select Community");
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #111827;
  pointer-events: none;
  font-weight: 700;
  font-size: 14px;
  line-height: 20px;
  white-space: nowrap;
}

/* Manager Hub pixel-perfect header polish v24 */
.managerhub-hero__left{
  display:flex !important;
  flex-direction:column !important;
  align-items:flex-start !important;
  justify-content:center !important;
}

.managerhub-hero__logo{
  display:block !important;
