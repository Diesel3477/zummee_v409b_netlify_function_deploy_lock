.zummee-communityMenu *{
  list-style-type:none !important;
  list-style:none !important;
}

.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
}

.zummee-communityMenu li::marker{
  content:"" !important;
}

.zummee-communityMenu li::before{
  content:none !important;
  display:none !important;
}

/* Subpage Hub button — match Manager Hub */
.zummee-header .zummee-hubBtn {
  background: #ffffff !important;
  color: #0f2f4a !important;
  border-radius: 28px !important;
  padding: 10px 22px !important;
  font-weight: 700 !important;
  font-size: 16px !important;
  border: 1px solid rgba(15,47,74,0.15) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  transition: all .2s ease;
  text-decoration:none !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
}

.zummee-header .zummee-hubBtn:hover {
  background: #f4f6f8 !important;
}

/* Fix Hub button text color + alignment under dropdown */
.zummee-header .zummee-hubBtn {
  color: #000000 !important;
  display: block !important;
  margin-left: auto !important;
  margin-top: 10px !important;
}

.zummee-header .community-header-right {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important;
}

/* Correct Hub button sizing and force black text */
.zummee-header .zummee-hubBtn {
  background:#ffffff !important;
  color:#000000 !important;
  border-radius:28px !important;
  padding:8px 18px !important;
  font-weight:700 !important;
  font-size:15px !important;
  border:1px solid rgba(15,47,74,0.15) !important;
  box-shadow:0 4px 10px rgba(0,0,0,0.08) !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:auto !important;
  min-width:auto !important;
  margin-top:8px !important;
  align-self:flex-end !important;
}

/* Ensure container stacks properly */
.zummee-header .community-header-right {
  display:flex !important;
  flex-direction:column !important;
  align-items:flex-end !important;
}

/* Force Hub button text to true black */
.zummee-header .zummee-hubBtn,
.zummee-header .zummee-hubBtn:visited,
.zummee-header .zummee-hubBtn span {
  color:#000000 !important;
}

/* Align page titles (like Daily Ops) to the left */
.page-title,
h1.page-title,
.ops-title,
h1 {
  text-align:left !important;
  margin-left:0 !important;
}

/* Precisely align page titles with main card container */
.main-content h1,
.content-wrapper h1,
.page-container h1 {
  text-align:left !important;
  margin-left:40px !important;  /* matches card container padding */
  margin-right:0 !important;
}

/* Prevent centering from parent flex containers */
.page-header,
.title-row {
  justify-content:flex-start !important;
  text-align:left !important;
}

/* Precisely match left edge of main section container */
#opsHeaderRow {
  padding-left: 60px !important; /* match section container padding */
  justify-content: flex-start !important;
}

#opsHeaderRow h1 {
  margin: 0 !important;
}

/* Match subpage logo size to Manager Hub */
.zummee-header .zummee-logo {
  font-size: 42px !important;
  line-height: 1 !important;
}

.zummee-header .zummee-subtitle {
  font-size: 16px !important;
  letter-spacing: 2px !important;
}

.zummee-header svg {
  height: 28px !important;
}

/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}

/* More Tools flex layout fix */
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}

.more-tools-container .card{
  flex: 1 1 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 900px){
  .more-tools-container .card{
    flex: 1 1 calc(50% - 16px);
    max-width: calc(50% - 16px);
  }
}

@media (max-width: 600px){
  .more-tools-container .card{
    flex: 1 1 100%;
    max-width: 100%;
  }
}

</style>

