<body class="inspections-page manager-live-activity-pending" data-page-title="" data-header-mode="hub">
<div id="zummeeHeaderMount"></div>
<script>
(function () {
  const isManagerHub =
    document.body &&
    document.body.dataset &&
    document.body.dataset.headerMode === 'hub';

  if (!isManagerHub) return;

  const mount = document.getElementById('zummeeHeaderMount');
  if (!mount) return;

  mount.style.display = 'none';
})();
