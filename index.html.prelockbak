<style id="liveActivityWhiteCardsFinalFix">
#activityFeedCard .activity-feed-item{
  background:#ffffff !important;
  border:1px solid rgba(18,47,76,0.08) !important;
  border-radius:16px !important;
  box-shadow:0 10px 22px rgba(15,47,74,0.10) !important;
  padding:14px 14px !important;
  margin-bottom:10px !important;
  min-height:0 !important;
}
#activityFeedCard .activity-feed-item:first-child{
  border-top:1px solid rgba(18,47,76,0.08) !important;
}
#activityFeedCard .activity-feed-item:hover{
  background:#ffffff !important;
}
#activityFeedCard .activity-feed-link{
  color:#16324d !important;
}
#activityFeedCard .activity-feed-time{
  color:rgba(22,50,77,0.64) !important;
}
#activityFeedCard .activity-feed-text,
#activityFeedCard .activity-feed-text-main,
#activityFeedCard .activity-feed-item *,
#activityFeedCard .activity-feed-link *{
  color:#16324d !important;
}
#activityFeedCard .activity-feed-open,
#activityFeedCard .activity-feed-text a{
  color:#28578f !important;
}
@media (max-width:860px){
  #activityFeedCard .activity-feed-item{
    padding:12px 12px !important;
  }
}
</style>

<script id="manager-mileage-reminder-runtime">
(function(){
  function getSelectedCommunityIdForMileageReminder(){
    try{
      return String(
        localStorage.getItem("zummee_selected_community_id") ||
        localStorage.getItem("zummee_selected_community_v1") ||
        "global"
      ).trim() || "global";
    }catch(_e){
      return "global";
    }
  }

  function getUserIdForMileageReminder(){
    try{ return String(localStorage.getItem("zummee_user_id_v1") || "").trim() || "anon"; }catch(_e){ return "anon"; }
  }

  function mileageReminderEnabled(){
    try{
      var key = "zummee_mileage_reminder_enabled__user__" + getUserIdForMileageReminder() + "__community__" + getSelectedCommunityIdForMileageReminder();
      return localStorage.getItem(key) === "1";
    }catch(_e){
      return false;
    }
  }

  function mileageComplianceDone(){
    try{
      var cid = getSelectedCommunityIdForMileageReminder();
      var uid = getUserIdForMileageReminder();
      // page-level compliance snapshots if the user has visited mileage page
      var month = new Date().toISOString().slice(0,7);
      var exact = [
        "zummee_mileage_compliance__user__" + uid + "__community__" + cid + "__month__" + month,
        "zummee_mileage_compliance_" + uid + "_" + cid + "_" + month
      ];
      for(var i=0;i<exact.length;i++){
        var v = localStorage.getItem(exact[i]);
        if(v === "1" || v === "true") return true;
      }
      return false;
    }catch(_e){
      return false;
    }
  }

  function getMileageReminderState(){
    if(!mileageReminderEnabled()) return null;
    if(mileageComplianceDone()) return null;

    var today = new Date();
    var day = today.getDate();
    if(day < 23) return null;

    return {
      urgent: day >= 25,
      label: day >= 25 ? "Due now" : "Due soon",
      text: "Submit mileage before month end"
    };
  }

  function findReminderMount(){
    var selectors = [
      '#remindersList',
      '#remindersCard .card-body',
      '#remindersCard .mz-shell',
      '#remindersCard',
      '[data-card="reminders"]',
      '.manager-reminders-list',
      '.reminders-list'
    ];
    for(var i=0;i<selectors.length;i++){
      var el = document.querySelector(selectors[i]);
      if(el) return el;
    }
    return null;
  }

  function renderMileageReminder(){
    try{
      var state = getMileageReminderState();
      var mount = findReminderMount();
      var existing = document.getElementById('managerMileageReminderCard');
      if(!mount){
        if(existing) existing.remove();
        return;
      }
      if(!state){
        if(existing) existing.remove();
        return;
      }
      if(!existing){
        existing = document.createElement('div');
        existing.id = 'managerMileageReminderCard';
        mount.prepend(existing);
      }
      existing.className = 'mileage-due-reminder' + (state.urgent ? ' is-urgent' : '');
      existing.innerHTML = ''
        + '<div>'
        +   '<div class="mileage-due-reminder__title">Mileage reminder</div>'
        +   '<div class="mileage-due-reminder__sub">' + state.text + '</div>'
        + '</div>'
        + '<div class="mileage-due-reminder__tag">' + state.label + '</div>';
    }catch(_e){}
  }

  document.addEventListener('DOMContentLoaded', function(){
    setTimeout(renderMileageReminder, 300);
    setTimeout(renderMileageReminder, 900);
  });
  window.addEventListener('pageshow', function(){
    setTimeout(renderMileageReminder, 180);
    setTimeout(renderMileageReminder, 520);
  });
  document.addEventListener('community:changed', function(){
    setTimeout(renderMileageReminder, 220);
    setTimeout(renderMileageReminder, 560);
  });
  document.addEventListener('mileage-reminder:changed', function(){
    setTimeout(renderMileageReminder, 80);
  });

  // expose for debugging if needed
  window.__renderMileageReminder = renderMileageReminder;
})();
</script>

</body>
</html>
