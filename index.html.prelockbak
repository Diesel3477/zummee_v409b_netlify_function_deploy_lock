/* Supervisor missing compliance phase 1 */
.supervisor-missing-compliance-card{
  max-width:1180px;
  margin:0 auto 24px auto;
  padding:18px 18px 14px;
  border-radius:30px;
  background:linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.14));
  border:1px solid rgba(255,255,255,0.32);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.24), 0 18px 40px rgba(15,47,74,0.10);
  backdrop-filter:blur(18px) saturate(120%);
  -webkit-backdrop-filter:blur(18px) saturate(120%);
}
.supervisor-missing-compliance__header{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:14px;
  margin-bottom:12px;
}
.supervisor-missing-compliance__eyebrow{
  font-size:12px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.12em;
  color:rgba(22,50,77,0.58);
}
.supervisor-missing-compliance__title{
  font-size:28px;
  line-height:1.04;
  font-weight:800;
  letter-spacing:-0.03em;
  color:#16324d;
  margin-top:4px;
}
.supervisor-missing-compliance__sub{
  margin-top:6px;
  font-size:15px;
  font-weight:700;
  color:rgba(22,50,77,0.72);
}
.supervisor-missing-compliance__count{
  flex:0 0 auto;
  min-width:48px;
  height:48px;
  padding:0 14px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border-radius:999px;
  background:linear-gradient(180deg, #f59e0b, #d97706);
  color:#fff;
  font-size:20px;
  font-weight:900;
  box-shadow:0 10px 22px rgba(217,119,6,0.28);
}
.supervisor-missing-compliance__list{
  display:grid;
  gap:10px;
}
.supervisor-missing-compliance__row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:14px 14px;
  border-radius:18px;
  background:rgba(255,255,255,0.14);
  border:1px solid rgba(255,255,255,0.20);
}
.supervisor-missing-compliance__row-left{
  min-width:0;
}
.supervisor-missing-compliance__row-community{
  font-size:17px;
  font-weight:800;
  color:#16324d;
}
.supervisor-missing-compliance__row-employee{
  margin-top:2px;
  font-size:14px;
  font-weight:700;
  color:rgba(22,50,77,0.68);
}
.supervisor-missing-compliance__row-status{
  flex:0 0 auto;
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:9px 12px;
  border-radius:999px;
  background:rgba(245,158,11,0.14);
  color:#9a5a00;
  border:1px solid rgba(245,158,11,0.22);
  font-size:13px;
  font-weight:800;
}
.supervisor-missing-compliance__row-status::before{
  content:"";
  width:9px;
  height:9px;
  border-radius:999px;
  background:#f59e0b;
  box-shadow:0 0 0 5px rgba(245,158,11,0.14);
}
.supervisor-missing-compliance__empty{
  padding:16px 6px 8px;
  font-size:15px;
  font-weight:700;
  color:rgba(22,50,77,0.64);
}
@media (max-width: 860px){
  .supervisor-missing-compliance-card{
    margin:0 12px 22px 12px;
    padding:16px 14px 12px;
    border-radius:24px;
  }
  .supervisor-missing-compliance__title{
    font-size:24px;
  }
  .supervisor-missing-compliance__header{
    align-items:flex-start;
  }
  .supervisor-missing-compliance__row{
    flex-direction:column;
    align-items:flex-start;
  }
  .supervisor-missing-compliance__count{
    min-width:42px;
    height:42px;
    font-size:18px;
  }
}


/* v247 role-scoped card registry */
.role-card-hidden{
  display:none !important;
  visibility:hidden !important;
  pointer-events:none !important;
}


/* v256 collapsible live activity */
#activityFeedCard{
  overflow:hidden;
}
.activity-feed-header{
  cursor:pointer;
}
.activity-feed-toggle{
  margin-left:auto;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:34px;
  height:34px;
  border-radius:999px;
  background:rgba(255,255,255,0.22);
  border:1px solid rgba(255,255,255,0.28);
  color:#17324d;
  font-size:16px;
  font-weight:900;
  line-height:1;
  flex:0 0 auto;
  transition:transform .2s ease, background .2s ease;
}
#activityFeedCard.is-collapsed .activity-feed-toggle{
  transform:rotate(-180deg);
}
#activityFeedCard .activity-feed-list{
  max-height:420px;
  overflow:hidden;
  transition:max-height .25s ease, opacity .2s ease, margin .2s ease, padding .2s ease;
}
#activityFeedCard.is-collapsed .activity-feed-list{
  max-height:0 !important;
  opacity:0;
  margin-top:0 !important;
  padding-top:0 !important;
  padding-bottom:0 !important;
  pointer-events:none;
}


/* v257 fix live activity header alignment */
.activity-feed-header{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px;
}
.activity-feed-title{
  order:1;
}
.activity-feed-toggle{
  order:2;
  margin-left:auto !important;
}


/* v258 universal glass manager hub header */
.managerhub-hero{
  position:relative !important;
  width:min(1480px, calc(100% - 28px)) !important;
  margin:14px auto 18px auto !important;
  padding:18px 22px !important;
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:20px !important;
  border-radius:30px !important;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.02) 38%, rgba(255,255,255,0.00) 100%),
    linear-gradient(135deg, #143a5c 0%, #1b4468 100%) !important;
  border:1px solid rgba(255,255,255,0.16) !important;
  box-shadow:0 18px 42px rgba(15,47,74,0.20), inset 0 1px 0 rgba(255,255,255,0.12) !important;
  overflow:hidden !important;
}
.managerhub-hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    radial-gradient(1200px 320px at -10% -30%, rgba(255,255,255,0.10), transparent 45%),
    radial-gradient(720px 220px at 110% 10%, rgba(255,255,255,0.06), transparent 42%);
  pointer-events:none;
}
.managerhub-hero > *{ position:relative; z-index:1; }
.managerhub-hero__left{
  min-width:0 !important;
  flex:1 1 auto !important;
  display:flex !important;
  align-items:center !important;
  gap:20px !important;
}
.managerhub-hero__logo{
  width:340px !important;
  max-width:min(340px, 42vw) !important;
  height:auto !important;
  display:block !important;
  filter:drop-shadow(0 2px 10px rgba(0,0,0,0.10));
}
.managerhub-hero__copy{
  margin-left:0 !important;
  padding-left:0 !important;
}
.managerhub-title-inline{
  color:#ffffff !important;
  font-size:29px !important;
  line-height:1.02 !important;
  font-weight:700 !important;
  letter-spacing:-0.03em !important;
  margin:0 !important;
}
.managerhub-hero__actions{
  flex:0 0 auto !important;
  min-width:min(420px, 44vw) !important;
}
.managerhub-hero__community{
  width:100% !important;
}
.managerhub-hero__community-top{
  width:100% !important;
}
.managerhub-hero__community-top #zummeeCommunitySelect{
  min-width:min(420px, 42vw) !important;
  width:min(420px, 42vw) !important;
  max-width:100% !important;
  height:56px !important;
  padding:0 18px !important;
  border-radius:18px !important;
  background:#f7fbff !important;
  color:#17324d !important;
  border:1px solid rgba(15,47,74,0.14) !important;
  box-shadow:0 8px 20px rgba(7,24,39,0.12) !important;
  font-size:16px !important;
  font-weight:800 !important;
}
.managerhub-hero__account-row{
  margin-top:12px !important;
  display:flex !important;
  justify-content:flex-end !important;
  gap:10px !important;
  flex-wrap:wrap !important;
}
.managerhub-hero__account-btn{
  min-width:128px !important;
  height:46px !important;
  padding:0 20px !important;
  border-radius:999px !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  background:#f7fbff !important;
  color:#17324d !important;
  border:1px solid rgba(15,47,74,0.14) !important;
  box-shadow:0 8px 20px rgba(7,24,39,0.12) !important;
  text-decoration:none !important;
  font-size:15px !important;
  font-weight:800 !important;
}
.managerhub-hero__account-btn:hover{
  transform:translateY(-1px);
  filter:brightness(1.02);
}
.managerhub-signout-pop{
  z-index:12 !important;
}
@media (max-width: 1024px){
  .managerhub-hero{
    width:calc(100% - 22px) !important;
    padding:16px 18px !important;
    border-radius:26px !important;
  }
  .managerhub-hero__logo{
    width:300px !important;
    max-width:min(300px, 44vw) !important;
  }
  .managerhub-title-inline{
    font-size:26px !important;
  }
}
@media (max-width: 768px){
  .managerhub-hero{
    flex-direction:column !important;
