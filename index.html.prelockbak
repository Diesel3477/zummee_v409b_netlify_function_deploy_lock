</section>

<style>
  /* Supervisor Access layout () */
  #supervisorBox{display:none;}
  .sup-grid2{ display:grid; grid-template-columns: 1fr; gap:14px; }
  @media (min-width: 980px){ .sup-grid2{ grid-template-columns: 420px 1fr; align-items:start; } }
  .sup-subcard{ background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:14px; }
  .sup-row{ display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
  .sup-between{ justify-content:space-between; }
  .sup-row input, .sup-row select{ flex:1; min-width: 220px; }
  .sup-divider{ height:1px; background:#e5e7eb; margin:12px 0; }
  .sup-list{ display:flex; flex-direction:column; gap:10px; margin-top:10px; }
  .sup-list .item{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px; border:1px solid #e5e7eb; border-radius:10px; background:#fafafa; }
  .sup-checks{ display:flex; flex-direction:column; gap:8px; padding-top:8px; max-height:260px; overflow:auto; border:1px solid #e5e7eb; border-radius:10px; padding:10px; background:#fff; }
  .sup-checks .check{ display:flex; align-items:center; gap:10px; }
  
  .sup-emp{ display:flex; flex-direction:column; gap:8px; max-height:240px; overflow:auto; border:1px solid #e5e7eb; border-radius:10px; padding:10px; background:#fff; }
  .sup-emp .emp{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:8px 10px; border:1px solid #eef2f7; border-radius:10px; background:#fafafa; }
  .sup-emp .emp .meta{ display:flex; flex-direction:column; gap:2px; }
  .sup-emp .emp .meta .name{ font-weight:800; }
  .sup-emp .emp .meta .sub{ font-size:12px; color:#556; }
  .sup-emp .pill{ display:inline-block; padding:2px 8px; border-radius:999px; border:1px solid rgba(15,47,74,0.25); font-size:12px; font-weight:800; color:#0f2f4a; background:rgba(15,47,74,0.06); margin-left:6px;}

/* Pill variants */
.pill--admin{ border-color: rgba(220,38,38,0.35) !important; color:#991b1b !important; background: rgba(220,38,38,0.08) !important; }
.pill--employee{ border-color: rgba(107,114,128,0.35) !important; color:#374151 !important; background: rgba(107,114,128,0.08) !important; }
.pill--warn{ border-color: rgba(245,158,11,0.45) !important; color:#92400e !important; background: rgba(245,158,11,0.10) !important; }
.sup-checks input[type="checkbox"]{ width:16px; height:16px; }
.sup-subhead{ display:flex; justify-content:space-between; gap:12px; align-items:flex-end; flex-wrap:wrap; margin-bottom:6px; }
.sup-tabs{ display:flex; gap:6px; flex-wrap:wrap; }
.sup-tab{ border:1px solid rgba(15,47,74,0.18); background:rgba(255,255,255,0.85); color:#0f2f4a; font-weight:800; padding:8px 10px; border-radius:999px; cursor:pointer; }
.sup-tab.is-active{ background:#0f2f4a; color:#fff; border-color:#0f2f4a; }
.sup-tabpanel{ margin-top:4px; }
.sup-bulk{ margin:8px 0 10px; padding:10px; border:1px solid rgba(15,47,74,0.18); border-radius:12px; background:rgba(255,255,255,0.85); }
.sup-bulk__grid{ display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end; }
.sup-bulk__left{ min-width:240px; flex:1; }
.sup-bulk__actions{ display:flex; gap:8px; align-items:center; flex-wrap:wrap; }

/* Ensure community dropdown text is dark and readable */
#zummeeCommunitySelect{
  color:#0f2f4a !important;
  font-weight:700 !important;
}
.zummee-modern-picker__button,
.zummee-modern-picker__item{
  color:#0f2f4a !important;
}

/* Force subpage dropdown to match Manager Hub */
#zummeeCommunitySelect{
  background:#ffffff !important;
  color:#000000 !important;
  font-weight:700 !important;
}

.zummee-modern-picker__button{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

.zummee-modern-picker__menu{
  background:#ffffff !important;
}

.zummee-modern-picker__item{
  color:#000000 !important;
}

/* Match Manager Hub community picker styling (white dropdown, black text) */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communityBtn span{
  color:#000000 !important;
}
.zummee-communityMenu{
  background:#ffffff !important;
  border:1px solid rgba(15,47,74,0.18) !important;
}
.zummee-communitySearch{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}
.zummee-communitySearch::placeholder{
  color: rgba(0,0,0,0.55) !important;
}
.zummee-communityItem{
  color:#000000 !important;
}

/* Force dropdown button background to white */
.zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Override header generic button styling for community picker */
.zummee-header .zummee-communityBtn{
  background:#ffffff !important;
  color:#000000 !important;
  border:1px solid rgba(15,47,74,0.25) !important;
}

/* Remove bullet points from modern community dropdown */
.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
  padding-left:0 !important;
  margin-left:0 !important;
}

.zummee-communityItem::before{
  content:none !important;
  display:none !important;
}

/* FORCE remove bullets everywhere inside community dropdown */
.zummee-communityMenu,
.zummee-communityMenu *{
  list-style-type:none !important;
  list-style:none !important;
}

.zummee-communityMenu ul,
.zummee-communityMenu li{
  list-style:none !important;
}

.zummee-communityMenu li::marker{
  content:"" !important;
}

.zummee-communityMenu li::before{
  content:none !important;
  display:none !important;
}

/* Subpage Hub button — match Manager Hub */
.zummee-header .zummee-hubBtn {
  background: #ffffff !important;
  color: #0f2f4a !important;
  border-radius: 28px !important;
  padding: 10px 22px !important;
  font-weight: 700 !important;
  font-size: 16px !important;
  border: 1px solid rgba(15,47,74,0.15) !important;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08) !important;
  transition: all .2s ease;
  text-decoration:none !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
}

.zummee-header .zummee-hubBtn:hover {
  background: #f4f6f8 !important;
}

/* Fix Hub button text color + alignment under dropdown */
.zummee-header .zummee-hubBtn {
  color: #000000 !important;
  display: block !important;
  margin-left: auto !important;
  margin-top: 10px !important;
}

.zummee-header .community-header-right {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-end !important;
}

/* Correct Hub button sizing and force black text */
.zummee-header .zummee-hubBtn {
  background:#ffffff !important;
  color:#000000 !important;
  border-radius:28px !important;
  padding:8px 18px !important;
  font-weight:700 !important;
  font-size:15px !important;
  border:1px solid rgba(15,47,74,0.15) !important;
  box-shadow:0 4px 10px rgba(0,0,0,0.08) !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:auto !important;
  min-width:auto !important;
  margin-top:8px !important;
  align-self:flex-end !important;
}

/* Ensure container stacks properly */
.zummee-header .community-header-right {
  display:flex !important;
  flex-direction:column !important;
  align-items:flex-end !important;
}

/* Force Hub button text to true black */
.zummee-header .zummee-hubBtn,
.zummee-header .zummee-hubBtn:visited,
.zummee-header .zummee-hubBtn span {
  color:#000000 !important;
}

/* Align page titles (like Daily Ops) to the left */
.page-title,
h1.page-title,
.ops-title,
h1 {
  text-align:left !important;
  margin-left:0 !important;
}

/* Precisely align page titles with main card container */
.main-content h1,
.content-wrapper h1,
.page-container h1 {
  text-align:left !important;
  margin-left:40px !important;  /* matches card container padding */
  margin-right:0 !important;
}

/* Prevent centering from parent flex containers */
.page-header,
.title-row {
  justify-content:flex-start !important;
  text-align:left !important;
}

/* Precisely match left edge of main section container */
#opsHeaderRow {
  padding-left: 60px !important; /* match section container padding */
  justify-content: flex-start !important;
}

#opsHeaderRow h1 {
  margin: 0 !important;
}

/* Match subpage logo size to Manager Hub */
.zummee-header .zummee-logo {
  font-size: 42px !important;
  line-height: 1 !important;
}

.zummee-header .zummee-subtitle {
  font-size: 16px !important;
  letter-spacing: 2px !important;
}

.zummee-header svg {
  height: 28px !important;
}

/* Stronger pulsing prepare community alert button */
#weatherSuggestBtn{
  background: linear-gradient(180deg, #6fdc8c 0%, #38b86a 100%) !important;
  color: #ffffff !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  border-radius: 28px !important;
  position: relative !important;
  overflow: visible !important;
  animation: pulseGlowStrong 1.4s ease-in-out infinite !important;
}
#weatherSuggestBtn::after{
  content: "" !important;
  position: absolute !important;
  inset: -2px !important;
  border-radius: inherit !important;
  box-shadow: 0 0 0 0 rgba(56,184,106,0.75) !important;
  animation: pulseRingStrong 1.4s ease-out infinite !important;
  pointer-events: none !important;
}
#weatherSuggestBtn:hover{
  transform: translateY(-2px) scale(1.02);
  filter: brightness(1.05);
}
@keyframes pulseGlowStrong{
  0%,100%{ transform: scale(1); }
  50%{ transform: scale(1.05); }
}
@keyframes pulseRingStrong{
  0%{ box-shadow: 0 0 0 0 rgba(56,184,106,0.75); }
  70%{ box-shadow: 0 0 0 18px rgba(56,184,106,0); }
  100%{ box-shadow: 0 0 0 0 rgba(56,184,106,0); }
}

/* More Tools flex layout fix */
.more-tools-container.open{
  display:flex;
  flex-wrap:wrap;
  gap:16px;
}

.more-tools-container .card{
  flex: 1 1 calc(33.333% - 16px);
  max-width: calc(33.333% - 16px);
}

@media (max-width: 900px){
  .more-tools-container .card{
    flex: 1 1 calc(50% - 16px);
    max-width: calc(50% - 16px);
  }
}

@media (max-width: 600px){
  .more-tools-container .card{
    flex: 1 1 100%;
    max-width: 100%;
  }
}

</style>

<script>
(function(){
  var box = document.getElementById("supervisorBox");
  var hubCard = document.getElementById("supervisorHubCard");
  if(!box) return;

  function $(id){ return document.getElementById(id); }
  var elList = $("sup_companyCommunityList");
  var elAssign = $("sup_perCommunityAssign");
  var elPreview = $("sup_assignmentPreview");
  var elStatus = $("sup_status");

  // Community rename/edit state (Supervisor Access)
  var _selectedCommunityId = "";
  var _selectedCommunityName = "";
  var _lastRename = null; // {company,id,from,to,at,by}

  function setStatusText(t){
    try{ if(elStatus){ elStatus.textContent = String(t||""); } }catch(_e){}
  }
  function setStatusHtml(h){
    try{ if(elStatus){ elStatus.innerHTML = String(h||""); } }catch(_e){}
  }

  function auditKey(company){ return "zummee_comm_audit_v1__" + company; }
  function loadAudit(company){ return loadJSON(auditKey(company), {}); }
  function saveAudit(company, obj){ saveJSON(auditKey(company), obj||{}); }

  function setSelectedCommunity(id, name){
    _selectedCommunityId = String(id||"");
    _selectedCommunityName = String(name||"");
    var btnEdit = $("sup_editCommunityBtn");
    if(btnEdit){
      btnEdit.disabled = !_selectedCommunityId;
    }
  }

  async function renameCommunityCloud(company, id, newName){
    if(!company || !id || !newName || !window.sb) return false;
    try{
      var q = await window.sb.from('PropertyCommunities')
        .update({ name: newName })
        .eq('company', company)
        .eq('id', id);
      if(q && q.error) throw q.error;
      return true;
    }catch(e){
      console.warn("renameCommunityCloud failed:", e);
      return false;
    }
  }

  async function doRenameCommunity(company, id, fromName, toName){
    var auth = window.ZUMMEE_AUTH || {};
    var by = String(auth.name || auth.email || auth.userId || "Admin");
    var at = new Date().toISOString();
    // Cloud first
    var ok = await renameCommunityCloud(company, id, toName);
    // Update local cache so UI matches immediately
    var key = companyCommunitiesKey(company);
    var list = loadJSON(key, []);
    list = (list||[]).map(function(c){
      if(String(c.id)===String(id)) return { id: c.id, name: toName };
      return c;
    });
    saveJSON(key, list);

    // Save audit note locally (schema-safe)
    var audit = loadAudit(company);
    audit[String(id)] = { renamedBy: by, renamedAt: at, from: fromName, to: toName };
    saveAudit(company, audit);

    _lastRename = { company: company, id: id, from: fromName, to: toName, at: at, by: by };

    // Status with Undo
    setStatusHtml('Renamed to <strong>' + esc(toName) + '</strong>. <button class="btn btn--ghost" id="sup_undoRenameBtn" type="button" style="padding:6px 10px; margin-left:8px;">Undo</button>');
    return ok;
  }

  async function undoLastRename(){
    try{
      if(!_lastRename) return false;
      var r = _lastRename;
      _lastRename = null;
      var ok = await renameCommunityCloud(r.company, r.id, r.from);
      // Update local cache
      var key = companyCommunitiesKey(r.company);
      var list = loadJSON(key, []);
      list = (list||[]).map(function(c){
        if(String(c.id)===String(r.id)) return { id: c.id, name: r.from };
        return c;
      });
      saveJSON(key, list);

      // Update audit
      var audit = loadAudit(r.company);
      audit[String(r.id)] = { renamedBy: r.by, renamedAt: r.at, from: r.to, to: r.from };
      saveAudit(r.company, audit);

      setSelectedCommunity(r.id, r.from);
      setStatusText("Undo complete.");
      refreshAll();
      return ok;
    }catch(e){
      console.warn("undoLastRename failed:", e);
      setStatusText("Undo failed.");
      return false;
    }
  }

  // Handle Undo click in status area
  if(elStatus){
    elStatus.addEventListener("click", function(e){
      var t = e && e.target;
      if(t && t.id === "sup_undoRenameBtn"){
        e.preventDefault();
        undoLastRename();
      }
    });
  }

  function esc(s){ return String(s||"").replace(/[&<>"']/g, function(m){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]); }); }

  function getCompany(){
    try{
      var auth = window.ZUMMEE_AUTH || {};
      var role = String(auth.role || window.__zummeeUserRole || '').trim();
      if(role === 'Admin'){
        var picked = String(localStorage.getItem('zummee_admin_selected_company')||'').trim();
        if(picked) return picked;
      }
      return String(window.__zummeeCompany || localStorage.getItem('zummee_company') || '').trim();
    }catch(_e){
      return String(window.__zummeeCompany || '').trim();
    }
  }

  async function setCompanyName(newCompany){
    var c = String(newCompany||"").trim();
    if(!c) return false;
    try{ localStorage.setItem("zummee_company", c); }catch(_e){}
    window.__zummeeCompany = c;
    // Try to persist to Profiles if signed in
    try{
      if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb){
        var sess = await window.sb.auth.getSession();
        var uid = sess.data?.session?.user?.id;
        if(uid){
          await window.sb.from("profiles").upsert([{ id: uid, company: c }], { onConflict: "id" });
        }
      }
    }catch(_e){}
    // Notify listeners (badges, etc.)
    try{ window.dispatchEvent(new CustomEvent("profile:loaded", { detail: { company: c, role: window.__zummeeUserRole||"", department: window.__zummeeUserDepartment||"" } })); }catch(_e){}
    return true;
  }

  function assignmentsKey(company){ return "zummee_company_assignments_v2__" + company; }
  function companyCommunitiesKey(company){ return "zummee_company_communities_v1__" + company; }

  function loadJSON(key, fallback){
    try{ var v = localStorage.getItem(key); if(!v) return fallback; return JSON.parse(v); }catch(_e){ return fallback; }
  }
  function saveJSON(key, val){ localStorage.setItem(key, JSON.stringify(val)); }

  function normalizeCommunity(c){
    if(!c) return null;
    var id = String(c.id || c.communityId || c.value || "").trim();
    var name = String(c.name || c.communityName || c.label || c.text || "").trim();
    if(!id && name) id = String(Date.now()) + "_" + Math.random().toString(16).slice(2);
    if(!name) name = id;
    return { id:id, name:name };
  }

  // Cloud sync: Communities + CommunityAssignments (Supabase) with local fallback cache
  async function syncCompanyFromCloud(company){
    if(!company || !window.sb) return { communities: null, assignments: null };
    try{
      // Load communities for company
      var qc = await window.sb.from('PropertyCommunities')
        .select('id,name,company')
        .eq('company', company)
        .order('name', { ascending: true });
      if(qc && qc.error) throw qc.error;
      var comms = (qc && qc.data) ? qc.data : [];
      var cleaned = comms.map(function(r){ return normalizeCommunity({ id: r.id, name: r.name }); }).filter(Boolean);

      // Load assignments for company
      var qa = await window.sb.from('CommunityAssignments')
        .select('community_id,user_id,company')
        .eq('company', company);
      if(qa && qa.error) throw qa.error;
      var rows = (qa && qa.data) ? qa.data : [];
      var map = {};
      rows.forEach(function(r){
        if(r && r.community_id){
          var cid = String(r.community_id);
          var uid = r.user_id ? String(r.user_id) : "";
          if(uid) map[cid]=uid;
        }
      });

      // Persist into local cache keys so the rest of the app can use them
      try{ saveJSON(companyCommunitiesKey(company), cleaned); }catch(_e){}
      try{ saveJSON(assignmentsKey(company), map); }catch(_e){}
      return { communities: cleaned, assignments: map };
    }catch(e){
      console.warn("syncCompanyFromCloud failed:", e);
      return { communities: null, assignments: null };
    }
  }

  async function addCommunityToCloud(company, name){
    if(!company || !name || !window.sb) return false;
    try{
      // Prevent obvious duplicates (case-insensitive) by checking first
      var q = await window.sb.from('PropertyCommunities').select('id,name').eq('company', company).ilike('name', name);
      if(q && q.error) throw q.error;
      if(q && q.data && q.data.length){
        return true; // already exists
      }
      var _u = await window.sb.auth.getUser();
      var _uid = (_u && _u.data && _u.data.user && _u.data.user.id) ? _u.data.user.id : null;
      var ins = await window.sb.from('PropertyCommunities').insert({ company: company, name: name }).select('id').single();
      if(ins && ins.error) throw ins.error;
      return true;
    }catch(e){
      console.warn("addCommunityToCloud failed:", e);
      return false;
    }
  }

  async function deleteCommunityFromCloud(company, communityId){
    if(!company || !communityId || !window.sb) return false;
    try{
      // First delete any assignments referencing this community (prevents FK issues if you add FKs later)
      var delA = await window.sb.from('CommunityAssignments')
        .delete()
        .eq('company', company)
        .eq('community_id', communityId);
      if(delA && delA.error) throw delA.error;

      // Then delete the community itself
      var delC = await window.sb.from('PropertyCommunities')
        .delete()
        .eq('company', company)
        .eq('id', communityId);
      if(delC && delC.error) throw delC.error;

      return true;
    }catch(e){
      console.warn("deleteCommunityFromCloud failed:", e);
      return false;
    }
  }

  async function setAssignmentInCloud(company, communityId, userId){
    if(!company || !communityId || !window.sb) return false;
    try{
      if(userId){
        // Upsert (requires unique constraint on (company, community_id))
        var up = await window.sb.from('CommunityAssignments')
        .upsert({ company: company, community_id: communityId, user_id: userId }, { onConflict: 'user_id,community_id' });
        if(up && up.error) throw up.error;
      }else{
        var del = await window.sb.from('CommunityAssignments')
          .delete()
          .eq('company', company)
          .eq('community_id', communityId);
        if(del && del.error) throw del.error;
      }
      return true;
    }catch(e){
      console.warn("setAssignmentInCloud failed:", e);
      return false;
    }
  }

  function renderCompanyCommunities(list){
    // Always show communities in alphabetical order (by name)
    list = (list||[]).slice().sort(function(a,b){
      var na = String((a && a.name) || "").trim().toLowerCase();
      var nb = String((b && b.name) || "").trim().toLowerCase();
      return na.localeCompare(nb);
    });

    // Reset selection if selected id no longer exists
    if(_selectedCommunityId){
      var still = (list||[]).some(function(c){ return String(c.id)===String(_selectedCommunityId); });
      if(!still) setSelectedCommunity("", "");
    }

    elList.innerHTML = "";
    if(!list.length){
      elList.innerHTML = '<div class="muted">No company communities yet.</div>';
      return;
    }

    var company = getCompany();
    var audit = company ? loadAudit(company) : {};

    list.forEach(function(c){
      var row = document.createElement("div");
      row.className = "item";
      row.setAttribute("data-id", String(c.id));
      row.setAttribute("data-name", String(c.name||""));

      var auditLine = "";
      var a = audit && audit[String(c.id)];
      if(a && (a.renamedAt || a.renamedBy)){
        var when = "";
        try{
          when = new Date(a.renamedAt).toLocaleString();
        }catch(_e){ when = String(a.renamedAt||""); }
        auditLine = '<div class="muted tiny" style="margin-top:2px;">Last renamed by <strong>'+esc(a.renamedBy||"")+'</strong>' + (when?(' on '+esc(when)):'') + '</div>';
      }

      row.innerHTML =
        '<div style="flex:1; min-width:0;">' +
          '<div class="sup-name" style="font-weight:800; cursor:text;">'+esc(c.name)+'</div>' +
          auditLine +
        '</div>' +
        '<div style="display:flex; gap:8px; align-items:center;">' +
          '<button class="btn btn--ghost" data-inline-rename="'+esc(c.id)+'" type="button">Rename</button>' +
          '<button class="btn btn--ghost" data-remove="'+esc(c.id)+'" type="button">Remove</button>' +
        '</div>';

      // selected styling
      if(String(_selectedCommunityId) === String(c.id)){
        row.style.outline = "2px solid rgba(15,47,74,0.35)";
        row.style.background = "rgba(15,47,74,0.04)";
      }

      // Click row to select
      row.addEventListener("click", function(ev){
        // Avoid selecting when clicking buttons (but still select for convenience)
        setSelectedCommunity(String(c.id), String(c.name||""));
        // Prefill input for convenience
        var inp = $("sup_newCommunityName");
        if(inp && inp !== document.activeElement) inp.value = String(c.name||"");
        // Re-render selection highlight
        renderCompanyCommunities(list);
      });

      elList.appendChild(row);
    });

    // Inline rename handler (button)
    elList.querySelectorAll("button[data-inline-rename]").forEach(function(btn){
      btn.addEventListener("click", async function(ev){
        ev.stopPropagation();
        var id = btn.getAttribute("data-inline-rename");
        var company = getCompany(); if(!company) return;
        var currentName = "";
        try{
          var row = btn.closest(".item");
          currentName = row ? (row.getAttribute("data-name")||"") : "";
        }catch(_e){}
        if(!currentName){
          // fallback from cache
          var key = companyCommunitiesKey(company);
          var list0 = loadJSON(key, []);
          var found = (list0||[]).find(function(c){ return String(c.id)===String(id); });
          currentName = found ? String(found.name||"") : "";
        }

        // In-place editor UI
        var rowEl = null;
        try{ rowEl = btn.closest(".item"); }catch(_e){}
        if(!rowEl) return;

        var nameHost = rowEl.querySelector(".sup-name");
        if(!nameHost) return;

        var oldName = String(currentName||nameHost.textContent||"").trim();
        var input = document.createElement("input");
        input.value = oldName;
        input.style.width = "100%";
        input.style.padding = "6px 8px";
        input.style.borderRadius = "10px";
        input.style.border = "1px solid rgba(15,47,74,0.25)";

        var actions = document.createElement("div");
        actions.style.display = "flex";
        actions.style.gap = "8px";
        actions.style.marginTop = "6px";

        var bSave = document.createElement("button");
        bSave.type = "button";
        bSave.className = "btn";
        bSave.textContent = "Save";

        var bCancel = document.createElement("button");
        bCancel.type = "button";
        bCancel.className = "btn btn--ghost";
        bCancel.textContent = "Cancel";

        actions.appendChild(bSave);
        actions.appendChild(bCancel);

        // Replace nameHost content
        nameHost.innerHTML = "";
        nameHost.appendChild(input);
        nameHost.appendChild(actions);

        input.focus();
        input.select();

        async function finish(save){
          if(!save){
            // restore
            nameHost.textContent = oldName;
            refreshAll();
            return;
          }
          var newName = String(input.value||"").trim();
          if(!newName){ alert("Enter a community name."); return; }
          if(newName === oldName){ nameHost.textContent = oldName; return; }

          // Prevent duplicates within the company
          var key = companyCommunitiesKey(company);
          var list0 = loadJSON(key, []);
          var dup = (list0||[]).some(function(c){ return String(c.id)!==String(id) && String(c.name||"").trim().toLowerCase()===newName.toLowerCase(); });
          if(dup){ alert("A community with that name already exists for this company."); return; }

          bSave.disabled = true;
          bCancel.disabled = true;
          await doRenameCommunity(company, id, oldName, newName);
          setSelectedCommunity(id, newName);
          refreshAll();
        }

        bSave.addEventListener("click", function(e){ e.stopPropagation(); finish(true); });
        bCancel.addEventListener("click", function(e){ e.stopPropagation(); finish(false); });
        input.addEventListener("keydown", function(e){
          if(e.key === "Enter"){ e.preventDefault(); finish(true); }
          if(e.key === "Escape"){ e.preventDefault(); finish(false); }
        });
      });
    });

    // Remove handler
    elList.querySelectorAll("button[data-remove]").forEach(function(btn){
      btn.addEventListener("click", async function(ev){
        ev.stopPropagation();
        try{
          var id = btn.getAttribute("data-remove");
          var company = getCompany(); if(!company) return;

          if(!confirm("Remove this community? This will also clear any employee assignments for it.")) return;

          btn.disabled = true;
          var oldText = btn.textContent;
          btn.textContent = "Removing…";

          // Cloud-first delete (source of truth)
          var okCloud = await deleteCommunityFromCloud(company, id);

          // Update local cache
          var key = companyCommunitiesKey(company);
          var list = loadJSON(key, []);
          list = list.filter(function(c){ return String(c.id)!==String(id); });
          saveJSON(key, list);

          // Clear local assignment cache for this community
          var aKey = assignmentsKey(company);
          var map = loadJSON(aKey, {});
          if(map && typeof map === "object"){
            try{ delete map[String(id)]; }catch(_e){}
            saveJSON(aKey, map);
          }

          // Clear selection if needed
          if(String(_selectedCommunityId) === String(id)) setSelectedCommunity("", "");

          btn.textContent = okCloud ? "Removed" : "Removed (local)";
          setTimeout(function(){ try{ btn.textContent = oldText; }catch(_e){} try{ btn.disabled = false; }catch(_e){} }, 800);

          refreshAll();
        }catch(e){
          console.warn("Remove community failed:", e);
          try{ btn.disabled = false; btn.textContent = "Remove"; }catch(_e){}
          alert("Could not remove community. Check permissions (RLS) and try again.");
        }
      });
    });
  }

  function buildEmployeeOptions(users, selectedId){
    var html = "<option value=\"\">Unassigned…</option>";
    (users||[]).forEach(function(u){
      var id = String(u.id||"");
      var name = (u.name || u.full_name || u.email || u.id);
      html += "<option value=\""+esc(id)+"\"" + (String(selectedId||"")===id?" selected":"") + ">"+esc(name)+"</option>";
    });
    return html;
  }

  // Backward-compatible alias (some parts of the UI call buildUserOptions)
  function buildUserOptions(users, selectedId){
    return buildEmployeeOptions(users, selectedId);
  }

  function renderPerCommunityAssign(communities, users, map){
    if(!elAssign) return;
    elAssign.innerHTML = "";

    // Always reset bulk employee dropdown on each render so it never shows employees
    // from a previously selected company (especially when switching companies).
    var _bulkEmpEl = document.getElementById("sup_bulkEmployeeSelect");
    var _bulkAssignBtnEl = document.getElementById("sup_bulkAssignBtn");
    if(_bulkEmpEl){
      _bulkEmpEl.value = "";
      // Keep only the placeholder until we repopulate below.
      _bulkEmpEl.innerHTML = "<option value=\"\">Select employee…</option>";
    }
    if(_bulkAssignBtnEl){
      _bulkAssignBtnEl.disabled = true;
    }
    communities = (communities||[]).slice().sort(function(a,b){
      var na = String((a&&a.name)||"").trim().toLowerCase();
      var nb = String((b&&b.name)||"").trim().toLowerCase();
      return na.localeCompare(nb);
    });
    if(!communities.length){
      elAssign.innerHTML = "<div class=\"muted\">No company communities to assign.</div>";
      return;
    }
    map = map || {};
    // Build user lookup + options
    var usersById2 = {};
    (users||[]).forEach(function(u){ if(u && u.id) usersById2[String(u.id)] = u; });

    // Bulk controls (if present)
    var bulkBox = document.getElementById("sup_bulkBox");
    var bulkEmp = document.getElementById("sup_bulkEmployeeSelect");
    var bulkAssignBtn = document.getElementById("sup_bulkAssignBtn");
    var bulkSelAll = document.getElementById("sup_selectAllBtn");
    var bulkClear = document.getElementById("sup_clearSelBtn");

    function getSelectedCommunityIds(){
      return Array.from(elAssign.querySelectorAll('input[type="checkbox"][data-cid]:checked'))
        .map(function(cb){ return cb.getAttribute("data-cid"); })
        .filter(Boolean);
    }
    function updateBulkState(){
      if(!bulkAssignBtn || !bulkEmp) return;
      var ids = getSelectedCommunityIds();
      var uid = String(bulkEmp.value||"");
      bulkAssignBtn.disabled = !(ids.length && uid);
      if(bulkBox){
        bulkBox.querySelector(".tiny-status") && (bulkBox.querySelector(".tiny-status").textContent =
          ids.length ? (ids.length + " selected") : "Select communities to bulk assign.");
      }
    }

    if(bulkEmp){
      // Populate employee dropdown once per render
      bulkEmp.innerHTML = "<option value=\"\">Select employee…</option>" + buildUserOptions(users, "");
      // Use direct handler assignment to avoid stacking multiple listeners across refreshes.
      bulkEmp.onchange = updateBulkState;
    }
    if(bulkSelAll){
      bulkSelAll.onclick = function(){
        elAssign.querySelectorAll('input[type="checkbox"][data-cid]').forEach(function(cb){ cb.checked = true; });
        updateBulkState();
      };
    }
    if(bulkClear){
      bulkClear.onclick = function(){
        elAssign.querySelectorAll('input[type="checkbox"][data-cid]').forEach(function(cb){ cb.checked = false; });
        updateBulkState();
      };
    }
    if(bulkAssignBtn){
      bulkAssignBtn.onclick = async function(){
        var company = getCompany(); if(!company) return;
        var uid = String(bulkEmp && bulkEmp.value || "");
        var ids = getSelectedCommunityIds();
        if(!uid || !ids.length) return;
        if(elStatus) elStatus.textContent = "Assigning " + ids.length + " community" + (ids.length===1?"":"ies") + "…";
        // Write to cloud first (preferred), then local cache.
        if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb){
          try{
            var rows = ids.map(function(cid){ return { company: company, community_id: cid, user_id: uid }; });
            var up = await window.sb.from("CommunityAssignments")
              .upsert(rows, { onConflict: "user_id,community_id" });
            if(up && up.error) throw up.error;
          }catch(e){
            console.warn("bulk assign failed:", e);
            if(elStatus) elStatus.textContent = "Bulk assign failed (check permissions).";
            return;
          }
        }
        // Update local cache map
        var akey = assignmentsKey(company);
        var map2 = loadJSON(akey, {});
        ids.forEach(function(cid){ map2[String(cid)] = uid; });
        saveJSON(akey, map2);
        if(elStatus) elStatus.textContent = "Assigned " + ids.length + " community" + (ids.length===1?"":"ies") + ".";
        refreshAll();
      };
    }

    // Render rows
    var company = getCompany();
    var communitiesById2 = {};
    communities.forEach(function(c){ communitiesById2[String(c.id)] = c; });

    communities.forEach(function(c){
      var cid = String(c.id);
      var assignedUid = String(map[cid]||"");
      var row = document.createElement("div");
      row.className = "item";
      // left side: checkbox + name + status pill
      var left = document.createElement("div");
      left.style.flex = "1";
      left.style.minWidth = "0";
      left.style.display = "flex";
      left.style.alignItems = "center";
      left.style.gap = "10px";

      var cb = document.createElement("input");
      cb.type = "checkbox";
      cb.setAttribute("data-cid", cid);
      cb.addEventListener("change", updateBulkState);

      var nameWrap = document.createElement("div");
      nameWrap.style.minWidth = "0";
      nameWrap.innerHTML = "<div style=\"font-weight:800;\">"+esc(c.name||"")+"</div>" +
        "<div class=\"muted tiny\" data-assign-status></div>";

      left.appendChild(cb);
      left.appendChild(nameWrap);

      // right: employee select
      var right = document.createElement("div");
      right.style.display = "flex";
      right.style.alignItems = "center";
      right.style.gap = "8px";

      var sel = document.createElement("select");
      sel.innerHTML = buildUserOptions(users, assignedUid);
      sel.addEventListener("change", async function(){
        var company = getCompany(); if(!company) return;
        var uid = String(sel.value||"");
        if(elStatus) elStatus.textContent = "Saving assignment…";
        var ok = true;
        if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb){
          ok = await setAssignmentInCloud(company, cid, uid);
        }
        // Update local cache
        var akey = assignmentsKey(company);
        var map2 = loadJSON(akey, {});
        if(uid) map2[cid] = uid; else delete map2[cid];
        saveJSON(akey, map2);
        if(elStatus) elStatus.textContent = ok ? "Assignment saved." : "Saved locally (cloud failed).";
        refreshAll();
      });

      right.appendChild(sel);
      row.appendChild(left);
      row.appendChild(right);

      // status pill text
      var st = row.querySelector('[data-assign-status]');
      if(st){
        if(assignedUid){
          var uu = usersById2[assignedUid] || {};
          var nm2 = String(uu.name || uu.full_name || uu.email || 'Employee').trim();
          var role2 = String(uu.role || '').trim();
          var dept = '';
          var pill2 = (role2==='Admin') ? '<span class="pill pill--admin">Admin</span>' : (dept2==='Supervisor' ? '<span class="pill">Supervisor</span>' : '<span class="pill pill--employee">Employee</span>');
          st.innerHTML = 'Assigned: ' + esc(nm2) + ' ' + pill2;
        }else{
          st.innerHTML = '<span class="pill pill--warn">Unassigned</span>';
        }
      }

      elAssign.appendChild(row);
    });

    updateBulkState();
  }

  function renderAssignmentsPreview(map, usersById, communitiesById){
    elPreview.innerHTML = "";
    map = map || {};
    communitiesById = communitiesById || {};
    var cids = Object.keys(map);
    // Build list of unassigned communities (those present in company list but not mapped)
    var allCids = Object.keys(communitiesById || {});
    var unassigned = allCids.filter(function(cid){
      var uid = String(map[cid]||"").trim();
      return !uid;
    }).map(function(cid){ return (communitiesById[cid] && communitiesById[cid].name) ? communitiesById[cid].name : cid; })
      .sort(function(a,b){ return String(a).toLowerCase().localeCompare(String(b).toLowerCase()); });

    if(!cids.length){
      // No assignments yet, but we can still show unassigned if communities exist
      if(unassigned.length){
        elPreview.innerHTML = "<div class=\"item\"><div><strong>Unassigned</strong> <span class=\"pill pill--warn\">Needs manager</span><div class=\"muted tiny\">"+esc(unassigned.join(", "))+"</div></div></div>";
      }else{
        elPreview.innerHTML = "<div class=\"muted\">No assignments yet.</div>";
      }
      return;
    }

    // If there are some assignments, show unassigned summary first (if any)
    if(unassigned.length){
      var uRow = document.createElement("div");
      uRow.className = "item";
      uRow.innerHTML = "<div><strong>Unassigned</strong> <span class=\"pill pill--warn\">Needs manager</span><div class=\"muted tiny\">"+esc(unassigned.join(", "))+"</div></div>";
      elPreview.appendChild(uRow);
    }

    // Invert: userId -> [communityName]
    var byUser = {};
    cids.forEach(function(cid){
      var uid = String(map[cid]||"");
      if(!uid) return;
      if(!byUser[uid]) byUser[uid]=[];
      var cn = (communitiesById[cid] && communitiesById[cid].name) ? communitiesById[cid].name : cid;
      byUser[uid].push(cn);
    });
    var uids = Object.keys(byUser);
    if(!uids.length){
      elPreview.innerHTML = "<div class=\"muted\">No assignments yet.</div>";
      return;
    }
    uids.sort(function(a,b){
      var ua = usersById[a] || {};
      var ub = usersById[b] || {};
      var na = (ua.name || ua.full_name || ua.email || a).toLowerCase();
      var nb = (ub.name || ub.full_name || ub.email || b).toLowerCase();
      return na.localeCompare(nb);
    });
    uids.forEach(function(uid){
      var u = usersById[uid] || { id: uid };
      var uname = (u.name || u.full_name || u.email || uid);
      var commNames = byUser[uid] || [];
      var row = document.createElement("div");
      row.className = "item";
      var role2 = String(u.role || "").trim();
      var dept = '';
      var pill2 = (role2==="Admin") ? "<span class=\"pill pill--admin\">Admin</span>" : (dept2==="Supervisor" ? "<span class=\"pill\">Supervisor</span>" : "<span class=\"pill pill--employee\">Employee</span>");
      row.innerHTML = "<div><strong>"+esc(uname)+"</strong> "+pill2+"<div>"+esc(commNames.join(", "))+"</div></div>" +
        "<button class=\"btn btn--ghost\" data-clear-user=\""+esc(uid)+"\">Clear</button>";
      elPreview.appendChild(row);
    });
    elPreview.querySelectorAll("button[data-clear-user]").forEach(function(btn){
      btn.addEventListener("click", function(){
        var uid = btn.getAttribute("data-clear-user");
        var company = getCompany(); if(!company) return;
        var akey = assignmentsKey(company);
        var map2 = loadJSON(akey, {});
        Object.keys(map2||{}).forEach(function(cid){ if(String(map2[cid]||"")===String(uid)) delete map2[cid]; });
        saveJSON(akey, map2);
        refreshAll();
      });
    });
  }

  function ensureSupervisorVisible(profile){
  var role = String((profile && profile.role) || "").trim().toLowerCase();
  var approved = (profile && typeof profile.approved !== "undefined") ? !!profile.approved : true;
  var isSup = approved && (role === "supervisor" || role === "admin" || role === "companyadmin");
  var hubMainCard = document.getElementById("supervisorHubMainCard");
  box.style.display = isSup ? "" : "none";
  if(hubCard) hubCard.style.display = "none";
  if(hubMainCard) hubMainCard.style.display = isSup ? "" : "none";
  try{ if(typeof window.configureSupervisorManagerHub === "function") window.configureSupervisorManagerHub(profile); }catch(_e){}
  if(isSup){ try{ initAdminCompanyPicker(); }catch(_e){} try{ refreshAll(); }catch(_e){} }
}

  // Board Members should ONLY see the Board Member Hub card.
  // We treat role values like: "BoardMember", "Board Member", "boardmember".
  function ensureBoardMemberHubOnly(profile){
    var role = String((profile && profile.role) || "").trim();
    var roleL = role.toLowerCase().replace(/\s+/g, "");
    var isBoard = (roleL === "boardmember" || roleL === "board" || roleL === "board_member");
    var cardsWrap = document.querySelector('.cards');
    if(!cardsWrap) return;
    var allCards = Array.prototype.slice.call(cardsWrap.querySelectorAll('.card'));
    var bmCard = document.getElementById('boardMemberHubCard') || cardsWrap.querySelector('[data-card-id="board_member_hub"]');
    var customizeBar = document.getElementById('hubCustomizeBar');
    var hint = document.getElementById('hubCustomizeHint');

    if(isBoard){
      allCards.forEach(function(c){
        if(bmCard && c === bmCard) c.style.display = "";
        else c.style.display = "none";
      });
      if(customizeBar) customizeBar.style.display = "none";
      if(hint) hint.style.display = "none";
    } else {
      // restore defaults for non-board users (except Supervisor Access which is handled elsewhere)
      allCards.forEach(function(c){ c.style.display = ""; });
      if(customizeBar) customizeBar.style.display = "";
    }
  }

  

  var elCompanySelect = $("sup_companySelect");
  var elCompanyAdminPicker = document.getElementById("sup_companyAdminPicker");
  var elCompanySetter = document.getElementById("sup_companySetter");
  var elEmpList = document.getElementById("sup_employeeList");

  function isAdmin(){
    var auth = window.ZUMMEE_AUTH || {};
    var role = String(auth.role || window.__zummeeUserRole || "").trim();
    var roleL = role.toLowerCase().replace(/\s+/g, "");
    return (roleL === "admin" || roleL === "companyadmin");
  }

  function renderCompanyOptions(companies){
    if(!elCompanySelect) return;
    elCompanySelect.innerHTML = '<option value="">Select a company…</option>';
    companies.forEach(function(c){
      var opt=document.createElement('option');
      opt.value=c;
      opt.textContent=c;
      elCompanySelect.appendChild(opt);
    });
    var picked = String(localStorage.getItem("zummee_admin_selected_company")||"").trim();
    if(picked) elCompanySelect.value = picked;
  }

  async function loadAllCompanies(){
    // Match Profile page company dropdown: pull from Companies table.
    if(!window.sb) return [];
    try{
      var q = await window.sb.from('Companies')
        .select('name,active')
        .eq('active', true)
        .order('name', { ascending: true });
      if(q && q.error) throw q.error;
      var rows = (q && q.data) ? q.data : [];
      var out = [];
      for(var i=0;i<rows.length;i++){
        var nm = rows[i] && rows[i].name ? String(rows[i].name) : '';
        nm = nm.trim();
        if(nm) out.push(nm);
      }
      // De-dupe defensively
      var seen = {}; var uniq = [];
      out.forEach(function(n){ if(!seen[n]){ seen[n]=true; uniq.push(n); } });
      return uniq;
    }catch(_e){
      return [];
    }
  }

  function renderEmployees(users, company){
    if(!elEmpList) return;
    elEmpList.innerHTML='';
    if(!users.length){
      elEmpList.innerHTML='<div class="muted">No users found for this company.</div>';
      return;
    }
    users.forEach(function(u){
      var dept = '';
      var role=String(u.role||'').trim();
      var row=document.createElement('div');
      row.className='emp';
      var display=(u.name||u.full_name||u.email||u.id);
      var pill = (dept==='Supervisor') ? '<span class="pill">Supervisor</span>' : '';
      row.innerHTML = '<div class="meta"><div class="name">'+esc(display)+pill+'</div>' +
        '<div class="sub">'+esc(u.email||'')+'</div></div>' +
        '<div class="sup-row" style="gap:8px; justify-content:flex-end">' +
        '<button class="btn btn--ghost" data-toggle-sup="'+esc(u.id)+'">'+(dept==='Supervisor'?'Remove Supervisor':'Make Supervisor')+'</button>' +
        '</div>';
      elEmpList.appendChild(row);
    });
    elEmpList.querySelectorAll('button[data-toggle-sup]').forEach(function(btn){
      btn.addEventListener('click', async function(){
        if(!window.sb) { if(elStatus) elStatus.textContent='Supervisor toggles require database connection.'; return; }
        var uid = btn.getAttribute('data-toggle-sup');
        var u = _usersById[String(uid)] || {};
        var cur = String(u.department||'').trim();
        var next = (cur==='Supervisor') ? 'Manager' : 'Supervisor';
        if(elStatus) elStatus.textContent=(next==='Supervisor'?'Granting':'Removing') + ' Supervisor…';
        try{
          await window.sb.from("profiles").upsert([{ id: uid, company: company, department: next }], { onConflict: 'id' });
        }catch(e){
          if(elStatus) elStatus.textContent='Could not update user. Check permissions.';
          return;
        }
        if(elStatus) elStatus.textContent='Updated.';
        await refreshAll();
      });
    });
  }

  async function initAdminCompanyPicker(){
    if(!elCompanyAdminPicker) return;
    if(!isAdmin()){
      elCompanyAdminPicker.style.display='none';
      return;
    }
    elCompanyAdminPicker.style.display='';
    var companies = await loadAllCompanies();
    renderCompanyOptions(companies);
  }
var _cacheUsers = [];
  var _usersById = {};
  var _communities = [];

  async function refreshAll(){
    var company = getCompany();
    var setter = elCompanySetter;
    // Admins pick a company from the dropdown; Supervisors set their own company once.
    if(!company){
      if(isAdmin()){
        if(setter) setter.style.display="none";
        if(elCompanyAdminPicker) elCompanyAdminPicker.style.display="";
        if(elStatus) elStatus.textContent="Select a company to manage.";
      }else{
        if(setter) setter.style.display="";
        if(elStatus) elStatus.textContent="Set company to manage assignments.";
      }
      return;
    }
    if(isAdmin() && elCompanyAdminPicker) elCompanyAdminPicker.style.display="";
    if(setter) setter.style.display = "none";

    // Sync from cloud first (writes to local cache keys)
    await syncCompanyFromCloud(company);

    var commKey = companyCommunitiesKey(company);
    _communities = loadJSON(commKey, []).map(normalizeCommunity).filter(Boolean);
    // Keep UI consistent: sort communities alphabetically
    _communities.sort(function(a,b){
      var na = String((a && a.name) || "").trim().toLowerCase();
      var nb = String((b && b.name) || "").trim().toLowerCase();
      return na.localeCompare(nb);
    });

    var communitiesById = {};
    _communities.forEach(function(c){ communitiesById[String(c.id)] = c; });

    renderCompanyCommunities(_communities);

    if(typeof window.ensureSupabase==="function") { await window.ensureSupabase(); }
    const sb = window.sb || null;
    if(sb){
      try{
        // Keep this schema-compatible: most projects store name (not full_name) and may not persist email in Profiles.
        var q = await window.sb.from("profiles").select("*").eq("company", company);
        _cacheUsers = (q && q.data) ? q.data : [];
      }catch(_e){ _cacheUsers = []; }
    }

    _usersById = {};
    _cacheUsers.forEach(function(u){ _usersById[String(u.id)] = u; });
    // Admin-only: show employee list with Supervisor toggles
    if(isAdmin()){
      if(elEmpList) elEmpList.style.display='';
      renderEmployees(_cacheUsers, company);
    }else{
      if(elEmpList){ elEmpList.style.display='none'; elEmpList.innerHTML=''; }
    }

    var akey = assignmentsKey(company);
    var map = loadJSON(akey, {});
    renderPerCommunityAssign(_communities, _cacheUsers, map);
    renderAssignmentsPreview(map, _usersById, communitiesById);
  }

    // Admin company picker wiring
  if(elCompanySelect){
    elCompanySelect.addEventListener('change', function(){
      var v = String(elCompanySelect.value||'').trim();
      try{ localStorage.setItem('zummee_admin_selected_company', v); }catch(_e){}
      refreshAll();
    });
  }
  var btnRefreshCompanies = $("sup_refreshCompaniesBtn");
  if(btnRefreshCompanies){
    btnRefreshCompanies.addEventListener('click', async function(){
      if(elStatus) elStatus.textContent='Refreshing companies…';
      await initAdminCompanyPicker();
      if(elStatus) elStatus.textContent='';
      refreshAll();
    });
  }

var btnSetCompany = $("sup_setCompanyBtn");
  if(btnSetCompany){
    btnSetCompany.addEventListener("click", async function(){
      var v = String($("sup_companyInput").value||"").trim();
      if(!v){ if(elStatus) elStatus.textContent="Enter a company name."; return; }
      if(elStatus) elStatus.textContent="Saving company…";
      var ok = await setCompanyName(v);
      if(ok){
        document.getElementById("sup_companySetter").style.display = "none";
        if(elStatus) elStatus.textContent="Company set to " + v + ".";
        refreshAll();
      }else{
        if(elStatus) elStatus.textContent="Could not set company.";
      }
    });
  }

  var btnAddCommunity = $("sup_addCommunityBtn");
  if(btnAddCommunity){
    btnAddCommunity.addEventListener("click", async function(){
      try{
        var company = getCompany();
        var setter = document.getElementById("sup_companySetter");
        if(!company){
          if(setter) setter.style.display="";
          if(elStatus) elStatus.textContent="Select or set a company first.";
          return;
        }
        if(setter) setter.style.display="none";
        var name = String($("sup_newCommunityName").value||"").trim();
        if(!name){ if(elStatus) elStatus.textContent="Enter a community name."; return; }

        // Cloud insert + refresh cache
        if(elStatus) elStatus.textContent="Adding community…";
        var ok = await addCommunityToCloud(company, name);
        if(!ok){
          if(elStatus) elStatus.textContent="Could not add community. Check Supabase permissions (RLS).";
          alert("Could not add community. If this keeps happening, open DevTools > Console and share the first red error.");
          return;
        }

        $("sup_newCommunityName").value = "";
        if(elStatus) elStatus.textContent="Community added.";
        await refreshAll();
      }catch(err){
        if(elStatus) elStatus.textContent="Add failed.";
        alert("Add failed: " + (err && (err.message||err.error_description) ? (err.message||err.error_description) : err));
      }
    });
  }

  
  var btnEditCommunity = $("sup_editCommunityBtn");
  if(btnEditCommunity){
    btnEditCommunity.addEventListener("click", async function(){
      try{
        var company = getCompany();
        var setter = document.getElementById("sup_companySetter");
        if(!company){
          if(setter) setter.style.display="";
          setStatusText("Select or set a company first.");
          return;
        }
        if(!_selectedCommunityId){
          setStatusText("Select a community from the list to edit.");
          return;
        }
        var id = _selectedCommunityId;
        var current = _selectedCommunityName;
        var proposed = String($("sup_newCommunityName").value||"").trim();
        var newName = proposed || prompt("Rename community:", current);
        if(newName === null) return; // cancelled
        newName = String(newName||"").trim();
        if(!newName){ alert("Enter a community name."); return; }
        if(newName === current){ setStatusText("No changes."); return; }

        // Prevent duplicates
        var key = companyCommunitiesKey(company);
        var list0 = loadJSON(key, []);
        var dup = (list0||[]).some(function(c){ return String(c.id)!==String(id) && String(c.name||"").trim().toLowerCase()===newName.toLowerCase(); });
        if(dup){ alert("A community with that name already exists for this company."); return; }

        setStatusText("Renaming…");
        await doRenameCommunity(company, id, current, newName);
        setSelectedCommunity(id, newName);
        $("sup_newCommunityName").value = newName;
        refreshAll();
      }catch(e){
        console.warn("Edit community failed:", e);
        setStatusText("Rename failed.");
        alert("Could not rename community. Check permissions (RLS) and try again.");
      }
    });
  }

// Assign per-community: on change, persist { communityId: userId }
  if(elAssign){
    elAssign.addEventListener("change", async function(e){
      var tgt = e && e.target;
      if(!tgt || !tgt.matches || !tgt.matches("select[data-community]")) return;
      var company = getCompany();
      var setter = document.getElementById("sup_companySetter");
      if(!company){ if(setter) setter.style.display=""; if(elStatus) elStatus.textContent="Set company to manage assignments."; return; }
      if(setter) setter.style.display="none";
      var cid = String(tgt.getAttribute("data-community")||"");
      var uid = String(tgt.value||"");

      if(elStatus) elStatus.textContent="Saving…";
      var ok = await setAssignmentInCloud(company, cid, uid || "");
      if(!ok){ if(elStatus) elStatus.textContent="Could not save assignment."; return; }

      // Update local cache immediately for UI + legacy pages
      var akey = assignmentsKey(company);
      var map = loadJSON(akey, {});
      if(uid){ map[cid]=uid; } else { delete map[cid]; }
      try{ saveJSON(akey, map); }catch(_e){}
      if(elStatus) elStatus.textContent="Saved.";

      try{ window.dispatchEvent(new CustomEvent("communities:updated", { detail: { userId: uid } })); }catch(_e){}
      await refreshAll();
    });
  }

  // Show/hide based on profile department
  window.addEventListener("profile:loaded", function(ev){
    var d = (ev && ev.detail) || {};
    var dept = '';
    if(!dept && window.__zummeeUserDepartment) dept = String(window.__zummeeUserDepartment).trim();

    (async function(){
      try{
        var company = String(d.company||"").trim();
        if(window.sb && d.userId){
          var q = await window.sb.from("profiles").select("*").eq("id", d.userId).maybeSingle();
          if(q && q.data){
            window.__zummeeCompany = (q.data.company||company||"").trim();
            window.__zummeeUserDepartment = (q.data.department||"").trim();
            ensureSupervisorVisible({ department: window.__zummeeUserDepartment, role: window.__zummeeUserRole });
            ensureBoardMemberHubOnly({ role: window.__zummeeUserRole, department: window.__zummeeUserDepartment });
          } else {
            ensureSupervisorVisible({ department: dept, role: window.__zummeeUserRole });
            ensureBoardMemberHubOnly({ role: window.__zummeeUserRole, department: dept });
          }
        } else {
          ensureSupervisorVisible({ department: dept, role: window.__zummeeUserRole });
          ensureBoardMemberHubOnly({ role: window.__zummeeUserRole, department: dept });
        }
      }catch(_e){
        ensureSupervisorVisible({ department: dept, role: window.__zummeeUserRole });
        ensureBoardMemberHubOnly({ role: window.__zummeeUserRole, department: dept });
      }
    })();
  });
// ---- Supervisor Access: tabs (Assignments / Employees / Current) ----
function initSupervisorTabs(){
  var box = document.getElementById('supervisorBox');
  if(!box) return;
  var tabs = Array.prototype.slice.call(box.querySelectorAll('.sup-tab'));
  if(!tabs.length) return;

  var panels = {
    assign: document.getElementById('sup_tab_assign'),
    employees: document.getElementById('sup_tab_employees'),
    current: document.getElementById('sup_tab_current')
  };

  function activate(name){
    tabs.forEach(function(t){
      var on = (t.getAttribute('data-sup-tab') === name);
      t.classList.toggle('is-active', on);
    });
    Object.keys(panels).forEach(function(k){
      if(!panels[k]) return;
      panels[k].style.display = (k === name) ? '' : 'none';
    });
  }

  tabs.forEach(function(btn){
    btn.addEventListener('click', function(){
      activate(btn.getAttribute('data-sup-tab'));
    });
  });

  // Default tab
  activate('assign');
}

document.addEventListener('DOMContentLoaded', function(){
  setTimeout(initSupervisorTabs, 0);
});

})();
</script>

  </div>
<script>
(() => {
  function applyTagline(){
    const el = document.querySelector(".zummee-header__subtitle");
    if(!el) return;
    // Store full text once
    if(!el.dataset.fullText) el.dataset.fullText = (el.textContent || "").trim();
    // Default short text (you can change this later)
    const shortText = el.dataset.shortText || "Property Assistant";
    const isMobile = window.matchMedia("(max-width: 640px)").matches;
    el.textContent = isMobile ? shortText : el.dataset.fullText;
    el.classList.remove("zummee-tagline-animate");
    // reflow to restart animation
    void el.offsetWidth;
    el.classList.add("zummee-tagline-animate");
  }

  document.addEventListener("DOMContentLoaded", () => {
    applyTagline();
    window.addEventListener("resize", () => {
      // Debounce-ish
      clearTimeout(window.__zummeeTaglineT);
      window.__zummeeTaglineT = setTimeout(applyTagline, 120);
    });
  });
})();
</script>

<script>
(() => {
  function safeParse(raw){ try { return JSON.parse(raw); } catch(e){ return null; } }
  function hashToHue(str){
    let h = 0;
    for(let i=0;i<str.length;i++){ h = (h*31 + str.charCodeAt(i)) >>> 0; }
    return h % 360;
  }
  function getAccent(seed){
    const hue = hashToHue(seed || "community");
    // Pleasant, brand-consistent blue-green range
    const base = 190 + (hue % 70); // 190-259
    return {
      bg: `hsl(${base} 55% 78%)`,
      border: `hsl(${base} 55% 55%)`
    };
  }

  function getSelectedCommunity(){
    const commKey = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || window.COMMUNITIES_KEY || "zummee_communities_v1";
    const selKey = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || window.SELECTED_COMMUNITY_KEY || "zummee_selected_community_v1";
    let selectedId = "";
    try { selectedId = localStorage.getItem(selKey) || ""; } catch(e) {}
    let list = [];
    try { list = safeParse(localStorage.getItem(commKey) || "[]") || []; } catch(e) {}
    const match = list.find(c => c && (c.id === selectedId || c.name === selectedId));
    return match || (selectedId ? { id:selectedId, name:selectedId } : null);
  }

  function applyAccent(){
    const sw = document.getElementById("zummeeCommunitySwatch");
    const select = document.getElementById("zummeeCommunitySelect");
    const c = getSelectedCommunity();

    if(!c){
      document.documentElement.style.removeProperty("--communityAccent");
      document.documentElement.style.removeProperty("--communityAccentBorder");
      if(sw) sw.style.background = "#ffffff";
      return;
    }

    const seed = String(c.id || c.name || "");
    const a = getAccent(seed);
    document.documentElement.style.setProperty("--communityAccent", a.bg);
    document.documentElement.style.setProperty("--communityAccentBorder", a.border);
    if(sw) sw.style.background = a.bg;

    // Add a dot to each option label (cross-browser).
    if(select){
      Array.from(select.options || []).forEach(opt => {
        if(!opt) return;
        const baseText = (opt.dataset.baseText || opt.textContent || "").replace(/^●\s+/, "");
        opt.dataset.baseText = baseText;
        opt.textContent = baseText;
        // Some browsers ignore option background; harmless where unsupported.
        const ao = getAccent(opt.value || baseText);
        opt.style.backgroundColor = ao.bg;
        opt.style.color = "#0f2f4a";
      });
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    applyAccent();

    const select = document.getElementById("zummeeCommunitySelect");
    if(select){
      select.addEventListener("change", () => setTimeout(applyAccent, 0));
    }

    // If other scripts repopulate the dropdown a moment later.
    setTimeout(applyAccent, 250);
  });
})();
</script>

