<!-- Zummee Confirm Modal -->
<div id="zummeeConfirmModal" class="zummee-modal__backdrop" aria-hidden="true">
  <div class="zummee-modal__card" role="dialog" aria-modal="true" aria-labelledby="zummeeConfirmTitle">
    <div class="zummee-modal__header">
      <div class="zummee-modal__icon" aria-hidden="true">!</div>
      <div style="min-width:0">
        <div id="zummeeConfirmTitle" class="zummee-modal__title">Confirm</div>
        <div id="zummeeConfirmMsg" class="zummee-modal__subtitle">Are you sure?</div>
      </div>
    </div>
    <div class="zummee-modal__footer">
      <button id="zummeeConfirmCancel" class="zummee-modal__btn" type="button">Cancel</button>
      <button id="zummeeConfirmOk" class="zummee-modal__btn zummee-modal__btn--primary" type="button">Delete</button>
    </div>
  </div>
</div>

<script>
  // Global helper: Supervisor-style confirm + alert (white modal, blue primary)
  (function(){
    function qs(id){ return document.getElementById(id); }

    function openModal(){
      var back = qs('zummeeConfirmModal');
      if(!back) return null;
      back.classList.add('is-open');
      back.setAttribute('aria-hidden','false');
      try{ document.body.style.overflow = 'hidden'; }catch(_e){}
      return back;
    }
    function closeModal(){
      var back = qs('zummeeConfirmModal');
      if(!back) return;
      back.classList.remove('is-open');
      back.setAttribute('aria-hidden','true');
      try{ document.body.style.overflow = ''; }catch(_e){}
    }

    window.zummeeConfirm = function(title, msg, okText, cancelText /* danger ignored for design consistency */){
      return new Promise(function(resolve){
        var back = qs('zummeeConfirmModal');
        var t = qs('zummeeConfirmTitle');
        var m = qs('zummeeConfirmMsg');
        var ok = qs('zummeeConfirmOk');
        var cancel = qs('zummeeConfirmCancel');

        if(!back || !t || !m || !ok || !cancel){
          resolve(window.confirm((msg||title||'Are you sure?')));
          return;
        }

        t.textContent = title || 'Confirm';
        m.textContent = msg || 'Are you sure?';
        ok.textContent = okText || 'OK';
        cancel.textContent = cancelText || 'Cancel';

        // Always blue primary to match Supervisor
        ok.classList.remove('zummee-modal__btn--danger');
        ok.classList.add('zummee-modal__btn--primary');
        cancel.style.display = '';

        var done = false;
        function finish(val){
          if(done) return;
          done = true;
          cleanup();
          closeModal();
          resolve(!!val);
        }
        function onKey(e){ if(e.key === 'Escape') finish(false); }
        function onBack(e){ if(e && e.target === back) finish(false); }

        function cleanup(){
          try{ ok.onclick = null; }catch(_e){}
          try{ cancel.onclick = null; }catch(_e){}
          try{ back.onclick = null; }catch(_e){}
          try{ document.removeEventListener('keydown', onKey); }catch(_e){}
        }

        ok.onclick = function(){ finish(true); };
        cancel.onclick = function(){ finish(false); };
        back.onclick = onBack;
        document.addEventListener('keydown', onKey);

        openModal();
        try{ ok.focus(); }catch(_e){}
      });
    };

    window.zummeeAlert = function(title, msg, okText){
      okText = okText || 'OK';
      return new Promise(function(resolve){
        var back = qs('zummeeConfirmModal');
        var t = qs('zummeeConfirmTitle');
        var m = qs('zummeeConfirmMsg');
        var ok = qs('zummeeConfirmOk');
        var cancel = qs('zummeeConfirmCancel');

        if(!back || !t || !m || !ok){
          try{ window.alert(msg || title || ''); }catch(_e){}
          resolve(true);
          return;
        }

        t.textContent = title || 'Notice';
        m.textContent = msg || '';
        ok.textContent = okText;

        ok.classList.remove('zummee-modal__btn--danger');
        ok.classList.add('zummee-modal__btn--primary');

        if(cancel) cancel.style.display = 'none';

        var done = false;
        function finish(){
          if(done) return;
          done = true;
          cleanup();
          closeModal();
          if(cancel) cancel.style.display = '';
          resolve(true);
        }
        function onKey(e){ if(e.key === 'Escape') finish(); }
        function onBack(e){ if(e && e.target === back) finish(); }

        function cleanup(){
          try{ ok.onclick = null; }catch(_e){}
          try{ if(cancel) cancel.onclick = null; }catch(_e){}
          try{ back.onclick = null; }catch(_e){}
          try{ document.removeEventListener('keydown', onKey); }catch(_e){}
        }

        ok.onclick = finish;
        if(cancel) cancel.onclick = finish;
        back.onclick = onBack;
        document.addEventListener('keydown', onKey);

        openModal();
        try{ ok.focus(); }catch(_e){}
      });
    };
  })();
</script>

<script>
(function(){
  // Supabase-only mileage storage (no local mileage storage)
  // Communities list remains managed on the Hub (local storage) for now.

  // --- Supabase client (same project as login) ---
  var SUPABASE_URL = "https://slcwuuwyrgnmlmxpcaim.supabase.co";
  var SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNsY3d1dXd5cmdubWxteHBjYWltIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkwMjI5MTAsImV4cCI6MjA4NDU5ODkxMH0.3pZZLufFv5SUHREjgPys-q8SnYVMzHona-yeXMVHuOg";
  if(!window.sb && window.supabase && window.supabase.createClient){
    try{
      window.sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY, {
        auth: { storageKey:'sb-zummee-auth', storage: window.localStorage, persistSession:true, autoRefreshToken:true, detectSessionInUrl:true  }
      });
    }catch(e0){}
  }

  var COMMUNITIES_KEY_BASE = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || "zummee_communities_v1";

  function safeParse(raw){ try{ return JSON.parse(raw); }catch(e){ return null; } }
  function pad2(n){ return (n<10 ? ("0"+n) : (""+n)); }
  function nowMonthKey(){ var d=new Date(); return d.getFullYear()+"-"+pad2(d.getMonth()+1); }
  function setMonthInputDefault(){ var el=document.getElementById("monthPick"); if(el) el.value = nowMonthKey(); }

  function mkLabel(mk){
    // mk = YYYY-MM
    var y = Number(String(mk).slice(0,4));
    var m = Number(String(mk).slice(5,7));
    if(!isFinite(y) || !isFinite(m)) return String(mk||"");
    var names = ["January","February","March","April","May","June","July","August","September","October","November","December"];
    var name = names[Math.max(0, Math.min(11, m-1))];
    return name + " " + y;
  }

  function escapeHtml(s){
    s = String(s==null?"":s);
    return s
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;")
      .replace(/\"/g,"&quot;")
      .replace(/'/g,"&#39;");
  }

  function fmtMiles(n){ n = Number(n||0); if(!isFinite(n)) n=0; return n.toFixed(1).replace(/\.0$/,""); }
  function monthStartEnd(mk){
    // mk = YYYY-MM
    var y = Number(String(mk).slice(0,4));
    var m = Number(String(mk).slice(5,7));
    if(!isFinite(y) || !isFinite(m)){
      var d=new Date(); y=d.getFullYear(); m=d.getMonth()+1;
    }
    var start = y+"-"+pad2(m)+"-01";
    // next month start
    var ny=y, nm=m+1; if(nm===13){ nm=1; ny=y+1; }
    var end = ny+"-"+pad2(nm)+"-01";
    return { start:start, end:end };
  }

  function loadCommunities(){
    var raw=null; try{ var k = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || COMMUNITIES_KEY_BASE; raw = localStorage.getItem(k); }catch(e){ raw=null; }
    var arr = safeParse(raw||"");
    if(!arr || !arr.length) return [];
    var out=[];
    for(var i=0;i<arr.length;i++){
      var c=arr[i];
      if(!c) continue;
      var name = String(c.name||c.id||"Community");
      var id = String(c.id||c.name||("c"+i));

      // Hide placeholder/default community entries (users often keep one around for testing)
      // so the mileage page starts with only real communities.
      var n = name.trim().toLowerCase();
      var did = id.trim().toLowerCase();
      if(n === "default" || n === "default community" || did === "default") continue;

      out.push({ id: id, name: name });
    }
    return out;
  }

  function ensureSignedIn(cb){
    if(!window.sb || !window.sb.auth){ cb(new Error("Supabase not initialized"), null); return; }
    window.sb.auth.getSession().then(function(r){
      var ses = r && r.data ? r.data.session : null;
      if(ses && ses.user && ses.user.id){ cb(null, ses); return; }
      // try refresh once
      window.sb.auth.refreshSession().then(function(){
        window.sb.auth.getSession().then(function(r2){
          var ses2 = r2 && r2.data ? r2.data.session : null;
          if(ses2 && ses2.user && ses2.user.id){ cb(null, ses2); return; }
          cb(new Error("Not signed in"), null);
        });
      }).catch(function(){ cb(new Error("Not signed in"), null); });
    }).catch(function(){ cb(new Error("Not signed in"), null); });
  }

  function getProfileCompany(userId, cb){
    if(!window.sb || !window.sb.from){ cb(null, ""); return; }

    function tryTable(tname){
      window.sb.from(tname).select("company").eq("id", userId).maybeSingle().then(function(res){
        if(res && res.error){
          // if table doesn't exist, try the other
          cb(res.error, "");
          return;
        }
        var company = (res && res.data && res.data.company) ? String(res.data.company) : "";
        cb(null, company);
      }).catch(function(err){ cb(err, ""); });
    }

    // Try "Profiles" first (your project commonly uses capitalized tables)
    tryTable("Profiles");
  }

  function getProfileCompanyRobust(userId, cb){
    getProfileCompany(userId, function(err, company){
      if(!err) { cb(null, company); return; }
      // try lowercase fallback
      window.sb.from("profiles").select("company").eq("id", userId).maybeSingle().then(function(res2){
        if(res2 && res2.error){ cb(res2.error, ""); return; }
        var company2 = (res2 && res2.data && res2.data.company) ? String(res2.data.company) : "";
        cb(null, company2);
      }).catch(function(err2){ cb(err2, ""); });
    });
  }

  function loadMileageForMonth(userId, mk, cb){
    var range = monthStartEnd(mk);
    window.sb
      .from("mileage_entries")
      .select("id,community,drive_date,miles,created_at")
      .eq("user_id", userId)
      .gte("drive_date", range.start)
      .lt("drive_date", range.end)
      .order("drive_date", { ascending:false })
      .then(function(res){
        if(res && res.error){ cb(res.error, []); return; }
        cb(null, (res && res.data) ? res.data : []);
      })
      .catch(function(err){ cb(err, []); });
  }

  function insertMileageRow(userId, companyName, communityName, driveDate, miles, cb){
    // Attempt with company_name; if column doesn't exist, retry without.
    var base = { user_id:userId, community:communityName, drive_date:driveDate, miles:Number(miles) };
    var withCompany = { user_id:userId, community:communityName, drive_date:driveDate, miles:Number(miles), company_name: companyName };

    function doInsert(payload, retryOnMissingColumn){
      window.sb.from("mileage_entries").insert([payload]).then(function(res){
        if(res && res.error){
          var msg = String(res.error.message||"");
          if(retryOnMissingColumn && msg.indexOf('column "company_name"') !== -1 && msg.indexOf("does not exist") !== -1){
            doInsert(base, false);
            return;
          }
          cb(res.error);
          return;
        }
        cb(null);
      }).catch(function(err){ cb(err); });
    }

    // If company_name is required and empty, the insert will fail; we handle that earlier.
    doInsert(withCompany, true);
  }

  function deleteMileageRow(rowId, cb){
    window.sb.from("mileage_entries").delete().eq("id", rowId).then(function(res){
      if(res && res.error){ cb(res.error); return; }
      cb(null);
    }).catch(function(err){ cb(err); });
  }

  // --- UI Rendering ---
  var STATE = { userId:"", email:"", company:"", mk: nowMonthKey(), rows: [] };

  // Default email address for monthly mileage reports (per-user)
  function getDefaultReportEmail(){
    var uid = String(STATE.userId||"").trim();
    var v = "";
    if(uid){ v = safeLocalGet("mileage_default_report_email::" + uid) || ""; }
    if(!v) v = safeLocalGet("mileage_default_report_email") || "";
    return String(v||"").trim();
  }

  function setDefaultReportEmail(val){
    var uid = String(STATE.userId||"").trim();
    var v = String(val||"").trim();
    if(uid){
      safeLocalSet("mileage_default_report_email::" + uid, v);
    } else {
      safeLocalSet("mileage_default_report_email", v);
    }
  }

  function wireDefaultReportEmailInput(){
    var el = document.getElementById("defaultReportEmail");
    if(!el) return;
    if(el.dataset && el.dataset.wired === "1"){ 
      // Still refresh value when user scope changes
      el.value = getDefaultReportEmail();
      return;
    }
    if(el.dataset) el.dataset.wired = "1";
    // Load saved value
    el.value = getDefaultReportEmail();
    var save = function(){
      var v = String(el.value||"").trim();
      if(v && el.checkValidity && !el.checkValidity()){
        window.zummeeAlert("Notice", "Please enter a valid email address."); return;
      }
      setDefaultReportEmail(v);
    };
    el.addEventListener("change", save);
    el.addEventListener("blur", save);
  }

  function setMonthlyTotal(){
    var grand = 0;
    for(var i=0;i<STATE.rows.length;i++){
      var m = Number(STATE.rows[i].miles||0);
      if(!isFinite(m)) m=0;
      grand += m;
    }
    var el = document.getElementById("monthlyTotal");
    if(el) el.textContent = fmtMiles(grand) + " mi";
  }

  function totalsByCommunity(){
    var totals = {};
    for(var i=0;i<STATE.rows.length;i++){
      var r = STATE.rows[i];
      var key = String(r.community||"");
      if(!key) continue;
      var m = Number(r.miles||0);
      if(!isFinite(m)) m=0;
      totals[key] = (totals[key]||0) + m;
    }
    return totals;
  }

  function computeGrandTotal(){
    var g=0;
    for(var i=0;i<STATE.rows.length;i++){
      var m = Number(STATE.rows[i].miles||0);
      if(!isFinite(m)) m=0;
      g += m;
    }
    return g;
  }

  function rowsAsc(){
    var a = (STATE.rows||[]).slice();
    a.sort(function(x,y){
      var dx = String(x.drive_date||"");
      var dy = String(y.drive_date||"");
      if(dx<dy) return -1;
      if(dx>dy) return 1;
      return 0;
    });
    return a;
  }

  function makeCSV(){
    var rows = rowsAsc();
    var lines = ["Date,Community,Miles"]; 
    for(var i=0;i<rows.length;i++){
      var r = rows[i];
      var d = String(r.drive_date||"");
      var c = String(r.community||"").replace(/"/g,'""');
      var m = fmtMiles(r.miles||0);
      lines.push(d + ',"' + c + '",' + m);
    }
    return lines.join("\n");
  }

  function downloadTextFile(filename, text, mime){
    try{
      var blob = new Blob([text], { type: mime || "text/plain" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      setTimeout(function(){
        try{ document.body.removeChild(a); }catch(_e){}
        try{ URL.revokeObjectURL(url); }catch(_e2){}
      }, 0);
    }catch(e){
      window.zummeeAlert("Notice", "Could not export file: " + (e.message||e)); }
  }

  function openMonthlyReport(){
    var title = "Mileage Report – " + mkLabel(STATE.mk);
    var totals = totalsByCommunity();
    var grand = computeGrandTotal();
    var rows = rowsAsc();

    var summaryRows = "";
    var keys = Object.keys(totals).sort();
    for(var i=0;i<keys.length;i++){
      var k = keys[i];
      summaryRows += '<tr><td>'+escapeHtml(k)+'</td><td style="text-align:right">'+escapeHtml(fmtMiles(totals[k]))+'</td></tr>';
    }
    if(!summaryRows) summaryRows = '<tr><td class="muted" colspan="2">No entries for this month.</td></tr>';

    var entryRows = "";
    for(var j=0;j<rows.length;j++){
      var r = rows[j];
      entryRows += '<tr><td>'+escapeHtml(String(r.drive_date||""))+'</td><td>'+escapeHtml(String(r.community||""))+'</td><td style="text-align:right">'+escapeHtml(fmtMiles(r.miles||0))+'</td></tr>';
    }
    if(!entryRows) entryRows = '<tr><td class="muted" colspan="3">No entries for this month.</td></tr>';

    var companyLine = STATE.company ? ('<div style="margin-top:6px" class="muted"><b>Management Company:</b> '+escapeHtml(STATE.company)+'</div>') : '';
    var emailLine = STATE.email ? ('<div class="muted"><b>User:</b> '+escapeHtml(STATE.email)+'</div>') : '';

    var html = ''+
    '<!doctype html><html><head><meta charset="utf-8"/>'+
    '<meta name="viewport" content="width=device-width,initial-scale=1"/>'+
    '<title>'+escapeHtml(title)+'</title>'+
    '<style>'+
      'body{font-family:Arial,system-ui,-apple-system,Segoe UI,Roboto;margin:24px;color:#111827}'+
      'h1{margin:0 0 6px;font-size:22px}'+
      '.muted{color:#6b7280;font-size:12px}'+
      '.card{border:1px solid #e5e7eb;border-radius:12px;padding:14px;margin-top:14px}'+
      'table{width:100%;border-collapse:collapse}'+
      'th,td{padding:8px 6px;border-bottom:1px solid #e5e7eb;font-size:12px;vertical-align:top}'+
      'th{background:#f9fafb;text-align:left}'+
      '.right{text-align:right}'+
      '@media print{.noprint{display:none}}'+
    '</style></head><body>'+
    '<div class="noprint" style="display:flex;gap:10px;justify-content:flex-end">'+
      '<button onclick="window.print()" style="padding:8px 10px;border:1px solid #e5e7eb;border-radius:10px;background:#fff;font-weight:700;cursor:pointer">Print / Save PDF</button>'+
      '<button onclick="window.close()" style="padding:8px 10px;border:1px solid #e5e7eb;border-radius:10px;background:#fff;font-weight:700;cursor:pointer">Close</button>'+
    '</div>'+
    '<h1>'+escapeHtml(title)+'</h1>'+
    emailLine +
    companyLine +
    '<div class="muted" style="margin-top:6px"><b>Month:</b> '+escapeHtml(STATE.mk)+'</div>'+
    '<div class="card">'+
      '<div style="font-weight:800;margin-bottom:8px">Summary (Totals by Community)</div>'+
      '<table><thead><tr><th>Community</th><th style="text-align:right">Miles</th></tr></thead><tbody>'+
        summaryRows +
        '<tr><td style="font-weight:800">Grand Total</td><td style="text-align:right;font-weight:800">'+escapeHtml(fmtMiles(grand))+'</td></tr>'+
      '</tbody></table>'+
    '</div>'+
    '<div class="card">'+
      '<div style="font-weight:800;margin-bottom:8px">Entries</div>'+
      '<table><thead><tr><th>Date</th><th>Community</th><th style="text-align:right">Miles</th></tr></thead><tbody>'+
        entryRows +
      '</tbody></table>'+
    '</div>'+
    '</body></html>';

    var w = window.open("", "_blank");
    if(!w){
      window.zummeeAlert("Notice", "Pop-up blocked. Please allow pop-ups for this site to generate the report."); return;
    }
    w.document.open();
    w.document.write(html);
    w.document.close();
  }

  function openEmailSummary(){
    var totals = totalsByCommunity();
    var keys = Object.keys(totals).sort();
    var lines = [];
    lines.push("Mileage summary for " + mkLabel(STATE.mk) + " (" + STATE.mk + ")");
    if(STATE.company) lines.push("Management Company: " + STATE.company);
    lines.push("");
    if(!keys.length){
      lines.push("No mileage entries for this month.");
    } else {
      lines.push("Totals by community:");
      for(var i=0;i<keys.length;i++){
        var k = keys[i];
        lines.push("- " + k + ": " + fmtMiles(totals[k]) + " mi");
      }
      lines.push("");
      lines.push("Grand Total: " + fmtMiles(computeGrandTotal()) + " mi");
    }
    lines.push("");
    lines.push("Attached: Mileage Report (PDF) and/or CSV export.");

    var subject = "Mileage Report – " + mkLabel(STATE.mk);
    var body = lines.join("\n");

    var to = getDefaultReportEmail();
    // Basic sanitize for safety (single recipient)
    if(to) to = to.replace(/[^a-zA-Z0-9@._+\-]/g, "");
    var mailto = "mailto:" + (to ? to : "") + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
    window.location.href = mailto;
  }

  function renderEntriesList(){
    var el = document.getElementById("entriesList");
    if(!el) return;
    if(!STATE.rows || !STATE.rows.length){
      el.textContent = "No entries yet.";
      el.className = "muted";
      return;
    }
    var mk = STATE.mk;
    var html = '<div class="muted" style="margin-bottom:8px">Month: '+mk+'</div>';
    html += '<div style="overflow:auto"><table><thead><tr><th>Date</th><th>Community</th><th class="right">Miles</th><th class="right">Delete</th></tr></thead><tbody>';
    for(var i=0;i<STATE.rows.length;i++){
      var r = STATE.rows[i];
      var d = String(r.drive_date||"");
      var c = String(r.community||"");
      html += '<tr>';
      html += '<td>'+d+'</td>';
      html += '<td>'+c+'</td>';
      html += '<td class="right">'+fmtMiles(r.miles||0)+'</td>';
      html += '<td class="right"><button class="smallbtn danger" data-id="'+String(r.id||"")+'">Delete</button></td>';
      html += '</tr>';
    }
    html += '</tbody></table></div>';
    el.className = "";
    el.innerHTML = html;

    var btns = el.querySelectorAll("button[data-id]");
    for(var j=0;j<btns.length;j++){
      btns[j].onclick = async function(){
        var id = this.getAttribute("data-id");
        if(!id) return;
        try{
          const ok = await window.zummeeConfirm("Delete mileage entry", "Delete this mileage entry?", "Delete", "Cancel", true);
          if(!ok) return;
        }catch(_e){
          if(!confirm("Delete this mileage entry?")) return;
        }
        deleteMileageRow(id, function(err){
          if(err){ window.zummeeAlert("Notice", "Could not delete: " + (err.message||err)); return; }
          reloadMonth();
        });
      };
    }
  }

  function renderCommunitiesTable(){
    var tbody = document.getElementById("commBody");
    var empty = document.getElementById("emptyMsg");
    if(!tbody) return;
    tbody.innerHTML = "";

    // Build communities from the header dropdown (source of truth on this page)
    var sel = document.getElementById("zummeeCommunitySelect");
    var comms = [];
    try{
      if(sel && sel.options && sel.options.length){
        for(var oi=0; oi<sel.options.length; oi++){
          var opt = sel.options[oi];
          if(!opt) continue;
          var id = String(opt.value||"").trim();
          var name = String(opt.textContent||opt.innerText||"").trim();
          if(!id) continue; // skip "Select a community"
          if(!name) name = id;
          comms.push({ id:id, name:name });
        }
      }
    }catch(_eSel){}

    if(!comms.length){ if(empty) empty.style.display = "block"; return; }
    if(empty) empty.style.display = "none";

    var totals = totalsByCommunity();

    for(var j=0;j<comms.length;j++){
      var c = comms[j];
      var tr = document.createElement("tr");

      var tdName = document.createElement("td");
      tdName.textContent = c.name;
      tr.appendChild(tdName);

      var tdDate = document.createElement("td");
      var dspan = document.createElement("span");
      dspan.className = "muted";
      dspan.textContent = "Auto";
      dspan.title = "Date is captured automatically when you click Add.";
      tdDate.appendChild(dspan);
      tr.appendChild(tdDate);

      var tdMiles = document.createElement("td");
      var milesIn = document.createElement("input");
      milesIn.type = "number";
      milesIn.step = "0.1";
      milesIn.min = "0";
      milesIn.placeholder = "0";
      milesIn.id = "mi_"+c.id;
      tdMiles.appendChild(milesIn);
      tr.appendChild(tdMiles);

      var tdTotal = document.createElement("td");
      tdTotal.className = "right";
      tdTotal.textContent = fmtMiles(totals[c.name]||0) + " mi";
      tr.appendChild(tdTotal);

      var tdBtn = document.createElement("td");
      tdBtn.className = "right";
      var btn = document.createElement("button");
      btn.className = "smallbtn";
      btn.textContent = "Add";
      btn.setAttribute("data-cid", c.id);
      btn.setAttribute("data-cname", c.name);
      btn.onclick = function(){
        var cid = this.getAttribute("data-cid");
        var cname = this.getAttribute("data-cname");
        var mEl = document.getElementById("mi_"+cid);
        var mVal = mEl ? String(mEl.value||"").trim() : "";
        var miles = Number(mVal);

        // Capture today's date automatically
        var today = new Date();
        var driveDate = today.getFullYear()+"-"+pad2(today.getMonth()+1)+"-"+pad2(today.getDate());
        // Ensure we're viewing the month we just recorded
        var todayMk = today.getFullYear()+"-"+pad2(today.getMonth()+1);
        var mpEl = document.getElementById("monthPick");
        if(mpEl && mpEl.value !== todayMk){
          mpEl.value = todayMk;
          STATE.mk = todayMk;
        }
        if(!isFinite(miles) || miles <= 0){ window.zummeeAlert("Notice", "Please enter mileage greater than 0 for " + cname + "."); return; }

        if(!STATE.company){
          window.zummeeAlert("Notice", "Please set your Management Company in Profile before saving mileage."); window.location.href = "profile.html";
          return;
        }

        insertMileageRow(STATE.userId, STATE.company, cname, driveDate, miles, function(err){
          if(err){ window.zummeeAlert("Notice", "Could not save mileage: " + (err.message||err)); return; }
          if(mEl) mEl.value = "";
          reloadMonth();
        });
      };
      tdBtn.appendChild(btn);
      tr.appendChild(tdBtn);

      tbody.appendChild(tr);
    }
  }

  function reloadMonth(){
    ensureSignedIn(function(err, ses){
      if(err || !ses){ window.location.href = "login.html"; return; }
      STATE.userId = ses.user.id;
      STATE.email = (ses && ses.user && ses.user.email) ? String(ses.user.email) : "";
      // Wire + load per-user default recipient email
      try{ wireDefaultReportEmailInput(); }catch(_e){}
      try{ if(window.ZUMMEE_applyUserScope) window.ZUMMEE_applyUserScope(STATE.userId); }catch(_e){}
      var mp = document.getElementById("monthPick");
      STATE.mk = (mp && mp.value) ? mp.value : nowMonthKey();

      // load profile company then mileage rows
      getProfileCompanyRobust(STATE.userId, function(err2, company){
        // If company table fails, still allow mileage insert without company_name (if schema allows)
        STATE.company = company || "";

        loadMileageForMonth(STATE.userId, STATE.mk, function(err3, rows){
          if(err3){
            window.zummeeAlert("Notice", "Could not load mileage: " + (err3.message||err3)); STATE.rows = [];
          } else {
            STATE.rows = rows || [];
          }
          setMonthlyTotal();
          renderCommunitiesTable();
          renderEntriesList();
        });
      });
    });
  }

  function init(){
    setMonthInputDefault();
    try{ setTimeout(setMonthInputDefault, 150); }catch(_e){}
    var mp = document.getElementById("monthPick");
    if(mp){ mp.addEventListener("change", function(){ reloadMonth(); }); }
    // When community changes in header, just re-render the community rows (no reload needed)
    var cs = document.getElementById("zummeeCommunitySelect");
    if(cs){ cs.addEventListener("change", function(){ try{ renderCommunitiesTable(); }catch(_e){} }); }

    var b1 = document.getElementById("btnMonthlyReport");
    if(b1){ b1.addEventListener("click", function(){ openMonthlyReport(); }); }
    var b2 = document.getElementById("btnExportCSV");
    if(b2){ b2.addEventListener("click", function(){
      var csv = makeCSV();
      var fn = "Mileage_" + String(STATE.mk||"") + ".csv";
      downloadTextFile(fn, csv, "text/csv;charset=utf-8");
    }); }
    var b3 = document.getElementById("btnEmailSummary");
    if(b3){ b3.addEventListener("click", function(){ openEmailSummary(); }); }
    reloadMonth();
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
