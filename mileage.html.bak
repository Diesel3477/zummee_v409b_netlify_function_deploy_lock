<!doctype html>
<html lang="en">
<head>
<script>
// v840: ensureSupabase Promise shim (clean)
function ensureSupabaseSync(){
  try{
    if(window.sb) return window.sb;
    if(window.supabaseClient) return window.supabaseClient;
    if(window.supabase) return window.supabase;
    if(typeof getSupabaseClientSafe === 'function') return getSupabaseClientSafe();
  }catch(e){}
  return null;
}
function ensureSupabase(){
  return new Promise(function(resolve){
    var c = ensureSupabaseSync();
    if(c) return resolve(c);
    var start = Date.now();
    var t = setInterval(function(){
      var cc = ensureSupabaseSync();
      if(cc){
        clearInterval(t);
        resolve(cc);
      } else if(Date.now() - start > 4000){
        clearInterval(t);
        resolve(null);
      }
    }, 50);
  });
}
</script>


<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Mileage Tracker</title>
<style>
  :root{--bg:#f6f7fb;--card:#fff;--text:#111827;--muted:#6b7280;--line:#e5e7eb;--shadow:0 10px 30px rgba(0,0,0,.08);--r:18px}
  *{box-sizing:border-box}
  body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}

  /* Supervisor-style header */
  .zummee-header{
    display:flex;align-items:center;justify-content:space-between;gap:16px;
    padding:16px 22px;border-bottom:1.2px solid rgba(33,59,90,0.7);
    background:#9fc9ec;box-shadow:0 1px 6px rgba(0,0,0,0.08);
  }
  .zummee-header__left{display:flex;align-items:center;gap:16px;min-width:0}
  .zummee-header__right{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end}
  .zummee-header__logo{display:inline-flex;align-items:center;text-decoration:none;flex:0 0 auto}
  .zummee-header__logo img{height:96px;max-height:96px;width:auto;display:block}
  .zummee-header__titles{display:flex;flex-direction:column;line-height:1.1}
  .zummee-header__title{margin:0;font-size:1.6rem;font-weight:700;color:#0f2f4a}
  .zummee-header__subtitle{margin-top:6px;font-size:1rem;font-weight:500;color:#0f2f4a;opacity:0.9}
  .zummee-header__ctl-label{font-weight:700;color:#0f2f4a;opacity:0.95}
  #zummeeCommunitySwatch{width:12px;height:12px;border-radius:999px;background:#0f2f4a22;border:1px solid rgba(15,47,74,0.35)}
  .zummee-header__hubBtn{
    display:inline-flex;align-items:center;gap:8px;
    border:2px solid rgba(15,47,74,0.45);
    background:rgba(255,255,255,0.78);
    color:#0f2f4a;
    padding:8px 12px;border-radius:14px;text-decoration:none;
    font-weight:800;font-size:13px;
  }
  .zummee-header__hubBtn:hover{background:rgba(255,255,255,0.92)}

  @media(max-width:640px){
    .zummee-header{padding:12px 16px;gap:12px}
    .zummee-header__logo img{height:72px;max-height:72px}
  }

  .wrap{max-width:1200px;margin:0 auto;padding:20px 14px 60px}
  h1{margin:0 0 6px;font-size:34px;letter-spacing:-.02em;color:#0f2f4a}
  .pageTitle{margin:0 0 6px;font-size:34px;letter-spacing:-.02em;color:#0f2f4a;font-weight:900}
  .sub{color:var(--muted);font-size:14px;margin:6px 0 18px;line-height:1.4}

  .pageBox{
    border:2px solid rgba(15,47,74,0.35);
    border-radius:22px;
    padding:18px;
    background:rgba(255,255,255,0.92);
    box-shadow:0 10px 28px rgba(15,47,74,0.08);
    margin-top:14px;
  }
  @media(max-width:640px){
    .pageBox{padding:14px;border-radius:18px}
  }

  /* Section cards (match Daily Ops hover + outline) */
  .card{
    background:var(--card);
    border:2px solid rgba(15,47,74,0.35);
    border-radius:18px;
    box-shadow:0 8px 22px rgba(15,47,74,0.08);
    padding:16px;
    margin-top:14px;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }
  .card:hover{
    transform: translateY(-2px);
    box-shadow:0 12px 28px rgba(15,47,74,0.14);
  }
  @media (prefers-reduced-motion: reduce){
    .card{transition:none}
    .card:hover{transform:none}
  }

  .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
  label{font-weight:800;font-size:12px;color:#374151}
  input,select{border:1px solid rgba(15,47,74,0.25);border-radius:10px;padding:10px 12px;font-size:14px;background:#fff}
  input[type="number"]{width:120px}
  input[type="date"]{width:170px}
  input[type="month"]{width:170px}
  table{width:100%;border-collapse:collapse}
  th,td{padding:10px 8px;border-bottom:1px solid var(--line);text-align:left;font-size:13px;vertical-align:top}
  th{color:#374151;font-weight:900;background:#f9fafb}
  .muted{color:var(--muted)}
  .right{text-align:right}
  .pill{display:inline-block;padding:4px 10px;border-radius:999px;background:#eef2ff;color:#1e3a8a;font-weight:900;font-size:12px}
  .total{display:flex;justify-content:space-between;align-items:center;font-weight:900;font-size:14px;margin-top:10px}
  .smallbtn{border:1px solid rgba(15,47,74,0.25);background:rgba(255,255,255,0.9);border-radius:10px;padding:8px 10px;font-weight:900;font-size:12px;cursor:pointer}
  .smallbtn:hover{border-color:rgba(15,47,74,0.45)}
  .danger{color:#b91c1c}
  /* Zummee confirm/alert modal (match Supervisor white/blue modals) */
  .zummee-modal__backdrop{position:fixed;inset:0;background:rgba(15,47,74,0.35);display:none;align-items:center;justify-content:center;z-index:9999;padding:18px}
  .zummee-modal__backdrop[aria-hidden="false"]{display:flex}
  .zummee-modal__card{width:min(720px,100%);background:#ffffff;border:1px solid rgba(15,47,74,0.18);border-radius:22px;box-shadow:0 28px 70px rgba(15,47,74,0.22);overflow:hidden}
  .zummee-modal__header{display:flex;gap:12px;align-items:flex-start;padding:22px 22px 10px}
  .zummee-modal__icon{width:34px;height:34px;border-radius:12px;background:rgba(15,47,74,0.08);display:flex;align-items:center;justify-content:center;color:#0f2f4a;font-weight:900}
  .zummee-modal__title{font-size:22px;font-weight:900;color:#0f2f4a;margin:0}
  .zummee-modal__subtitle{margin-top:8px;color:#546577;font-size:16px;line-height:1.35}
  .zummee-modal__body{padding:0 22px 16px}
  .zummee-modal__footer{display:flex;gap:12px;justify-content:flex-end;padding:14px 22px 22px}
  .zummee-modal__btn{border:2px solid rgba(15,47,74,0.22);background:rgba(255,255,255,0.95);color:#0f2f4a;border-radius:18px;padding:12px 18px;font-weight:900;cursor:pointer}
  .zummee-modal__btn:hover{border-color:rgba(15,47,74,0.42);background:rgba(255,255,255,1)}
  .zummee-modal__btn--primary{background:#0f2f4a;color:#ffffff;border-color:#0f2f4a}
  .zummee-modal__btn--primary:hover{background:#0d2940;border-color:#0d2940}
  .zummee-modal__btn--danger{background:#b91c1c;color:#ffffff;border-color:#b91c1c}
  .zummee-modal__btn--danger:hover{background:#a31818;border-color:#a31818}

</style>

<!-- Supabase JS (browser client) -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>
(() => {
  const SESSION_KEY = "zummee_session_v1";

  function getSupabaseSession(){
    function extract(o){
      try{
        if(!o) return null;
        if(o.user && o.user.id) return { id:o.user.id, email:(o.user.email||"") };
        if(o.currentSession && o.currentSession.user && o.currentSession.user.id) return { id:o.currentSession.user.id, email:(o.currentSession.user.email||"") };
        if(o.session && o.session.user && o.session.user.id) return { id:o.session.user.id, email:(o.session.user.email||"") };
      }catch(_e){}
      return null;
    }
    function scan(store){
      try{
        for(var i=0;i<store.length;i++){
          var key = store.key(i);
          if(!key) continue;
          if(!(key === 'sb-zummee-auth' || /^sb-.*-auth-token$/.test(key))) continue;
          var raw = null;
          try{ raw = store.getItem(key); }catch(_e){}
          if(!raw) continue;
          var obj = null;
          try{ obj = JSON.parse(raw); }catch(_e2){}
          var ex = extract(obj);
          if(ex && ex.id) return ex;
        }
      }catch(_e3){}
      return null;
    }
    try{
      var a = scan(localStorage) || scan(sessionStorage);
      if(a && a.id){
        return { provider:"supabase", userId:a.id, email:(a.email||""), supabase:true };
      }
    }catch(_e4){}
    return null;
  }

  let SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || "zummee_selected_community_v1";

  function safeParse(raw){ try { return JSON.parse(raw); } catch(e){ return null; } }
  function getSession(){
    var ses = safeParse((sessionStorage.getItem(SESSION_KEY) || localStorage.getItem(SESSION_KEY) || ""));
    if(ses && ses.userId){
      try{ if(window.ZUMMEE_applyUserScope){ window.ZUMMEE_applyUserScope(ses.userId); } }catch(_e){}
      try{ SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || SELECTED_COMMUNITY_KEY; }catch(_e){}
      try{ COMMUNITIES_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || COMMUNITIES_KEY; }catch(_e){}
      return ses;
    }
    var sbSes = getSupabaseSession();
    if(sbSes){
      try{ if(window.ZUMMEE_applyUserScope){ window.ZUMMEE_applyUserScope(sbSes.userId); } }catch(_e){}
      try{ SELECTED_COMMUNITY_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.SELECTED_COMMUNITY_KEY) || SELECTED_COMMUNITY_KEY; }catch(_e){}
      try{ COMMUNITIES_KEY = (window.ZUMMEE_KEYS && window.ZUMMEE_KEYS.COMMUNITIES_KEY) || COMMUNITIES_KEY; }catch(_e){}
      return sbSes;
    }
    return null;
  }

  function requireAuth(){
    const ses = getSession();
    if(!ses || !ses.userId){
      window.location.href = "login.html";
      return null;
    }
    return ses;
  }

  window.ZummeeAuth = {
    requireAuth,
    getSession,
    getUserId: () => (getSession() && getSession().userId) || "",
    getSelectedCommunityId: () => {
      try { return localStorage.getItem(SELECTED_COMMUNITY_KEY) || ""; } catch(e){ return ""; }
    },
    scopedKey: (baseKey) => {
      const ses = getSession();
      const u = (ses && ses.userId) ? ses.userId : "";
      const c = (() => { try { return localStorage.getItem(SELECTED_COMMUNITY_KEY) || ""; } catch(e){ return ""; } })();
      if(u && c) return `${baseKey}::${u}::${c}`;
      if(u) return `${baseKey}::${u}`;
      return baseKey;
    },
	    signOut: () => { try{sessionStorage.removeItem(SESSION_KEY);}catch(e){}
	      try{localStorage.removeItem(SESSION_KEY);}catch(e2){}
	      // Supabase auth cleanup (support default sb-*-auth-token and custom sb-zummee-auth)
	      try{
	        [localStorage, sessionStorage].forEach(function(store){
	          try{
	            for(var i=store.length-1;i>=0;i--){
	              var k = store.key(i);
	              if(!k) continue;
	              if(k === 'sb-zummee-auth' || /^sb-.*-auth-token$/.test(k) || /^sb-zummee-auth/.test(k)){
	                try{ store.removeItem(k); }catch(_e){}
	              }
	            }
	          }catch(_e2){}
	        });
	      }catch(_e3){}
	      try{ if(window.sb && window.sb.auth && window.sb.auth.signOut){ window.sb.auth.signOut(); } }catch(e5){}
	      window.location.replace("login.html"); }
  };
})();
</script>

<style>
/* Mileage nav hub-only override (v310) */
.top{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  justify-content:flex-end;
  align-items:center;
  padding:10px 12px;
  max-width:980px;
  margin:0 auto 14px auto;
}
